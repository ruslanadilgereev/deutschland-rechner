---
import Layout from '../layouts/Layout.astro';
import SteuerklassenRechner from '../components/rechner/SteuerklassenRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Steuerklassen-Rechner 2026 – Optimale Steuerklasse finden";
const description = "Steuerklassen-Rechner 2026: Finde die optimale Kombination für Ehepaare. Vergleiche III/V, IV/IV und Faktorverfahren. Berechne Netto, Erstattung & Nachzahlung!";
const keywords = "Steuerklassen Rechner, Steuerklasse, Steuerklassenwechsel, Steuerklasse 3 5, Steuerklasse 4, Steuerklasse Ehepaar, Faktorverfahren, Steuerklasse ändern, optimale Steuerklasse 2026";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Steuerklassen-Rechner", url: "/steuerklassen-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-pink-600 to-rose-700 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-pink-200 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">💑</span>
          <div>
            <h1 class="text-2xl font-bold">Steuerklassen-Rechner 2026</h1>
            <p class="text-pink-200 text-sm">Optimale Kombination für Ehepaare finden</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <SteuerklassenRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Steuerklassen 2026: Übersicht & Wechsel</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Die <strong>Steuerklasse</strong> bestimmt, wie viel Lohnsteuer monatlich vom Gehalt einbehalten wird. 
            Mit unserem <strong>Steuerklassen-Rechner</strong> finden Ehepaare die optimale Kombination 
            und können berechnen, ob ein Wechsel lohnt.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Die 6 Steuerklassen im Überblick</h3>
          <div class="bg-pink-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>Steuerklasse I:</strong> Ledige, Geschiedene, Verwitwete</li>
              <li><strong>Steuerklasse II:</strong> Alleinerziehende (Entlastungsbetrag 4.260€)</li>
              <li><strong>Steuerklasse III:</strong> Verheiratete – Allein- oder Mehrverdiener</li>
              <li><strong>Steuerklasse IV:</strong> Verheiratete mit ähnlichem Einkommen</li>
              <li><strong>Steuerklasse V:</strong> Verheiratete – Partner von Steuerklasse III</li>
              <li><strong>Steuerklasse VI:</strong> Für Zweit- und Nebenjobs</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Steuerklassenkombinationen für Ehepaare</h3>
          <p>
            Verheiratete haben die Wahl zwischen drei Kombinationen:
          </p>
          
          <h4 class="font-semibold text-gray-700 mt-4">III/V – Der Klassiker für ungleiche Einkommen</h4>
          <ul class="list-disc pl-5 space-y-1">
            <li>Partner mit höherem Einkommen: Steuerklasse III</li>
            <li>Partner mit niedrigerem Einkommen: Steuerklasse V</li>
            <li><strong>Vorteil:</strong> Mehr Netto monatlich für den Hauptverdiener</li>
            <li><strong>Nachteil:</strong> Oft Steuernachzahlung am Jahresende</li>
          </ul>
          
          <h4 class="font-semibold text-gray-700 mt-4">IV/IV – Für ähnliche Einkommen</h4>
          <ul class="list-disc pl-5 space-y-1">
            <li>Beide Partner haben Steuerklasse IV</li>
            <li><strong>Vorteil:</strong> Einfach, meist weder Erstattung noch Nachzahlung</li>
            <li><strong>Nachteil:</strong> Nicht optimal bei stark unterschiedlichen Gehältern</li>
          </ul>
          
          <h4 class="font-semibold text-gray-700 mt-4">IV/IV mit Faktor – Der Präzisions-Modus</h4>
          <ul class="list-disc pl-5 space-y-1">
            <li>Beide haben Klasse IV, aber mit individuellem Faktor</li>
            <li>Der Faktor berücksichtigt Freibeträge und Einkommensverhältnis</li>
            <li><strong>Vorteil:</strong> Monatlich genauere Steuerabzüge, kaum Nachzahlung</li>
            <li><strong>Nachteil:</strong> Muss beim Finanzamt beantragt werden</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wann lohnt sich welche Kombination?</h3>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>III/V:</strong> Ein Partner verdient deutlich mehr (z.B. 70:30 Verhältnis)</li>
              <li><strong>IV/IV:</strong> Beide verdienen ähnlich viel (z.B. 55:45 Verhältnis)</li>
              <li><strong>IV/IV Faktor:</strong> Genaueste Lösung, Pflicht zur Steuererklärung</li>
            </ul>
          </div>
          
          <div class="bg-yellow-50 p-4 rounded-lg my-4">
            <p class="text-sm text-yellow-800">
              <strong>Wichtig:</strong> Die Steuerklasse beeinflusst nur die monatliche Lohnsteuer, 
              nicht die Jahressteuerlast! Bei der Steuererklärung wird die tatsächliche Steuer 
              berechnet – egal welche Steuerklasse.
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Steuerklasse wechseln</h3>
          <p>
            Ein <strong>Steuerklassenwechsel</strong> ist mehrmals im Jahr möglich:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Online über ELSTER oder beim Finanzamt</li>
            <li>Antrag wirkt ab dem Folgemonat</li>
            <li>Empfehlung: Zu Jahresbeginn wechseln für volle Wirkung</li>
            <li>Bei Heirat: Automatisch IV/IV, danach Wechsel möglich</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Einfluss auf Lohnersatzleistungen</h3>
          <p>
            Die Steuerklasse beeinflusst die Höhe von Lohnersatzleistungen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Arbeitslosengeld I:</strong> Höheres Netto = höheres ALG</li>
            <li><strong>Elterngeld:</strong> Netto der letzten 12 Monate relevant</li>
            <li><strong>Krankengeld:</strong> Basiert auf Nettoentgelt</li>
            <li><strong>Kurzarbeitergeld:</strong> Steuerklasse entscheidend für Höhe</li>
          </ul>
          
          <div class="bg-green-50 p-4 rounded-lg my-4">
            <p class="text-sm text-green-800">
              <strong>Tipp:</strong> Bei geplanter Elternzeit sollte der künftige Elterngeld-Beziehende 
              mindestens 7 Monate vor dem Mutterschutz in Steuerklasse III wechseln – das maximiert 
              das Elterngeld!
            </p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/brutto-netto-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💵</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Brutto-Netto-Rechner</p>
          </a>
          <a href="/einkommensteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🧾</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Einkommensteuer-Rechner</p>
          </a>
          <a href="/lohnsteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💳</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Lohnsteuer-Rechner</p>
          </a>
          <a href="/elterngeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🍼</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Elterngeld-Rechner</p>
          </a>
          <a href="/ehegattenunterhalt-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💔</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Ehegattenunterhalt-Rechner</p>
          </a>
          <a href="/arbeitslosengeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📋</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Arbeitslosengeld-Rechner</p>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Zuständige Behörde -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🏛️</span>
          Steuerklasse ändern
        </h2>
        
        <div class="p-4 bg-pink-50 rounded-lg">
          <h3 class="font-semibold text-pink-800 mb-2">Finanzamt / ELSTER</h3>
          <p class="text-pink-700 text-sm mb-2">
            Der <strong>Steuerklassenwechsel</strong> kann online über ELSTER oder direkt beim 
            Finanzamt beantragt werden. Nutzen Sie das Formular "Antrag auf Steuerklassenwechsel".
          </p>
          <p class="text-pink-700 text-sm">
            <strong>ELSTER:</strong> elster.de<br/>
            <strong>Formular:</strong> "Antrag auf Steuerklassenwechsel bei Ehegatten/Lebenspartnern"
          </p>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Steuerklassen-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/steuerklassen-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Welche Steuerklasse ist die beste für Ehepaare?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bei ähnlichen Einkommen ist IV/IV optimal. Bei deutlich unterschiedlichen Einkommen (z.B. 70:30) ist III/V für den Mehrverdiener günstiger. Das Faktorverfahren (IV/IV mit Faktor) bietet die genaueste monatliche Steuerverteilung."
        }
      },
      {
        "@type": "Question",
        "name": "Wie oft kann man die Steuerklasse wechseln?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Seit 2020 kann die Steuerklasse mehrmals im Jahr gewechselt werden. Der Wechsel wirkt ab dem Folgemonat. Empfehlenswert ist ein Wechsel zu Jahresbeginn, um die volle Wirkung zu erzielen."
        }
      },
      {
        "@type": "Question",
        "name": "Muss ich bei Steuerklasse III/V eine Steuererklärung abgeben?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, bei der Kombination III/V sind Sie zur Abgabe einer Steuererklärung verpflichtet. Da bei III/V oft zu wenig Lohnsteuer einbehalten wird, kommt es häufig zu einer Nachzahlung."
        }
      },
      {
        "@type": "Question",
        "name": "Wie beeinflusst die Steuerklasse das Elterngeld?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das Elterngeld wird aus dem Nettoeinkommen der letzten 12 Monate berechnet. Ein Wechsel in Steuerklasse III (höheres Netto) mindestens 7 Monate vor dem Mutterschutz kann das Elterngeld erhöhen."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist das Faktorverfahren?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Beim Faktorverfahren haben beide Partner Steuerklasse IV, aber mit einem individuellen Faktor, der Freibeträge und Einkommensverhältnis berücksichtigt. So wird monatlich genauer besteuert und es gibt kaum Nachzahlungen."
        }
      },
      {
        "@type": "Question",
        "name": "Welche Steuerklasse nach der Hochzeit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nach der Hochzeit werden beide Partner automatisch in Steuerklasse IV eingestuft. Ein Wechsel zu III/V oder IV/IV mit Faktor ist jederzeit möglich und kann sich je nach Einkommenssituation lohnen."
        }
      }
    ]
  })} />
</Layout>
