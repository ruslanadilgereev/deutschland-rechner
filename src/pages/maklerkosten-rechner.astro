---
import Layout from '../layouts/Layout.astro';
import MaklerkostenRechner from '../components/rechner/MaklerkostenRechner';

const title = "Maklerkosten-Rechner – Provision alle Bundesländer";
const description = "Maklerkosten-Rechner 2026: Provision (5,95–7,14%) je Bundesland berechnen. Käufer-Verkäufer-Aufteilung nach Gesetz. Kostenlos!";
const keywords = "Maklerkosten Rechner, Maklerprovision 2026, Maklergebühr berechnen, Immobilienmakler Kosten, Maklerprovision Käufer Verkäufer, Courtage Rechner, Makler Provision Bundesland";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-blue-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🏠</span>
          <div>
            <h1 class="text-2xl font-bold">Maklerkosten-Rechner 2026</h1>
            <p class="text-blue-100 text-sm">Provision fair aufteilen – alle Bundesländer</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <MaklerkostenRechner client:load />
    </div>
<!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Maklerkosten 2026: Das müssen Sie wissen</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Die <strong>Maklerprovision</strong> gehört zu den größten Nebenkosten beim Immobilienkauf. 
            Mit unserem kostenlosen <strong>Maklerkosten-Rechner 2026</strong> berechnen Sie schnell die 
            Courtage für Ihr Bundesland und sehen, wie die Kosten fair zwischen Käufer und Verkäufer aufgeteilt werden.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Das neue Maklergesetz seit Dezember 2020</h3>
          <p>
            Seit dem 23. Dezember 2020 gilt das <strong>Gesetz über die Verteilung der Maklerkosten</strong> 
            (§ 656a-d BGB). Die wichtigsten Änderungen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Halbteilung:</strong> Bei Wohnungen und Einfamilienhäusern zahlt der Käufer maximal 50% der Provision</li>
            <li><strong>Keine einseitige Belastung:</strong> Die Provision muss fair zwischen Käufer und Verkäufer geteilt werden</li>
            <li><strong>Schriftform:</strong> Der Maklervertrag muss in Textform (schriftlich, E-Mail, Fax) geschlossen werden</li>
          </ul>
          
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <p class="text-sm text-blue-800">
              <strong>💡 Früher vs. Heute:</strong> Vor 2020 zahlte in vielen Bundesländern der Käufer die volle 
              Provision (oft 7,14%). Heute ist das nicht mehr erlaubt – der Käufer zahlt maximal die Hälfte!
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Maklerprovisionen nach Bundesland (2026)</h3>
          
          <div class="bg-gray-50 p-4 rounded-lg my-4">
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="space-y-1">
                <p><strong>7,14%</strong> – Bayern, Baden-Württemberg, Berlin, Brandenburg, NRW, Niedersachsen, Sachsen, etc.</p>
                <p><strong>6,25%</strong> – Hamburg</p>
              </div>
              <div class="space-y-1">
                <p><strong>5,95%</strong> – Bremen, Hessen, Mecklenburg-Vorpommern</p>
              </div>
            </div>
            <p class="mt-2 text-xs text-gray-500">Alle Angaben inkl. 19% MwSt. | Bei Halbteilung trägt jede Partei die Hälfte</p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wer bezahlt den Makler?</h3>
          <p>
            Die Kostenverteilung hängt davon ab, wer den Makler beauftragt:
          </p>
          <div class="bg-gray-50 p-4 rounded-lg my-4 space-y-3">
            <div class="flex items-start gap-3">
              <span class="text-xl">👥</span>
              <div>
                <p class="font-semibold">Beide Parteien beauftragen den Makler</p>
                <p class="text-sm text-gray-600">→ Provision wird 50/50 geteilt (Normalfall)</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-xl">🏷️</span>
              <div>
                <p class="font-semibold">Nur Verkäufer beauftragt Makler</p>
                <p class="text-sm text-gray-600">→ Verkäufer zahlt volle Provision (Käufer provisionsfrei)</p>
              </div>
            </div>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was ist die Maklerprovision?</h3>
          <p>
            Die <strong>Maklerprovision</strong> (auch <strong>Courtage</strong>) ist die Vergütung für den 
            Immobilienmakler. Sie wird in der Regel prozentual vom Kaufpreis berechnet und ist erst nach 
            erfolgreichem Vertragsabschluss fällig (Erfolgsprovision).
          </p>
          
          <div class="bg-yellow-50 p-4 rounded-lg my-4">
            <p class="text-sm text-yellow-800">
              <strong>Rechenbeispiel:</strong> Kaufpreis 350.000 € in Bayern (7,14% Gesamtprovision):<br/>
              Gesamtprovision: 24.990 € | Käufer: 12.495 € | Verkäufer: 12.495 €
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Spartipps bei Maklerkosten</h3>
          <ul class="list-disc pl-5 space-y-2">
            <li><strong>Provision verhandeln:</strong> Die üblichen Sätze sind nicht gesetzlich festgelegt – verhandeln Sie!</li>
            <li><strong>Privatverkauf:</strong> Kaufen Sie direkt vom Eigentümer (z.B. über eBay Kleinanzeigen, ImmoScout24 privat)</li>
            <li><strong>Verkäuferauftrag:</strong> Suchen Sie Objekte, bei denen der Verkäufer die Provision übernimmt</li>
            <li><strong>Online-Makler:</strong> Neue Anbieter (z.B. McMakler, Homeday) bieten oft günstigere Pauschalen</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wann ist die Provision fällig?</h3>
          <p>
            Die Maklerprovision wird fällig, sobald:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Der <strong>Kaufvertrag notariell beurkundet</strong> wurde</li>
            <li>Die Tätigkeit des Maklers <strong>kausal</strong> für den Abschluss war</li>
          </ul>
          <p class="text-sm text-gray-500 mt-2">
            Üblicherweise ist die Zahlung 14 Tage nach Rechnungsstellung fällig.
          </p>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/grunderwerbsteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏗️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Grunderwerbsteuer-Rechner</p>
          </a>
          <a href="/kaufnebenkosten-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🧾</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kaufnebenkosten-Rechner</p>
          </a>
          <a href="/eigenkapital-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Eigenkapital-Rechner</p>
          </a>
          <a href="/tilgungsplan-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📊</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Tilgungsplan-Rechner</p>
          </a>
          <a href="/baufinanzierung-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏦</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Baufinanzierung-Rechner</p>
          </a>
          <a href="/mieten-oder-kaufen-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🤔</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Mieten oder Kaufen?</p>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Rechtliche Grundlage -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">⚖️</span>
          Rechtliche Grundlage
        </h2>
        
        <div class="p-4 bg-blue-50 rounded-lg">
          <h3 class="font-semibold text-blue-800 mb-2">§ 656a-d BGB – Maklervertrag bei Wohnungsvermittlung</h3>
          <p class="text-blue-700 text-sm mb-2">
            Seit dem 23.12.2020 regelt das Gesetz über die Verteilung der Maklerkosten bei der Vermittlung 
            von Kaufverträgen über Wohnungen und Einfamilienhäuser die faire Aufteilung der Provision.
          </p>
          <p class="text-blue-700 text-sm">
            <strong>Kernpunkte:</strong> Schriftformerfordernis, Halbteilungsprinzip, Verbot der Überwälzung auf den Käufer
          </p>
        </div>
      </div>
    </div>
</main>
  
  <!-- BreadcrumbSchema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://www.deutschland-rechner.de/" },
      { "@type": "ListItem", "position": 2, "name": "Maklerkosten-Rechner", "item": "https://www.deutschland-rechner.de/maklerkosten-rechner" }
    ]
  })} />
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Maklerkosten-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/maklerkosten-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie hoch ist die Maklerprovision 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Maklerprovision variiert zwischen 5,95% und 7,14% je nach Bundesland (inkl. MwSt.). In den meisten Bundesländern beträgt sie 7,14%. Seit Dezember 2020 wird die Provision bei Wohnungen und Einfamilienhäusern zwischen Käufer und Verkäufer geteilt."
        }
      },
      {
        "@type": "Question",
        "name": "Wer bezahlt die Maklerprovision beim Hauskauf?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Seit dem Gesetz von 2020 gilt das Halbteilungsprinzip: Käufer und Verkäufer teilen sich die Provision 50/50. Der Käufer darf nicht mehr als die Hälfte der Courtage zahlen. Beauftragt nur der Verkäufer den Makler, trägt er die gesamte Provision."
        }
      },
      {
        "@type": "Question",
        "name": "Kann man die Maklerprovision verhandeln?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, die üblichen Provisionssätze sind nicht gesetzlich festgelegt, sondern marktüblich. Sie können die Höhe der Provision verhandeln. Besonders bei hochpreisigen Objekten oder in einem Käufermarkt haben Sie Verhandlungsspielraum."
        }
      },
      {
        "@type": "Question",
        "name": "Wann ist die Maklerprovision fällig?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Provision wird fällig, sobald der Kaufvertrag notariell beurkundet wurde und die Tätigkeit des Maklers ursächlich für den Vertragsabschluss war. Die Zahlungsfrist beträgt üblicherweise 14 Tage nach Rechnungsstellung."
        }
      },
      {
        "@type": "Question",
        "name": "In welchen Bundesländern ist die Maklerprovision am niedrigsten?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die niedrigsten Maklerprovisionen gibt es in Bremen, Hessen und Mecklenburg-Vorpommern mit 5,95% (inkl. MwSt.). Hamburg liegt bei 6,25%. Die meisten anderen Bundesländer haben 7,14% als üblichen Satz."
        }
      }
    ]
  })} />
</Layout>
