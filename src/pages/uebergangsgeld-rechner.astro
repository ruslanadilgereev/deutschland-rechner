import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = "Übergangsgeld-Rechner 2026 – Höhe bei Reha berechnen (§ 66 SGB IX)";
const description = "Übergangsgeld berechnen 2026: 68 % oder 75 % der Berechnungsgrundlage (80 % Regelentgelt, max. Netto). Reha-Übergangsgeld nach §§ 66–68 SGB IX kostenlos schätzen!";
const keywords = "Übergangsgeld Rechner, Übergangsgeld berechnen, Übergangsgeld Höhe, Übergangsgeld 2026, Übergangsgeld Reha, Übergangsgeld Rentenversicherung, Übergangsgeld Berechnung, Übergangsgeld 68 75 Prozent, SGB IX 66, Übergangsgeld DRV, Reha Übergangsgeld, Übergangsgeld Teilhabe, Übergangsgeld netto";
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Übergangsgeld-Rechner", url: "/uebergangsgeld-rechner" }]} />
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Sozialleistungen', href: '/sozialleistungen' },
    { name: 'Übergangsgeld-Rechner' }
  ]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-orange-500 to-amber-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-orange-100 hover:text-white mb-4 transition-colors"
