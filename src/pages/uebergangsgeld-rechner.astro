            <span class="text-2xl">♿</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Erwerbsminderungsrente-Rechner</p>
          </a>
          <a href="/arbeitslosengeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📋</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Arbeitslosengeld-Rechner</p>
          </a>
