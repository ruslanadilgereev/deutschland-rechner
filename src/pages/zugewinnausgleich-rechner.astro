import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Zugewinnausgleich-Rechner 2026 – Ausgleichsforderung berechnen";
const description = "Zugewinnausgleich berechnen: Endvermögen minus Anfangsvermögen, halber Überschuss, Kappung nach §§ 1373–1378 BGB. Kostenlos die Ausgleichsforderung bei Scheidung ermitteln.";
const keywords = "Zugewinnausgleich Rechner, Zugewinnausgleich berechnen, Zugewinn berechnen, Ausgleichsforderung, Zugewinngemeinschaft, Zugewinnausgleich Scheidung, Anfangsvermögen Endvermögen, § 1378 BGB, Zugewinnausgleich Erbschaft, Gütertrennung Zugewinn";
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Zugewinnausgleich-Rechner", url: "/zugewinnausgleich-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
