import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RechnerTrust from '../components/RechnerTrust.astro';
import VerwandteRechner from '../components/VerwandteRechner.astro';

const title = "Geburtstag-Rechner – Wochentag & Sternzeichen berechnen";
const description = "Geburtstag-Rechner: An welchem Wochentag wurden Sie geboren? Countdown bis zum nächsten Geburtstag, Sternzeichen, chinesisches Tierzeichen & mehr!";
const keywords = "Geburtstag Rechner, Geburtstag berechnen, Wochentag Geburt, Tage bis Geburtstag, Sternzeichen berechnen, Geburtstag Countdown, nächster Geburtstag, Geburtstag Wochentag, Alter berechnen, Geburtstagsrechner";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Geburtstag-Rechner", url: "/geburtstag-rechner" }]} />
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Alltag & Lifestyle', href: '/alltag-lifestyle' },
    { name: 'Geburtstags-Rechner' }
  ]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-pink-500 to-rose-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-pink-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🎈</span>
          <div>
            <h1 class="text-2xl font-bold">Geburtstag-Rechner</h1>
            <p class="text-pink-100 text-sm">Geburtstagsdaten berechnen – kostenlos & sofort</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <GeburtstagRechner client:load />
    </div>

    <!-- Use-Case-Block -->
    <div class="max-w-3xl mx-auto px-4 mt-8">
      <article class="prose prose-lg max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold mt-12 mb-6">Wann brauchst du den Geburtstag-Rechner?</h2>
        <p>
          Der Geburtstag-Rechner ist mehr als eine Spielerei: Er beantwortet ganz konkrete Fragen,
          die im Alltag auftauchen — von der Geschenkplanung bis zum 10.000sten Lebenstag als
          ungewöhnlichem Anlass für eine kleine Feier. Typische Anwendungsfälle:
        </p>
        <ul>
          <li>
            <strong>Wochentag des Geburtstags ermitteln:</strong> Fällt der nächste runde
            Geburtstag auf einen Samstag oder mitten unter der Woche? Wichtig für Feier-,
            Restaurant- und Reise-Planung.
          </li>
          <li>
            <strong>Tage bis zum nächsten Geburtstag zählen:</strong> Countdown für Kinder, oder
            Erinnerung für überforderte Geschwister, die das Geschenk noch besorgen müssen.
          </li>
          <li>
            <strong>Geburtstag in einer beliebigen Woche/Jahr finden:</strong> "Wann wäre Opa 100?"
            oder "An welchem Wochentag ist mein 50.?".
          </li>
          <li>
            <strong>Sternzeichen + chinesisches Tierkreiszeichen anzeigen:</strong> Für Geschenke,
            Karten, Geburtstags-Posts in sozialen Medien.
          </li>
          <li>
            <strong>Runde Lebenstage berechnen:</strong> 10.000. Lebenstag, 1 Milliarde Sekunden,
            5.000. Tag — ungewöhnliche, persönliche Anlässe, die den Standardgeburtstag aufpeppen.
          </li>
        </ul>

        <h2 class="text-2xl font-bold mt-12 mb-6">Beispiele aus der Praxis</h2>

        <h3>Beispiel 1: Nächster Geburtstag und Wochentag</h3>
        <p>
          Geburtsdatum: <strong>03.06.1990</strong>. Heute ist der 27.04.2026.
        </p>
        <div class="bg-gray-100 p-4 rounded-lg my-4 not-prose font-mono text-sm">
          Nächster Geburtstag: 03.06.2026<br/>
          Wochentag: <strong>Mittwoch</strong><br/>
          Tage bis dahin: <strong>37 Tage</strong><br/>
          Erreichtes Alter: 36 Jahre
        </div>
        <p>
          Wer den Geburtstag mitten in der Woche hat und trotzdem groß feiern will, sollte das
          Wochenende davor blockieren — der Wochentag ist also Planungsgröße Nummer eins.
        </p>

        <h3>Beispiel 2: Sternzeichen + chinesisches Tier</h3>
        <p>
          Geburtsdatum: <strong>12.11.1985</strong>.
        </p>
        <div class="bg-gray-100 p-4 rounded-lg my-4 not-prose font-mono text-sm">
          Westliches Sternzeichen: <strong>Skorpion</strong> (23.10. – 21.11.)<br/>
          Chinesisches Tier: <strong>Büffel</strong> (Jahr 1985)<br/>
          Generation: Millennials (Gen Y)
        </div>

        <h3>Beispiel 3: 10.000. Lebenstag</h3>
        <p>
          Geboren am <strong>01.01.2000</strong>. Wann ist der 10.000. Lebenstag?
        </p>
        <div class="bg-gray-100 p-4 rounded-lg my-4 not-prose font-mono text-sm">
          Tag 1: 01.01.2000<br/>
          + 9.999 Tage<br/>
          = <strong>10.000. Lebenstag: 19.05.2027</strong> (ein Mittwoch)
        </div>
        <p>
          10.000 Tage entsprechen rund 27 Jahren und 4 Monaten. Ein guter, ungewöhnlicher Anlass
          zwischen dem 25. und 30. Geburtstag.
        </p>

        <h2 class="text-2xl font-bold mt-12 mb-6">Häufige Fragen rund um Geburtstage</h2>

        <details class="border border-gray-200 rounded-lg p-4 mb-3">
          <summary class="font-semibold cursor-pointer">Welcher Wochentag war der 1. Januar 2000?</summary>
          <p class="mt-3">
            Der 01.01.2000 war ein <strong>Samstag</strong>. Das ist ein beliebter
            Referenz-Anker, weil viele Menschen heute diesen Termin als "Millennium-Geburtstag" im
            Kopf haben. Auch Funktionen wie der Zeller-Algorithmus oder Doomsday-Trick nutzen das
            Jahr 2000 gerne als Basis.
          </p>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 mb-3">
          <summary class="font-semibold cursor-pointer">Warum hat das Jahr manchmal 366 Tage?</summary>
          <p class="mt-3">
            Schaltjahre gleichen die Differenz zwischen Kalenderjahr (365 Tage) und tatsächlichem
            Sonnenjahr (≈ 365,2422 Tage) aus. Die <strong>gregorianische Schaltjahresregel</strong>
            lautet: durch 4 teilbar = Schaltjahr, ABER nicht wenn durch 100 teilbar, AUSSER wenn durch
            400 teilbar. Beispiele: 2000 war Schaltjahr (durch 400 teilbar), 1900 war keines (nur durch
            100, aber nicht 400), 2024 war Schaltjahr (durch 4), 2100 wird keines sein.
          </p>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 mb-3">
          <summary class="font-semibold cursor-pointer">Wann feiern Schaltjahr-Babys (29.02.)?</summary>
          <p class="mt-3">
            In Nicht-Schaltjahren feiern die meisten Schaltjahres-Babys entweder am
            <strong>28. Februar</strong> oder am <strong>1. März</strong>. Rechtlich (§ 187 BGB)
            gilt in Deutschland: das nächste Lebensjahr beginnt am 1. März, weil der 29.02.
            schlicht nicht existiert. Für die "richtige" Feier mit Datum kommt nur alle vier Jahre
            ein 29.02. — der nächste fällt auf 2028.
          </p>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 mb-3">
          <summary class="font-semibold cursor-pointer">Was bedeutet ein "runder" Geburtstag rechtlich/gesellschaftlich?</summary>
          <p class="mt-3">
            Rechtlich gibt es nur wenige "runde" Geburtstage mit Wirkung: <strong>14, 16, 18 und
            21</strong> sind in unterschiedlichen Gesetzen Schwellenwerte (Strafmündigkeit,
            Religionsmündigkeit, Volljährigkeit, USA-Alkoholgrenze). Gesellschaftlich gelten 30, 40,
            50, 60, 70, 80, 90, 100 als "runde" Anlässe. Ab 100 verschickt das Bundespräsidialamt
            auf Antrag ein Glückwunschschreiben — auch zu jedem weiteren Geburtstag.
          </p>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 mb-3">
          <summary class="font-semibold cursor-pointer">Wann ist der nächste Freitag, der 13., in 2026?</summary>
          <p class="mt-3">
            2026 hat zwei Freitag-der-13.-Termine: <strong>13. Februar 2026</strong> und
            <strong>13. März 2026</strong>. Diese ungewöhnliche Häufung in zwei aufeinanderfolgenden
            Monaten kommt nur in Nicht-Schaltjahren mit bestimmtem Wochentagsanker vor. Für 2027
            ist der nächste am 13. August.
          </p>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 mb-3">
          <summary class="font-semibold cursor-pointer">Ist mein Sternzeichen wirklich "richtig" laut Astronomie?</summary>
          <p class="mt-3">
            Die in der Zeitung verbreiteten Sternzeichen folgen der <strong>tropischen
            Astrologie</strong> mit festen Datumsbereichen. Astronomisch hat sich der Frühlingspunkt
            durch die Erdpräzession seit der Antike um etwa 30° verschoben — wer also "Stier" ist,
            steht astronomisch heute eher im Sternbild Widder. Für unseren Rechner gelten die
            klassischen astrologischen Daten, weil sie das ist, was die meisten meinen.
          </p>
        </details>

        <h2 class="text-2xl font-bold mt-12 mb-6">Quellen &amp; Methodik</h2>
        <p>
          Wochentags- und Datumsberechnung folgen dem <strong>gregorianischen Kalender</strong>,
          der 1582 durch Papst Gregor XIII. eingeführt und in Deutschland nach 1700 (in den
          protestantischen Territorien) bzw. schon 1583/84 (in den katholischen) übernommen
          wurde. Die <strong>Schaltjahresregel</strong> (durch 4 teilbar, außer durch 100, außer
          durch 400) ist seitdem unverändert. Sternzeichen-Datumsbereiche entsprechen der
          gängigen tropischen Astrologie. Das chinesische Tierkreiszeichen wird nach dem
          Sonnenjahr (1.1.) zugeordnet — astrologisch korrekter wäre das chinesische Neujahr
          (zwischen 21.01. und 20.02.), für die meisten Anwendungen reicht aber die
          Jahresgrenze.
        </p>

        <p class="text-sm text-gray-500 mt-8">Zuletzt aktualisiert: April 2026</p>
      </article>
    </div>

    <RechnerTrust quellen="Gregorianischer Kalender (1582), in Deutschland gültig seit 1700; tropische Astrologie" aktualisiert="April 2026" />

    <VerwandteRechner aktuellerSlug="geburtstag" slugs={['alter', 'geburtstermin', 'tage', 'hochzeit']} />

<!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Geburtstag-Rechner: Alles, was Sie wissen müssen</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem <strong>Geburtstag-Rechner</strong> können Sie spannende Fakten zu Ihrem 
            Geburtstag herausfinden: An welchem Wochentag wurden Sie geboren? Wie viele Tage sind 
            es noch bis zu Ihrem nächsten Geburtstag? Was ist Ihr Sternzeichen?
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">An welchem Wochentag wurde ich geboren?</h3>
          <p>
            Geben Sie Ihr Geburtsdatum ein und erfahren Sie sofort, ob Sie an einem Montag, Dienstag, 
            Mittwoch, Donnerstag, Freitag, Samstag oder Sonntag geboren wurden. Fun Fact: Laut 
            Statistik werden die meisten Babys <strong>dienstags</strong> geboren, die wenigsten 
            <strong>sonntags</strong>.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Countdown bis zum nächsten Geburtstag</h3>
          <p>
            Der Rechner zeigt Ihnen automatisch:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Tage bis zum nächsten Geburtstag</strong></li>
            <li><strong>Wochen und Monate</strong> bis zum Geburtstag</li>
            <li><strong>Wochentag</strong> Ihres nächsten Geburtstags</li>
            <li><strong>Welches Alter</strong> Sie dann erreichen</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Sternzeichen nach Geburtsdatum</h3>
          <p>
            Die 12 Sternzeichen und ihre Zeiträume:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Widder:</strong> 21. März – 19. April</li>
            <li><strong>Stier:</strong> 20. April – 20. Mai</li>
            <li><strong>Zwillinge:</strong> 21. Mai – 20. Juni</li>
            <li><strong>Krebs:</strong> 21. Juni – 22. Juli</li>
            <li><strong>Löwe:</strong> 23. Juli – 22. August</li>
            <li><strong>Jungfrau:</strong> 23. August – 22. September</li>
            <li><strong>Waage:</strong> 23. September – 22. Oktober</li>
            <li><strong>Skorpion:</strong> 23. Oktober – 21. November</li>
            <li><strong>Schütze:</strong> 22. November – 21. Dezember</li>
            <li><strong>Steinbock:</strong> 22. Dezember – 19. Januar</li>
            <li><strong>Wassermann:</strong> 20. Januar – 18. Februar</li>
            <li><strong>Fische:</strong> 19. Februar – 20. März</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Chinesisches Tierkreiszeichen</h3>
          <p>
            Das chinesische Horoskop basiert auf einem 12-Jahres-Zyklus:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Ratte:</strong> 2020, 2008, 1996, 1984, 1972</li>
            <li><strong>Büffel:</strong> 2021, 2009, 1997, 1985, 1973</li>
            <li><strong>Tiger:</strong> 2022, 2010, 1998, 1986, 1974</li>
            <li><strong>Hase:</strong> 2023, 2011, 1999, 1987, 1975</li>
            <li><strong>Drache:</strong> 2024, 2012, 2000, 1988, 1976</li>
            <li><strong>Schlange:</strong> 2025, 2013, 2001, 1989, 1977</li>
            <li><strong>Pferd:</strong> 2026, 2014, 2002, 1990, 1978</li>
            <li><strong>Ziege:</strong> 2027, 2015, 2003, 1991, 1979</li>
            <li><strong>Affe:</strong> 2028, 2016, 2004, 1992, 1980</li>
            <li><strong>Hahn:</strong> 2029, 2017, 2005, 1993, 1981</li>
            <li><strong>Hund:</strong> 2030, 2018, 2006, 1994, 1982</li>
            <li><strong>Schwein:</strong> 2031, 2019, 2007, 1995, 1983</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Generationen nach Geburtsjahr</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Generation Alpha:</strong> 2013 – heute</li>
            <li><strong>Generation Z:</strong> 1997 – 2012</li>
            <li><strong>Millennials (Gen Y):</strong> 1981 – 1996</li>
            <li><strong>Generation X:</strong> 1965 – 1980</li>
            <li><strong>Baby Boomer:</strong> 1946 – 1964</li>
            <li><strong>Stille Generation:</strong> 1928 – 1945</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Besondere Geburtstage</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>1 Jahr:</strong> Erster Geburtstag – ein Meilenstein!</li>
            <li><strong>18 Jahre:</strong> Volljährigkeit in Deutschland</li>
            <li><strong>21 Jahre:</strong> Volljährigkeit in den USA (Alkohol)</li>
            <li><strong>30, 40, 50...:</strong> Runde Geburtstage werden groß gefeiert</li>
            <li><strong>100 Jahre:</strong> Glückwunsch vom Bundespräsidenten</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Geburtstag am 29. Februar?</h3>
          <p>
            Wer am <strong>29. Februar</strong> geboren wurde, hat einen seltenen Geburtstag! Dieser 
            Tag gibt es nur alle vier Jahre (im Schaltjahr). In Nicht-Schaltjahren feiern viele am 
            28. Februar oder 1. März.
          </p>
          <p>
            <strong>Rechtlich:</strong> In Deutschland gilt man am 1. März als ein Jahr älter, wenn 
            der 29. Februar nicht existiert.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Interessante Geburtstags-Fakten</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Häufigster Geburtstag:</strong> Ende September (9 Monate nach Silvester)</li>
            <li><strong>Seltenster Geburtstag:</strong> 29. Februar, 25. Dezember</li>
            <li><strong>Geburtstags-Paradoxon:</strong> In einer Gruppe von 23 Personen haben zwei 
              mit 50% Wahrscheinlichkeit am gleichen Tag Geburtstag</li>
            <li><strong>Weltweit:</strong> Etwa 385.000 Menschen werden täglich geboren</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Geburtstag in Zahlen</h3>
          <p>
            Mit jedem Geburtstag haben Sie erlebt:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Pro Jahr:</strong> 365 Tage, ca. 8.760 Stunden</li>
            <li><strong>Mit 30:</strong> ca. 10.950 Tage gelebt</li>
            <li><strong>Mit 50:</strong> ca. 18.250 Tage gelebt</li>
            <li><strong>Mit 80:</strong> ca. 29.200 Tage gelebt</li>
          </ul>
        </div>
      </div>
    </div>
    
