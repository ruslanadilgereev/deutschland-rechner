---
import Layout from '../layouts/Layout.astro';
import LaminatRechner from '../components/rechner/LaminatRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = "Laminat-Rechner 2026 – Pakete, Verschnitt & Kosten berechnen";
const description = "Laminatbedarf kostenlos berechnen: Pakete und Materialbedarf aus Raumgröße, Verlegemuster und Verschnitt – plus Kostenschätzung für Trittschall, Sockelleisten und Verlegung. Mit Richtwerten und Beispielen.";
const keywords = "Laminat Rechner, Laminat berechnen, Laminatbedarf, Verschnitt Laminat, wie viele Pakete Laminat, Laminat Kosten pro m2, Laminat verlegen Kosten, Laminat m2 pro Paket, Bodenbelag berechnen";
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Laminat-Rechner", url: "/laminat-rechner" }]} />
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Wohnen & Immobilien', href: '/wohnen-immobilien' },
    { name: 'Laminat-Rechner' }
  ]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-blue-200 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🪵</span>
          <div>
            <h1 class="text-2xl font-bold">Laminat-Rechner 2026</h1>
            <p class="text-blue-200 text-sm">Pakete, Verschnitt und Kosten berechnen</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Trust-Block -->
    <div class="max-w-2xl mx-auto px-4 mt-4">
      <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-sm text-green-800">
        <div class="flex items-start gap-3">
          <span class="text-xl mt-0.5">✅</span>
          <div>
            <p class="font-semibold mb-1">Zuletzt aktualisiert am 5. Juni 2026</p>
            <p class="mb-1"><strong>Grundlage:</strong> Materialbedarf = Fläche × Verschnittfaktor; Pakete = Bedarf ÷ m² pro Paket, aufgerundet, plus Reserve. Verschnitt je Muster: gerade 5 %, Standard 8 %, diagonal 15 %, Fischgrät 18 %.</p>
            <p class="mb-1"><strong>Voreinstellungen:</strong> 2,4 m² pro Paket, ein Reserve-Paket, Material 15 €/m², Trittschall ≈ 2 €/m², Sockelleisten ≈ 10 €/m. Alle Werte sind anpassbar.</p>
            <p><strong>Nicht berücksichtigt:</strong> Untergrundvorbereitung, Übergangsprofile und regionale Preisunterschiede. Die genaue m²-Zahl pro Paket steht auf der Verpackung. Richtwerte, Angaben ohne Gewähr.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <LaminatRechner client:load />
    </div>

    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Laminatbedarf richtig berechnen</h2>

        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit dem <strong>Laminat-Rechner</strong> ermitteln Sie, wie viele Pakete Sie für einen
            Raum brauchen – inklusive <strong>Verschnitt</strong> je nach Verlegemuster, Reserve und
            einer optionalen Kostenschätzung für Trittschalldämmung, Sockelleisten und Verlegung. So
            kaufen Sie weder zu wenig noch unnötig viel und kennen vorab das ungefähre Budget.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Die Formel</h3>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>Fläche</strong> = Länge × Breite (mehrere Räume addieren)</li>
              <li><strong>Materialbedarf</strong> = Fläche × Verschnittfaktor</li>
              <li><strong>Pakete</strong> = Materialbedarf ÷ m² pro Paket, aufgerundet, + Reserve</li>
            </ul>
          </div>
          <p>
            Da Laminat nur in ganzen Paketen verkauft wird, rundet der Rechner immer auf. Ein
            zusätzliches Reserve-Paket ist sinnvoll, falls später eine Diele beschädigt wird – eine
            Nachbestellung passt farblich oft nicht exakt.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Verschnitt nach Verlegemuster</h3>
          <p>
            Der <strong>Verschnitt</strong> hängt vor allem vom Verlegemuster und der Raumform ab.
            Übliche Faktoren sind:
          </p>
          <ul class="list-disc pl-5 space-y-1 text-sm">
            <li><strong>Gerade / Halbverband</strong> – ca. 5 % Verschnitt (Faktor 1,05)</li>
            <li><strong>Standard-Verlegung</strong> – ca. 8 % (Faktor 1,08)</li>
            <li><strong>Diagonal</strong> – ca. 15 % (Faktor 1,15)</li>
            <li><strong>Fischgrät</strong> – ca. 18 % (Faktor 1,18)</li>
          </ul>
          <p>
            Bei verwinkelten Räumen mit vielen Nischen und Türen kann der Verschnitt höher ausfallen.
            Großzügige Reserve schadet hier nicht.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was kostet Laminat verlegen?</h3>
          <p>
            Das <strong>Material</strong> liegt je nach Qualität bei rund <strong>7 bis 18 €/m²</strong>.
            Dazu kommen <strong>Trittschalldämmung</strong> (ca. 2 €/m²) und
            <strong>Sockelleisten</strong> (ca. 10 €/m Wandumfang). Verlegen Sie selbst, entfallen die
            Lohnkosten. Beauftragen Sie einen Profi, kommen rund <strong>20 bis 35 €/m²</strong>
            hinzu. Der Rechner addiert die gewählten Posten zu einer groben Gesamtsumme – ein
            verbindliches Angebot ersetzt das nicht.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Die m² pro Paket variieren</h3>
          <p>
            Wie viele Quadratmeter in einem Paket stecken, hängt von Diele und Hersteller ab. Übliche
            Werte liegen zwischen <strong>2,2 und 2,5 m²</strong>. Schmale Landhausdielen kommen teils
            auf weniger, große Formate auf mehr. Tragen Sie für ein exaktes Ergebnis den Wert von der
            Verpackung ein.
          </p>
        </div>
      </div>
    </div>

    <!-- Referenztabelle -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">🪵 Pakete je Raumgröße (Standard-Verlegung)</h2>
        <p class="text-gray-600 text-sm mb-4">
          Richtwerte mit 8 % Verschnitt, 2,4 m² pro Paket, ohne Reserve.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200 text-left text-gray-500">
                <th class="py-2 pr-2 font-semibold">Fläche</th>
                <th class="py-2 px-2 font-semibold text-right">Bedarf inkl. 8 %</th>
                <th class="py-2 pl-2 font-semibold text-right">≈ Pakete</th>
              </tr>
            </thead>
            <tbody class="text-gray-700">
              <tr class="border-b border-gray-100"><td class="py-2 pr-2">10 m²</td><td class="py-2 px-2 text-right">10,8 m²</td><td class="py-2 pl-2 text-right">5</td></tr>
              <tr class="border-b border-gray-100"><td class="py-2 pr-2">15 m²</td><td class="py-2 px-2 text-right">16,2 m²</td><td class="py-2 pl-2 text-right">7</td></tr>
              <tr class="border-b border-gray-100"><td class="py-2 pr-2">20 m²</td><td class="py-2 px-2 text-right">21,6 m²</td><td class="py-2 pl-2 text-right">9</td></tr>
              <tr class="border-b border-gray-100"><td class="py-2 pr-2">25 m²</td><td class="py-2 px-2 text-right">27,0 m²</td><td class="py-2 pl-2 text-right">12</td></tr>
              <tr class="border-b border-gray-100"><td class="py-2 pr-2">30 m²</td><td class="py-2 px-2 text-right">32,4 m²</td><td class="py-2 pl-2 text-right">14</td></tr>
              <tr><td class="py-2 pr-2">40 m²</td><td class="py-2 px-2 text-right">43,2 m²</td><td class="py-2 pl-2 text-right">18</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-400 mt-3">
          Quellen: casando.de, parkett-direkt.net, renovierungskosten.net (Stand 2026).
        </p>
      </div>
    </div>

    <!-- Beispielrechnungen -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Beispielrechnungen</h2>
        <p class="text-gray-600 text-sm mb-4">
          2,4 m² pro Paket, ein Reserve-Paket:
        </p>

        <div class="space-y-4">
          <!-- Beispiel 1 -->
          <div class="bg-gray-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 1: Wohnzimmer 5 × 4 m, Standard</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Fläche:</div>
              <div class="font-medium text-gray-800">5 × 4 = 20 m²</div>
              <div class="text-gray-600">Bedarf inkl. 8 %:</div>
              <div class="font-medium text-gray-800">20 × 1,08 = 21,6 m²</div>
              <div class="text-gray-600">Pakete ohne Reserve:</div>
              <div class="font-medium text-gray-800">21,6 ÷ 2,4 = 9</div>
              <div class="text-gray-600">Pakete + 1 Reserve:</div>
              <div class="font-medium text-green-700">10 Pakete</div>
            </div>
          </div>

          <!-- Beispiel 2 -->
          <div class="bg-blue-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 2: Schlafzimmer 15 m², diagonal</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Fläche:</div>
              <div class="font-medium text-gray-800">15 m²</div>
              <div class="text-gray-600">Bedarf inkl. 15 %:</div>
              <div class="font-medium text-gray-800">15 × 1,15 = 17,25 m²</div>
              <div class="text-gray-600">Pakete ohne Reserve:</div>
              <div class="font-medium text-gray-800">17,25 ÷ 2,4 = 8</div>
              <div class="text-gray-600">Pakete + 1 Reserve:</div>
              <div class="font-medium text-green-700">9 Pakete</div>
            </div>
          </div>

          <!-- Beispiel 3 -->
          <div class="bg-gray-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 3: Kosten Wohnzimmer (Bsp. 1), DIY</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Material 10 Pakete × 2,4 m² × 15 €:</div>
              <div class="font-medium text-gray-800">360 €</div>
              <div class="text-gray-600">Trittschall 20 m² × 2 €:</div>
              <div class="font-medium text-gray-800">40 €</div>
              <div class="text-gray-600">Sockelleisten 18 m × 10 €:</div>
              <div class="font-medium text-gray-800">180 €</div>
              <div class="text-gray-600">Gesamt (Selbstverlegung):</div>
              <div class="font-medium text-green-700">580 €</div>
            </div>
          </div>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mt-4 text-sm text-blue-800">
          <strong>💡 Tipp:</strong> Beispiel 2 zeigt: Diagonale Verlegung erhöht den Verschnitt auf
          15 %, dadurch wird ein Paket mehr fällig als bei gerader Verlegung. Wer sparen will, verlegt
          gerade im Halbverband – dort reichen oft 5 % Verschnitt.
        </div>
      </div>
    </div>

    <!-- Typische Fehler -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">⚠️ Typische Fehler & Sonderfälle</h2>

        <div class="space-y-4 text-sm text-gray-600">
          <div class="border-l-4 border-red-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 1: Verschnitt zu niedrig ansetzen</h3>
            <p>Bei diagonaler oder Fischgrät-Verlegung entsteht deutlich mehr Verschnitt als bei
            gerader. Wer pauschal 5 % rechnet, hat am Ende zu wenig Material.</p>
          </div>

          <div class="border-l-4 border-red-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 2: m² pro Paket raten</h3>
            <p>Die Paketgröße variiert zwischen 2,2 und 2,5 m². Eine falsche Annahme verschiebt die
            Paketzahl. Tragen Sie immer den Wert von der konkreten Verpackung ein.</p>
          </div>

          <div class="border-l-4 border-orange-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 3: Reserve vergessen</h3>
            <p>Wird später eine Diele beschädigt, passt eine Nachbestellung farblich oft nicht. Ein
            ungeöffnetes Reserve-Paket aus der gleichen Charge löst das Problem.</p>
          </div>

          <div class="border-l-4 border-blue-400 pl-4">
            <h3 class="font-semibold text-gray-800">Sonderfall: Mehrere Räume</h3>
            <p>Verlegen Sie über Türschwellen hinweg durchgehend, addieren Sie die Flächen vor der
            Berechnung. Bei getrennten Räumen rechnen Sie jeden Raum einzeln, da der Verschnitt pro
            Raum anfällt.</p>
          </div>

          <div class="border-l-4 border-blue-400 pl-4">
            <h3 class="font-semibold text-gray-800">Sonderfall: Sockelleisten und Profile</h3>
            <p>Die Sockelleisten richten sich nach dem Raumumfang, nicht nach der Fläche.
            Übergangsprofile an Türen und Raumübergängen sind hier nicht enthalten und kommen je nach
            Grundriss hinzu.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Section (sichtbar) -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">❓ Häufig gestellte Fragen zu Laminat</h2>

        <div class="space-y-4">
          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viel Laminat brauche ich für meinen Raum?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Multiplizieren Sie die Raumfläche mit dem Verschnittfaktor und teilen Sie das Ergebnis
              durch die m² pro Paket. Für 20 m² mit 8 % Verschnitt und 2,4 m² pro Paket sind das
              21,6 ÷ 2,4 = 9 Pakete, plus mindestens ein Reserve-Paket.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viel Verschnitt sollte ich bei Laminat einplanen?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Bei gerader Verlegung im Halbverband reichen rund 5 %, bei Standard-Verlegung etwa
              8 %. Diagonale Verlegung erfordert ca. 15 %, Fischgrät rund 18 %. Verwinkelte Räume mit
              vielen Nischen brauchen tendenziell mehr.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viele m² sind in einem Paket Laminat?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Üblich sind 2,2 bis 2,5 m² pro Paket, abhängig von Dielenformat und Hersteller. Schmale
              Landhausdielen kommen teils auf weniger, große Formate auf mehr. Der genaue Wert steht auf
              der Verpackung und sollte für die Rechnung verwendet werden.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Was kostet Laminat verlegen pro m²?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Das Material kostet je nach Qualität rund 7 bis 18 €/m². Trittschalldämmung schlägt mit
              etwa 2 €/m² zu Buche, Sockelleisten mit rund 10 €/m. Wer einen Profi beauftragt, zahlt
              zusätzlich etwa 20 bis 35 €/m² Lohnkosten.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Brauche ich Trittschalldämmung unter Laminat?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Ja, eine Trittschalldämmung ist fast immer sinnvoll. Sie reduziert Gehgeräusche,
              gleicht kleine Unebenheiten aus und ist in Mietwohnungen oft vorgeschrieben. Manche
              Laminate haben die Dämmung bereits integriert – dann entfällt sie als Extra-Posten.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Sollte ich ein Reserve-Paket kaufen?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Ja. Ein ungeöffnetes Reserve-Paket aus derselben Charge ermöglicht später den Austausch
              beschädigter Dielen, ohne dass Farbe oder Dekor abweichen. Nachbestellungen aus einer
              anderen Produktion passen häufig nicht exakt.</p>
            </div>
          </details>
        </div>
      </div>
    </div>

    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/fliesen-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🧱</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Fliesen-Rechner</p>
          </a>
          <a href="/wandfarbe-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🎨</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Wandfarben-Rechner</p>
          </a>
          <a href="/tapeten-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🧻</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Tapeten-Rechner</p>
          </a>
          <a href="/wohnflaeche-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📐</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Wohnflächen-Rechner</p>
          </a>
          <a href="/handwerkerkosten-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🔨</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Handwerkerkosten-Rechner</p>
          </a>
          <a href="/quadratmeterpreis-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📏</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Quadratmeterpreis-Rechner</p>
          </a>
        </div>
      </div>
    </div>
  </main>

  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Laminat-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/laminat-rechner",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />

  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie viel Laminat brauche ich für meinen Raum?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Multiplizieren Sie die Raumfläche mit dem Verschnittfaktor und teilen Sie das Ergebnis durch die m² pro Paket. Für 20 m² mit 8 % Verschnitt und 2,4 m² pro Paket sind das 21,6 ÷ 2,4 = 9 Pakete, plus mindestens ein Reserve-Paket."
        }
      },
      {
        "@type": "Question",
        "name": "Wie viel Verschnitt sollte ich bei Laminat einplanen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bei gerader Verlegung im Halbverband reichen rund 5 %, bei Standard-Verlegung etwa 8 %. Diagonale Verlegung erfordert ca. 15 %, Fischgrät rund 18 %. Verwinkelte Räume mit vielen Nischen brauchen tendenziell mehr."
        }
      },
      {
        "@type": "Question",
        "name": "Wie viele m² sind in einem Paket Laminat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Üblich sind 2,2 bis 2,5 m² pro Paket, abhängig von Dielenformat und Hersteller. Schmale Landhausdielen kommen teils auf weniger, große Formate auf mehr. Der genaue Wert steht auf der Verpackung und sollte für die Rechnung verwendet werden."
        }
      },
      {
        "@type": "Question",
        "name": "Was kostet Laminat verlegen pro m²?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das Material kostet je nach Qualität rund 7 bis 18 €/m². Trittschalldämmung schlägt mit etwa 2 €/m² zu Buche, Sockelleisten mit rund 10 €/m. Wer einen Profi beauftragt, zahlt zusätzlich etwa 20 bis 35 €/m² Lohnkosten."
        }
      },
      {
        "@type": "Question",
        "name": "Brauche ich Trittschalldämmung unter Laminat?",
