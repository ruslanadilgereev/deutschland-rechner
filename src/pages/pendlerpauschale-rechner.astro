---
import Layout from '../layouts/Layout.astro';
import PendlerpauschaleRechner from '../components/rechner/PendlerpauschaleRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Pendlerpauschale-Rechner – 38 Cent ab km 1";
const description = "Pendlerpauschale 2026 berechnen: Einheitlich 0,38€/km ab dem 1. Kilometer. Steuerersparnis, Homeoffice-Abzug & Mobilitätsprämie.";
const keywords = "Pendlerpauschale Rechner, Pendlerpauschale 2026, Entfernungspauschale Rechner, Pendlerpauschale berechnen, 38 Cent Kilometer, Fahrtkostenrechner, Pendlerpauschale Steuerersparnis, Arbeitsweg absetzen, Kilometerpauschale 2026";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Pendlerpauschale-Rechner", url: "/pendlerpauschale-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-blue-500 to-indigo-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-blue-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🚗</span>
          <div>
            <h1 class="text-2xl font-bold">Pendlerpauschale-Rechner 2026</h1>
            <p class="text-blue-100 text-sm">NEU: Einheitlich 38 Cent/km ab km 1!</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <PendlerpauschaleRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Pendlerpauschale 2026: Das Wichtigste auf einen Blick</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <div class="bg-green-50 p-4 rounded-lg my-4">
            <p class="text-sm text-green-800 font-semibold mb-2">🆕 Neu ab 2026:</p>
            <ul class="space-y-1 text-sm text-green-700">
              <li><strong>38 Cent pro Kilometer ab dem ersten Kilometer</strong></li>
              <li>Keine Staffelung mehr (vorher: 30 Cent bis km 20, dann 38 Cent)</li>
              <li>Gilt für alle Verkehrsmittel: Auto, Fahrrad, ÖPNV, zu Fuß</li>
            </ul>
          </div>
          
          <p>
            Die <strong>Pendlerpauschale</strong> (auch Entfernungspauschale genannt) ist einer der wichtigsten 
            Steuerabzüge für Arbeitnehmer in Deutschland. Mit unserem kostenlosen <strong>Pendlerpauschale-Rechner 2026</strong> 
            berechnen Sie schnell, wie viel Steuern Sie durch Ihre Fahrt zur Arbeit sparen können.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Pendlerpauschale Höhe 2026</h3>
          <p>
            Ab Januar 2026 wurde die Pendlerpauschale <strong>vereinheitlicht</strong>:
          </p>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>0,38 € pro Kilometer</strong> – für jeden Kilometer der einfachen Strecke</li>
              <li>Die bisherige Staffelung (30 Cent bis km 20, 38 Cent ab km 21) entfällt</li>
              <li>Maximal absetzbar: <strong>4.500 € pro Jahr</strong> (außer bei Nutzung eines eigenen PKW)</li>
              <li>Gilt nur für die <strong>einfache Entfernung</strong>, nicht Hin- und Rückweg</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wie berechnet man die Pendlerpauschale?</h3>
          <p>
            Die <strong>Berechnung der Pendlerpauschale</strong> ist einfach:
          </p>
          <div class="bg-gray-50 p-4 rounded-lg my-4 font-mono text-sm">
            Pendlerpauschale = Entfernung (km) × 0,38 € × Arbeitstage
          </div>
          <p>
            <strong>Beispielrechnung:</strong> Bei 25 km Arbeitsweg und 220 Arbeitstagen:<br/>
            25 km × 0,38 € × 220 Tage = <strong>2.090 € absetzbar</strong>
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Welche Verkehrsmittel zählen?</h3>
          <p>
            Die Pendlerpauschale gilt <strong>verkehrsmittelunabhängig</strong>:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Auto/Motorrad:</strong> Keine Obergrenze (volle Pauschale)</li>
            <li><strong>Öffentliche Verkehrsmittel:</strong> Max. 4.500 € oder tatsächliche Kosten</li>
            <li><strong>Fahrrad/E-Bike:</strong> Max. 4.500 €</li>
            <li><strong>Zu Fuß:</strong> Max. 4.500 €</li>
            <li><strong>Fahrgemeinschaft:</strong> Jeder Mitfahrer kann die volle Pauschale ansetzen</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Homeoffice und Pendlerpauschale</h3>
          <p>
            Wichtig: An <strong>Homeoffice-Tagen</strong> können Sie keine Pendlerpauschale geltend machen. 
            Stattdessen gilt die <strong>Homeoffice-Pauschale</strong> von 6 € pro Tag (max. 1.260 € pro Jahr 
            für 210 Tage). Unser Rechner berücksichtigt beide Pauschalen automatisch.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wie viele Arbeitstage ansetzen?</h3>
          <p>
            Das Finanzamt akzeptiert folgende <strong>Richtwerte für Arbeitstage</strong>:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>5-Tage-Woche:</strong> 220-230 Arbeitstage pro Jahr</li>
            <li><strong>6-Tage-Woche:</strong> 260-280 Arbeitstage pro Jahr</li>
            <li><strong>Teilzeit 3 Tage:</strong> entsprechend weniger</li>
          </ul>
          <div class="bg-yellow-50 p-4 rounded-lg my-4">
            <p class="text-sm text-yellow-800">
              <strong>Tipp:</strong> Führen Sie ein Fahrtenbuch oder notieren Sie Ihre Arbeitstage, um bei 
              einer Prüfung durch das Finanzamt Nachweise zu haben. Urlaub, Krankheit und Homeoffice-Tage 
              müssen abgezogen werden.
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Mobilitätsprämie für Geringverdiener</h3>
          <p>
            Wer unter dem <strong>Grundfreibetrag</strong> (2026: 12.348 €) verdient und mehr als 20 km zur 
            Arbeit fährt, kann die <strong>Mobilitätsprämie</strong> beantragen. Diese beträgt 14% der 
            Pendlerpauschale ab km 21 und wird direkt ausgezahlt.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Werbungskostenpauschale beachten</h3>
          <p>
            Die <strong>Werbungskostenpauschale</strong> beträgt 1.230 € (2026). Die Pendlerpauschale lohnt 
            sich also besonders, wenn Sie diesen Betrag überschreiten. Bei einem Arbeitsweg von nur 15 km 
            (220 Tage) erreichen Sie bereits: 15 × 0,38 × 220 = <strong>1.254 €</strong>.
          </p>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/homeoffice-pauschale-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏡</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Homeoffice-Pauschale</p>
          </a>
          <a href="/brutto-netto-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💵</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Brutto-Netto-Rechner</p>
          </a>
          <a href="/einkommensteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🧾</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Einkommensteuer-Rechner</p>
          </a>
          <a href="/kfz-steuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🚗</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kfz-Steuer-Rechner</p>
          </a>
          <a href="/verpflegungsmehraufwand-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🍽️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Verpflegungsmehraufwand</p>
          </a>
          <a href="/stundenlohn-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">⏰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Stundenlohn-Rechner</p>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Zuständige Behörde -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🏛️</span>
          Hinweise zur Steuererklärung
        </h2>
        
        <div class="p-4 bg-blue-50 rounded-lg">
          <h3 class="font-semibold text-blue-800 mb-2">Wo eintragen?</h3>
          <p class="text-blue-700 text-sm mb-2">
            Die Pendlerpauschale wird in der <strong>Anlage N</strong> der Steuererklärung eingetragen, 
            Zeile 31-35 (Wege zwischen Wohnung und erster Tätigkeitsstätte).
          </p>
          <p class="text-blue-700 text-sm">
            <strong>Abgabefrist:</strong> 31. Juli des Folgejahres (mit Steuerberater: 28./29. Februar)<br/>
            <strong>Online:</strong> ELSTER (elster.de) – kostenlose Steuererklärung
          </p>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Pendlerpauschale-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/pendlerpauschale-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie hoch ist die Pendlerpauschale 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ab 2026 gilt einheitlich 38 Cent (0,38 €) pro Kilometer für die einfache Entfernung zwischen Wohnung und Arbeitsstätte. Die bisherige Staffelung (30 Cent bis km 20, 38 Cent ab km 21) wurde abgeschafft."
        }
      },
      {
        "@type": "Question",
        "name": "Wie berechnet man die Pendlerpauschale?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Multiplizieren Sie die einfache Entfernung in Kilometern mit 0,38 € und der Anzahl Ihrer Arbeitstage. Beispiel: 25 km × 0,38 € × 220 Tage = 2.090 € absetzbare Werbungskosten."
        }
      },
      {
        "@type": "Question",
        "name": "Gilt die Pendlerpauschale für alle Verkehrsmittel?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, die Pendlerpauschale ist verkehrsmittelunabhängig. Sie gilt für Auto, Motorrad, Fahrrad, ÖPNV und sogar zu Fuß. Bei nicht-motorisierten Verkehrsmitteln und ÖPNV gilt jedoch eine Obergrenze von 4.500 € pro Jahr."
        }
      },
      {
        "@type": "Question",
        "name": "Kann ich an Homeoffice-Tagen Pendlerpauschale absetzen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nein, an Homeoffice-Tagen gilt stattdessen die Homeoffice-Pauschale von 6 € pro Tag (max. 1.260 € pro Jahr für 210 Tage). Sie müssen die Tage entsprechend aufteilen."
        }
      },
      {
        "@type": "Question",
        "name": "Wie viele Arbeitstage kann ich ansetzen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das Finanzamt akzeptiert bei einer 5-Tage-Woche typischerweise 220-230 Arbeitstage pro Jahr. Urlaubstage, Krankheitstage und Homeoffice-Tage müssen abgezogen werden."
        }
      },
      {
        "@type": "Question",
        "name": "Wo trage ich die Pendlerpauschale in der Steuererklärung ein?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Pendlerpauschale wird in der Anlage N der Steuererklärung eingetragen, in den Zeilen 31-35 unter 'Wege zwischen Wohnung und erster Tätigkeitsstätte'."
        }
      }
    ]
  })} />
</Layout>
