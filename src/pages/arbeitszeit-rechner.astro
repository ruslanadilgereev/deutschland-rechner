---
import Layout from '../layouts/Layout.astro';
import ArbeitszeitRechner from '../components/rechner/ArbeitszeitRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = "Arbeitszeit-Rechner 2026 – Netto-Arbeitszeit & Pausen berechnen";
const description = "Arbeitszeit aus Beginn, Ende und Pause berechnen: Netto-Stunden in h:min und dezimal, Pflicht-Pausen nach § 4 ArbZG (30/45 Min.) und Über-/Unterstunden. Kostenlos.";
const keywords = "Arbeitszeit Rechner, Arbeitszeit berechnen, Netto Arbeitszeit, Pausen Rechner, Pause berechnen, Überstunden Rechner, Arbeitszeitgesetz, ArbZG Pausen, Arbeitsstunden berechnen, Stundenrechner";
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Arbeitszeit-Rechner", url: "/arbeitszeit-rechner" }]} />
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Arbeit & Gehalt', href: '/arbeit-gehalt' },
    { name: 'Arbeitszeit-Rechner' }
  ]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-blue-200 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">⏱️</span>
          <div>
            <h1 class="text-2xl font-bold">Arbeitszeit-Rechner 2026</h1>
            <p class="text-blue-200 text-sm">Netto-Arbeitszeit & Pausen nach § 4 ArbZG</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Trust-Block -->
    <div class="max-w-2xl mx-auto px-4 mt-4">
      <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-sm text-green-800">
        <div class="flex items-start gap-3">
          <span class="text-xl mt-0.5">✅</span>
          <div>
            <p class="font-semibold mb-1">Zuletzt aktualisiert am 5. Juni 2026</p>
            <p class="mb-1"><strong>Grundlage:</strong> § 4 ArbZG (Ruhepausen), § 3 ArbZG (Höchstarbeitszeit), § 5 ArbZG (Ruhezeit)</p>
            <p class="mb-1"><strong>Berücksichtigt:</strong> Netto-Arbeitszeit (Ende − Beginn − Pause) in Stunden:Minuten und dezimal, Pflicht-Pausen 30/45 Min., Schichten über Mitternacht, optionaler Über-/Unterstunden-Vergleich</p>
            <p><strong>Nicht berücksichtigt:</strong> abweichende Tarif- oder Betriebsvereinbarungen, Sonderregeln für Jugendliche (JArbSchG), Bereitschaftsdienst, Zuschläge für Nacht-, Sonn- und Feiertagsarbeit – der Rechner ersetzt keine Rechtsberatung</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <ArbeitszeitRechner client:load />
    </div>

    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Arbeitszeit berechnen: Netto-Stunden, Pausen & Gesetz</h2>

        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit dem <strong>Arbeitszeit-Rechner</strong> ermitteln Sie aus Beginn, Ende und Pause Ihre
            tatsächliche <strong>Netto-Arbeitszeit</strong> – auf die Minute genau und zusätzlich in
            Dezimalstunden für die Lohnabrechnung. Der Rechner prüft außerdem, ob Ihre Pause die
            gesetzlichen Vorgaben des <strong>Arbeitszeitgesetzes (ArbZG)</strong> erfüllt, und kann
            auf Wunsch Über- oder Unterstunden gegen Ihre Sollarbeitszeit ausweisen.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">So wird die Netto-Arbeitszeit berechnet</h3>
          <p>
            Die Formel ist denkbar einfach – entscheidend ist nur, dass die Pause korrekt abgezogen wird:
          </p>
          <div class="bg-blue-50 p-4 rounded-lg my-4 text-sm">
            <p class="font-mono text-blue-900">
              Netto-Arbeitszeit = Ende − Beginn − Pause
            </p>
            <p class="mt-2">Beispiel: 08:00 bis 17:00 (= 9 Std. Anwesenheit) − 30 Min. Pause = <strong>8 Std. 30 Min.</strong> bzw. 8,50 Dezimalstunden.</p>
          </div>
          <p>
            Endet die Schicht nach Mitternacht (das Ende liegt zeitlich vor dem Beginn), rechnet der
            Rechner automatisch über den Tageswechsel hinweg – etwa von 22:00 bis 06:00.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Pflicht-Pausen nach § 4 ArbZG</h3>
          <p>
            Das Arbeitszeitgesetz schreibt feste Mindestpausen vor. Sie richten sich nach der
            tatsächlichen Arbeitszeit (ohne die Pause selbst):
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>bis 6 Stunden:</strong> keine gesetzliche Pause vorgeschrieben</li>
            <li><strong>mehr als 6 bis 9 Stunden:</strong> mindestens 30 Minuten</li>
            <li><strong>mehr als 9 Stunden:</strong> mindestens 45 Minuten</li>
          </ul>
          <p>
            Die Ruhepausen lassen sich in Abschnitte von <strong>jeweils mindestens 15 Minuten</strong>
            aufteilen. Niemand darf länger als <strong>6 Stunden am Stück</strong> ohne Pause
            beschäftigt werden. Wer von zu Hause arbeitet, kann übrigens parallel die
            <a href="/homeoffice-pauschale-rechner" class="text-blue-600 hover:text-blue-800 underline">Homeoffice-Pauschale</a>
            steuerlich geltend machen.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Höchstarbeitszeit nach § 3 ArbZG</h3>
          <p>
            Die werktägliche Arbeitszeit darf <strong>8 Stunden</strong> nicht überschreiten. Eine
            Verlängerung auf bis zu <strong>10 Stunden</strong> ist nur zulässig, wenn innerhalb von
            sechs Kalendermonaten (oder 24 Wochen) im Durchschnitt 8 Stunden pro Werktag nicht
            überschritten werden. Zwischen Feierabend und dem nächsten Arbeitsbeginn muss eine
            ununterbrochene <strong>Ruhezeit von mindestens 11 Stunden</strong> liegen (§ 5 ArbZG).
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Stunden in Dezimal umrechnen</h3>
          <p>
            Für die Lohnabrechnung werden Arbeitszeiten meist als Dezimalzahl benötigt. Eine Minute
            entspricht dabei <strong>nicht</strong> 0,01, sondern 1/60 einer Stunde:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>15 Minuten = 0,25 Stunden</li>
            <li>30 Minuten = 0,50 Stunden</li>
            <li>45 Minuten = 0,75 Stunden</li>
            <li>42 Minuten = 0,70 Stunden (42 ÷ 60)</li>
          </ul>
          <p>
            Wie sich Ihre Stunden auf das Gehalt auswirken, sehen Sie mit dem
            <a href="/stundenlohn-rechner" class="text-blue-600 hover:text-blue-800 underline">Stundenlohn-Rechner</a>
            und dem
            <a href="/brutto-netto-rechner" class="text-blue-600 hover:text-blue-800 underline">Brutto-Netto-Rechner</a>.
          </p>
        </div>
      </div>
    </div>

    <!-- Beispielrechnungen -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Beispielrechnungen</h2>
        <p class="text-gray-600 text-sm mb-4">
          So setzt sich die Netto-Arbeitszeit in typischen Fällen zusammen:
        </p>

        <div class="space-y-4">
          <!-- Beispiel 1 -->
          <div class="bg-gray-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 1: Klassischer Bürotag</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Beginn / Ende:</div>
              <div class="font-medium text-gray-800">08:00 – 17:00</div>
              <div class="text-gray-600">Anwesenheit:</div>
              <div class="font-medium text-gray-800">9 Std. 0 Min.</div>
              <div class="text-gray-600">Pause:</div>
              <div class="font-medium text-gray-800">30 Min.</div>
              <div class="text-gray-600">Netto-Arbeitszeit:</div>
              <div class="font-medium text-gray-800">8 Std. 30 Min. (8,50 h)</div>
              <div class="text-gray-600">Pausen-Vorgabe:</div>
              <div class="font-medium text-green-700">erfüllt (30 Min. ab &gt; 6 Std.)</div>
            </div>
          </div>

          <!-- Beispiel 2 -->
          <div class="bg-yellow-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 2: Langer Tag mit zu kurzer Pause</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Beginn / Ende:</div>
              <div class="font-medium text-gray-800">07:00 – 17:30</div>
              <div class="text-gray-600">Anwesenheit:</div>
              <div class="font-medium text-gray-800">10 Std. 30 Min.</div>
              <div class="text-gray-600">Pause:</div>
              <div class="font-medium text-gray-800">30 Min.</div>
              <div class="text-gray-600">Netto-Arbeitszeit:</div>
              <div class="font-medium text-gray-800">10 Std. 0 Min. (10,00 h)</div>
              <div class="text-gray-600">Pausen-Vorgabe:</div>
              <div class="font-medium text-red-700">zu kurz – bei &gt; 9 Std. sind 45 Min. nötig</div>
            </div>
          </div>

          <!-- Beispiel 3 -->
          <div class="bg-blue-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 3: Nachtschicht über Mitternacht</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Beginn / Ende:</div>
              <div class="font-medium text-gray-800">22:00 – 06:00</div>
              <div class="text-gray-600">Anwesenheit:</div>
              <div class="font-medium text-gray-800">8 Std. 0 Min.</div>
              <div class="text-gray-600">Pause:</div>
              <div class="font-medium text-gray-800">45 Min.</div>
              <div class="text-gray-600">Netto-Arbeitszeit:</div>
              <div class="font-medium text-gray-800">7 Std. 15 Min. (7,25 h)</div>
              <div class="text-gray-600">Pausen-Vorgabe:</div>
              <div class="font-medium text-green-700">erfüllt</div>
            </div>
          </div>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mt-4 text-sm text-blue-800">
          <strong>💡 Tipp:</strong> Tragen Sie Ihre eigenen Zeiten oben ein – der Rechner warnt
          automatisch, wenn die eingegebene Pause unter der gesetzlichen Mindestpause liegt.
        </div>
      </div>
    </div>

    <!-- Sonderfälle & Typische Fehler -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">⚠️ Typische Fehler & Sonderfälle</h2>

        <div class="space-y-4 text-sm text-gray-600">
          <div class="border-l-4 border-red-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 1: Pause als Arbeitszeit zählen</h3>
            <p>Die gesetzliche Ruhepause ist <strong>keine</strong> bezahlte Arbeitszeit und zählt nicht
            zur Höchstarbeitszeit. Wer 9 Stunden anwesend ist und 30 Minuten Pause macht, hat
            8,5 Stunden gearbeitet – nicht 9.</p>
          </div>

          <div class="border-l-4 border-red-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 2: Minuten als Dezimalstellen rechnen</h3>
            <p>8 Stunden 30 Minuten sind <strong>8,50</strong> Stunden, nicht 8,30. Minuten werden durch
            60 geteilt. Der Rechner gibt deshalb beide Formate aus.</p>
          </div>

          <div class="border-l-4 border-orange-400 pl-4">
            <h3 class="font-semibold text-gray-800">Sonderfall: Pause aufteilen</h3>
            <p>Sie müssen die Pause nicht am Stück nehmen. § 4 ArbZG erlaubt eine Aufteilung in
            Abschnitte von <strong>je mindestens 15 Minuten</strong> – etwa zweimal 15 Minuten statt
            einmal 30.</p>
          </div>

          <div class="border-l-4 border-orange-400 pl-4">
            <h3 class="font-semibold text-gray-800">Sonderfall: Jugendliche</h3>
            <p>Für Beschäftigte unter 18 Jahren gilt das strengere
            <strong>Jugendarbeitsschutzgesetz (JArbSchG)</strong>: 30 Minuten Pause schon ab mehr als
            4,5 Stunden, 60 Minuten ab mehr als 6 Stunden. Dieser Rechner bildet die Erwachsenen-Regeln
            des ArbZG ab.</p>
          </div>

          <div class="border-l-4 border-blue-400 pl-4">
            <h3 class="font-semibold text-gray-800">Sonderfall: Tarif- und Betriebsvereinbarungen</h3>
            <p>Tarifverträge oder Betriebsvereinbarungen können <strong>längere</strong> Pausen oder
            kürzere Arbeitszeiten vorsehen. Die hier genutzten Werte sind die gesetzlichen
            Mindeststandards.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Section (sichtbar) -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">❓ Häufig gestellte Fragen zur Arbeitszeit</h2>

        <div class="space-y-4">
          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie berechne ich meine Netto-Arbeitszeit?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Die Netto-Arbeitszeit ergibt sich aus <strong>Ende − Beginn − Pause</strong>. Beispiel:
              Von 08:00 bis 17:00 sind 9 Stunden Anwesenheit; abzüglich 30 Minuten Pause bleiben
              8 Stunden 30 Minuten bzw. 8,50 Dezimalstunden. Die Pause wird also vollständig
              herausgerechnet.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viel Pause ist gesetzlich vorgeschrieben?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Nach § 4 ArbZG sind bei einer Arbeitszeit von <strong>mehr als 6 bis 9 Stunden
              mindestens 30 Minuten</strong> Pause vorgeschrieben, bei <strong>mehr als 9 Stunden
              mindestens 45 Minuten</strong>. Bei bis zu 6 Stunden ist keine Pause gesetzlich
              vorgeschrieben.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Darf ich die Pause aufteilen?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Ja. § 4 ArbZG erlaubt, die Ruhepausen in Abschnitte von <strong>jeweils mindestens
              15 Minuten</strong> aufzuteilen. Sie können die vorgeschriebenen 30 Minuten also zum
              Beispiel in zweimal 15 Minuten zerlegen. Länger als 6 Stunden am Stück ohne Pause ist
              jedoch nicht erlaubt.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viele Stunden darf ich pro Tag arbeiten?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Die werktägliche Arbeitszeit beträgt nach § 3 ArbZG grundsätzlich <strong>8 Stunden</strong>.
              Sie kann auf bis zu <strong>10 Stunden</strong> verlängert werden, wenn innerhalb von
              sechs Kalendermonaten bzw. 24 Wochen im Schnitt 8 Stunden pro Werktag eingehalten werden.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie rechne ich Minuten in Dezimalstunden um?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Teilen Sie die Minuten durch 60: 15 Minuten = 0,25, 30 Minuten = 0,50, 45 Minuten = 0,75.
              8 Stunden 30 Minuten entsprechen also <strong>8,50</strong> Stunden – nicht 8,30. Der
              Rechner zeigt beide Werte parallel an.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Funktioniert der Rechner für Nachtschichten über Mitternacht?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Ja. Liegt das Ende zeitlich vor dem Beginn (zum Beispiel 22:00 bis 06:00), erkennt der
              Rechner den Tageswechsel und rechnet automatisch <strong>plus 24 Stunden</strong>. So
              ergeben sich bei 22:00–06:00 acht Stunden Anwesenheit.</p>
            </div>
          </details>
        </div>
      </div>
    </div>

    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/stundenlohn-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">⏰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Stundenlohn-Rechner</p>
          </a>
          <a href="/brutto-netto-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💵</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Brutto-Netto-Rechner</p>
          </a>
          <a href="/ueberstunden-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📈</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Überstunden-Rechner</p>
          </a>
          <a href="/arbeitstage-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📅</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Arbeitstage-Rechner</p>
          </a>
          <a href="/urlaubstage-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏖️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Urlaubstage-Rechner</p>
          </a>
          <a href="/homeoffice-pauschale-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏠</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Homeoffice-Pauschale-Rechner</p>
          </a>
        </div>
      </div>
    </div>
  </main>

  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Arbeitszeit-Rechner 2026",
