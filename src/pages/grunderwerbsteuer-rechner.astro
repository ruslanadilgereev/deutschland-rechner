---
import Layout from '../layouts/Layout.astro';
import GrunderwerbsteuerRechner from '../components/rechner/GrunderwerbsteuerRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Grunderwerbsteuer-Rechner 2025 & 2026 – Bundesländer-Vergleich";
const description = "Grunderwerbsteuer berechnen: Von 3,5% (Bayern) bis 6,5% (NRW). Alle 16 Bundesländer vergleichen, Spartipps für Immobilienkauf. Jetzt kostenlos!";
const keywords = "Grunderwerbsteuer Rechner, Grunderwerbsteuer 2026, Grunderwerbsteuer Bundesländer, Grunderwerbsteuer Bayern, Grunderwerbsteuer NRW, Immobilienkauf Nebenkosten, Grunderwerbsteuer berechnen, Hauskauf Steuer";
import RechnerFeedback from '../components/RechnerFeedback.astro';
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Grunderwerbsteuer-Rechner", url: "/grunderwerbsteuer-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-yellow-500 to-orange-500 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-yellow-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🏗️</span>
          <div>
            <h1 class="text-2xl font-bold">Grunderwerbsteuer-Rechner 2026</h1>
            <p class="text-yellow-100 text-sm">3,5% bis 6,5% – Alle Bundesländer vergleichen</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <GrunderwerbsteuerRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Grunderwerbsteuer 2026: Alle Bundesländer im Überblick</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Die <strong>Grunderwerbsteuer</strong> ist eine der größten Nebenkosten beim Immobilienkauf in Deutschland. 
            Mit unserem kostenlosen <strong>Grunderwerbsteuer-Rechner 2026</strong> berechnen Sie schnell die Steuer 
            für Ihr Bundesland und planen Ihre Kaufnebenkosten genau.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Grunderwerbsteuer-Sätze 2026 nach Bundesland</h3>
          
          <div class="bg-gray-50 p-4 rounded-lg my-4">
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="space-y-1">
                <p><strong>3,5%</strong> – Bayern</p>
                <p><strong>5,0%</strong> – Baden-Württemberg, Niedersachsen, Rheinland-Pfalz, Sachsen-Anhalt, Thüringen</p>
                <p><strong>5,5%</strong> – Bremen, Hamburg, Sachsen</p>
              </div>
              <div class="space-y-1">
                <p><strong>6,0%</strong> – Berlin, Hessen, Mecklenburg-Vorpommern</p>
                <p><strong>6,5%</strong> – Brandenburg, NRW, Saarland, Schleswig-Holstein</p>
              </div>
            </div>
          </div>
          
          <div class="bg-green-50 p-4 rounded-lg my-4">
            <p class="text-sm text-green-800">
              <strong>💡 Spartipp:</strong> Bayern hat mit 3,5% den niedrigsten Satz in ganz Deutschland. 
              Bei einem Kaufpreis von 400.000 € sparen Sie dort <strong>12.000 €</strong> gegenüber NRW (6,5%)!
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was ist die Grunderwerbsteuer?</h3>
          <p>
            Die <strong>Grunderwerbsteuer</strong> (GrESt) ist eine einmalige Steuer beim Kauf eines Grundstücks 
            oder einer Immobilie. Sie fällt an bei:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Kauf von bebauten und unbebauten Grundstücken</li>
            <li>Kauf von Eigentumswohnungen</li>
            <li>Erwerb von Erbbaurechten</li>
            <li>Übertragung von Gesellschaftsanteilen (bei Immobilien-GmbHs)</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Befreiungen von der Grunderwerbsteuer</h3>
          <p>
            In bestimmten Fällen fällt <strong>keine Grunderwerbsteuer</strong> an:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Erbschaft:</strong> Grundstücke, die vererbt werden</li>
            <li><strong>Schenkung:</strong> Übertragung unter nahen Verwandten (stattdessen: Schenkungsteuer)</li>
            <li><strong>Geringwertiger Erwerb:</strong> Kaufpreis unter 2.500 €</li>
            <li><strong>Übertragung zwischen Ehepartnern</strong> (bei Scheidung unter Auflagen)</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Förderprogramme für Erstkäufer</h3>
          <p>
            Einige Bundesländer bieten <strong>Entlastungen für Erstkäufer</strong>:
          </p>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>🏠 Hessen – „Hessengeld":</strong> Bis zu 10.000 € Zuschuss für Erstkäufer (+ 5.000 € pro Kind)</li>
              <li><strong>🏠 NRW (geplant):</strong> Grunderwerbsteuerbefreiung für Erstkäufer bei selbstgenutztem Wohneigentum</li>
              <li><strong>🏠 Hamburg:</strong> Freibetrag von 500.000 € für Erstkäufer (Kaufpreis bis 750.000 €)</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wann ist die Grunderwerbsteuer fällig?</h3>
          <p>
            Nach Unterzeichnung des <strong>notariellen Kaufvertrags</strong> informiert der Notar das Finanzamt. 
            Sie erhalten dann einen Steuerbescheid mit <strong>4 Wochen Zahlungsfrist</strong>. Erst nach 
            Zahlung stellt das Finanzamt die <strong>Unbedenklichkeitsbescheinigung</strong> aus, die für die 
            Eintragung ins Grundbuch nötig ist.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Alle Kaufnebenkosten im Überblick</h3>
          <p>
            Neben der Grunderwerbsteuer fallen beim Immobilienkauf weitere <strong>Nebenkosten</strong> an:
          </p>
          <div class="bg-gray-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>Grunderwerbsteuer:</strong> 3,5% – 6,5% (je nach Bundesland)</li>
              <li><strong>Notarkosten:</strong> ca. 1,5% des Kaufpreises</li>
              <li><strong>Grundbuchkosten:</strong> ca. 0,5% des Kaufpreises</li>
              <li><strong>Maklergebühr:</strong> 3,57% – 7,14% (je nach Bundesland, häufig geteilt)</li>
            </ul>
            <p class="mt-2 text-sm font-semibold">→ Insgesamt: ca. 9% – 15% Kaufnebenkosten</p>
          </div>
          
          <div class="bg-yellow-50 p-4 rounded-lg my-4">
            <p class="text-sm text-yellow-800">
              <strong>Rechenbeispiel:</strong> Bei einem Kaufpreis von 350.000 € in NRW (6,5%):<br/>
              Grunderwerbsteuer: 22.750 € | Notar: 5.250 € | Grundbuch: 1.750 € | Makler: 12.495 €<br/>
              <strong>Nebenkosten gesamt: ca. 42.245 €</strong>
            </p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/grundsteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏡</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Grundsteuer-Rechner</p>
          </a>
          <a href="/erbschaftsteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📜</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Erbschaftsteuer-Rechner</p>
          </a>
          <a href="/schenkungsteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🎁</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Schenkungsteuer-Rechner</p>
          </a>
          <a href="/kredit-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💳</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kredit-Rechner</p>
          </a>
          <a href="/einkommensteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🧾</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Einkommensteuer-Rechner</p>
          </a>
          <a href="/photovoltaik-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">☀️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Photovoltaik-Rechner</p>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Zuständige Behörde -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🏛️</span>
          Zuständige Behörde
        </h2>
        
        <div class="p-4 bg-blue-50 rounded-lg">
          <h3 class="font-semibold text-blue-800 mb-2">Finanzamt am Standort der Immobilie</h3>
          <p class="text-blue-700 text-sm mb-2">
            Die <strong>Grunderwerbsteuer</strong> wird vom Finanzamt erhoben, in dessen Bezirk das Grundstück liegt – 
            nicht von Ihrem Wohnsitz-Finanzamt.
          </p>
          <p class="text-blue-700 text-sm">
            <strong>Zahlungsfrist:</strong> 4 Wochen nach Erhalt des Steuerbescheids<br/>
            <strong>Wichtig:</strong> Ohne Zahlung keine Eintragung ins Grundbuch!
          </p>
        </div>
      </div>
    </div>
      <RechnerFeedback rechnerName="Grunderwerbsteuer-Rechner 2025 & 2026" rechnerSlug="grunderwerbsteuer-rechner" />
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Grunderwerbsteuer-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/grunderwerbsteuer-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie hoch ist die Grunderwerbsteuer 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Grunderwerbsteuer variiert je nach Bundesland zwischen 3,5% (Bayern) und 6,5% (NRW, Brandenburg, Schleswig-Holstein, Saarland). Sie wird auf den Kaufpreis der Immobilie berechnet."
        }
      },
      {
        "@type": "Question",
        "name": "Welches Bundesland hat die niedrigste Grunderwerbsteuer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bayern hat mit 3,5% den niedrigsten Grunderwerbsteuersatz in Deutschland. Bei einem Kaufpreis von 400.000 € zahlen Sie dort nur 14.000 € statt 26.000 € in NRW (6,5%)."
        }
      },
      {
        "@type": "Question",
        "name": "Wann muss ich keine Grunderwerbsteuer zahlen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Keine Grunderwerbsteuer fällt an bei: Erbschaft, Schenkung unter nahen Verwandten, Kaufpreis unter 2.500 €, und in bestimmten Fällen bei Übertragung zwischen Ehepartnern."
        }
      },
      {
        "@type": "Question",
        "name": "Wann ist die Grunderwerbsteuer fällig?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nach dem notariellen Kaufvertrag erhalten Sie einen Steuerbescheid vom Finanzamt. Die Zahlungsfrist beträgt 4 Wochen. Erst nach Zahlung wird die Unbedenklichkeitsbescheinigung für die Grundbucheintragung ausgestellt."
        }
      },
      {
        "@type": "Question",
        "name": "Gibt es Förderungen für Erstkäufer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, einige Bundesländer bieten Entlastungen: Hessen zahlt das 'Hessengeld' (bis 10.000 € + 5.000 € pro Kind), Hamburg gewährt Erstkäufern einen Freibetrag von 500.000 €. NRW plant eine Grunderwerbsteuerbefreiung für Erstkäufer."
        }
      },
      {
        "@type": "Question",
        "name": "Wie hoch sind die gesamten Kaufnebenkosten?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Kaufnebenkosten betragen insgesamt ca. 9-15% des Kaufpreises: Grunderwerbsteuer (3,5-6,5%), Notarkosten (ca. 1,5%), Grundbuchkosten (ca. 0,5%) und ggf. Maklergebühren (3,57-7,14%)."
        }
      }
    ]
  })} />
</Layout>
