---
import Layout from '../layouts/Layout.astro';
import RentenlueckeRechner from '../components/rechner/RentenlueckeRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Rentenlücke-Rechner 2026 – Versorgungslücke berechnen";
const description = "Rentenlücke-Rechner 2026: Berechnen Sie Ihre Versorgungslücke im Alter. Sparrate, Kapital, Inflation & Kapitalverzehr. Kostenlos!";
const keywords = "Rentenlücke Rechner, Rentenlücke berechnen, Versorgungslücke, Altersvorsorge Rechner, private Rentenvorsorge, Rente berechnen, Sparrate berechnen, Kapitalverzehr Rechner, ewige Rente, Rentenplanung 2026, Rentenbedarf, gesetzliche Rente, Rentenniveau, Ruhestandsplanung";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Rentenlücke-Rechner", url: "/rentenluecke-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-indigo-500 to-purple-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-indigo-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🎯</span>
          <div>
            <h1 class="text-2xl font-bold">Rentenlücke-Rechner 2026</h1>
            <p class="text-indigo-100 text-sm">Versorgungslücke berechnen</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <RentenlueckeRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Rentenlücke 2026: Alles was Sie wissen müssen</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Die <strong>Rentenlücke</strong> (auch Versorgungslücke) ist der Unterschied zwischen Ihrem 
            finanziellen Bedarf im Ruhestand und der Höhe Ihrer gesetzlichen Rente. Mit unserem 
            <strong>Rentenlücke-Rechner</strong> können Sie schnell ermitteln, wie viel Sie zusätzlich 
            für das Alter ansparen müssen.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was ist die Rentenlücke?</h3>
          <p>
            Die Rentenlücke entsteht, weil die <strong>gesetzliche Rente</strong> in den meisten Fällen 
            nicht ausreicht, um den gewohnten Lebensstandard im Alter zu halten:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Rentenniveau 2026:</strong> Die Standardrente liegt bei ca. 48% des Durchschnittslohns</li>
            <li><strong>Bedarf im Alter:</strong> Experten empfehlen 70-80% des letzten Nettoeinkommens</li>
            <li><strong>Die Differenz:</strong> Diese Lücke muss durch private Vorsorge geschlossen werden</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Warum 80% des Nettos als Richtwert?</h3>
          <p>
            Im Ruhestand fallen einige Kosten weg, andere kommen hinzu:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Wegfallende Kosten:</strong> Pendeln zur Arbeit, Berufskleidung, Sparraten, ggf. Kredittilgung</li>
            <li><strong>Gleichbleibend:</strong> Miete/Wohnen, Ernährung, Versicherungen, Freizeit</li>
            <li><strong>Steigend:</strong> Gesundheitskosten, Pflege, mehr Freizeit (Reisen, Hobbys)</li>
          </ul>
          <p>
            Daher gilt: <strong>70-80%</strong> des letzten Nettoeinkommens reichen meist aus, um den 
            Lebensstandard zu halten. Bei hohen Mietkosten oder pflegebedürftigen Angehörigen kann 
            mehr nötig sein.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wie berechnet man die Rentenlücke?</h3>
          <p>
            <strong>Schritt 1: Bedarf ermitteln</strong><br />
            Monatlicher Bedarf = Aktuelles Nettoeinkommen × 80%<br />
            <em>Beispiel: 3.000€ Netto × 80% = 2.400€ Bedarf</em>
          </p>
          <p>
            <strong>Schritt 2: Gesetzliche Rente schätzen</strong><br />
            Laut Renteninformation der Deutschen Rentenversicherung (kommt jährlich per Post) oder 
            mit unserem <a href="/renten-rechner" class="text-indigo-600 hover:underline">Rentenrechner</a>.
            <em>Beispiel: 1.400€ gesetzliche Rente (netto)</em>
          </p>
          <p>
            <strong>Schritt 3: Lücke berechnen</strong><br />
            Rentenlücke = Bedarf - Gesetzliche Rente<br />
            <em>Beispiel: 2.400€ - 1.400€ = 1.000€ monatliche Lücke</em>
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Kapitalverzehr vs. Ewige Rente</h3>
          <p>
            Es gibt zwei Strategien, um die Rentenlücke zu schließen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>
              <strong>Kapitalverzehr:</strong> Das angesparte Kapital wird über die Rentendauer 
              komplett aufgebraucht (inkl. Zinsen). Vorteil: Weniger Kapital nötig. Risiko: Was, 
              wenn man länger lebt?
            </li>
            <li>
              <strong>Ewige Rente:</strong> Nur die Zinsen werden entnommen, das Kapital bleibt 
              erhalten. Vorteil: Sicherheit, Vererbung möglich. Nachteil: Deutlich mehr Kapital 
              erforderlich.
            </li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Beispielrechnung: 35 Jahre, 3.000€ Netto</h3>
          <p>
            <strong>Annahmen:</strong>
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Alter: 35 Jahre, Rente mit 67 (32 Jahre Zeit)</li>
            <li>Netto: 3.000€, Bedarf: 2.400€ (80%)</li>
            <li>Gesetzliche Rente: ca. 1.400€ netto</li>
            <li>Lücke: 1.000€/Monat = 12.000€/Jahr</li>
          </ul>
          <p>
            <strong>Kapitalverzehr (Lebenserwartung 82 Jahre, 15 Jahre Rente):</strong><br />
            Benötigtes Kapital: ca. 156.000€<br />
            Sparrate bei 5% Rendite: ca. 180€/Monat
          </p>
          <p>
            <strong>Ewige Rente (3% Entnahme):</strong><br />
            Benötigtes Kapital: ca. 400.000€<br />
            Sparrate bei 5% Rendite: ca. 460€/Monat
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Inflation: Der stille Kaufkraft-Killer</h3>
          <p>
            Bei 2% Inflation verliert Geld über 30 Jahre etwa <strong>45% seiner Kaufkraft</strong>. 
            Was heute 1.000€ wert ist, entspricht in 30 Jahren nur noch 550€ Kaufkraft. Deshalb ist 
            es wichtig, die Inflation in die Planung einzubeziehen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Die Rentenlücke wird in heutiger Kaufkraft dargestellt</li>
            <li>Das benötigte Kapital ist bereits inflationsbereinigt</li>
            <li>Die Sparrate gleicht die Inflation mit einer entsprechenden Rendite aus</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Private Vorsorge: Die Säulen der Altersvorsorge</h3>
          <p>
            Das deutsche Altersvorsorgesystem basiert auf <strong>drei Säulen</strong>:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>
              <strong>1. Säule (Gesetzliche Rente):</strong> Pflichtversicherung für Arbeitnehmer. 
              Finanziert durch Beiträge (18,6% vom Brutto, je 50% AG/AN).
            </li>
            <li>
              <strong>2. Säule (Betriebliche Altersvorsorge):</strong> Über den Arbeitgeber, oft 
              mit Zuschüssen. Entgeltumwandlung spart Steuern und Sozialabgaben.
            </li>
            <li>
              <strong>3. Säule (Private Vorsorge):</strong> ETF-Sparpläne, Riester, Rürup, private 
              Rentenversicherung, Immobilien.
            </li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">ETF-Sparplan als Vorsorge</h3>
          <p>
            Ein <strong>ETF-Sparplan</strong> ist eine der effektivsten Methoden, um die Rentenlücke 
            zu schließen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Historische Rendite:</strong> MSCI World ca. 7% p.a. (langfristig)</li>
            <li><strong>Niedrige Kosten:</strong> TER meist unter 0,5%</li>
            <li><strong>Flexibilität:</strong> Jederzeit anpassbar oder kündbar</li>
            <li><strong>Zinseszinseffekt:</strong> Exponentielles Wachstum über Jahrzehnte</li>
          </ul>
          <p>
            Nutzen Sie unseren <a href="/etf-sparplan-rechner" class="text-indigo-600 hover:underline">ETF-Sparplan-Rechner</a>, 
            um die Entwicklung Ihres Vermögens zu berechnen.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Häufige Fragen (FAQ)</h3>
          
          <p><strong>Wie hoch wird meine gesetzliche Rente sein?</strong></p>
          <p>
            Die Deutsche Rentenversicherung schickt jährlich eine <strong>Renteninformation</strong>. 
            Dort steht Ihre hochgerechnete Rente. Alternativ nutzen Sie unseren 
            <a href="/renten-rechner" class="text-indigo-600 hover:underline">Rentenrechner</a>.
          </p>
          
          <p><strong>Ist die Rentenlücke bei Beamten gleich?</strong></p>
          <p>
            Nein. Beamte erhalten eine <strong>Pension</strong> von ca. 70% des letzten Gehalts. 
            Die Rentenlücke ist daher meist deutlich geringer oder nicht vorhanden.
          </p>
          
          <p><strong>Was, wenn ich länger lebe als erwartet?</strong></p>
          <p>
            Das ist das <strong>Langlebigkeitsrisiko</strong>. Lösungen: Ewige Rente wählen, 
            Sicherheitspuffer einplanen, oder eine private Rentenversicherung mit lebenslanger 
            Zahlung abschließen.
          </p>
          
          <p><strong>Ab wann sollte ich mit der Vorsorge beginnen?</strong></p>
          <p>
            <strong>Je früher, desto besser!</strong> Dank Zinseszinseffekt ist früh angelegtes Geld 
            wertvoller. Wer mit 25 anfängt, braucht nur halb so viel monatlich zu sparen wie jemand, 
            der mit 40 startet.
          </p>
          
          <p><strong>Wie sicher ist die gesetzliche Rente?</strong></p>
          <p>
            Die gesetzliche Rente ist <strong>politisch garantiert</strong> (Rentengarantie). 
            Das Rentenniveau soll nicht unter 48% sinken (Haltelinie). Allerdings: Demografischer Wandel setzt 
            das System unter Druck.
          </p>
        </div>
      </div>
    </div>
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/renten-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏖️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Renten-Rechner</p>
          </a>
          <a href="/rentensteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Rentensteuer-Rechner</p>
          </a>
          <a href="/etf-sparplan-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📈</span>
            <p class="font-medium text-gray-800 text-sm mt-1">ETF-Sparplan-Rechner</p>
          </a>
          <a href="/riester-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏦</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Riester-Rechner</p>
          </a>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Rentenlücke-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/rentenluecke-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Was ist die Rentenlücke?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Rentenlücke (Versorgungslücke) ist die Differenz zwischen Ihrem finanziellen Bedarf im Ruhestand (ca. 70-80% des letzten Nettoeinkommens) und der Höhe Ihrer gesetzlichen Rente. Diese Lücke muss durch private oder betriebliche Vorsorge geschlossen werden."
        }
      },
      {
        "@type": "Question",
        "name": "Wie berechne ich meine Rentenlücke?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Rentenlücke = Gewünschtes Einkommen im Alter - Gesetzliche Rente. Beispiel: Bei 3.000€ Netto heute und 80% Bedarf (2.400€) sowie 1.400€ gesetzlicher Rente ergibt sich eine Lücke von 1.000€ pro Monat."
        }
      },
      {
        "@type": "Question",
        "name": "Wie viel Kapital brauche ich für die Rentenlücke?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das hängt von der Strategie ab: Bei Kapitalverzehr (15 Jahre Rentendauer, 3% Rendite) benötigen Sie etwa das 13-fache der Jahreslücke. Bei ewiger Rente (nur Zinsentnahme) etwa das 33-fache."
        }
      },
      {
        "@type": "Question",
        "name": "Wie hoch sollte meine Sparrate sein?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die notwendige Sparrate hängt von Ihrer Lücke, der erwarteten Rendite und der verbleibenden Zeit bis zur Rente ab. Faustformel: Je früher Sie anfangen, desto weniger müssen Sie monatlich sparen. Mit 35 Jahren und 32 Jahren Zeit benötigen Sie bei 5% Rendite etwa 180-460€/Monat für eine 1.000€-Lücke."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist besser: Kapitalverzehr oder ewige Rente?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Kapitalverzehr benötigt weniger Kapital, birgt aber das Risiko, länger zu leben. Die ewige Rente ist sicherer und ermöglicht Vererbung, erfordert aber deutlich mehr Kapital. Eine Kombination aus beidem ist oft sinnvoll."
        }
      },
      {
        "@type": "Question",
        "name": "Warum reichen 80% des Nettos im Alter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Im Ruhestand fallen Kosten weg: Pendeln, Berufskleidung, Sparraten, evtl. Kredite. Gleichzeitig steigen Gesundheitskosten. 70-80% des letzten Nettos reichen erfahrungsgemäß aus, um den Lebensstandard zu halten."
        }
      }
    ]
  })} />
</Layout>
