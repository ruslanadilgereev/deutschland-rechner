---
import Layout from '../layouts/Layout.astro';
import RechnerCard from '../components/RechnerCard';
import { rechnerListe, kategorien } from '../data/rechner';

// Group by category
const gruppiertNachKategorie = Object.entries(kategorien).map(([key, kat]) => ({
  key,
  ...kat,
  rechner: rechnerListe.filter(r => r.kategorie === key),
}));

// Top-Rechner für "Beliebte Rechner"-Block
const topRechnerIds = ['brutto-netto', 'kindergeld', 'elterngeld', 'einkommensteuer', 'baufinanzierung', 'mietpreisbremse'];
const topRechner = topRechnerIds
  .map(id => rechnerListe.find(r => r.id === id))
  .filter((r): r is NonNullable<typeof r> => Boolean(r));

// FAQ-Daten (auch für JSON-LD)
const faqs = [
  {
    frage: 'Sind die Rechner wirklich kostenlos?',
    antwort: 'Ja, alle 143+ Rechner sind komplett kostenlos. Keine Anmeldung, kein Login, keine Premium-Features. Die Site finanziert sich über Werbeanzeigen, die niemals die Berechnung beeinflussen.',
  },
  {
    frage: 'Wie aktuell sind die Werte für 2026?',
    antwort: 'Die wichtigsten Eckwerte (Grundfreibetrag, Beitragsbemessungsgrenzen, Kindergeld, Bürgergeld-Regelsätze, Mindestlohn) sind auf den Stand 2026 aktualisiert. Steuerberechnungen folgen dem offiziellen BMF-Programmablaufplan 2026. Werden Werte später angepasst (z. B. Mindestlohn-Erhöhung Ende des Jahres), aktualisieren wir die betroffenen Rechner.',
  },
  {
    frage: 'Werden meine Eingaben gespeichert?',
    antwort: 'Nein. Alle Berechnungen laufen direkt in deinem Browser per JavaScript — nichts wird an einen Server gesendet, nichts wird in einer Datenbank gespeichert. Wir nutzen Vercel Web Analytics, das keine personenbezogenen Daten sammelt. Details in der Datenschutzerklärung.',
  },
  {
    frage: 'Wie genau sind die Ergebnisse?',
    antwort: 'Bei Steuern und Sozialleistungen folgen wir den offiziellen Formeln (BMF-PAP, BAföG-Verordnung, BEEG für Elterngeld etc.). Die Ergebnisse stimmen typischerweise auf den Cent genau mit den Behörden-Rechnern überein. Bei komplexen Sonderfällen (z. B. mehrere Kinder mit unterschiedlichem Status, ausländisches Einkommen) gilt: Die Rechner ersetzen keine Steuer- oder Rechtsberatung.',
  },
  {
    frage: 'Kann ich Fehler melden oder neue Rechner vorschlagen?',
    antwort: 'Ja, gerne. Die Site ist Open Source — Fehler kannst du auf GitHub melden, oder per E-Mail an kontakt@mahlzait.de. Vorschläge für neue Rechner sind willkommen.',
  },
  {
    frage: 'Wer steht hinter Deutschlandrechner?',
    antwort: 'Die Site wird von Ruslan Adilgereev (Berlin) entwickelt — Solo-Projekt, hauptberuflich Software-Entwickler. Mehr Infos unter Über uns und im Impressum.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.frage,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.antwort,
    },
  })),
};
---

<Layout 
  title="Alle Rechner" 
  description="Deutschlandrechner: Kostenlose Online-Rechner für Deutschland 2026. Kindergeld, Bürgergeld, Brutto-Netto, Elterngeld, Grunderwerbsteuer und mehr."
  keywords="Deutschland Rechner, Online Rechner, Kindergeld Rechner, Bürgergeld Rechner, Brutto Netto Rechner, Elterngeld Rechner, Steuerrechner 2026, kostenlos"
>
  <main class="min-h-screen">
    <!-- Header -->
    <header class="bg-gradient-to-r from-blue-600 to-purple-600 text-white py-12 px-4">
      <div class="max-w-7xl mx-auto text-center">
        <h1 class="text-4xl font-bold mb-3">🇩🇪 Deutschlandrechner</h1>
        <p class="text-blue-100 text-lg">Alle wichtigen Rechner für Deutschland – kostenlos & aktuell</p>
        <div class="flex items-center justify-center gap-3 mt-4">
          <a href="https://github.com/ruslanadilgereev/deutschland-rechner" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-white/15 hover:bg-white/25 backdrop-blur-sm text-white px-4 py-2 rounded-full text-sm font-medium transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            Open Source
          </a>
          <a href="/mitmachen" class="inline-flex items-center gap-2 bg-white/15 hover:bg-white/25 backdrop-blur-sm text-white px-4 py-2 rounded-full text-sm font-medium transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Mitmachen
          </a>
        </div>
      </div>
    </header>

    <!-- Search -->
    <div class="sticky top-0 z-10 bg-white/80 backdrop-blur-md border-b px-4 py-4">
      <div class="max-w-xl mx-auto">
        <input 
          type="search" 
          placeholder="🔍 Rechner suchen..." 
          class="w-full px-5 py-3 rounded-xl bg-gray-100 border-0 focus:ring-2 focus:ring-blue-500 outline-none text-lg"
          id="search-input"
        />
      </div>
    </div>

    <!-- Über Deutschlandrechner -->
    <section class="max-w-7xl mx-auto px-4 py-12">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-6">Kostenlose Rechner für Deutschland — transparent, aktuell, Open Source</h2>
        <div class="prose prose-lg text-gray-700 max-w-none space-y-4">
          <p>
            Deutschlandrechner bündelt <strong>143+ Rechner</strong> für die Themen, bei denen man in Deutschland am häufigsten nachrechnen muss:
            Steuern und Lohn, Sozialleistungen, Familie und Kinder, Wohnen und Immobilien, Auto, Gesundheit, Finanzen.
            Vom <a href="/brutto-netto-rechner" class="text-blue-600 hover:underline">Brutto-Netto-Vergleich</a> nach einer Gehaltsverhandlung
            über den <a href="/elterngeld-rechner" class="text-blue-600 hover:underline">Elterngeld-Antrag</a> bis zur Frage,
            ob die <a href="/mietpreisbremse-rechner" class="text-blue-600 hover:underline">Mietpreisbremse</a> in deinem Fall greift —
            jeder Rechner liefert in Sekunden ein Ergebnis, ohne Anmeldung, ohne Newsletter-Pflicht.
          </p>
          <p>
            Alle Werte sind auf den Stand <strong>2026</strong> aktualisiert: Grundfreibetrag <strong>12.348 €</strong>,
            Kindergeld <strong>259 € pro Kind</strong>, Bürgergeld-Regelsatz <strong>563 €</strong> für Alleinstehende,
            Mindestlohn <strong>13,90 €/Stunde</strong>, Beitragsbemessungsgrenzen nach der aktuellen Sozialversicherungsrechengrößen-Verordnung.
            Steuerberechnungen folgen dem offiziellen <strong>Programmablaufplan 2026</strong> des Bundesfinanzministeriums.
          </p>
          <p>
            Die Site ist als Solo-Projekt aus Berlin entstanden, weil offizielle Behörden-Rechner oft entweder fehlen,
            mobil schlecht funktionieren oder hinter umständlichen Formularen versteckt sind.
            Hier sollst du in unter 30 Sekunden zu einem belastbaren Ergebnis kommen — und zwar so,
            dass du die Rechnung nachvollziehen und im Zweifel im Quellcode überprüfen kannst.
          </p>
        </div>

        <!-- Trust-Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-10">
          <div class="bg-white rounded-2xl shadow-md p-6">
            <div class="text-3xl mb-3">📅</div>
            <h3 class="font-bold text-gray-900 mb-2">Aktuell für 2026</h3>
            <p class="text-sm text-gray-600">
              Steuersätze nach BMF-PAP 2026, Kindergeld 259 € pro Kind, Bürgergeld-Regelsätze, Mindestlohn 13,90 €/Stunde.
              Werte werden bei Gesetzesänderungen zeitnah angepasst.
            </p>
          </div>
          <div class="bg-white rounded-2xl shadow-md p-6">
            <div class="text-3xl mb-3">📂</div>
            <h3 class="font-bold text-gray-900 mb-2">Open Source</h3>
            <p class="text-sm text-gray-600">
              Quellcode auf <a href="https://github.com/ruslanadilgereev/deutschland-rechner" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">GitHub</a>,
              MIT-Lizenz. Du kannst jede Berechnung nachprüfen und Fehler melden.
            </p>
          </div>
          <div class="bg-white rounded-2xl shadow-md p-6">
            <div class="text-3xl mb-3">🔒</div>
            <h3 class="font-bold text-gray-900 mb-2">Keine Datenspeicherung</h3>
            <p class="text-sm text-gray-600">
              Alle Berechnungen laufen direkt im Browser. Keine Server, keine Cookies für Berechnungen,
              keine Eingaben werden gespeichert.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Beliebte Rechner -->
    <section class="max-w-7xl mx-auto px-4 py-12 border-t border-gray-200">
      <div class="max-w-4xl mx-auto mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Die meistgenutzten Rechner</h2>
        <p class="text-lg text-gray-700">
          Diese Rechner werden am häufigsten benötigt — vom Brutto-Netto-Vergleich nach einer Gehaltsverhandlung
          bis zum Elterngeld-Antrag nach der Geburt. Wenn du nicht weißt, wo du anfangen sollst:
          hier ist der schnellste Einstieg.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {topRechner.map((r) => (
          <RechnerCard rechner={r} client:load />
        ))}
      </div>
    </section>

    <!-- Rechner Liste - 3 Spalten Grid -->
    <div class="max-w-7xl mx-auto px-4 py-8 border-t border-gray-200" id="rechner-liste">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {gruppiertNachKategorie.map(({ key, name, icon, color, rechner }) => (
          <section class="kategorie-section" data-kategorie={key}>
            <div class="flex items-center gap-2 mb-4">
              <span class={`w-10 h-10 rounded-xl ${color} flex items-center justify-center text-white text-lg`}>
                {icon}
              </span>
              <div>
                <h2 class="font-bold text-gray-800">{name}</h2>
                <span class="text-xs text-gray-400">{rechner.length} Rechner</span>
              </div>
            </div>
            <div class="space-y-3">
              {rechner.map((r) => (
                <div class="rechner-item" data-name={r.name.toLowerCase()}>
                  <RechnerCard rechner={r} client:load />
                </div>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>

    <!-- Methodik & Quellen -->
    <section class="max-w-7xl mx-auto px-4 py-12 border-t border-gray-200">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-6">So rechnen wir</h2>
        <div class="prose prose-lg text-gray-700 max-w-none space-y-4">
          <p>
            Jeder Rechner basiert auf offiziellen Berechnungsformeln und Werten.
            Wir erfinden keine Faustformeln und nutzen keine Branchen-Schätzungen — wenn ein Wert auf der Site steht,
            steht er in dieser Form auch in einem Gesetz, einer Verordnung oder einer offiziellen Behörden-Veröffentlichung.
            Hier die wichtigsten Quellen pro Bereich:
          </p>
          <ul class="space-y-3">
            <li>
              <strong>Steuern &amp; Lohn:</strong> Programmablaufplan 2026 des Bundesfinanzministeriums (BMF) für die maschinelle
              Lohnsteuer-Berechnung, §§ 32a, 39b EStG (Tarif und Lohnsteuer-Berechnung), Sozialversicherungsrechengrößen-Verordnung 2026.
            </li>
            <li>
              <strong>Sozialleistungen:</strong> Bundesagentur für Arbeit (Bürgergeld, Arbeitslosengeld, Kindergeld),
              Bundesfamilienministerium (Eltern-/Kindergeld), Deutsche Rentenversicherung (Rentenformel, Entgeltpunkte).
            </li>
            <li>
              <strong>Gesundheit:</strong> WHO (BMI-Klassifikation), DGE (Grundumsatz und Kalorienbedarf nach Mifflin-St Jeor),
              Deutsche Gesellschaft für Ernährung für Referenzwerte.
            </li>
            <li>
              <strong>Wohnen &amp; Immobilien:</strong> §§ 558ff BGB (Mietrecht, Mieterhöhung, Mietpreisbremse),
              Landesgesetze für Grunderwerbsteuer (3,5 % bis 6,5 % je nach Bundesland), Bundesnotarordnung und GNotKG für Notarkosten.
            </li>
            <li>
              <strong>Auto:</strong> § 8 KraftStG (Kfz-Steuer-Berechnung nach Hubraum und CO₂-Ausstoß),
              § 24a StVG und § 316 StGB (Promille-Grenzen), Anlage XII zur StVZO (Bußgeldkatalog).
            </li>
          </ul>
          <p>
            Werden Werte falsch berechnet? Open Source heißt: Du kannst es im
            <a href="https://github.com/ruslanadilgereev/deutschland-rechner" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">GitHub-Repo</a>
            prüfen und einen <a href="https://github.com/ruslanadilgereev/deutschland-rechner/issues" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">Fehlerbericht stellen</a>.
            Jeder belastbare Hinweis wird gefixt — meist innerhalb weniger Tage.
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-7xl mx-auto px-4 py-12 border-t border-gray-200">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-6">Häufige Fragen</h2>
        <div class="space-y-3">
          <details class="bg-white rounded-2xl shadow-sm p-5 group">
            <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
              <span>Sind die Rechner wirklich kostenlos?</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Ja, alle 143+ Rechner sind komplett kostenlos. Keine Anmeldung, kein Login, keine Premium-Features.
              Die Site finanziert sich über Werbeanzeigen, die niemals die Berechnung beeinflussen.
            </p>
          </details>

          <details class="bg-white rounded-2xl shadow-sm p-5 group">
            <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
              <span>Wie aktuell sind die Werte für 2026?</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Die wichtigsten Eckwerte (Grundfreibetrag, Beitragsbemessungsgrenzen, Kindergeld, Bürgergeld-Regelsätze, Mindestlohn)
              sind auf den Stand 2026 aktualisiert. Steuerberechnungen folgen dem offiziellen BMF-Programmablaufplan 2026.
              Werden Werte später angepasst (z. B. Mindestlohn-Erhöhung Ende des Jahres), aktualisieren wir die betroffenen Rechner.
            </p>
          </details>

          <details class="bg-white rounded-2xl shadow-sm p-5 group">
            <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
              <span>Werden meine Eingaben gespeichert?</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Nein. Alle Berechnungen laufen direkt in deinem Browser per JavaScript — nichts wird an einen Server gesendet,
              nichts wird in einer Datenbank gespeichert. Wir nutzen Vercel Web Analytics, das keine personenbezogenen Daten sammelt.
              Details in der <a href="/datenschutz" class="text-blue-600 hover:underline">Datenschutzerklärung</a>.
            </p>
          </details>

          <details class="bg-white rounded-2xl shadow-sm p-5 group">
            <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
              <span>Wie genau sind die Ergebnisse?</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Bei Steuern und Sozialleistungen folgen wir den offiziellen Formeln (BMF-PAP, BAföG-Verordnung, BEEG für Elterngeld etc.).
              Die Ergebnisse stimmen typischerweise auf den Cent genau mit den Behörden-Rechnern überein.
              Bei komplexen Sonderfällen (z. B. mehrere Kinder mit unterschiedlichem Status, ausländisches Einkommen) gilt:
              Die Rechner ersetzen keine Steuer- oder Rechtsberatung.
            </p>
          </details>

          <details class="bg-white rounded-2xl shadow-sm p-5 group">
            <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
              <span>Kann ich Fehler melden oder neue Rechner vorschlagen?</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Ja, gerne. Die Site ist Open Source — Fehler kannst du auf
              <a href="https://github.com/ruslanadilgereev/deutschland-rechner/issues" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">GitHub</a>
              melden, oder per E-Mail an <a href="mailto:kontakt@mahlzait.de" class="text-blue-600 hover:underline">kontakt@mahlzait.de</a>.
              Vorschläge für neue Rechner sind willkommen.
            </p>
          </details>

          <details class="bg-white rounded-2xl shadow-sm p-5 group">
            <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
              <span>Wer steht hinter Deutschlandrechner?</span>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <p class="mt-3 text-gray-700">
              Die Site wird von Ruslan Adilgereev (Berlin) entwickelt — Solo-Projekt, hauptberuflich Software-Entwickler.
              Mehr Infos im <a href="/impressum" class="text-blue-600 hover:underline">Impressum</a>
              und unter <a href="/kontakt" class="text-blue-600 hover:underline">Kontakt</a>.
            </p>
          </details>
        </div>
      </div>
    </section>

  </main>

  <!-- Structured Data: FAQPage -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />
</Layout>

<script>
  // Search functionality - fixed version
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const rechnerItems = document.querySelectorAll('.rechner-item') as NodeListOf<HTMLElement>;
    const kategorienSections = document.querySelectorAll('.kategorie-section') as NodeListOf<HTMLElement>;

    if (!searchInput) return;

    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
      
      // Reset all if empty query
      if (!query) {
        rechnerItems.forEach(item => item.style.display = '');
        kategorienSections.forEach(section => section.style.display = '');
        return;
      }

      // Filter rechner items
      rechnerItems.forEach(item => {
        const name = item.getAttribute('data-name') || '';
        const matches = name.includes(query);
        item.style.display = matches ? '' : 'none';
      });

      // Hide empty categories
      kategorienSections.forEach(section => {
        const items = section.querySelectorAll('.rechner-item') as NodeListOf<HTMLElement>;
        const hasVisible = Array.from(items).some(item => item.style.display !== 'none');
        section.style.display = hasVisible ? '' : 'none';
      });
    });
  });
</script>
