        }
      },
      {
        "@type": "Question",
        "name": "Wie hoch ist der IHK-Freibetrag?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der Umlage-Freibetrag beträgt bundeseinheitlich 15.340 €. Er gilt nur für natürliche Personen und Personengesellschaften, die nicht im Handelsregister eingetragen sind. Kapitalgesellschaften (GmbH, UG, AG) erhalten keinen Freibetrag."
        }
      },
      {
        "@type": "Question",
        "name": "Sind Existenzgründer vom IHK-Beitrag befreit?",
        "acceptedAnswer": {
