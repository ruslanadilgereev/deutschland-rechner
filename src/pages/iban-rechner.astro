import IbanRechner from '../components/rechner/IbanRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RechnerTrust from '../components/RechnerTrust.astro';
import VerwandteRechner from '../components/VerwandteRechner.astro';

const title = "IBAN-Rechner – IBAN generieren, prüfen & zerlegen";
const description = "IBAN aus Kontonummer & BLZ generieren, Prüfziffer validieren oder IBAN zerlegen. Mit BIC-Anzeige & Bank-Erkennung. Sofort & kostenlos!";
const keywords = "IBAN Rechner, IBAN berechnen, IBAN generieren, IBAN prüfen, IBAN validieren, IBAN zerlegen, BLZ zu IBAN, Kontonummer zu IBAN, IBAN Prüfziffer, IBAN Deutschland, IBAN kostenlos, BIC ermitteln, IBAN Aufbau, SEPA IBAN";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie ist eine deutsche IBAN aufgebaut?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Eine deutsche IBAN besteht aus 22 Zeichen: Ländercode 'DE' (2 Zeichen), Prüfziffer (2 Ziffern), Bankleitzahl (8 Ziffern) und Kontonummer (10 Ziffern, ggf. mit führenden Nullen aufgefüllt)."
      }
    },
    {
      "@type": "Question",
      "name": "Wie berechne ich die IBAN-Prüfziffer?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Prüfziffer wird nach ISO 7064 (Modulo 97) berechnet: BLZ + Kontonummer + Ländercode als Zahl (DE=1314) + '00' werden zusammengesetzt, der Rest bei Division durch 97 wird von 98 subtrahiert. Beispiel: Ergibt sich Rest 3, ist die Prüfziffer 95."
      }
    },
    {
      "@type": "Question",
      "name": "Brauche ich für SEPA-Überweisungen noch den BIC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Für SEPA-Überweisungen innerhalb der EU und des EWR wird der BIC seit 2016 nicht mehr benötigt – die IBAN reicht aus. Für Überweisungen außerhalb des SEPA-Raums ist der BIC weiterhin erforderlich."
      }
    },
    {
      "@type": "Question",
      "name": "Was bedeutet IBAN?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "IBAN steht für 'International Bank Account Number'. Sie ist eine international standardisierte Kontonummer, die Zahlungen im SEPA-Raum vereinfacht und sicherer macht."
      }
    },
    {
      "@type": "Question",
      "name": "Kann ich meine alte Kontonummer noch verwenden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Seit Februar 2016 ist die IBAN für alle SEPA-Überweisungen in Deutschland Pflicht. Alte Kontonummern und BLZ werden von Banken intern automatisch in die IBAN umgewandelt, aber für Überweisungen benötigen Sie die IBAN."
      }
    },
    {
      "@type": "Question",
      "name": "Wie erkenne ich eine ungültige IBAN?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Eine IBAN ist ungültig, wenn: die Länge nicht stimmt (22 Zeichen für DE), die Prüfziffer falsch ist, oder ungültige Zeichen enthalten sind. Unser IBAN-Rechner prüft alle diese Kriterien automatisch."
      }
    }
  ]
};
---

<Layout 
