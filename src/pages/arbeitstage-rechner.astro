              </tr>
            </tbody>
          </table>
          <p class="text-xs text-gray-500 mt-2">* Bayern: Mariä Himmelfahrt nur in Gemeinden mit überwiegend katholischer Bevölkerung. Fronleichnam fällt 2026 auf einen Werktag (Do, 4. Juni).</p>
        </div>
      </div>

      <!-- Feiertage-Übersicht -->
      <div class="mt-8 bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📅 Gesetzliche Feiertage 2026 nach Bundesland</h2>
        
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left py-2 font-semibold text-gray-700">Feiertag</th>
                <th class="text-left py-2 font-semibold text-gray-700">Datum 2026</th>
                <th class="text-left py-2 font-semibold text-gray-700">Wochentag</th>
                <th class="text-left py-2 font-semibold text-gray-700">Bundesländer</th>
              </tr>
            </thead>
            <tbody class="text-gray-600">
              <tr class="border-b border-gray-100">
                <td class="py-2">Neujahr</td>
                <td class="py-2">1. Januar</td>
                <td class="py-2">Donnerstag</td>
                <td class="py-2"><span class="bg-green-100 text-green-700 px-2 py-0.5 rounded text-xs">Alle</span></td>
              </tr>
