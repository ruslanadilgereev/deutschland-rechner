---
import Layout from '../layouts/Layout.astro';
import ArbeitstageRechner from '../components/rechner/ArbeitstageRechner.tsx';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = 'Arbeitstage-Rechner 2026 – Werktage & Feiertage nach Bundesland';
const description = 'Arbeitstage 2026 berechnen: Werktage zwischen zwei Daten mit allen Feiertagen nach Bundesland. Für 5- oder 6-Tage-Woche. Kostenlos & sofort.';
const keywords = 'Arbeitstage Rechner, Arbeitstage berechnen, Werktage zählen, Arbeitstage zwischen zwei Daten, Werktage Rechner, Arbeitstage im Jahr, Arbeitstage 2025, Arbeitstage 2026, Feiertage Deutschland, gesetzliche Feiertage, Arbeitstage Bundesland, Werktage berechnen, Kalendertage in Arbeitstage, Arbeitstage Steuererklärung, Pendlerpauschale Arbeitstage';
import RechnerFeedback from '../components/RechnerFeedback.astro';
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Arbeitstage-Rechner", url: "/arbeitstage-rechner" }]} />
  <main class="min-h-screen bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 py-8 px-4">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl shadow-lg mb-4">
          <span class="text-4xl">📆</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">
          Arbeitstage-Rechner 2026
        </h1>
        <p class="text-gray-600 max-w-lg mx-auto">
          Berechnen Sie die Anzahl der Arbeitstage zwischen zwei Daten – mit Feiertagen nach Bundesland. Ideal für Ihre <a href="/pendlerpauschale-rechner" class="text-blue-600 hover:underline">Pendlerpauschale</a> und <a href="/einkommensteuer-rechner" class="text-blue-600 hover:underline">Steuererklärung</a>.
        </p>
      </div>

      <!-- Trust-Block -->
      <div class="mb-6 bg-white border border-green-200 rounded-2xl p-4">
        <div class="flex flex-wrap items-center gap-3 text-sm text-gray-600">
          <span class="inline-flex items-center gap-1">
            <span class="text-green-600">✅</span>
            <strong>Zuletzt aktualisiert:</strong> 11.03.2026
          </span>
          <span class="text-gray-300">|</span>
          <span class="inline-flex items-center gap-1">
            <span>📜</span>
            <strong>Grundlage:</strong> Feiertagsgesetze der Länder, ArbZG, BUrlG
          </span>
        </div>
        <div class="mt-2 text-xs text-gray-500 grid grid-cols-1 md:grid-cols-2 gap-1">
          <div>✔ Alle 16 Bundesländer mit regionalen Feiertagen</div>
          <div>✔ 5-Tage- und 6-Tage-Woche</div>
          <div>✘ Kein Abzug von Urlaub/Krankheit/Homeoffice</div>
          <div>✘ Keine Brückentage oder Betriebsferien</div>
        </div>
      </div>

      <!-- Calculator Component -->
      <ArbeitstageRechner client:load />

      <!-- Beispielrechnungen -->
      <div class="mt-12 bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">🧮 Beispielrechnungen für 2026</h2>
        
        <div class="space-y-5 text-sm text-gray-600">
          <div class="bg-blue-50 border border-blue-100 rounded-xl p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 1: Ganzes Jahr 2026 in NRW (5-Tage-Woche)</h3>
            <div class="space-y-1">
              <p>365 Kalendertage − 104 Wochenendtage − 8 Feiertage auf Werktage = <strong>253 Arbeitstage</strong></p>
              <p class="text-xs text-gray-500">Feiertage 2026 auf Werktage: Neujahr (Do), Karfreitag (Fr), Ostermontag (Mo), Tag der Arbeit (Fr), Christi Himmelfahrt (Do), Pfingstmontag (Mo), Fronleichnam (Do), 1. Weihnachtsfeiertag (Fr). Allerheiligen fällt 2026 auf einen Sonntag.</p>
              <p class="mt-2">→ Für die <a href="/pendlerpauschale-rechner" class="text-blue-600 hover:underline">Pendlerpauschale</a> bei 30 km einfacher Strecke: 253 × 30 × 0,38 € = <strong>2.884,20 €</strong> Werbungskosten (vor Abzug von Urlaub/Krankheit).</p>
            </div>
          </div>

          <div class="bg-green-50 border border-green-100 rounded-xl p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 2: Ganzes Jahr 2026 in Bayern (5-Tage-Woche)</h3>
            <div class="space-y-1">
              <p>365 − 104 − 9 Feiertage = <strong>252 Arbeitstage</strong></p>
              <p class="text-xs text-gray-500">Bayern hat 2026 einen zusätzlichen Feiertag auf einem Werktag: Heilige Drei Könige (Di, 6. Jan.). Mariä Himmelfahrt (Sa) und Allerheiligen (So) entfallen auf Wochenenden.</p>
            </div>
          </div>

          <div class="bg-purple-50 border border-purple-100 rounded-xl p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 3: Projektplanung Q2 2026 (April–Juni, Berlin)</h3>
            <div class="space-y-1">
              <p>01.04.–30.06.2026 = 91 Kalendertage − 26 Wochenendtage − 4 Feiertage = <strong>61 Arbeitstage</strong></p>
              <p class="text-xs text-gray-500">Feiertage im Q2: Karfreitag (3.4.), Ostermontag (6.4.), Tag der Arbeit (1.5.), Christi Himmelfahrt (14.5.), Pfingstmontag (25.5.). Da Berlin kein Fronleichnam hat, sind es 5 Feiertage – wobei der Frauentag (8.3.) außerhalb des Zeitraums liegt.</p>
              <p class="mt-2">→ Bei einem <a href="/stundenlohn-rechner" class="text-blue-600 hover:underline">Stundenlohn</a> von 25 €/h und 8 Stunden/Tag: 61 × 8 × 25 € = <strong>12.200 €</strong> Bruttolohn für das Quartal.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- SEO Content Section -->
      <div class="mt-8 bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📚 Alles Wichtige zu Arbeitstagen in Deutschland</h2>
        
        <div class="space-y-4 text-sm text-gray-600">
          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Wie viele Arbeitstage hat 2026?</h3>
            <p>
              Das Jahr 2026 hat <strong>365 Tage</strong>. Nach Abzug von 104 Wochenendtagen 
              und den bundesweiten Feiertagen bleiben je nach Bundesland <strong>252–254 Arbeitstage</strong> 
              bei einer 5-Tage-Woche. In <strong>Bayern</strong> mit den meisten regionalen Feiertagen 
              sind es nur <strong>252 Arbeitstage</strong>, in <strong>Berlin</strong> und <strong>Hamburg</strong> 
              hingegen <strong>254</strong>. Eine genaue Aufschlüsselung liefert unser 
              <a href="/brutto-netto-rechner" class="text-blue-600 hover:underline">Brutto-Netto-Rechner</a>, 
              wenn Sie wissen möchten, was die Arbeitstage für Ihr Nettogehalt bedeuten.
            </p>
          </div>
          
          <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 rounded">
            <h3 class="font-semibold text-gray-800 mb-2">📋 Arbeitstage für die Steuererklärung 2026 (Anlage N)</h3>
            <p>
              Die Anzahl der Arbeitstage ist entscheidend für die <strong>Entfernungspauschale</strong> in der 
              <strong>Anlage N</strong> Ihrer <a href="/einkommensteuer-rechner" class="text-blue-600 hover:underline">Einkommensteuererklärung</a>. 
              <strong>Neu ab 2026:</strong> Die Pendlerpauschale beträgt einheitlich <strong>0,38 € pro Kilometer</strong> ab dem ersten Kilometer 
              (keine Staffelung mehr). Das Finanzamt akzeptiert folgende 
              <strong>Nichtaufgriffsgrenzen</strong> in der Regel ohne Nachweise:
            </p>
            <ul class="list-disc pl-5 mt-2 space-y-1">
              <li><strong>4-Tage-Woche:</strong> 180 Arbeitstage</li>
              <li><strong>5-Tage-Woche:</strong> 230 Arbeitstage</li>
              <li><strong>6-Tage-Woche:</strong> 280 Arbeitstage</li>
            </ul>
            <p class="mt-2 text-sm">
              <strong>Wichtig:</strong> Bei mehr Arbeitstagen sollten Sie Nachweise führen (z.B. Arbeitgeberbescheinigung).
              Urlaub, Krankheit und <a href="/homeoffice-pauschale-rechner" class="text-blue-600 hover:underline">Homeoffice-Tage</a> 
              müssen abgezogen werden! Nutzen Sie unseren 
              <a href="/pendlerpauschale-rechner" class="text-blue-600 hover:underline">Pendlerpauschale-Rechner</a> 
              für die genaue Berechnung.
            </p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Welche Bundesländer haben die meisten Feiertage?</h3>
            <p>
              <strong>Bayern und Baden-Württemberg</strong> haben mit 12–13 gesetzlichen Feiertagen die meisten. 
              <strong>Berlin</strong> hatte lange die wenigsten (9), hat aber seit 2019 den 
              Internationalen Frauentag (8. März). 
              <strong>Mecklenburg-Vorpommern</strong> hat seit 2023 ebenfalls den Frauentag.
              Generell haben süddeutsche, katholisch geprägte Bundesländer mehr Feiertage — was sich direkt 
              auf Ihren <a href="/stundenlohn-rechner" class="text-blue-600 hover:underline">effektiven Stundenlohn</a> auswirkt.
            </p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Was sind die bundesweiten Feiertage?</h3>
            <p>
              Es gibt <strong>9 bundesweite gesetzliche Feiertage</strong>:
              Neujahr (1.1.), Karfreitag, Ostermontag, Tag der Arbeit (1.5.), 
              Christi Himmelfahrt, Pfingstmontag, Tag der Deutschen Einheit (3.10.), 
              1. und 2. Weihnachtsfeiertag (25./26.12.).
              Heiligabend (24.12.) und Silvester (31.12.) sind <strong>keine</strong> gesetzlichen Feiertage!
            </p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Wie berechne ich Arbeitstage bei Teilzeit?</h3>
            <p>
              Bei <a href="/teilzeit-rechner" class="text-blue-600 hover:underline">Teilzeit</a> kommt es darauf an, ob Sie weniger 
              <strong>Stunden pro Tag</strong> oder weniger <strong>Tage pro Woche</strong> arbeiten. Bei weniger Stunden 
              pro Tag bleibt die Anzahl der Arbeitstage gleich. Bei einer 3-Tage-Woche haben Sie entsprechend 
              weniger Arbeitstage. Für die <a href="/urlaubstage-rechner" class="text-blue-600 hover:underline">Urlaubsberechnung</a> gilt: 
              Mindesturlaub × Ihre Wochentage ÷ betriebsübliche Wochentage (§ 3 BUrlG).
            </p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Muss ich an Feiertagen arbeiten?</h3>
            <p>
              An gesetzlichen Feiertagen darf grundsätzlich <strong>nicht gearbeitet werden</strong> 
              (§ 9 Arbeitszeitgesetz). Ausnahmen gelten für bestimmte Branchen wie 
              Gastronomie, Gesundheitswesen, Polizei, Feuerwehr und öffentliche Verkehrsmittel.
              Für Feiertagsarbeit gibt es oft <strong>Zuschläge</strong> oder Freizeitausgleich — 
              prüfen Sie die Auswirkungen mit unserem 
              <a href="/brutto-netto-rechner" class="text-blue-600 hover:underline">Brutto-Netto-Rechner</a>.
            </p>
          </div>

          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Arbeitstage und Homeoffice: Was zählt 2026?</h3>
            <p>
              Seit 2023 gibt es die <a href="/homeoffice-pauschale-rechner" class="text-blue-600 hover:underline">Homeoffice-Pauschale</a> 
              von <strong>6 € pro Tag</strong> (max. 1.260 € pro Jahr für 210 Tage). Wichtig: An Homeoffice-Tagen 
              dürfen Sie <strong>keine Pendlerpauschale</strong> geltend machen. Sie müssen daher genau aufteilen: 
              Wie viele Tage Büro (→ <a href="/pendlerpauschale-rechner" class="text-blue-600 hover:underline">Pendlerpauschale</a>) und 
              wie viele Homeoffice (→ Homeoffice-Pauschale)?
            </p>
          </div>
        </div>
      </div>

      <!-- Typische Fehler -->
      <div class="mt-8 bg-red-50 border border-red-200 rounded-2xl p-6">
        <h2 class="text-xl font-bold text-red-800 mb-4">⚠️ Typische Fehler bei der Arbeitstage-Berechnung</h2>
        <div class="space-y-3 text-sm text-red-700">
          <div class="flex gap-2">
            <span class="text-red-500 font-bold mt-0.5">1.</span>
            <div>
              <strong>Urlaub und Krankheit nicht abgezogen.</strong> Das Finanzamt erwartet die <em>tatsächlichen</em> 
              Fahrttage, nicht die theoretischen Arbeitstage. Bei 30 Urlaubstagen und 10 Krankheitstagen 
              sinkt die Zahl von z.B. 253 auf nur noch 213 Tage.
            </div>
          </div>
          <div class="flex gap-2">
            <span class="text-red-500 font-bold mt-0.5">2.</span>
            <div>
              <strong>Homeoffice-Tage doppelt angesetzt.</strong> Wer an 2 Tagen pro Woche im Homeoffice arbeitet, 
              darf für diese Tage <em>entweder</em> die Homeoffice-Pauschale <em>oder</em> die Pendlerpauschale 
              ansetzen — nicht beides.
            </div>
          </div>
          <div class="flex gap-2">
            <span class="text-red-500 font-bold mt-0.5">3.</span>
            <div>
              <strong>Falsches Bundesland gewählt.</strong> Regionale Feiertage (z.B. Fronleichnam in NRW, 
              Reformationstag in Sachsen) machen 1–4 Arbeitstage Unterschied. Der Arbeitsort zählt, 
              nicht der Wohnort.
            </div>
          </div>
          <div class="flex gap-2">
            <span class="text-red-500 font-bold mt-0.5">4.</span>
            <div>
              <strong>Werktage und Arbeitstage verwechselt.</strong> Werktage = Mo–Sa (relevant für 
              <a href="/urlaubstage-rechner" class="text-red-700 underline">Urlaubsanspruch</a> nach BUrlG). 
              Arbeitstage = Mo–Fr bei einer 5-Tage-Woche. Das sind etwa 50 Tage Unterschied pro Jahr!
            </div>
          </div>
          <div class="flex gap-2">
            <span class="text-red-500 font-bold mt-0.5">5.</span>
            <div>
              <strong>Nichtaufgriffsgrenze als Freibetrag verstanden.</strong> Die 230-Tage-Grenze ist <em>kein 
              Rechtsanspruch</em>, sondern eine interne Prüfgrenze. Das Finanzamt kann trotzdem Nachweise fordern.
            </div>
          </div>
        </div>
      </div>

      <!-- Arbeitstage 2026 nach Bundesland -->
      <div class="mt-8 bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Arbeitstage 2026 nach Bundesland (5-Tage-Woche)</h2>
        
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left py-2 font-semibold text-gray-700">Bundesland</th>
                <th class="text-center py-2 font-semibold text-gray-700">Feiertage gesamt</th>
                <th class="text-center py-2 font-semibold text-gray-700">davon auf Werktag</th>
                <th class="text-center py-2 font-semibold text-gray-700">Arbeitstage 2026</th>
              </tr>
            </thead>
            <tbody class="text-gray-600">
              <tr class="border-b border-gray-100">
                <td class="py-2">Baden-Württemberg</td>
                <td class="text-center py-2">12</td>
                <td class="text-center py-2">9</td>
                <td class="text-center py-2 font-semibold">252</td>
              </tr>
              <tr class="border-b border-gray-100 bg-yellow-50">
                <td class="py-2">Bayern*</td>
                <td class="text-center py-2">13</td>
                <td class="text-center py-2">9</td>
                <td class="text-center py-2 font-semibold">252</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Berlin</td>
                <td class="text-center py-2">10</td>
                <td class="text-center py-2">7</td>
                <td class="text-center py-2 font-semibold">254</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Brandenburg</td>
                <td class="text-center py-2">10</td>
                <td class="text-center py-2">7</td>
                <td class="text-center py-2 font-semibold">254</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Bremen</td>
                <td class="text-center py-2">10</td>
                <td class="text-center py-2">7</td>
                <td class="text-center py-2 font-semibold">254</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Hamburg</td>
                <td class="text-center py-2">10</td>
                <td class="text-center py-2">7</td>
                <td class="text-center py-2 font-semibold">254</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Hessen</td>
                <td class="text-center py-2">10</td>
                <td class="text-center py-2">8</td>
                <td class="text-center py-2 font-semibold">253</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Mecklenburg-Vorpommern</td>
                <td class="text-center py-2">11</td>
                <td class="text-center py-2">7</td>
                <td class="text-center py-2 font-semibold">254</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Niedersachsen</td>
                <td class="text-center py-2">10</td>
                <td class="text-center py-2">7</td>
                <td class="text-center py-2 font-semibold">254</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Nordrhein-Westfalen</td>
                <td class="text-center py-2">11</td>
                <td class="text-center py-2">8</td>
                <td class="text-center py-2 font-semibold">253</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Rheinland-Pfalz</td>
                <td class="text-center py-2">11</td>
                <td class="text-center py-2">8</td>
                <td class="text-center py-2 font-semibold">253</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Saarland</td>
                <td class="text-center py-2">12</td>
                <td class="text-center py-2">8</td>
                <td class="text-center py-2 font-semibold">253</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Sachsen</td>
                <td class="text-center py-2">12</td>
                <td class="text-center py-2">8</td>
                <td class="text-center py-2 font-semibold">253</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Sachsen-Anhalt</td>
                <td class="text-center py-2">11</td>
                <td class="text-center py-2">8</td>
                <td class="text-center py-2 font-semibold">253</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Schleswig-Holstein</td>
                <td class="text-center py-2">10</td>
                <td class="text-center py-2">7</td>
                <td class="text-center py-2 font-semibold">254</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-2">Thüringen</td>
                <td class="text-center py-2">11</td>
