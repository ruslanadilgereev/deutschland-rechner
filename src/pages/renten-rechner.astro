---
import Layout from '../layouts/Layout.astro';
import RentenRechner from '../components/rechner/RentenRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Renten-Rechner 2026 – Gesetzliche Rente kostenlos berechnen";
const description = "Renten-Rechner 2026: Berechnen Sie Ihre gesetzliche Rente. Entgeltpunkte, Regelaltersgrenze, Rente mit 63. Aktueller Rentenwert 40,79€. Kostenlos & sofort.";
const keywords = "Renten Rechner, Rentenberechnung, gesetzliche Rente, Entgeltpunkte, Rentenhöhe berechnen, Regelaltersgrenze, Rente mit 63, Rentenformel, Deutsche Rentenversicherung";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Renten-Rechner", url: "/renten-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-blue-500 to-indigo-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-blue-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🏖️</span>
          <div>
            <h1 class="text-2xl font-bold">Renten-Rechner 2026</h1>
            <p class="text-blue-100 text-sm">Wie hoch wird Ihre gesetzliche Rente?</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <RentenRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Gesetzliche Rente berechnen: So funktioniert die Rentenformel</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem <strong>Renten-Rechner</strong> berechnen Sie kostenlos Ihre voraussichtliche 
            gesetzliche Rente. Die Berechnung basiert auf der offiziellen <strong>Rentenformel</strong> 
            der Deutschen Rentenversicherung mit dem aktuellen Rentenwert von <strong>40,79€</strong>.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Die Rentenformel erklärt</h3>
          <p>
            Ihre Monatsrente berechnet sich nach der Formel:
          </p>
          <div class="bg-blue-50 p-4 rounded-lg my-4 text-center">
            <p class="text-lg font-mono text-blue-800">
              <strong>Rente = Entgeltpunkte × Zugangsfaktor × Rentenartfaktor × Rentenwert</strong>
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was sind Entgeltpunkte?</h3>
          <p>
            <strong>Entgeltpunkte</strong> sind das Herzstück der Rentenberechnung. Sie spiegeln 
            wider, wie viel Sie im Vergleich zum Durchschnittsverdiener eingezahlt haben:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>1 Entgeltpunkt</strong> = Durchschnittsverdienst eines Jahres (2026: 51.944€)</li>
            <li>Verdienen Sie mehr, erhalten Sie mehr als 1 Punkt</li>
            <li>Verdienen Sie weniger, erhalten Sie entsprechend weniger</li>
            <li>Maximum durch Beitragsbemessungsgrenze: ca. 2 Punkte/Jahr</li>
          </ul>
          
          <div class="bg-green-50 p-4 rounded-lg my-4">
            <h4 class="font-semibold text-green-800 mb-2">Beispielrechnung</h4>
            <ul class="space-y-1 text-sm text-green-700">
              <li>Bruttolohn: 4.000€/Monat = 48.000€/Jahr</li>
              <li>Entgeltpunkte pro Jahr: 48.000€ ÷ 51.944€ = <strong>0,92 EP</strong></li>
              <li>Bei 40 Beitragsjahren: 40 × 0,92 = <strong>36,8 EP</strong></li>
              <li>Monatsrente: 36,8 × 40,79€ = <strong>ca. 1.501€</strong></li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Regelaltersgrenze nach Geburtsjahr</h3>
          <p>
            Die <strong>Regelaltersgrenze</strong> steigt schrittweise auf 67 Jahre an:
          </p>
          <div class="bg-gray-100 p-4 rounded-lg my-4">
            <ul class="space-y-1 text-sm">
              <li><strong>1958:</strong> 66 Jahre</li>
              <li><strong>1960:</strong> 66 Jahre + 4 Monate</li>
              <li><strong>1962:</strong> 66 Jahre + 8 Monate</li>
              <li><strong>ab 1964:</strong> 67 Jahre</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Rente mit 63 – Früher in Rente</h3>
          <p>
            Mit <strong>45 Beitragsjahren</strong> (besonders langjährig Versicherte) können Sie 
            abschlagsfrei früher in Rente gehen. Das Alter steigt schrittweise:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Jahrgang 1960:</strong> Abschlagsfrei ab 64 Jahren + 4 Monate</li>
            <li><strong>Jahrgang 1964+:</strong> Abschlagsfrei ab 65 Jahren</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Abschläge bei Frühverrentung</h3>
          <p>
            Ohne 45 Beitragsjahre können Sie frühestens mit 63 in Rente, jedoch mit 
            <strong>Abschlägen von 0,3% pro Monat</strong> (maximal 14,4% = 48 Monate). 
            Diese Abzüge gelten lebenslang!
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Aktuelle Werte 2026</h3>
          <div class="bg-gray-100 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>Rentenwert:</strong> 40,79€ pro Entgeltpunkt</li>
              <li><strong>Durchschnittsentgelt:</strong> 51.944€/Jahr</li>
              <li><strong>Beitragssatz:</strong> 18,6% (je Hälfte AG/AN)</li>
              <li><strong>Beitragsbemessungsgrenze:</strong> 8.050€/Monat</li>
              <li><strong>Rentenniveau:</strong> 48% (Haltelinie)</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Renteninformation verstehen</h3>
          <p>
            Jährlich erhalten Sie ab 27 Jahren (mit 5 Beitragsjahren) eine 
            <strong>Renteninformation</strong> per Post. Diese zeigt Ihre bisher erworbenen 
            Ansprüche und eine Hochrechnung auf Basis Ihres aktuellen Verdienstes.
          </p>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/rentensteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Rentensteuer-Rechner</p>
          </a>
          <a href="/rentenluecke-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📉</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Rentenlücke-Rechner</p>
          </a>
          <a href="/riester-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏦</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Riester-Rechner</p>
          </a>
          <a href="/altersteilzeit-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">⏰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Altersteilzeit-Rechner</p>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Zuständige Behörde -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🏛️</span>
          Zuständige Behörden & Hilfe
        </h2>
        
        <div class="space-y-4">
          <div class="p-4 bg-blue-50 rounded-lg">
            <h3 class="font-semibold text-blue-800 mb-2">Deutsche Rentenversicherung</h3>
            <p class="text-blue-700 text-sm">
              <strong>Kostenlose Hotline:</strong> 0800 1000 4800<br/>
              <strong>Online:</strong> deutsche-rentenversicherung.de<br/>
              Nutzen Sie die kostenlose Rentenberatung in Ihrer Nähe!
            </p>
          </div>
          
          <div class="p-4 bg-green-50 rounded-lg">
            <h3 class="font-semibold text-green-800 mb-2">Versicherungskonto klären</h3>
            <p class="text-green-700 text-sm">
              Überprüfen Sie regelmäßig Ihr <strong>Versicherungskonto</strong> auf Vollständigkeit. 
              Fehlende Zeiten (Ausbildung, Kindererziehung, Pflege) können nachgetragen werden – 
              das erhöht Ihre spätere Rente!
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Renten-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/renten-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie berechnet sich meine gesetzliche Rente?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Rente berechnet sich nach der Formel: Entgeltpunkte × Zugangsfaktor × Rentenartfaktor × Rentenwert. 2026 beträgt der Rentenwert 40,79€ pro Entgeltpunkt. Ein Entgeltpunkt entspricht einem Jahr Arbeit zum Durchschnittslohn (51.944€)."
        }
      },
      {
        "@type": "Question",
        "name": "Wann kann ich in Rente gehen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Regelaltersgrenze liegt je nach Geburtsjahr zwischen 65 und 67 Jahren. Ab Jahrgang 1964 gilt einheitlich 67 Jahre. Mit 45 Beitragsjahren können Sie bis zu 2 Jahre früher abschlagsfrei in Rente gehen."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist ein Entgeltpunkt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ein Entgeltpunkt entspricht einem Jahr Arbeit zum Durchschnittslohn (2026: 51.944€). Verdienen Sie 60.000€, erhalten Sie 60.000 ÷ 51.944 = 1,16 Entgeltpunkte. Die Punkte werden über Ihr gesamtes Berufsleben addiert."
        }
      },
      {
        "@type": "Question",
        "name": "Wie hoch sind die Abschläge bei Frühverrentung?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pro Monat vorzeitiger Rente werden 0,3% Abschlag berechnet, maximal 14,4% (48 Monate). Bei 3 Jahren früher bedeutet das: 36 × 0,3% = 10,8% weniger Rente – und zwar lebenslang."
        }
      },
      {
        "@type": "Question",
        "name": "Wie hoch ist der aktuelle Rentenwert?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der aktuelle Rentenwert beträgt seit Juli 2025 bundeseinheitlich 40,79€ pro Entgeltpunkt. Er wird jährlich angepasst und bestimmt, wie viel Rente Sie pro gesammeltem Entgeltpunkt erhalten."
        }
      },
      {
        "@type": "Question",
        "name": "Kann ich meine Rente durch freiwillige Beiträge erhöhen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, Sie können freiwillige Beiträge zur Rentenversicherung zahlen. Der Mindestbeitrag beträgt ca. 100€/Monat, der Höchstbeitrag orientiert sich an der Beitragsbemessungsgrenze. Auch Lücken im Versicherungskonto können Sie so schließen."
        }
      }
    ]
  })} />
</Layout>
