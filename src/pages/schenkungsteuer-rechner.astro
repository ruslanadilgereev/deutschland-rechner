  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie hoch ist der Freibetrag bei der Schenkungsteuer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Freibeträge bei der Schenkungsteuer sind: Ehepartner 500.000€, Kinder 400.000€, Enkel 200.000€, Eltern und Geschwister nur 20.000€ (Steuerklasse II), Lebensgefährte und Freunde 20.000€ (Steuerklasse III). Die Freibeträge können alle 10 Jahre erneut genutzt werden."
        }
      },
      {
        "@type": "Question",
        "name": "Wie funktioniert die 10-Jahres-Regel bei Schenkungen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die 10-Jahres-Regel besagt, dass Schenkungen vom selben Schenker innerhalb von 10 Jahren zusammengerechnet werden. Der Freibetrag gilt also für alle Schenkungen innerhalb dieses Zeitraums zusammen. Nach 10 Jahren steht der volle Freibetrag erneut zur Verfügung."
        }
      },
      {
        "@type": "Question",
        "name": "Muss ich eine Schenkung dem Finanzamt melden?",
