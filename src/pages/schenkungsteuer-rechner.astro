    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://www.deutschland-rechner.de/" },
      { "@type": "ListItem", "position": 2, "name": "Schenkungsteuer-Rechner", "item": "https://www.deutschland-rechner.de/schenkungsteuer-rechner" }
    ]
  })} />
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Schenkungsteuer-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/schenkungsteuer-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
