        }
      },
      {
        "@type": "Question",
        "name": "Muss ich Fenster und Türen abziehen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, ziehen Sie größere Öffnungen ab, um nicht zu viel zu bestellen. Bei vielen kleinen Fenstern sollten Sie aber etwas Reserve lassen, weil an den Laibungen zusätzlicher Putz anfällt."
        }
      }
    ]
  })} />
</Layout>
