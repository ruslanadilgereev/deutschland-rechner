        }
      },
      {
        "@type": "Question",
        "name": "Wie dick muss Putz aufgetragen werden?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Für Innenputz sind nach DIN 18550 typische Gesamtschichtdicken von 10 bis 15 mm üblich. Außen liegt allein der Unterputz meist bei 20 mm oder mehr. Die genaue Dicke hängt von Putz und Untergrund ab."
        }
      },
      {
        "@type": "Question",
        "name": "Wie viele Säcke Putz brauche ich?",
        "acceptedAnswer": {
          "@type": "Answer",
