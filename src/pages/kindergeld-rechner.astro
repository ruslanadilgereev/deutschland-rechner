---
import Layout from '../layouts/Layout.astro';
import KindergeldRechner from '../components/rechner/KindergeldRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Kindergeld-Rechner 2026 – Höhe, Antrag & Auszahlung";
const description = "Kindergeld berechnen 2026: 259€ pro Kind pro Monat. Mit Auszahlungsterminen, Antrag & Kinderfreibetrag-Vergleich. Jetzt kostenlos berechnen!";
const keywords = "Kindergeld Rechner, Kindergeld 2026, Kindergeld Höhe, Kindergeld berechnen, Kindergeld beantragen, Familienkasse, 259 Euro Kindergeld, Kindergeld Auszahlung, Kindergeld Antrag";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Kindergeld-Rechner", url: "/kindergeld-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-blue-600 to-purple-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-blue-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">👶</span>
          <div>
            <h1 class="text-2xl font-bold">Kindergeld-Rechner 2026</h1>
            <p class="text-blue-100 text-sm">259€ pro Kind – Jetzt Anspruch berechnen!</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <KindergeldRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Kindergeld 2026: Alles was Sie wissen müssen</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Das <strong>Kindergeld</strong> ist eine der wichtigsten Familienleistungen in Deutschland. 
            Mit unserem kostenlosen <strong>Kindergeld-Rechner 2026</strong> berechnen Sie schnell und 
            einfach, wie viel Kindergeld Ihnen zusteht.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Kindergeld Höhe 2026</h3>
          <p>
            Seit Januar 2023 gilt ein <strong>einheitlicher Kindergeldsatz für alle Kinder</strong>:
          </p>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>259€ pro Kind pro Monat</strong> – unabhängig von der Kinderanzahl</li>
              <li>Das entspricht <strong>3.108€ pro Kind pro Jahr</strong></li>
              <li>Bei 2 Kindern: 518€/Monat (6.216€/Jahr)</li>
              <li>Bei 3 Kindern: 777€/Monat (9.324€/Jahr)</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wer hat Anspruch auf Kindergeld?</h3>
          <p>
            <strong>Anspruchsvoraussetzungen</strong> für Kindergeld in Deutschland:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Das Kind lebt in Deutschland, der EU, im EWR oder der Schweiz</li>
            <li>Sie haben Ihren Wohnsitz oder gewöhnlichen Aufenthalt in Deutschland</li>
            <li>Das Kind lebt in Ihrem Haushalt oder wird von Ihnen überwiegend unterhalten</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Kindergeld Altersgrenze</h3>
          <p>
            Kindergeld wird gezahlt <strong>bis zur Vollendung des 18. Lebensjahres</strong>. Darüber 
            hinaus unter bestimmten Voraussetzungen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Bis 21 Jahre:</strong> Bei Arbeitslosigkeit und Meldung bei der Agentur für Arbeit</li>
            <li><strong>Bis 25 Jahre:</strong> Während Ausbildung, Studium, Freiwilligendienst oder Übergangszeit</li>
            <li><strong>Ohne Altersgrenze:</strong> Bei Kindern mit Behinderung (wenn vor dem 25. Lebensjahr eingetreten)</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Kindergeld beantragen</h3>
          <p>
            Das Kindergeld muss <strong>schriftlich bei der Familienkasse</strong> beantragt werden. 
            Der Antrag kann online über die Website der Bundesagentur für Arbeit gestellt werden.
          </p>
          <div class="bg-green-50 p-4 rounded-lg my-4">
            <p class="text-sm text-green-800">
              <strong>Tipp:</strong> Stellen Sie den Antrag frühzeitig! Kindergeld wird maximal 6 Monate 
              rückwirkend gezahlt. Am besten direkt nach der Geburt beantragen.
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Kindergeld Auszahlungstermine 2026</h3>
          <p>
            Die <strong>Auszahlung des Kindergelds</strong> erfolgt monatlich. Der genaue Termin richtet 
            sich nach der letzten Ziffer Ihrer Kindergeldnummer:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Endziffer 0:</strong> Anfang des Monats</li>
            <li><strong>Endziffer 1-4:</strong> Erste Monatshälfte</li>
            <li><strong>Endziffer 5-9:</strong> Zweite Monatshälfte</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Kindergeld oder Kinderfreibetrag?</h3>
          <p>
            Eltern erhalten entweder <strong>Kindergeld oder den Kinderfreibetrag</strong> – nicht beides 
            zusammen. Das Finanzamt prüft bei der Steuererklärung automatisch, was günstiger ist 
            (Günstigerprüfung). Der <strong>Kinderfreibetrag 2026</strong> beträgt 9.756€ pro Kind.
          </p>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/kinderzuschlag-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kinderzuschlag-Rechner</p>
          </a>
          <a href="/elterngeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🍼</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Elterngeld-Rechner</p>
          </a>
          <a href="/unterhalts-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Unterhalts-Rechner</p>
          </a>
          <a href="/mutterschutz-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🤰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Mutterschutz-Rechner</p>
          </a>
          <a href="/buergergeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏦</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Bürgergeld-Rechner</p>
          </a>
          <a href="/wohngeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏠</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Wohngeld-Rechner</p>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Zuständige Behörde -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🏛️</span>
          Zuständige Behörde
        </h2>
        
        <div class="p-4 bg-blue-50 rounded-lg">
          <h3 class="font-semibold text-blue-800 mb-2">Familienkasse der Bundesagentur für Arbeit</h3>
          <p class="text-blue-700 text-sm mb-2">
            Die <strong>Familienkasse</strong> ist zuständig für die Bearbeitung von Kindergeldanträgen 
            und die monatliche Auszahlung.
          </p>
          <p class="text-blue-700 text-sm">
            <strong>Kindergeld-Hotline:</strong> 0800 4 555530 (kostenlos)<br/>
            <strong>Online-Antrag:</strong> www.arbeitsagentur.de/familie-und-kinder/kindergeld
          </p>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kindergeld-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/kindergeld-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie hoch ist das Kindergeld 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das Kindergeld beträgt 2026 einheitlich 259€ pro Kind pro Monat, unabhängig von der Kinderanzahl. Das entspricht 3.108€ pro Jahr und Kind."
        }
      },
      {
        "@type": "Question",
        "name": "Bis wann bekommt man Kindergeld?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Kindergeld wird bis zum 18. Geburtstag gezahlt. Darüber hinaus bis 21 Jahre bei Arbeitslosigkeit, bis 25 Jahre während Ausbildung oder Studium, und ohne Altersgrenze bei Kindern mit Behinderung."
        }
      },
      {
        "@type": "Question",
        "name": "Wo beantrage ich Kindergeld?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Kindergeld wird bei der Familienkasse der Bundesagentur für Arbeit beantragt. Der Antrag kann online, per Post oder persönlich gestellt werden. Die Hotline erreichen Sie unter 0800 4 555530 (kostenlos)."
        }
      },
      {
        "@type": "Question",
        "name": "Wann wird das Kindergeld ausgezahlt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das Kindergeld wird monatlich ausgezahlt. Der genaue Termin hängt von der letzten Ziffer Ihrer Kindergeldnummer ab: Endziffer 0 = Monatsanfang, 1-4 = erste Monatshälfte, 5-9 = zweite Monatshälfte."
        }
      },
      {
        "@type": "Question",
        "name": "Kindergeld oder Kinderfreibetrag – was ist besser?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das Finanzamt prüft automatisch, was günstiger ist (Günstigerprüfung). Bei höheren Einkommen kann der Kinderfreibetrag (2026: 9.756€) vorteilhafter sein. Sie erhalten aber nur eine der beiden Leistungen."
        }
      },
      {
        "@type": "Question",
        "name": "Wie lange wird Kindergeld rückwirkend gezahlt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Kindergeld kann maximal 6 Monate rückwirkend beantragt werden. Deshalb sollten Sie den Antrag möglichst früh stellen – idealerweise direkt nach der Geburt des Kindes."
        }
      }
    ]
  })} />
</Layout>
