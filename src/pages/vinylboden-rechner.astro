---
import Layout from '../layouts/Layout.astro';
import VinylbodenRechner from '../components/rechner/VinylbodenRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = "Vinylboden-Rechner 2026 – Bedarf, Pakete & Kosten berechnen";
const description = "Vinylboden-Bedarf berechnen: benötigte m² inklusive Verschnitt, Anzahl Pakete sowie Material- und Verlegekosten. Mit Verschnittwerten für Klick-Vinyl und Trittschalldämmung.";
const keywords = "Vinylboden Rechner, Vinyl berechnen, Vinylboden bedarf berechnen, Klick Vinyl m2 berechnen, Vinylboden Verschnitt, Vinylboden Pakete, Vinylboden Kosten pro m2, Designboden Rechner";
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Vinylboden-Rechner", url: "/vinylboden-rechner" }]} />
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Wohnen & Immobilien', href: '/wohnen-immobilien' },
    { name: 'Vinylboden-Rechner' }
  ]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-blue-200 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🧱</span>
          <div>
            <h1 class="text-2xl font-bold">Vinylboden-Rechner 2026</h1>
            <p class="text-blue-200 text-sm">Bedarf, Pakete und Kosten berechnen</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Trust-Block -->
    <div class="max-w-2xl mx-auto px-4 mt-4">
      <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-sm text-green-800">
        <div class="flex items-start gap-3">
          <span class="text-xl mt-0.5">✅</span>
          <div>
            <p class="font-semibold mb-1">Zuletzt aktualisiert am 6. Juni 2026</p>
            <p class="mb-1"><strong>Grundlage:</strong> Materialbedarf = Raumfläche × (1 + Verschnitt); Pakete = aufrunden(Bedarf ÷ m² pro Paket); bestellte Fläche = Pakete × m² pro Paket. Verschnittwerte nach casando und sanier.de.</p>
            <p class="mb-1"><strong>Voreinstellungen:</strong> gerade/schwimmend 6 %, diagonal/Muster 12 %; 2,2 m² pro Paket; Materialpreis 25 €/m². Alle Werte frei anpassbar.</p>
            <p><strong>Nicht berücksichtigt:</strong> exaktes Aufmaß, Untergrundvorbereitung und Sockelleisten. Paketgrößen und Verschnitt sind produktabhängig. Kostenangaben Stand 2026, regional abweichend. Angaben ohne Gewähr.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <VinylbodenRechner client:load />
    </div>

    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Vinylboden-Bedarf richtig berechnen</h2>

        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit dem <strong>Vinylboden-Rechner</strong> ermitteln Sie schnell, wie viele Quadratmeter
            Vinyl Sie für Ihren Raum brauchen, wie viele Pakete das sind und was Material und Verlegung
            kosten. Klick-Vinyl, Designboden und SPC/Rigid werden wie Laminat oder Parkett nach der Formel
            <strong>Fläche × Verschnitt</strong> berechnet – die Paketgrößen unterscheiden sich aber je
            Produkt, deshalb sind sie hier frei einstellbar.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Die Formel</h3>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>Materialbedarf (m²)</strong> = Raumfläche × (1 + Verschnitt)</li>
              <li><strong>Pakete</strong> = aufrunden(Materialbedarf ÷ m² pro Paket)</li>
              <li><strong>Bestellte Fläche</strong> = Pakete × m² pro Paket</li>
              <li><strong>Materialkosten</strong> = bestellte Fläche × Materialpreis</li>
              <li><strong>Verlegekosten</strong> = Raumfläche × Lohnsatz pro m²</li>
            </ul>
          </div>
          <p>
            Da Vinyl nur in vollen Paketen verkauft wird, rundet der Rechner die Paketzahl auf. Die
            Materialkosten beziehen sich daher auf die tatsächlich bestellte Fläche, die Verlegekosten auf
            die reine Nutzfläche.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Verschnitt bei Vinyl</h3>
          <p>
            Bei <strong>schwimmender, gerader Verlegung</strong> in einem rechteckigen Raum reichen rund
            5–8 % Verschnitt. Wird <strong>diagonal</strong> verlegt, gibt es viele Ecken, Nischen oder
            Treppen, steigt der Verschnitt auf 10–15 %. Wie bei allen Bodenbelägen gilt: lieber etwas mehr
            Reserve einplanen, als knapp zu kalkulieren und nachbestellen zu müssen.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Material- und Verlegekosten 2026</h3>
          <p>
            Klick-Vinyl-Material kostet je nach Qualität rund <strong>5 bis 50 €/m²</strong>; hochwertige
            SPC- oder Rigid-Böden liegen am oberen Ende. Für die <strong>Verlegung durch einen
            Handwerker</strong> fallen bei Klick-Vinyl schwimmend etwa 15–30 €/m² an, bei Klebevinyl
            20–35 €/m² und bei Loose-Lay 12–20 €/m². Wer selbst verlegt, trägt im Rechner einfach 0 €/m²
            Verlegekosten ein.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Trittschall und Untergrund</h3>
          <p>
            Bei schwimmender Verlegung ist oft eine <strong>Trittschalldämmung</strong> sinnvoll oder vom
            Hersteller vorgeschrieben (manche SPC-Böden haben sie bereits integriert). Die Menge entspricht
            etwa der Raumfläche. Achten Sie zudem auf einen ebenen, sauberen und trockenen Untergrund – das
            ist die Grundlage für ein dauerhaft schönes Ergebnis.
          </p>
        </div>
      </div>
    </div>

    <!-- Referenztabelle -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">🧱 Vinyl-Bedarf nach Fläche</h2>
        <p class="text-gray-600 text-sm mb-4">
          Beispielwerte mit 6 % Verschnitt und 2,2 m² pro Paket.
        </p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200 text-left text-gray-500">
                <th class="py-2 pr-2 font-semibold">Raumfläche</th>
                <th class="py-2 px-2 font-semibold text-right">Bedarf (+6 %)</th>
                <th class="py-2 px-2 font-semibold text-right">Pakete</th>
                <th class="py-2 pl-2 font-semibold text-right">bestellt</th>
              </tr>
            </thead>
            <tbody class="text-gray-700">
              <tr class="border-b border-gray-100"><td class="py-2 pr-2">15 m²</td><td class="py-2 px-2 text-right">15,9 m²</td><td class="py-2 px-2 text-right">8</td><td class="py-2 pl-2 text-right">17,6 m²</td></tr>
              <tr class="border-b border-gray-100"><td class="py-2 pr-2">25 m²</td><td class="py-2 px-2 text-right">26,5 m²</td><td class="py-2 px-2 text-right">13</td><td class="py-2 pl-2 text-right">28,6 m²</td></tr>
              <tr class="border-b border-gray-100"><td class="py-2 pr-2">40 m²</td><td class="py-2 px-2 text-right">42,4 m²</td><td class="py-2 px-2 text-right">20</td><td class="py-2 pl-2 text-right">44,0 m²</td></tr>
              <tr><td class="py-2 pr-2">60 m²</td><td class="py-2 px-2 text-right">63,6 m²</td><td class="py-2 px-2 text-right">29</td><td class="py-2 pl-2 text-right">63,8 m²</td></tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-400 mt-3">
          Quellen: casando, sanier.de, handwerk.cloud. Werte gerundet, Paketgröße produktabhängig.
        </p>
      </div>
    </div>

    <!-- Beispielrechnungen -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Beispielrechnungen</h2>

        <div class="space-y-4">
          <!-- Beispiel 1 -->
          <div class="bg-gray-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 1: 25 m², gerade verlegt</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Bedarf (+6 %):</div>
              <div class="font-medium text-gray-800">25 × 1,06 = 26,5 m²</div>
              <div class="text-gray-600">Pakete (2,2 m²):</div>
              <div class="font-medium text-gray-800">aufrunden(12,04) = 13 Pakete</div>
              <div class="text-gray-600">Material (25 €/m², 28,6 m²):</div>
              <div class="font-medium text-green-700">715,00 €</div>
            </div>
          </div>

          <!-- Beispiel 2 -->
          <div class="bg-blue-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 2: 25 m² mit Handwerker-Verlegung</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Verlegekosten:</div>
              <div class="font-medium text-gray-800">25 m² × 20 €/m²</div>
              <div class="text-gray-600">Summe Verlegung:</div>
              <div class="font-medium text-green-700">500,00 €</div>
              <div class="text-gray-600">Material + Verlegung:</div>
              <div class="font-medium text-gray-800">715 + 500 = 1.215 €</div>
            </div>
          </div>

          <!-- Beispiel 3 -->
          <div class="bg-gray-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 3: 25 m² diagonal</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Bedarf (+12 %):</div>
              <div class="font-medium text-gray-800">25 × 1,12 = 28,0 m²</div>
              <div class="text-gray-600">Pakete (2,2 m²):</div>
              <div class="font-medium text-green-700">aufrunden(12,7) = 13 Pakete</div>
            </div>
          </div>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mt-4 text-sm text-blue-800">
          <strong>💡 Tipp:</strong> SPC- und Rigid-Vinyl sind formstabiler und eignen sich besser für
          Räume mit Temperaturschwankungen (z. B. Wintergarten). Klassisches Klick-Vinyl reagiert
          empfindlicher auf direkte Sonneneinstrahlung – Herstellerhinweise beachten.
        </div>
      </div>
    </div>

    <!-- Typische Fehler -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">⚠️ Typische Fehler & Sonderfälle</h2>

        <div class="space-y-4 text-sm text-gray-600">
          <div class="border-l-4 border-red-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 1: Paketgröße raten</h3>
            <p>Vinyl-Pakete enthalten je nach Produkt unterschiedlich viele m². Wer mit einem falschen
            Wert rechnet, bestellt zu viel oder zu wenig. Den genauen Paketinhalt finden Sie auf der
            Verpackung oder im Datenblatt.</p>
          </div>

          <div class="border-l-4 border-red-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 2: Verschnitt unterschätzen</h3>
            <p>Bei vielen Ecken, Türnischen oder diagonaler Verlegung fällt deutlich mehr Verschnitt an.
            Setzen Sie dann 10–15 % an statt der 5–8 % für einen einfachen rechteckigen Raum.</p>
          </div>

          <div class="border-l-4 border-orange-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 3: Untergrund vernachlässigen</h3>
            <p>Vinyl braucht einen ebenen, sauberen und trockenen Untergrund. Unebenheiten zeichnen sich
            durch und können bei Klick-Vinyl zu Knarzen oder offenen Fugen führen. Ggf. ausgleichen.</p>
          </div>

          <div class="border-l-4 border-blue-400 pl-4">
            <h3 class="font-semibold text-gray-800">Sonderfall: Trittschall schon integriert</h3>
            <p>Manche SPC-/Rigid-Böden haben die Trittschalldämmung bereits werkseitig verklebt. Dann
            entfällt die separate Dämmung – nicht doppelt einplanen.</p>
          </div>

          <div class="border-l-4 border-blue-400 pl-4">
            <h3 class="font-semibold text-gray-800">Sonderfall: Klebevinyl statt Klick</h3>
            <p>Vollflächig verklebtes Vinyl ist robuster und für hohe Belastung geeignet, aber aufwendiger
            zu verlegen. Die Verlegekosten liegen höher (ca. 20–35 €/m²) – im Rechner entsprechend
            anpassen.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Section (sichtbar) -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">❓ Häufig gestellte Fragen zum Vinylboden</h2>

        <div class="space-y-4">
          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viel Vinylboden brauche ich?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Der Bedarf ergibt sich aus <strong>Raumfläche × (1 + Verschnitt)</strong>. Für 25 m² mit
              gerader Verlegung (6 % Verschnitt) sind das 25 × 1,06 = 26,5 m². Bei 2,2 m² pro Paket
              brauchen Sie aufgerundet 13 Pakete.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viel Verschnitt bei Vinylboden einplanen?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Bei schwimmender, gerader Verlegung 5–8 %, bei diagonaler Verlegung, Mustern oder vielen
              Ecken 10–15 %. Diese Werte sind branchenübliche Faustregeln und kein verbindlicher Bedarf.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Was kostet Vinylboden pro m²?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Das Material kostet je nach Qualität rund <strong>5 bis 50 €/m²</strong>, hochwertiges
              SPC/Rigid am oberen Ende. Die Verlegung durch einen Handwerker kommt mit etwa 15–35 €/m²
              hinzu (Stand 2026, regional abweichend).</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viele m² hat ein Vinyl-Paket?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Klick-Vinyl-Pakete enthalten typischerweise <strong>2,0 bis 2,6 m²</strong>. Der genaue
              Wert ist produktabhängig und steht auf der Verpackung. Da nur volle Pakete verkauft werden,
              rundet der Rechner die Paketzahl auf.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Brauche ich bei Vinyl eine Trittschalldämmung?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Bei schwimmender Verlegung ist eine Trittschalldämmung meist sinnvoll oder vorgeschrieben;
              die Menge entspricht der Raumfläche. Manche SPC-/Rigid-Böden haben sie bereits integriert –
              dann ist keine separate Dämmung nötig.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Vinyl, Laminat oder Parkett – was ist günstiger?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Die Bedarfsberechnung ist bei allen gleich (Fläche × Verschnitt). Laminat ist meist am
              günstigsten, hochwertiges Vinyl und Parkett liegen darüber. Für den direkten Vergleich nutzen
              Sie den Laminat- und den Parkett-Rechner.</p>
            </div>
          </details>
        </div>
      </div>
    </div>

    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/laminat-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🟫</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Laminat-Rechner</p>
          </a>
          <a href="/parkett-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🪵</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Parkett-Rechner</p>
          </a>
          <a href="/fliesen-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🔲</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Fliesen-Rechner</p>
          </a>
          <a href="/teppichboden-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🧶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Teppichboden-Rechner</p>
          </a>
          <a href="/handwerkerkosten-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🔨</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Handwerkerkosten-Rechner</p>
          </a>
          <a href="/estrich-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🧰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Estrich-Rechner</p>
          </a>
        </div>
      </div>
    </div>
  </main>

  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
