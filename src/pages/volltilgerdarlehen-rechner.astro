            <p class="font-medium text-gray-800 text-sm mt-1">Kaufnebenkosten-Rechner</p>
          </a>
          <a href="/vorfaelligkeitsentschaedigung-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">⚖️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Vorfälligkeitsentschädigung</p>
          </a>
          <a href="/zinseszins-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📈</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Zinseszins-Rechner</p>
          </a>
        </div>
      </div>
    </div>
  </main>

