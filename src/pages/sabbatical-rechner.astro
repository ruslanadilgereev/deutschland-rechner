---
import Layout from '../layouts/Layout.astro';
import SabbaticalRechner from '../components/rechner/SabbaticalRechner.tsx';

const title = 'Sabbatical-Rechner 2026 – Ansparmodell berechnen: Gehalt, Dauer & Freistellung';
const description = 'Sabbatical planen mit dem Ansparmodell: Berechnen Sie Ansparzeit, Gehaltsprozent und Freistellungsdauer. Kostenloser Sabbatical-Rechner für Ihre berufliche Auszeit.';
const keywords = 'Sabbatical Rechner, Sabbatical berechnen, Ansparmodell, Sabbatical Finanzierung, Auszeit finanzieren, Sabbatjahr planen, Langzeitarbeitskonto, Zeitwertkonto, Sabbatical Gehalt, Sabbatical Dauer, berufliche Auszeit, Freistellung berechnen';
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <main class="min-h-screen bg-gradient-to-br from-teal-50 via-emerald-50 to-cyan-50 py-8 px-4">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-20 h-20 bg-gradient-to-br from-teal-500 to-emerald-600 rounded-2xl shadow-lg mb-4">
          <span class="text-4xl">🌴</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">
          Sabbatical-Rechner 2026
        </h1>
        <p class="text-gray-600 max-w-lg mx-auto">
          Planen Sie Ihr Sabbatical mit dem Ansparmodell: X Monate Gehaltsverzicht für Y Monate bezahlte Freistellung.
        </p>
      </div>

      <!-- Calculator Component -->
      <SabbaticalRechner client:load />

      <!-- SEO Content Section -->
      <div class="mt-12 bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📚 Alles Wichtige zum Sabbatical</h2>
        
        <div class="space-y-4 text-sm text-gray-600">
          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Was ist ein Sabbatical?</h3>
            <p>
              Ein <strong>Sabbatical</strong> (auch Sabbatjahr oder Langzeiturlaub) ist eine längere berufliche 
              Auszeit bei fortbestehendem Arbeitsverhältnis. Die Dauer variiert typischerweise zwischen 
              <strong>1 und 12 Monaten</strong>. Viele nutzen die Zeit für Reisen, Weiterbildung, Familie 
              oder persönliche Projekte.
            </p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Wie funktioniert das Ansparmodell?</h3>
            <p>
              Beim <strong>Ansparmodell</strong> arbeiten Sie über einen längeren Zeitraum mit reduziertem Gehalt 
              (z.B. 80%). Die eingesparten 20% werden angesammelt und finanzieren dann Ihre Freistellung – 
              in der Sie ebenfalls 80% Gehalt erhalten. Das Prinzip: <strong>Vorarbeiten mit Gehaltsverzicht = 
              bezahlte Auszeit</strong>.
            </p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Welche Sabbatical-Modelle gibt es?</h3>
            <p>
              Neben dem Ansparmodell gibt es weitere Varianten:
            </p>
            <ul class="list-disc list-inside mt-2 space-y-1">
              <li><strong>Zeitwertkonto:</strong> Überstunden und Urlaubstage ansparen</li>
              <li><strong>Unbezahlter Urlaub:</strong> Sofort möglich, aber ohne Gehalt</li>
              <li><strong>Teilzeit-Sabbatical:</strong> Stundenreduzierung statt kompletter Auszeit</li>
              <li><strong>Kombination:</strong> Mehrere Modelle kombinieren</li>
            </ul>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Habe ich ein Recht auf Sabbatical?</h3>
            <p>
              <strong>Nein</strong>, es gibt in Deutschland keinen gesetzlichen Anspruch auf ein Sabbatical. 
              Eine Ausnahme bildet der <strong>öffentliche Dienst</strong> (z.B. Beamte), wo teilweise 
              Freistellungsregelungen im Tarifvertrag verankert sind. In der Privatwirtschaft hängt es 
              vom Arbeitgeber ab – immer mehr Unternehmen bieten Sabbatical-Modelle an, um attraktiv zu bleiben.
            </p>
          </div>
          
          <div>
            <h3 class="font-semibold text-gray-800 mb-2">Was passiert mit meiner Sozialversicherung?</h3>
            <p>
              Bei einem ordnungsgemäß vereinbarten <strong>Wertguthabenmodell</strong> (Zeitwertkonto nach §§ 7b-7f SGB IV) 
              bleiben Sie während der gesamten Sabbatical-Zeit <strong>voll sozialversichert</strong>. 
              Kranken-, Renten-, Pflege- und Arbeitslosenversicherung laufen weiter. 
              Bei unbezahltem Urlaub müssen Sie sich hingegen selbst versichern.
            </p>
          </div>
        </div>
      </div>

      <!-- FAQ Schema -->
      <div class="mt-8 bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">❓ Häufige Fragen zum Sabbatical</h2>
        
        <div class="space-y-4">
          <details class="group">
            <summary class="cursor-pointer font-medium text-gray-800 hover:text-teal-600">
              Wie berechne ich die Ansparzeit für mein Sabbatical?
            </summary>
            <p class="mt-2 text-sm text-gray-600 pl-4">
              Die Formel lautet: <strong>Ansparzeit = Freistellung × (Gehaltsprozent ÷ Verzichtsprozent)</strong>. 
              Für 3 Monate Sabbatical bei 80% Gehalt: 3 × (80 ÷ 20) = 12 Monate Ansparzeit. 
              Sie arbeiten also 12 Monate bei 80% Gehalt, um 3 Monate bezahlte Freistellung zu erhalten.
            </p>
          </details>
          
          <details class="group">
            <summary class="cursor-pointer font-medium text-gray-800 hover:text-teal-600">
              Kann ich ein Sabbatical steuerlich absetzen?
            </summary>
            <p class="mt-2 text-sm text-gray-600 pl-4">
              Das Sabbatical selbst ist nicht steuerlich absetzbar, da Sie weiterhin Gehalt beziehen 
              und versteuern. Allerdings können Sie <strong>Weiterbildungskosten</strong> während des 
              Sabbaticals als Werbungskosten absetzen, wenn sie beruflich relevant sind. Auch Umzugs- 
              oder Reisekosten für eine beruflich bedingte Auszeit können u.U. geltend gemacht werden.
            </p>
          </details>
          
          <details class="group">
            <summary class="cursor-pointer font-medium text-gray-800 hover:text-teal-600">
              Was passiert bei Kündigung während der Ansparphase?
            </summary>
            <p class="mt-2 text-sm text-gray-600 pl-4">
              Bei Beendigung des Arbeitsverhältnisses wird das angesparte Wertguthaben in der Regel 
              <strong>ausgezahlt</strong>. Achtung: Die Auszahlung ist dann voll steuerpflichtig und kann 
              zu einer höheren Steuerlast führen ("Progressionsvorbehalt"). Eine Übertragung auf den 
              neuen Arbeitgeber ist möglich, wenn dieser zustimmt.
            </p>
          </details>
          
          <details class="group">
            <summary class="cursor-pointer font-medium text-gray-800 hover:text-teal-600">
              Wie lange vorher muss ich ein Sabbatical planen?
            </summary>
            <p class="mt-2 text-sm text-gray-600 pl-4">
              Das hängt vom gewählten Modell ab. Beim <strong>Ansparmodell</strong> müssen Sie entsprechend 
              der Ansparphase vorausplanen (z.B. 12-24 Monate). Für <strong>unbezahlten Urlaub</strong> reichen 
              oft wenige Monate Vorlauf. Grundsätzlich gilt: Je früher Sie mit Ihrem Arbeitgeber sprechen, 
              desto besser können beide Seiten planen.
            </p>
          </details>
          
          <details class="group">
            <summary class="cursor-pointer font-medium text-gray-800 hover:text-teal-600">
              Ist mein Arbeitsplatz während des Sabbaticals sicher?
            </summary>
            <p class="mt-2 text-sm text-gray-600 pl-4">
              Bei einem vertraglich vereinbarten Sabbatical besteht das Arbeitsverhältnis fort. 
              Sie haben Anspruch auf <strong>Rückkehr auf einen gleichwertigen Arbeitsplatz</strong>. 
              Kündigungen während des Sabbaticals unterliegen den normalen arbeitsrechtlichen Regelungen 
              (kein besonderer Kündigungsschutz wie bei Elternzeit). Eine schriftliche Vereinbarung ist wichtig!
            </p>
          </details>
          
          <details class="group">
            <summary class="cursor-pointer font-medium text-gray-800 hover:text-teal-600">
              Was ist der Unterschied zwischen Sabbatical und unbezahltem Urlaub?
            </summary>
            <p class="mt-2 text-sm text-gray-600 pl-4">
              Bei einem <strong>Sabbatical</strong> (Ansparmodell) erhalten Sie weiterhin Gehalt und bleiben 
              sozialversichert. Bei <strong>unbezahltem Urlaub</strong> (Sonderurlaub) ruht das Gehalt komplett, 
              und Sie müssen sich selbst krankenversichern. Unbezahlter Urlaub ist flexibler, aber finanziell 
              anspruchsvoller.
            </p>
          </details>
        </div>
      </div>

      <!-- Sabbatical-Checkliste -->
      <div class="mt-8 bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">✅ Sabbatical-Checkliste</h2>
        
        <div class="space-y-3 text-sm">
          <div class="flex items-start gap-3 p-3 bg-gray-50 rounded-xl">
            <span class="text-xl">1️⃣</span>
            <div>
              <p class="font-medium text-gray-800">Ziele definieren</p>
              <p class="text-gray-500">Was wollen Sie im Sabbatical machen? Reisen, Weiterbildung, Familie, Erholung?</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3 p-3 bg-gray-50 rounded-xl">
            <span class="text-xl">2️⃣</span>
            <div>
              <p class="font-medium text-gray-800">Finanzen planen</p>
              <p class="text-gray-500">Ansparmodell berechnen, Kosten schätzen, Rücklagen prüfen</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3 p-3 bg-gray-50 rounded-xl">
            <span class="text-xl">3️⃣</span>
            <div>
              <p class="font-medium text-gray-800">Arbeitgeber ansprechen</p>
              <p class="text-gray-500">Frühzeitig das Gespräch suchen, Modelle vorstellen, Vorteile erklären</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3 p-3 bg-gray-50 rounded-xl">
            <span class="text-xl">4️⃣</span>
            <div>
              <p class="font-medium text-gray-800">Schriftliche Vereinbarung</p>
              <p class="text-gray-500">Dauer, Gehalt, Rückkehrrecht, Vertretung – alles schriftlich fixieren</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3 p-3 bg-gray-50 rounded-xl">
            <span class="text-xl">5️⃣</span>
            <div>
              <p class="font-medium text-gray-800">Sozialversicherung klären</p>
              <p class="text-gray-500">Krankenversicherung, Rentenversicherung, Arbeitslosenversicherung prüfen</p>
            </div>
          </div>
          
          <div class="flex items-start gap-3 p-3 bg-gray-50 rounded-xl">
            <span class="text-xl">6️⃣</span>
            <div>
              <p class="font-medium text-gray-800">Übergabe vorbereiten</p>
              <p class="text-gray-500">Vertretung einarbeiten, Dokumentation erstellen, Kontaktmöglichkeiten klären</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Vergleichsrechner -->
      <div class="mt-8 bg-teal-50 border border-teal-200 rounded-2xl p-6">
        <h3 class="font-bold text-teal-800 mb-3">📱 Weitere nützliche Rechner</h3>
        <div class="grid grid-cols-2 gap-3">
          <a 
            href="/brutto-netto-rechner"
            class="bg-white p-4 rounded-xl hover:shadow-md transition-shadow"
          >
            <span class="text-2xl">💵</span>
            <span class="block text-sm font-medium text-gray-800 mt-1">Brutto-Netto</span>
          </a>
          <a 
            href="/teilzeit-rechner"
            class="bg-white p-4 rounded-xl hover:shadow-md transition-shadow"
          >
            <span class="text-2xl">⏰</span>
            <span class="block text-sm font-medium text-gray-800 mt-1">Teilzeit</span>
          </a>
          <a 
            href="/urlaubstage-rechner"
            class="bg-white p-4 rounded-xl hover:shadow-md transition-shadow"
          >
            <span class="text-2xl">🏖️</span>
            <span class="block text-sm font-medium text-gray-800 mt-1">Urlaubstage</span>
          </a>
          <a 
            href="/elternzeit-rechner"
            class="bg-white p-4 rounded-xl hover:shadow-md transition-shadow"
          >
            <span class="text-2xl">📅</span>
            <span class="block text-sm font-medium text-gray-800 mt-1">Elternzeit</span>
          </a>
        </div>
      </div>

      <!-- Back Link -->
      <div class="mt-8 text-center">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-teal-600 hover:text-teal-800 font-medium"
        >
          ← Alle Rechner anzeigen
        </a>
      </div>
    </div>
  </main>
</Layout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie funktioniert das Ansparmodell für ein Sabbatical?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Beim Ansparmodell arbeiten Sie über einen längeren Zeitraum mit reduziertem Gehalt (z.B. 80%). Die eingesparte Differenz (20%) wird angesammelt und finanziert dann Ihre Freistellung, in der Sie ebenfalls 80% Gehalt erhalten. Für 3 Monate Sabbatical bei 80% Gehalt müssen Sie 12 Monate ansparen."
      }
    },
    {
      "@type": "Question",
      "name": "Habe ich einen Anspruch auf ein Sabbatical?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In Deutschland gibt es keinen gesetzlichen Anspruch auf ein Sabbatical in der Privatwirtschaft. Eine Ausnahme bildet der öffentliche Dienst mit speziellen Regelungen. In vielen Unternehmen werden Sabbaticals jedoch als Benefit angeboten und individuell vereinbart."
      }
    },
    {
      "@type": "Question",
      "name": "Was passiert mit meiner Sozialversicherung im Sabbatical?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Bei einem ordnungsgemäß vereinbarten Wertguthabenmodell (Zeitwertkonto nach §§ 7b-7f SGB IV) bleiben Sie während der gesamten Sabbatical-Zeit voll sozialversichert. Kranken-, Renten-, Pflege- und Arbeitslosenversicherung laufen weiter."
      }
    },
    {
      "@type": "Question",
      "name": "Wie berechne ich die Ansparzeit für mein Sabbatical?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Formel lautet: Ansparzeit = Freistellung × (Gehaltsprozent ÷ Verzichtsprozent). Für 3 Monate Sabbatical bei 80% Gehalt: 3 × (80 ÷ 20) = 12 Monate Ansparzeit."
      }
    },
    {
      "@type": "Question",
      "name": "Was passiert bei Kündigung während der Ansparphase?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Bei Beendigung des Arbeitsverhältnisses wird das angesparte Wertguthaben in der Regel ausgezahlt. Achtung: Die Auszahlung ist dann voll steuerpflichtig. Eine Übertragung auf den neuen Arbeitgeber ist möglich, wenn dieser zustimmt."
      }
    }
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Sabbatical-Rechner 2026",
  "description": "Planen Sie Ihr Sabbatical mit dem Ansparmodell: Berechnen Sie Ansparzeit, Gehaltsprozent und Freistellungsdauer. Kostenloser Rechner für Ihre berufliche Auszeit.",
  "url": "https://www.deutschland-rechner.de/sabbatical-rechner",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  }
}
</script>
</Layout>
