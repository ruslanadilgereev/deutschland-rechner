---
import Layout from '../layouts/Layout.astro';
import SSWRechner from '../components/rechner/SSWRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "SSW-Rechner 2025 & 2026 – Schwangerschaftswoche berechnen";
const description = "SSW berechnen: Schwangerschaftswoche mit Trimester, Geburtstermin & Baby-Entwicklung. In welcher Woche bin ich?";
const keywords = "SSW Rechner, Schwangerschaftswoche berechnen, welche SSW bin ich, SSW berechnen, SSW Tabelle, SSW Entwicklung, Schwangerschaftswoche Rechner, in welcher Woche bin ich schwanger, SSW aktuell";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "SSW-Rechner", url: "/ssw-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-pink-500 to-rose-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-pink-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🤰</span>
          <div>
            <h1 class="text-2xl font-bold">SSW-Rechner 2026</h1>
            <p class="text-pink-100 text-sm">Schwangerschaftswoche berechnen</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <SSWRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">SSW berechnen: So funktioniert's</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem kostenlosen <strong>SSW-Rechner</strong> ermitteln Sie schnell Ihre aktuelle 
            <strong>Schwangerschaftswoche</strong>, das <strong>Trimester</strong> und den 
            voraussichtlichen <strong>Geburtstermin (ET)</strong>. Erfahren Sie außerdem, wie groß 
            Ihr Baby gerade ist und was in der aktuellen Woche passiert.
          </p>
          
          <div class="bg-pink-50 p-4 rounded-lg my-4">
            <p class="text-sm text-pink-800 font-semibold mb-2">📅 Was bedeutet SSW?</p>
            <p class="text-sm text-pink-700">
              <strong>SSW</strong> steht für <strong>Schwangerschaftswoche</strong>. Die Zählung 
              beginnt am ersten Tag der letzten Periode – also etwa 2 Wochen vor der eigentlichen 
              Befruchtung. „SSW 10+3" bedeutet: 10. Woche + 3 Tage.
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wie wird die SSW berechnet?</h3>
          <p>
            Die <strong>Schwangerschaftswoche</strong> wird ab dem ersten Tag der letzten 
            Menstruation (LMP) gezählt:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>SSW 1-2:</strong> Noch nicht schwanger – die Periode beginnt, Eizelle reift</li>
            <li><strong>SSW 3:</strong> Befruchtung findet statt</li>
            <li><strong>SSW 4:</strong> Einnistung in der Gebärmutter</li>
            <li><strong>SSW 40:</strong> Errechneter Geburtstermin (280 Tage nach LMP)</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Die drei Trimester der Schwangerschaft</h3>
          <div class="bg-gray-50 p-4 rounded-lg my-4">
            <ul class="space-y-3 text-sm">
              <li>
                <strong class="text-pink-600">1. Trimester (SSW 1-12):</strong><br/>
                Alle wichtigen Organe werden angelegt. Die kritischste Phase – danach sinkt das 
                Fehlgeburtsrisiko deutlich.
              </li>
              <li>
                <strong class="text-purple-600">2. Trimester (SSW 13-27):</strong><br/>
                Baby wächst schnell, erste Bewegungen spürbar. Die „Honeymoon-Phase" der Schwangerschaft.
              </li>
              <li>
                <strong class="text-blue-600">3. Trimester (SSW 28-40):</strong><br/>
                Endspurt! Baby legt an Gewicht zu, Lunge reift aus. Vorbereitung auf die Geburt.
              </li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Baby-Entwicklung nach SSW</h3>
          <p>
            In jeder Schwangerschaftswoche entwickelt sich Ihr Baby weiter:
          </p>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm text-blue-800">
              <li><strong>SSW 5:</strong> Herzschlag beginnt (ca. 2mm groß)</li>
              <li><strong>SSW 8:</strong> Alle wichtigen Organe angelegt (ca. 1,5cm)</li>
              <li><strong>SSW 12:</strong> Baby bewegt sich, Fingernägel wachsen (ca. 5cm)</li>
              <li><strong>SSW 16:</strong> Geschlecht erkennbar (ca. 12cm, 100g)</li>
              <li><strong>SSW 20:</strong> Halbzeit! Kindsbewegungen spürbar (ca. 25cm, 300g)</li>
              <li><strong>SSW 28:</strong> Augen öffnen sich (ca. 37cm, 1.100g)</li>
              <li><strong>SSW 36:</strong> Baby dreht sich in Geburtsposition (ca. 47cm, 2.700g)</li>
              <li><strong>SSW 40:</strong> Geburtsbereit! (ca. 51cm, 3.400g)</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">SSW vs. Schwangerschaftsmonat</h3>
          <p>
            Die Umrechnung von Wochen in Monate ist nicht ganz einfach:
          </p>
          <div class="bg-green-50 p-4 rounded-lg my-4">
            <ul class="space-y-1 text-sm text-green-800">
              <li><strong>1. Monat:</strong> SSW 1-4</li>
              <li><strong>2. Monat:</strong> SSW 5-8</li>
              <li><strong>3. Monat:</strong> SSW 9-12</li>
              <li><strong>4. Monat:</strong> SSW 13-16</li>
              <li><strong>5. Monat:</strong> SSW 17-20</li>
              <li><strong>6. Monat:</strong> SSW 21-24</li>
              <li><strong>7. Monat:</strong> SSW 25-28</li>
              <li><strong>8. Monat:</strong> SSW 29-32</li>
              <li><strong>9. Monat:</strong> SSW 33-36</li>
              <li><strong>10. Monat:</strong> SSW 37-40</li>
            </ul>
          </div>
          
          <div class="bg-yellow-50 p-4 rounded-lg my-4">
            <p class="text-sm text-yellow-800">
              <strong>💡 Wichtig:</strong> Eine Schwangerschaft dauert 10 Mondmonate (je 28 Tage) 
              oder etwa 9 Kalendermonate. Deshalb spricht man von 40 Wochen.
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Vorsorgeuntersuchungen nach SSW</h3>
          <p>
            Der Mutterpass dokumentiert alle Vorsorgeuntersuchungen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Bis SSW 32:</strong> Vorsorge alle 4 Wochen</li>
            <li><strong>Ab SSW 32:</strong> Vorsorge alle 2 Wochen</li>
            <li><strong>SSW 9-12:</strong> 1. Ultraschall-Screening</li>
            <li><strong>SSW 19-22:</strong> 2. Ultraschall-Screening (Feindiagnostik)</li>
            <li><strong>SSW 29-32:</strong> 3. Ultraschall-Screening</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Ab wann zählt ein Baby nicht mehr als Frühchen?</h3>
          <p>
            Die Reife des Babys wird nach SSW eingeteilt:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Vor SSW 28:</strong> Extrem unreif (intensive Betreuung nötig)</li>
            <li><strong>SSW 28-34:</strong> Sehr früh geboren (Frühchen)</li>
            <li><strong>SSW 34-37:</strong> Mäßig früh geboren</li>
            <li><strong>Ab SSW 37:</strong> Termingerecht – kein Frühchen mehr!</li>
            <li><strong>Ab SSW 42:</strong> Übertragen (Einleitung wird erwogen)</li>
          </ul>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/geburtstermin-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🗓️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Geburtstermin-Rechner</p>
          </a>
          <a href="/mutterschutz-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🤰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Mutterschutz-Rechner</p>
          </a>
          <a href="/elterngeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🍼</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Elterngeld-Rechner</p>
          </a>
          <a href="/elternzeit-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📅</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Elternzeit-Rechner</p>
          </a>
          <a href="/eisprung-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🌸</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Eisprung-Rechner</p>
          </a>
          <a href="/kindergeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">👶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kindergeld-Rechner</p>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Zuständige Behörde -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🏥</span>
          Wichtige Anlaufstellen
        </h2>
        
        <div class="p-4 bg-blue-50 rounded-lg">
          <h3 class="font-semibold text-blue-800 mb-2">Schwangerenvorsorge</h3>
          <p class="text-blue-700 text-sm mb-2">
            Regelmäßige Vorsorgeuntersuchungen beim Frauenarzt oder der Hebamme sind wichtig für 
            eine gesunde Schwangerschaft. Die Kosten übernimmt die Krankenkasse.
          </p>
          <p class="text-blue-700 text-sm">
            <strong>Hebammen-Suche:</strong> hebammensuche.de<br/>
            <strong>Schwangerschaftsberatung:</strong> profamilia.de
          </p>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "SSW-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/ssw-rechner",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Was bedeutet SSW?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "SSW steht für Schwangerschaftswoche. Die Zählung beginnt am ersten Tag der letzten Periode, also etwa 2 Wochen vor der eigentlichen Befruchtung. Eine komplette Schwangerschaft dauert 40 SSW oder 280 Tage."
        }
      },
      {
        "@type": "Question",
        "name": "Wie wird die SSW berechnet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die SSW wird ab dem ersten Tag der letzten Menstruation (LMP) gezählt. Wenn z.B. die letzte Periode vor 70 Tagen war, sind Sie in SSW 10+0 (70 Tage / 7 = 10 Wochen)."
        }
      },
      {
        "@type": "Question",
        "name": "Was bedeutet SSW 10+3?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Schreibweise 'SSW 10+3' bedeutet: 10 vollendete Wochen plus 3 Tage. Sie befinden sich also am 73. Schwangerschaftstag und sind in der 11. Schwangerschaftswoche."
        }
      },
      {
        "@type": "Question",
        "name": "Welche SSW entspricht welchem Monat?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Eine Schwangerschaft dauert 10 Mondmonate: 1. Monat = SSW 1-4, 2. Monat = SSW 5-8, 3. Monat = SSW 9-12 usw. Der 10. Monat endet mit SSW 40 am errechneten Geburtstermin."
        }
      },
      {
        "@type": "Question",
        "name": "Ab wann ist ein Baby kein Frühchen mehr?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ab SSW 37 gilt ein Baby als termingerecht geboren und nicht mehr als Frühchen. Die meisten Babys kommen zwischen SSW 38 und SSW 42 zur Welt."
        }
      },
      {
        "@type": "Question",
        "name": "Wann beginnt welches Trimester?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das 1. Trimester umfasst SSW 1-12, das 2. Trimester SSW 13-27 und das 3. Trimester SSW 28-40. Jedes Trimester hat etwa 13 Wochen."
        }
      }
    ]
  })} />
</Layout>
