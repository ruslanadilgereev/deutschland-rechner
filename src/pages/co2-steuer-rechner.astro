---
import Layout from '../layouts/Layout.astro';
import CO2SteuerRechner from '../components/rechner/CO2SteuerRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "CO2-Steuer-Rechner 2025 & 2026 – CO₂-Abgabe kostenlos berechnen";
const description = "CO2-Steuer-Rechner 2026: Berechnen Sie Ihre CO₂-Abgabe auf Benzin, Diesel, Erdgas & Heizöl. Preiskorridor 55-65€/Tonne. Mit Jahresvergleich & Spartipps!";
const keywords = "CO2 Steuer Rechner, CO2 Abgabe berechnen, CO2 Preis 2026, CO2 Steuer Benzin, CO2 Steuer Diesel, CO2 Steuer Heizöl, Brennstoffemissionshandelsgesetz, BEHG, CO2 Bepreisung, Klimasteuer, CO2 Abgabe 55 Euro, CO2 Steuer Deutschland, CO2 Steuer berechnen";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "CO2-Steuer-Rechner", url: "/co2-steuer-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-green-500 to-emerald-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-green-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🌱</span>
          <div>
            <h1 class="text-2xl font-bold">CO2-Steuer-Rechner</h1>
            <p class="text-green-100 text-sm">CO₂-Abgabe auf Kraftstoff & Heizung berechnen 2026</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <CO2SteuerRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">CO2-Steuer-Rechner: CO₂-Abgabe einfach berechnen</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem <strong>CO2-Steuer-Rechner</strong> berechnen Sie schnell und einfach, wie viel 
            CO₂-Abgabe Sie für Ihren Kraftstoff- oder Heizölverbrauch zahlen. <strong>Ab 2026 gilt ein 
            Preiskorridor von 55-65 Euro pro Tonne CO₂</strong> (Emissionshandel statt Festpreis). Die Steuer 
            ist bereits im Benzin-, Diesel- und Heizölpreis enthalten.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was ist die CO2-Steuer?</h3>
          <p>
            Die CO2-Steuer (offiziell: <strong>CO₂-Bepreisung</strong>) ist eine Abgabe auf fossile Brennstoffe, 
            die beim Verbrennen CO₂ freisetzen. Sie wurde 2021 in Deutschland eingeführt und soll:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Anreize zum <strong>Energiesparen</strong> schaffen</li>
            <li>Den Umstieg auf <strong>klimafreundliche Alternativen</strong> fördern</li>
            <li>Die <strong>Klimaziele 2030 und 2045</strong> erreichen helfen</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">CO₂-Preis Entwicklung 2021-2026</h3>
          <p>
            Der CO₂-Preis steigt schrittweise an:
          </p>
          <div class="bg-green-50 p-4 rounded-xl my-4">
            <ul class="space-y-1 text-sm">
              <li><strong>2021:</strong> 25 €/Tonne → ca. 7 Cent/Liter Benzin</li>
              <li><strong>2022:</strong> 30 €/Tonne → ca. 8 Cent/Liter</li>
              <li><strong>2023:</strong> 30 €/Tonne → ca. 8 Cent/Liter</li>
              <li><strong>2024:</strong> 45 €/Tonne → ca. 12 Cent/Liter</li>
              <li><strong>2025:</strong> 55 €/Tonne → ca. 15 Cent/Liter</li>
              <li><strong>2026:</strong> 55-65 €/Tonne (Preiskorridor) → ca. 15-17 Cent/Liter</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">CO₂-Steuer nach Kraftstoffart</h3>
          <p>
            Je nach Brennstoff variiert die CO₂-Steuer, da unterschiedlich viel CO₂ freigesetzt wird:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Benzin (Super E10):</strong> 2,37 kg CO₂/Liter → ca. 13 Cent/Liter (2026)</li>
            <li><strong>Diesel:</strong> 2,65 kg CO₂/Liter → ca. 15 Cent/Liter (2026)</li>
            <li><strong>Heizöl:</strong> 2,66 kg CO₂/Liter → ca. 15 Cent/Liter (2026)</li>
            <li><strong>Erdgas:</strong> 2,79 kg CO₂/kg → ca. 15 Cent/kg (2026)</li>
            <li><strong>Autogas (LPG):</strong> 1,64 kg CO₂/Liter → ca. 9 Cent/Liter (2026)</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">So berechnen Sie Ihre CO₂-Steuer</h3>
          <p>
            Die Formel ist einfach:
          </p>
          <div class="bg-green-50 p-4 rounded-xl my-4">
            <p class="font-mono text-center text-green-800 font-bold">
              Verbrauch × CO₂/Einheit × CO₂-Preis = CO₂-Steuer
            </p>
          </div>
          
          <h4 class="font-semibold text-gray-800">Beispielrechnung Benzin (2026):</h4>
          <ul class="list-disc pl-5 space-y-1">
            <li>Jahresverbrauch: <strong>1.200 Liter</strong></li>
            <li>CO₂ pro Liter: <strong>2,37 kg</strong></li>
            <li>CO₂-Ausstoß: 1.200 × 2,37 = <strong>2.844 kg = 2,844 t</strong></li>
            <li>CO₂-Preis 2026: <strong>55 €/Tonne</strong></li>
            <li>CO₂-Steuer: 2,844 × 55 = <strong>156,42 €/Jahr</strong></li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wer zahlt die CO₂-Steuer?</h3>
          <p>
            Die CO₂-Abgabe wird von den <strong>Inverkehrbringern</strong> fossiler Brennstoffe gezahlt – 
            also Mineralölkonzerne, Gasversorger und Heizölhändler. Diese geben die Kosten jedoch über 
            <strong>höhere Preise</strong> an die Verbraucher weiter.
          </p>
          <p>
            <strong>Das bedeutet:</strong> Die CO₂-Steuer ist bereits im Tankstellen- und Heizölpreis 
            enthalten. Sie zahlen keine separate Steuer.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Entlastungen für Bürger</h3>
          <p>
            Um soziale Härten abzufedern, gibt es verschiedene Entlastungen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Klimageld:</strong> Pro-Kopf-Rückzahlung der Einnahmen an Bürger (geplant, noch nicht umgesetzt)</li>
            <li><strong>Pendlerpauschale:</strong> Erhöht auf 38 Cent ab dem 21. Kilometer</li>
            <li><strong>Mobilitätsprämie:</strong> Für Geringverdiener ohne Steuerpflicht</li>
            <li><strong>Heizkostenzuschuss:</strong> Für Wohngeldempfänger und BAföG-Bezieher</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">CO₂-Steuer bei Mietwohnungen</h3>
          <p>
            Seit 2023 wird die CO₂-Steuer für Heizung zwischen Mieter und Vermieter aufgeteilt. 
            Je schlechter die Energieeffizienz des Gebäudes, desto mehr zahlt der Vermieter:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Sehr gute Dämmung:</strong> Mieter zahlt 100%</li>
            <li><strong>Mittlere Effizienz:</strong> 50/50 Aufteilung</li>
            <li><strong>Schlechte Dämmung:</strong> Vermieter zahlt bis 90%</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">So sparen Sie CO₂-Steuer</h3>
          
          <h4 class="font-semibold text-gray-800">Beim Autofahren:</h4>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Spritsparend fahren:</strong> Vorausschauendes Fahren spart 10-20%</li>
            <li><strong>E-Auto:</strong> Keine CO₂-Steuer auf Strom</li>
            <li><strong>ÖPNV & Fahrrad:</strong> Komplett CO₂-steuerfrei</li>
            <li><strong>Fahrgemeinschaften:</strong> Kosten pro Person sinken</li>
          </ul>
          
          <h4 class="font-semibold text-gray-800 mt-4">Beim Heizen:</h4>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Heizung runterdrehen:</strong> 1°C weniger = 6% weniger Verbrauch</li>
            <li><strong>Wärmepumpe:</strong> Nutzt Strom statt fossile Brennstoffe</li>
            <li><strong>Dämmung verbessern:</strong> Weniger Heizenergie nötig</li>
            <li><strong>Solarthermie:</strong> Warmwasser durch Sonne</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Rechtliche Grundlage</h3>
          <p>
            Die CO₂-Bepreisung basiert auf dem <strong>Brennstoffemissionshandelsgesetz (BEHG)</strong> 
            vom 12. Dezember 2019. Unternehmen müssen für jede Tonne CO₂ Emissionszertifikate kaufen.
          </p>
          <p>
            Zuständig für die Umsetzung ist die <strong>Deutsche Emissionshandelsstelle (DEHSt)</strong> 
            beim Umweltbundesamt.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Häufige Fragen zur CO₂-Steuer</h3>
          
          <p class="font-semibold">Wie hoch ist die CO₂-Steuer pro Liter Benzin 2026?</p>
          <p>
            Bei 55 €/Tonne CO₂-Preis und 2,37 kg CO₂ pro Liter Benzin beträgt die Steuer 
            ca. 13 Cent pro Liter.
          </p>
          
          <p class="font-semibold">Wird die CO₂-Steuer weiter steigen?</p>
          <p>
            Ja, ursprünglich war geplant, dass ab 2026 der Preis in einem Korridor zwischen 
            55 und 65 Euro gehandelt wird. Die genaue Entwicklung hängt von politischen 
            Entscheidungen ab.
          </p>
          
          <p class="font-semibold">Gilt die CO₂-Steuer auch für Strom?</p>
          <p>
            Nein, für den Stromsektor gilt der <strong>EU-Emissionshandel (EU ETS)</strong>. 
            Die nationale CO₂-Bepreisung betrifft nur Wärme und Verkehr.
          </p>
          
          <p class="font-semibold">Wann kommt das Klimageld?</p>
          <p>
            Die Auszahlung des Klimagelds ist gesetzlich vorgesehen, aber noch nicht umgesetzt. 
            Ursprünglich sollte es bereits 2024 kommen. Der genaue Termin ist noch offen.
          </p>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/kfz-steuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🚗</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kfz-Steuer-Rechner</p>
          </a>
          <a href="/pendlerpauschale-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🚌</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Pendlerpauschale-Rechner</p>
          </a>
          <a href="/brutto-netto-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💵</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Brutto-Netto-Rechner</p>
          </a>
          <a href="/einkommensteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🧾</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Einkommensteuer-Rechner</p>
          </a>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "CO2-Steuer-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/co2-steuer-rechner",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie hoch ist die CO2-Steuer 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der CO2-Preis beträgt 2026 55 Euro pro Tonne CO2. Das entspricht etwa 13 Cent pro Liter Benzin und 15 Cent pro Liter Diesel. Die Steuer ist bereits im Kraftstoffpreis an der Tankstelle enthalten."
        }
      },
      {
        "@type": "Question",
        "name": "Wie berechne ich meine CO2-Steuer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Formel lautet: Jahresverbrauch × CO2 pro Liter × CO2-Preis pro Tonne. Beispiel: 1.200 Liter Benzin × 2,37 kg CO2/Liter = 2.844 kg CO2. 2,844 Tonnen × 55 €/Tonne = 156,42 € CO2-Steuer pro Jahr."
        }
      },
      {
        "@type": "Question",
        "name": "Wer zahlt die CO2-Steuer?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die CO2-Abgabe wird von den Unternehmen gezahlt, die fossile Brennstoffe in Verkehr bringen (Mineralölkonzerne, Gasversorger). Diese geben die Kosten über höhere Preise an die Verbraucher weiter. Sie zahlen keine separate Steuer."
        }
      },
      {
        "@type": "Question",
        "name": "Gilt die CO2-Steuer auch für Strom?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nein, für Strom gilt der EU-Emissionshandel (EU ETS). Die nationale CO2-Bepreisung nach dem Brennstoffemissionshandelsgesetz (BEHG) gilt nur für Wärme und Verkehr."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist das Klimageld?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das Klimageld soll die Einnahmen aus der CO2-Bepreisung pro Kopf an die Bürger zurückgeben. Es ist gesetzlich vorgesehen, aber die Auszahlung ist noch nicht umgesetzt (Stand 2025)."
        }
      },
      {
        "@type": "Question",
        "name": "Wie kann ich CO2-Steuer sparen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Durch weniger Verbrauch fossiler Brennstoffe: Spritsparend fahren, E-Auto oder ÖPNV nutzen, Heizung runterdrehen, auf Wärmepumpe umsteigen, Gebäude dämmen. Jede eingesparte Tonne CO2 spart auch die Steuer."
        }
      }
    ]
  })} />
</Layout>
