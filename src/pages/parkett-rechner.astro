        }
      },
      {
        "@type": "Question",
        "name": "Wie viel Verschnitt sollte ich bei Parkett einplanen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Als Faustregel: gerade/parallele Verlegung 5–6 %, diagonale oder verwinkelte Verlegung 8–10 %, aufwendige Muster wie Fischgrät rund 15 %. Diese Werte sind branchenübliche Richtwerte, kein verbindlicher Bedarf."
        }
      },
      {
