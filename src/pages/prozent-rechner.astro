    ]
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie berechnet man Prozent?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Um einen Prozentsatz zu berechnen, teilt man den Teil durch das Ganze und multipliziert mit 100. Formel: Prozentsatz = (Teil ÷ Ganzes) × 100. Beispiel: 30 von 200 = (30 ÷ 200) × 100 = 15%."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist der Grundwert in der Prozentrechnung?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der Grundwert (G) ist die Ausgangsgröße, von der aus gerechnet wird. Er entspricht immer 100%. Beispiele: Der Originalpreis bei Rabatten, die Gesamtzahl bei Anteilen oder der Anfangswert bei Zinsberechnungen."
        }
      },
      {
        "@type": "Question",
        "name": "Wie berechnet man Prozent von einer Zahl?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Um X% von einer Zahl zu berechnen, multipliziert man die Zahl mit dem Prozentsatz und teilt durch 100. Formel: Prozentwert = Zahl × (Prozent ÷ 100). Beispiel: 15% von 200 = 200 × 0,15 = 30."
        }
      },
      {
        "@type": "Question",
        "name": "Wie rechnet man prozentuale Veränderung aus?",
