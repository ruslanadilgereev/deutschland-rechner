---
import Layout from '../layouts/Layout.astro';
import ProzentRechner from '../components/rechner/ProzentRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RechnerTrust from '../components/RechnerTrust.astro';
import VerwandteRechner from '../components/VerwandteRechner.astro';

const title = "Prozent-Rechner – Prozent berechnen einfach erklärt";
const description = "Prozent-Rechner: Prozentwert, Prozentsatz & prozentuale Veränderung berechnen. Einfache Erklärung mit Formeln und Beispielen. Kostenlos!";
const keywords = "Prozent Rechner, Prozent berechnen, Prozentrechnung, Prozentwert berechnen, Prozentsatz berechnen, prozentuale Veränderung, Grundwert Prozentwert, Prozent ausrechnen, Rabatt berechnen, Prozent Formel";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Prozent-Rechner", url: "/prozent-rechner" }]} />
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Alltag & Lifestyle', href: '/alltag-lifestyle' },
    { name: 'Prozent-Rechner' }
  ]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-blue-500 to-indigo-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-blue-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">%</span>
          <div>
            <h1 class="text-2xl font-bold">Prozent-Rechner</h1>
            <p class="text-blue-100 text-sm">Prozentwert, Prozentsatz & Veränderung berechnen</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <ProzentRechner client:load />
    </div>
<!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Prozentrechnung einfach erklärt</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem kostenlosen <strong>Prozent-Rechner</strong> berechnest du schnell und einfach 
            alles rund um <strong>Prozente</strong>: Prozentwert, Prozentsatz und prozentuale Veränderung. 
            Perfekt für Schule, Studium und Alltag!
          </p>
          
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <p class="text-sm text-blue-800 font-semibold mb-2">📐 Die 3 Berechnungsarten:</p>
            <ul class="space-y-1 text-sm text-blue-700">
              <li><strong>Prozentwert berechnen:</strong> Wie viel ist X% von Y?</li>
              <li><strong>Prozentsatz berechnen:</strong> X ist wieviel Prozent von Y?</li>
              <li><strong>Veränderung berechnen:</strong> Um wieviel % hat sich etwas verändert?</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was ist Prozent?</h3>
          <p>
            Das Wort <strong>Prozent</strong> kommt vom lateinischen "pro centum" und bedeutet "von hundert". 
            1 Prozent (1%) bedeutet also 1 von 100 oder der hundertste Teil von etwas.
          </p>
          <div class="bg-gray-50 p-4 rounded-lg my-4 font-mono text-sm">
            <p><strong>1% = 1/100 = 0,01</strong></p>
            <p><strong>50% = 50/100 = 0,5 = die Hälfte</strong></p>
            <p><strong>100% = 100/100 = 1 = das Ganze</strong></p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wie berechnet man Prozent?</h3>
          <p>
            Die <strong>Prozentrechnung</strong> basiert auf drei Grundwerten, von denen immer zwei bekannt sein müssen:
          </p>
          
          <h4 class="font-semibold text-gray-700 mt-4">1. Prozentwert berechnen (W)</h4>
          <div class="bg-blue-50 p-4 rounded-lg my-2">
            <code class="text-blue-800">Prozentwert = Grundwert × (Prozentsatz ÷ 100)</code>
            <p class="text-sm text-blue-700 mt-2"><strong>Beispiel:</strong> 15% von 200€ = 200 × 0,15 = 30€</p>
          </div>
          
          <h4 class="font-semibold text-gray-700 mt-4">2. Prozentsatz berechnen (p)</h4>
          <div class="bg-green-50 p-4 rounded-lg my-2">
            <code class="text-green-800">Prozentsatz = (Prozentwert ÷ Grundwert) × 100</code>
            <p class="text-sm text-green-700 mt-2"><strong>Beispiel:</strong> 30 ist wieviel % von 200? = (30 ÷ 200) × 100 = 15%</p>
          </div>
          
          <h4 class="font-semibold text-gray-700 mt-4">3. Grundwert berechnen (G)</h4>
          <div class="bg-yellow-50 p-4 rounded-lg my-2">
            <code class="text-yellow-800">Grundwert = Prozentwert × (100 ÷ Prozentsatz)</code>
            <p class="text-sm text-yellow-700 mt-2"><strong>Beispiel:</strong> 30 sind 15% von was? = 30 × (100 ÷ 15) = 200</p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was ist der Grundwert?</h3>
          <p>
            Der <strong>Grundwert</strong> ist die Ausgangsgröße, von der aus gerechnet wird. Er entspricht 
            immer 100%. In der Schule wird er oft mit "G" abgekürzt.
          </p>
          <div class="bg-gray-50 p-4 rounded-lg my-4">
            <p class="text-sm"><strong>Beispiele für Grundwerte:</strong></p>
            <ul class="text-sm mt-2 space-y-1">
              <li>• Ursprünglicher Preis bei Rabatten</li>
              <li>• Gesamtzahl der Schüler in einer Klasse</li>
              <li>• Anfangswert bei Zinsberechnungen</li>
              <li>• Maximale Punktzahl bei Tests</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Prozentuale Veränderung berechnen</h3>
          <p>
            Die <strong>prozentuale Veränderung</strong> (auch: prozentuale Zu- oder Abnahme) zeigt, um wieviel 
            Prozent sich ein Wert verändert hat:
          </p>
          <div class="bg-purple-50 p-4 rounded-lg my-4">
            <code class="text-purple-800">Veränderung in % = ((Neuer Wert - Alter Wert) ÷ Alter Wert) × 100</code>
            <p class="text-sm text-purple-700 mt-2">
              <strong>Beispiel:</strong> Miete steigt von 800€ auf 850€<br/>
              = ((850 - 800) ÷ 800) × 100 = 6,25% Erhöhung
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Prozent im Alltag</h3>
          <p>
            <strong>Prozentrechnung</strong> begegnet uns täglich:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Einkaufen:</strong> Rabatte (20% Nachlass), Mehrwertsteuer (19%)</li>
            <li><strong>Finanzen:</strong> Zinsen, Renditen, Inflation</li>
            <li><strong>Schule:</strong> Noten, Testergebnisse</li>
            <li><strong>Statistik:</strong> Umfragen, Wahlergebnisse</li>
            <li><strong>Gesundheit:</strong> Fettgehalt, Alkoholgehalt</li>
            <li><strong>Technik:</strong> Akkustand, Ladebalken</li>
          </ul>
          
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <p class="text-sm text-blue-800">
              <strong>💡 Tipp:</strong> Beim Kopfrechnen hilft es, 10% als Basis zu nehmen 
              (einfach Komma verschieben) und dann zu addieren oder zu halbieren.
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Prozent vs. Prozentpunkte</h3>
          <p>
            Ein häufiger Fehler: <strong>Prozent</strong> und <strong>Prozentpunkte</strong> sind nicht dasselbe!
          </p>
          <div class="bg-yellow-50 p-4 rounded-lg my-4">
            <p class="text-sm text-yellow-800">
              <strong>Beispiel:</strong> Ein Steuersatz steigt von 20% auf 25%.<br/>
              ✅ Das sind <strong>5 Prozentpunkte</strong> mehr.<br/>
              ✅ Das ist aber eine <strong>25% Erhöhung</strong> (5 ÷ 20 × 100)!
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Prozent zu Dezimalzahl umrechnen</h3>
          <div class="bg-gray-50 p-4 rounded-lg my-4">
            <p class="text-sm"><strong>Prozent → Dezimalzahl:</strong> Durch 100 teilen</p>
            <p class="text-sm">25% = 25 ÷ 100 = 0,25</p>
            <p class="text-sm mt-3"><strong>Dezimalzahl → Prozent:</strong> Mit 100 multiplizieren</p>
            <p class="text-sm">0,25 = 0,25 × 100 = 25%</p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Wann brauchst du den Prozent-Rechner? -->
    <div class="max-w-3xl mx-auto px-4 mt-8">
      <div class="prose prose-lg max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold mt-12 mb-6 text-gray-900">Wann brauchst du den Prozent-Rechner?</h2>
        <p class="text-gray-700">
          Prozentrechnung ist eines der wenigen Mathe-Themen, das du wirklich jeden Tag brauchst — und trotzdem rutscht der Kopf bei genau der falschen Stelle ab. Klassisches Beispiel: Du willst aus einer Brutto-Rechnung von 119 € die <strong>Mehrwertsteuer herausrechnen</strong>, tippst aber „minus 19 %" in den Taschenrechner und liegst um knapp einen Euro daneben. Genau dafür gibt es diesen Rechner.
        </p>
        <p class="text-gray-700">
          Typische Situationen, in denen du den Rechner aufrufst: <strong>Rabatt auf einen Listenpreis</strong> berechnen („20 % auf 250 € — was zahle ich am Ende?"), <strong>Trinkgeld-Anteil</strong> ermitteln (10 % Trinkgeld auf 47,50 € sind keine 5 €), eine <strong>Lohnerhöhung in Prozent vs. Euro</strong> vergleichen (sind 150 € mehr Brutto eigentlich viel oder wenig?), eine <strong>Aktien-Performance</strong> über mehrere Monate auswerten oder die <strong>prozentuale Veränderung</strong> einer Miete, eines Strompreises oder einer Versicherungsprämie über die Jahre ausrechnen. Auch im Schul- und Studiums-Alltag landet man hier: Notenpunkte aus erreichten Punkten in Prozent umrechnen, Skonto bei einer Eingangsrechnung korrekt abziehen, Wahlergebnisse in Prozentpunkten interpretieren.
        </p>

        <h2 class="text-2xl font-bold mt-12 mb-6 text-gray-900">Beispiele aus der Praxis</h2>

        <h3 class="text-xl font-semibold mt-8 mb-3 text-gray-900">Beispiel 1: 19 % Mehrwertsteuer aus einem Bruttobetrag herausrechnen</h3>
        <p class="text-gray-700">
          Auf der Rechnung stehen 119 € brutto und du brauchst Netto und MwSt-Anteil getrennt für die Buchhaltung. Wichtig: Du teilst <em>nicht</em> einfach durch 1,19 im Kopf und subtrahierst — du arbeitest mit dem korrekten Faktor.
        </p>
        <div class="bg-blue-50 p-4 rounded-lg my-4 text-sm text-gray-800">
          <p>Brutto: <strong>119,00 €</strong></p>
          <p>Netto = 119 ÷ 1,19 = <strong>100,00 €</strong></p>
          <p>MwSt = 119 − 100 = <strong>19,00 €</strong></p>
          <p class="text-gray-600 mt-2">Häufiger Fehler: 119 × 0,19 = 22,61 € — das wäre 19 % vom <em>Brutto</em>, nicht vom Netto. Immer durch 1,19 teilen, nicht „minus 19 %" rechnen.</p>
        </div>

        <h3 class="text-xl font-semibold mt-8 mb-3 text-gray-900">Beispiel 2: 20 % Rabatt auf 250 €</h3>
        <p class="text-gray-700">
          Im Online-Shop steht eine Jacke für 250 €, im Warenkorb wird ein 20 %-Gutschein eingelöst. Was zahlst du am Ende — und wie viel sparst du wirklich?
        </p>
        <div class="bg-blue-50 p-4 rounded-lg my-4 text-sm text-gray-800">
          <p>Listenpreis: <strong>250,00 €</strong></p>
          <p>Ersparnis: 250 × 0,20 = <strong>50,00 €</strong></p>
          <p>Endpreis: 250 − 50 = <strong>200,00 €</strong></p>
          <p>Schneller Weg: 250 × 0,80 = 200 € (du zahlst 80 % des Listenpreises).</p>
        </div>

        <h3 class="text-xl font-semibold mt-8 mb-3 text-gray-900">Beispiel 3: Lohnerhöhung von 3.200 € auf 3.350 € — wie viel Prozent?</h3>
        <p class="text-gray-700">
          Du bekommst nach einem Mitarbeitergespräch 150 € mehr Brutto pro Monat. Klingt fair — aber wie viel ist das eigentlich in Prozent, gemessen an der Inflation?
        </p>
        <div class="bg-blue-50 p-4 rounded-lg my-4 text-sm text-gray-800">
          <p>Alter Wert: <strong>3.200 €</strong>, neuer Wert: <strong>3.350 €</strong></p>
          <p>Differenz: 3.350 − 3.200 = <strong>150 €</strong></p>
          <p>Veränderung in %: (150 ÷ 3.200) × 100 = <strong>4,69 %</strong></p>
          <p class="text-gray-600 mt-2">Liegt die Inflation bei 3 %, ist das eine reale Erhöhung von ca. 1,7 %. Liegt sie bei 5 %, hast du real Kaufkraft verloren — trotz mehr Brutto.</p>
        </div>

        <h2 class="text-2xl font-bold mt-12 mb-6 text-gray-900">Häufige Fragen zur Prozentrechnung</h2>

        <details class="border border-gray-200 rounded-lg p-4 my-3 bg-white">
          <summary class="font-semibold cursor-pointer text-gray-900">Wie rechnet man Prozent im Kopf?</summary>
          <div class="mt-3 text-gray-700">
            <p>Der schnellste Trick: Erst <strong>10 %</strong> berechnen (Komma eine Stelle nach links verschieben), dann zusammensetzen. Beispiel: 15 % von 240 € — 10 % sind 24 €, 5 % sind die Hälfte davon (12 €), zusammen also 36 €. Für 25 % einfach durch 4 teilen, für 50 % halbieren, für 75 % halbieren plus die Hälfte addieren. Mit ein bisschen Übung bist du in 90 % der Alltagsfälle ohne Taschenrechner schneller als mit.</p>
          </div>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 my-3 bg-white">
          <summary class="font-semibold cursor-pointer text-gray-900">Was ist der Unterschied zwischen Prozent und Prozentpunkten?</summary>
          <div class="mt-3 text-gray-700">
            <p><strong>Prozentpunkte</strong> sind die <em>absolute</em> Differenz zwischen zwei Prozentwerten. <strong>Prozent</strong> beschreibt eine <em>relative</em> Veränderung. Steigt ein Steuersatz von 20 % auf 25 %, sind das +5 Prozentpunkte — aber relativ eine Steigerung um 25 % (5 ÷ 20). In Wahlergebnissen, Zinsen und Statistik ist die Unterscheidung kein Detail, sondern entscheidend: „Die SPD hat 5 % verloren" und „die SPD hat 5 Prozentpunkte verloren" sind zwei völlig verschiedene Aussagen.</p>
          </div>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 my-3 bg-white">
          <summary class="font-semibold cursor-pointer text-gray-900">Wie berechne ich eine prozentuale Veränderung mit Vorzeichen?</summary>
          <div class="mt-3 text-gray-700">
            <p>Formel: ((neuer Wert − alter Wert) ÷ alter Wert) × 100. Wichtig ist der Bezugspunkt — immer der <em>alte</em> Wert im Nenner. Beispiel Aktie: Kurs steigt von 80 € auf 100 € → +25 %. Fällt der Kurs danach wieder auf 80 €, sind das aber <em>−20 %</em>, nicht −25 %. Der Bezugspunkt ist jetzt 100 €. Deshalb gleichen sich „+50 % und dann −50 %" auch nie aus: Aus 100 wird 150, dann 75. Ein häufiger Stolperstein bei Performance-Auswertungen.</p>
          </div>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 my-3 bg-white">
          <summary class="font-semibold cursor-pointer text-gray-900">Warum stimmt mein MwSt-Wert nicht beim Rückrechnen aus dem Brutto?</summary>
          <div class="mt-3 text-gray-700">
            <p>Der häufigste Fehler: 19 % vom Bruttobetrag abziehen statt durch 1,19 zu teilen. 119 € × 0,19 = 22,61 € — falsch. Richtig: 119 ÷ 1,19 = 100 € Netto, davon 19 % MwSt = 19 €. Die MwSt rechnet sich immer auf den <strong>Netto</strong>betrag, nicht auf das Brutto. Bei 7 % (ermäßigter Satz) entsprechend durch 1,07 teilen. Unser <a href="/mehrwertsteuer-rechner" class="text-blue-600 underline">Mehrwertsteuer-Rechner</a> macht beide Richtungen automatisch.</p>
          </div>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 my-3 bg-white">
          <summary class="font-semibold cursor-pointer text-gray-900">Wie ziehe ich einen Skonto-Prozentsatz korrekt ab?</summary>
          <div class="mt-3 text-gray-700">
            <p>Skonto wird <em>vom Bruttobetrag</em> der Rechnung abgezogen, bevor du überweist. Steht auf der Rechnung „2 % Skonto bei Zahlung innerhalb 10 Tagen" und der Betrag ist 1.190 € brutto, ziehst du 1.190 × 0,02 = 23,80 € ab und überweist 1.166,20 €. Achtung: Auf der buchhalterischen Seite reduziert Skonto sowohl den Netto- als auch den Vorsteuerbetrag anteilig — wichtig für die korrekte Verbuchung. Die Frist (oft 7, 10 oder 14 Tage) zählt ab Rechnungsdatum, nicht ab Erhalt.</p>
          </div>
        </details>

        <h2 class="text-2xl font-bold mt-12 mb-6 text-gray-900">Methodik & Quellen</h2>
        <p class="text-gray-700">
          Der Prozent-Rechner basiert auf den Standardformeln der Schulmathematik (Klasse 5–7) — kein Behördenrahmen nötig, weil Prozentrechnung mathematisch eindeutig definiert ist. Die im Rechner verwendeten <strong>Mehrwertsteuersätze</strong> (19 % Regelsteuersatz, 7 % ermäßigter Steuersatz) folgen <strong>§ 12 UStG</strong> (Umsatzsteuergesetz). Der <strong>Skonto-Begriff</strong> ist im deutschen Handelsrecht (HGB) und in der kaufmännischen Praxis fest verankert. Alle Berechnungen werden vollständig im Browser ausgeführt — es werden keine Eingaben übertragen oder gespeichert. Zuletzt aktualisiert: April 2026.
        </p>
      </div>
    </div>

    <!-- Trust-Block -->
    <div class="max-w-3xl mx-auto px-4">
      <RechnerTrust quellen="§12 UStG (Mehrwertsteuersätze), Standard-Schulmathematik" aktualisiert="April 2026" />
    </div>

    <!-- Verwandte Rechner -->
    <div class="max-w-7xl mx-auto px-4">
      <VerwandteRechner aktuellerSlug="prozent" slugs={['rabatt', 'mehrwertsteuer', 'dreisatz', 'bruch']} kategorie="alltag" />
    </div>
    
    <!-- Weitere Tipps -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🎓</span>
          Für Schüler: Merkhilfen
        </h2>
        
        <div class="space-y-4 text-sm text-gray-600">
          <div class="p-4 bg-blue-50 rounded-lg">
            <h3 class="font-semibold text-blue-800 mb-2">Das Dreisatz-Verfahren</h3>
            <p class="text-blue-700">
              Prozentrechnung lässt sich auch mit dem Dreisatz lösen:<br/>
              100% entsprechen dem Grundwert<br/>
              1% entspricht dem Grundwert ÷ 100<br/>
              p% entsprechen dem Grundwert ÷ 100 × p
            </p>
          </div>
          
          <div class="p-4 bg-green-50 rounded-lg">
            <h3 class="font-semibold text-green-800 mb-2">Die Prozent-Pyramide</h3>
            <p class="text-green-700">
              <strong>G</strong> = Grundwert (oben)<br/>
              <strong>p</strong> = Prozentsatz (links unten)<br/>
              <strong>W</strong> = Prozentwert (rechts unten)<br/>
              <br/>
              Formel: G × p = W × 100
            </p>
          </div>
          
          <div class="p-4 bg-yellow-50 rounded-lg">
            <h3 class="font-semibold text-yellow-800 mb-2">Eselsbrücke: "Pro Cent"</h3>
            <p class="text-yellow-700">
              "Pro Cent" = "von Hundert"<br/>
              Also immer an 100 denken!<br/>
              50% = 50 von 100 = die Hälfte
            </p>
          </div>
        </div>
      </div>
    </div>
</main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
