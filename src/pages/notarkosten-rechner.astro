---
import Layout from '../layouts/Layout.astro';
import NotarkostenRechner from '../components/rechner/NotarkostenRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Notarkosten-Rechner 2026 – Gebühren nach GNotKG berechnen";
const description = "Notarkosten-Rechner 2026: Berechnen Sie Notargebühren & Grundbuchkosten für Ihren Immobilienkauf nach GNotKG. Mit detaillierter Aufstellung & Grundschuld.";
const keywords = "Notarkosten Rechner, Notargebühren berechnen, Notarkosten Hauskauf, GNotKG, Grundbuchkosten, Notarkosten Immobilienkauf, Notarkosten 2025, Notarkosten 2026, Notar Gebühren, Notarkosten Grundschuld, Notarkosten Wohnungskauf, Beurkundung Kosten, Tabelle B";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Notarkosten-Rechner", url: "/notarkosten-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-purple-500 to-indigo-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-purple-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">📝</span>
          <div>
            <h1 class="text-2xl font-bold">Notarkosten-Rechner</h1>
            <p class="text-purple-100 text-sm">Notar- & Grundbuchkosten nach GNotKG berechnen</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <NotarkostenRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Notarkosten 2026: So berechnen sich Notar- und Grundbuchgebühren</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem <strong>Notarkosten-Rechner</strong> berechnen Sie schnell und kostenlos die Gebühren für 
            Notar und Grundbuchamt bei Ihrem Immobilienkauf. Die Kosten basieren auf dem 
            <strong>Gerichts- und Notarkostengesetz (GNotKG)</strong> und sind bundesweit einheitlich geregelt.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wie werden Notarkosten berechnet?</h3>
          <p>
            Die Notargebühren richten sich nach dem <strong>Geschäftswert</strong> (beim Immobilienkauf der Kaufpreis) 
            und werden nach <strong>Tabelle B des GNotKG</strong> berechnet:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Beurkundung Kaufvertrag:</strong> 2,0-fache Gebühr</li>
            <li><strong>Vollzugstätigkeit:</strong> 0,5-fache Gebühr (z.B. Fälligkeitsmitteilung)</li>
            <li><strong>Betreuungstätigkeit:</strong> 0,5-fache Gebühr</li>
            <li><strong>Grundschuldbestellung:</strong> 1,0-fache Gebühr (bei Finanzierung)</li>
            <li>Zusätzlich: <strong>19% MwSt</strong> auf Notarkosten + Auslagen</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Grundbuchkosten – Staatliche Gebühren</h3>
          <p>
            Die <strong>Grundbuchkosten</strong> werden vom Amtsgericht erhoben und sind nicht MwSt-pflichtig:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Eigentumsumschreibung:</strong> 1,0-fache Gebühr auf Kaufpreis</li>
            <li><strong>Auflassungsvormerkung:</strong> 0,5-fache Gebühr auf Kaufpreis</li>
            <li><strong>Grundschuldeintragung:</strong> 1,0-fache Gebühr auf Grundschuldbetrag</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Beispielrechnung: Notarkosten bei 350.000 € Kaufpreis</h3>
          <p>
            Bei einem <strong>Hauskauf für 350.000 €</strong> mit <strong>280.000 € Grundschuld</strong> fallen 
            ca. <strong>4.500–5.000 €</strong> an Notar- und Grundbuchkosten an:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Notarkosten (brutto): ca. 2.700–2.900 €</li>
            <li>Grundbuchkosten: ca. 1.700–1.900 €</li>
            <li>Das entspricht etwa <strong>1,3–1,5% des Kaufpreises</strong></li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Warum sind Notarkosten überall gleich?</h3>
          <p>
            Anders als bei Maklern oder Handwerkern können <strong>Notarkosten nicht verhandelt werden</strong>. 
            Das GNotKG schreibt die Gebühren verbindlich vor. Dies hat Vorteile:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Transparenz:</strong> Keine versteckten Kosten oder Preisunterschiede</li>
            <li><strong>Unabhängigkeit:</strong> Der Notar arbeitet neutral für beide Parteien</li>
            <li><strong>Planbarkeit:</strong> Die Kosten lassen sich vorab exakt berechnen</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wer zahlt die Notarkosten beim Hauskauf?</h3>
          <p>
            In Deutschland trägt <strong>üblicherweise der Käufer</strong> die Notar- und Grundbuchkosten. 
            Dies ist jedoch nicht gesetzlich vorgeschrieben und kann im Kaufvertrag anders geregelt werden.
          </p>
          <p>
            <strong>Ausnahme:</strong> Kosten für die Löschung von Belastungen (z.B. alte Grundschuld des Verkäufers) 
            trägt meist der Verkäufer.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Notarkosten steuerlich absetzen?</h3>
          <p>
            Bei <strong>privat genutzten Immobilien</strong> sind Notarkosten <strong>nicht steuerlich absetzbar</strong>. 
            Ausnahmen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Vermietete Immobilien:</strong> Notarkosten können als Anschaffungsnebenkosten 
                über die Nutzungsdauer abgeschrieben werden</li>
            <li><strong>Grundschuld für Mietobjekt:</strong> Notarkosten für die Finanzierung können 
                als Werbungskosten absetzbar sein</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Zusätzliche Kaufnebenkosten beachten</h3>
          <p>
            Die Notarkosten sind nur ein Teil der <strong>Kaufnebenkosten</strong>. Planen Sie zusätzlich ein:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Grunderwerbsteuer:</strong> 3,5–6,5% je nach Bundesland</li>
            <li><strong>Maklerkosten:</strong> 3,57–7,14% (falls Makler beteiligt)</li>
            <li><strong>Notar + Grundbuch:</strong> ca. 1,5–2%</li>
            <li><strong>Gesamt:</strong> Rechnen Sie mit <strong>10–15%</strong> Nebenkosten</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Weitere Rechner für Immobilienkäufer</h3>
          <p>
            Nutzen Sie auch unsere anderen Rechner für Ihren Immobilienkauf:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><a href="/grunderwerbsteuer-rechner" class="text-purple-600 hover:underline">Grunderwerbsteuer-Rechner</a> – Steuer nach Bundesland</li>
            <li><a href="/kaufnebenkosten-rechner" class="text-purple-600 hover:underline">Kaufnebenkosten-Rechner</a> – Alle Nebenkosten im Überblick</li>
            <li><a href="/kredit-rechner" class="text-purple-600 hover:underline">Kredit-Rechner</a> – Finanzierung berechnen</li>
            <li><a href="/grundsteuer-rechner" class="text-purple-600 hover:underline">Grundsteuer-Rechner</a> – Jährliche Grundsteuer</li>
          </ul>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/kaufnebenkosten-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏠</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kaufnebenkosten-Rechner</p>
          </a>
          <a href="/grunderwerbsteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏛️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Grunderwerbsteuer-Rechner</p>
          </a>
          <a href="/baufinanzierung-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏗️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Baufinanzierung-Rechner</p>
          </a>
          <a href="/maklerkosten-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🤝</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Maklerkosten-Rechner</p>
          </a>
          <a href="/grundsteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📋</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Grundsteuer-Rechner</p>
          </a>
          <a href="/eigenkapital-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Eigenkapital-Rechner</p>
          </a>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Notarkosten-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/notarkosten-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie hoch sind die Notarkosten beim Hauskauf?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Notarkosten beim Hauskauf betragen typischerweise 1,5-2% des Kaufpreises. Bei einem Kaufpreis von 350.000 € fallen etwa 4.500-5.000 € für Notar und Grundbuchamt an. Die genaue Höhe hängt vom Geschäftswert und der Grundschuldhöhe ab."
        }
      },
      {
        "@type": "Question",
        "name": "Kann man bei Notarkosten verhandeln?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nein, Notarkosten können nicht verhandelt werden. Die Gebühren sind im Gerichts- und Notarkostengesetz (GNotKG) bundesweit verbindlich festgelegt. Jeder Notar in Deutschland berechnet die gleichen Gebühren nach Tabelle B des GNotKG."
        }
      },
      {
        "@type": "Question",
        "name": "Wer zahlt die Notarkosten beim Immobilienkauf?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Beim Immobilienkauf trägt üblicherweise der Käufer die Notar- und Grundbuchkosten. Dies ist keine gesetzliche Pflicht, sondern eine Vereinbarung im Kaufvertrag. Kosten für die Löschung alter Belastungen trägt meist der Verkäufer."
        }
      },
      {
        "@type": "Question",
        "name": "Was sind Grundbuchkosten und wer erhebt sie?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Grundbuchkosten sind staatliche Gebühren, die vom Amtsgericht (Grundbuchamt) für Eintragungen im Grundbuch erhoben werden. Dazu gehören die Eigentumsumschreibung, die Auflassungsvormerkung und ggf. die Grundschuldeintragung. Sie sind nicht MwSt-pflichtig."
        }
      },
      {
        "@type": "Question",
        "name": "Sind Notarkosten steuerlich absetzbar?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bei privat genutzten Immobilien sind Notarkosten nicht steuerlich absetzbar. Bei vermieteten Immobilien können sie als Anschaffungsnebenkosten über die Abschreibung geltend gemacht werden. Notarkosten für die Finanzierung eines Mietobjekts können als Werbungskosten absetzbar sein."
        }
      },
      {
        "@type": "Question",
        "name": "Wie berechnet sich die Gebühr nach GNotKG Tabelle B?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Gebühr nach GNotKG Tabelle B basiert auf dem Geschäftswert und steigt degressiv. Beispiel: Bei 100.000 € Geschäftswert beträgt die einfache Gebühr 273 €, bei 500.000 € sind es 935 €. Für die Beurkundung eines Kaufvertrags wird die 2-fache Gebühr berechnet."
        }
      }
    ]
  })} />
</Layout>
