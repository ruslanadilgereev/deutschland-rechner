---
import Layout from '../layouts/Layout.astro';
import BuergergeldRechner from '../components/rechner/BuergergeldRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Bürgergeld-Rechner 2025 & 2026 – Regelsatz, Freibeträge & KdU";
const description = "Bürgergeld berechnen 2026: Regelsatz 563€ Alleinstehend, 506€ Partner. Rechner mit Freibeträgen, KdU & Mehrbedarf. Jetzt Anspruch kostenlos prüfen!";
const keywords = "Bürgergeld Rechner, Bürgergeld 2026, Bürgergeld Höhe, Regelsatz 2026, Bürgergeld berechnen, Bürgergeld Freibetrag, Kosten der Unterkunft, Bürgergeld beantragen, Jobcenter";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Bürgergeld-Rechner", url: "/buergergeld-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-green-500 to-teal-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-green-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🏦</span>
          <div>
            <h1 class="text-2xl font-bold">Bürgergeld-Rechner 2026</h1>
            <p class="text-green-100 text-sm">563€ Regelsatz – Jetzt Anspruch berechnen!</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <BuergergeldRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Bürgergeld 2026: Regelsätze, Voraussetzungen & Antrag</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Das <strong>Bürgergeld</strong> (ehemals Hartz IV) ist die Grundsicherung für Arbeitssuchende 
            in Deutschland. Mit unserem <strong>Bürgergeld-Rechner 2026</strong> berechnen Sie schnell 
            und kostenlos Ihren möglichen Anspruch.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Bürgergeld Regelsätze 2026</h3>
          <p>
            Die <strong>Regelsätze</strong> wurden zum 1. Januar 2026 angepasst:
          </p>
          <div class="bg-green-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>Alleinstehende/Alleinerziehende:</strong> 563€/Monat (Regelbedarfsstufe 1)</li>
              <li><strong>Paare je Partner:</strong> 506€/Monat (Regelbedarfsstufe 2)</li>
              <li><strong>Erwachsene unter 25 im Elternhaus:</strong> 451€/Monat (Regelbedarfsstufe 3)</li>
              <li><strong>Jugendliche 14-17 Jahre:</strong> 471€/Monat (Regelbedarfsstufe 4)</li>
              <li><strong>Kinder 6-13 Jahre:</strong> 390€/Monat (Regelbedarfsstufe 5)</li>
              <li><strong>Kinder 0-5 Jahre:</strong> 357€/Monat (Regelbedarfsstufe 6)</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wer hat Anspruch auf Bürgergeld?</h3>
          <p>
            <strong>Anspruchsvoraussetzungen</strong> für Bürgergeld:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Erwerbsfähigkeit (mindestens 3 Stunden täglich arbeitsfähig)</li>
            <li>Alter zwischen 15 Jahren und Rentenalter</li>
            <li>Hilfebedürftigkeit (Einkommen/Vermögen reicht nicht zum Leben)</li>
            <li>Gewöhnlicher Aufenthalt in Deutschland</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was umfasst das Bürgergeld?</h3>
          <p>
            Das Bürgergeld setzt sich aus mehreren Komponenten zusammen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Regelbedarf:</strong> Pauschale für Lebensunterhalt (Ernährung, Kleidung, Hygiene)</li>
            <li><strong>Kosten der Unterkunft (KdU):</strong> Miete und Heizkosten (tatsächliche, angemessene Kosten)</li>
            <li><strong>Mehrbedarf:</strong> Zusätzliche Leistungen bei Schwangerschaft, Alleinerziehung, Behinderung</li>
            <li><strong>Einmalleistungen:</strong> Erstausstattung Wohnung, Schwangerschaftskleidung, etc.</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Bürgergeld Freibeträge 2026</h3>
          <p>
            Bei Erwerbstätigkeit wird nicht das gesamte Einkommen angerechnet:
          </p>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>Grundfreibetrag:</strong> 100€ bleiben komplett anrechnungsfrei</li>
              <li><strong>100-520€:</strong> 20% Freibetrag</li>
              <li><strong>520-1.000€:</strong> 30% Freibetrag</li>
              <li><strong>1.000-1.200€:</strong> 10% Freibetrag (mit Kind bis 1.500€)</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Vermögensfreibeträge (Karenzzeit)</h3>
          <p>
            In den ersten 12 Monaten des Bürgergeld-Bezugs gilt eine <strong>Karenzzeit</strong> mit 
            höheren Freibeträgen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Karenzzeit (1. Jahr):</strong> 40.000€ pro Person + 15.000€ je weitere Person</li>
            <li><strong>Nach Karenzzeit:</strong> 15.000€ pro Person in der Bedarfsgemeinschaft</li>
            <li><strong>Selbstgenutztes Eigentum:</strong> Angemessene Größe wird nicht angerechnet</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Bürgergeld beantragen</h3>
          <p>
            Der Antrag auf Bürgergeld wird beim <strong>zuständigen Jobcenter</strong> gestellt. 
            Benötigte Unterlagen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Personalausweis/Reisepass</li>
            <li>Mietvertrag und Nebenkostenabrechnungen</li>
            <li>Einkommensnachweise (Lohnabrechnungen, Bescheide)</li>
            <li>Kontoauszüge der letzten 3 Monate</li>
            <li>Nachweise über Vermögen</li>
          </ul>
          
          <div class="bg-yellow-50 p-4 rounded-lg my-4">
            <p class="text-sm text-yellow-800">
              <strong>Wichtig:</strong> Die Bearbeitungszeit kann mehrere Wochen dauern. Bei dringendem 
              Bedarf können Sie einen Vorschuss beantragen.
            </p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/wohngeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏠</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Wohngeld-Rechner</p>
          </a>
          <a href="/arbeitslosengeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📋</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Arbeitslosengeld-Rechner</p>
          </a>
          <a href="/kinderzuschlag-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kinderzuschlag-Rechner</p>
          </a>
          <a href="/kindergeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">👶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kindergeld-Rechner</p>
          </a>
          <a href="/brutto-netto-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💵</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Brutto-Netto-Rechner</p>
          </a>
          <a href="/krankengeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏥</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Krankengeld-Rechner</p>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Zuständige Behörde -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🏛️</span>
          Zuständige Behörde
        </h2>
        
        <div class="p-4 bg-green-50 rounded-lg">
          <h3 class="font-semibold text-green-800 mb-2">Jobcenter</h3>
          <p class="text-green-700 text-sm mb-2">
            Das <strong>Jobcenter</strong> ist zuständig für alle Leistungen nach dem SGB II 
            (Bürgergeld). Finden Sie Ihr zuständiges Jobcenter über die Postleitzahl-Suche.
          </p>
          <p class="text-green-700 text-sm">
            <strong>Bürgertelefon:</strong> 0800 4 555500 (kostenlos)<br/>
            <strong>Online:</strong> www.jobcenter.digital
          </p>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Bürgergeld-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/buergergeld-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie hoch ist das Bürgergeld 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der Regelsatz für Alleinstehende beträgt 2026 563€ pro Monat. Paare erhalten je 506€, Jugendliche 14-17 Jahre 471€, Kinder 6-13 Jahre 390€ und Kinder 0-5 Jahre 357€. Hinzu kommen Kosten für Unterkunft und Heizung."
        }
      },
      {
        "@type": "Question",
        "name": "Wer bekommt Bürgergeld?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bürgergeld erhalten erwerbsfähige Personen zwischen 15 Jahren und Rentenalter, die ihren Lebensunterhalt nicht aus eigenem Einkommen oder Vermögen decken können und in Deutschland wohnen. Erwerbsfähig bedeutet mindestens 3 Stunden täglich arbeiten zu können."
        }
      },
      {
        "@type": "Question",
        "name": "Wie viel darf ich beim Bürgergeld hinzuverdienen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die ersten 100€ bleiben anrechnungsfrei. Von 100-520€ werden 20% nicht angerechnet, von 520-1000€ 30% und von 1000-1200€ (bzw. 1500€ mit Kind) weitere 10%. So bleibt ein Teil Ihres Verdienstes zusätzlich zum Bürgergeld."
        }
      },
      {
        "@type": "Question",
        "name": "Wie viel Vermögen darf ich beim Bürgergeld haben?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Im ersten Jahr (Karenzzeit) sind 40.000€ pro Person plus 15.000€ je weitere Person geschützt. Nach der Karenzzeit gilt ein Freibetrag von 15.000€ pro Person. Selbstgenutztes Wohneigentum in angemessener Größe wird nicht angerechnet."
        }
      },
      {
        "@type": "Question",
        "name": "Wo beantrage ich Bürgergeld?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bürgergeld wird beim zuständigen Jobcenter beantragt. Sie benötigen Personalausweis, Mietvertrag, Einkommensnachweise, Kontoauszüge und Vermögensnachweise. Das Bürgertelefon erreichen Sie unter 0800 4 555500."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist der Unterschied zwischen Bürgergeld und Hartz IV?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bürgergeld hat zum 1.1.2023 Hartz IV abgelöst. Die wichtigsten Änderungen: höhere Regelsätze, bessere Freibeträge bei Zuverdienst, Karenzzeit beim Vermögen und weniger Sanktionen. Das Ziel ist eine würdevollere Grundsicherung."
        }
      }
    ]
  })} />
</Layout>
