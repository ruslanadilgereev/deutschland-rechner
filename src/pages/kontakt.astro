---
import Layout from '../layouts/Layout.astro';

const title = "Kontakt";
const description = "Kontaktmöglichkeiten für Deutschlandrechner – per E-Mail, GitHub Issues oder Post.";
const githubBase = "https://github.com/ruslanadilgereev/deutschland-rechner";
---

<Layout title={title} description={description}>
  <main class="min-h-screen pb-8">
    <header class="bg-gradient-to-r from-blue-500 to-indigo-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-blue-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">✉️</span>
          <div>
            <h1 class="text-2xl font-bold">Kontakt</h1>
            <p class="text-blue-100 text-sm">So erreichst du uns</p>
          </div>
        </div>
      </div>
    </header>

    <div class="max-w-2xl mx-auto px-4 py-8 space-y-6">
      <!-- E-Mail -->
      <section class="bg-white rounded-2xl shadow-lg p-6">
        <div class="flex items-start gap-4">
          <span class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center text-2xl flex-shrink-0">📧</span>
          <div>
            <h2 class="text-lg font-bold text-gray-800 mb-2">Per E-Mail</h2>
            <p class="text-gray-600 mb-3">
              Für allgemeine Anfragen, rechtliche Hinweise, Datenschutz-Anliegen oder Presse:
            </p>
            <a
              href="mailto:kontakt@mahlzait.de"
              class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-xl text-sm font-semibold transition-colors"
            >
              kontakt@mahlzait.de
            </a>
          </div>
        </div>
      </section>

      <!-- GitHub Issues -->
      <section class="bg-white rounded-2xl shadow-lg p-6">
        <div class="flex items-start gap-4">
          <span class="w-12 h-12 rounded-xl bg-emerald-100 flex items-center justify-center text-2xl flex-shrink-0">🐛</span>
          <div>
            <h2 class="text-lg font-bold text-gray-800 mb-2">Fehler in einem Rechner?</h2>
            <p class="text-gray-600 mb-3">
              Wenn du einen Rechenfehler findest oder einen neuen Rechner vorschlagen möchtest,
              nutze bitte GitHub Issues. Das ist für uns am einfachsten zu tracken und für alle transparent.
            </p>
            <div class="flex flex-wrap gap-2">
              <a
                href={`${githubBase}/issues/new?template=rechner-fehler.yml`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-red-50 hover:bg-red-100 text-red-700 px-4 py-2 rounded-xl text-sm font-semibold transition-colors"
              >
                Fehler melden
              </a>
              <a
                href={`${githubBase}/issues/new?template=neuer-rechner.yml`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-blue-50 hover:bg-blue-100 text-blue-700 px-4 py-2 rounded-xl text-sm font-semibold transition-colors"
              >
                Rechner vorschlagen
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Postanschrift -->
      <section class="bg-white rounded-2xl shadow-lg p-6">
        <div class="flex items-start gap-4">
          <span class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center text-2xl flex-shrink-0">📬</span>
          <div>
            <h2 class="text-lg font-bold text-gray-800 mb-2">Postanschrift</h2>
            <address class="not-italic text-gray-700 leading-relaxed">
              Ruslan Adilgereev<br />
              Am Tierpark 62<br />
              10319 Berlin<br />
              Deutschland
            </address>
          </div>
        </div>
      </section>

      <!-- Verweis Impressum -->
      <section class="bg-gray-50 border border-gray-200 rounded-2xl p-6">
        <p class="text-gray-600 text-sm">
          Vollständige Anbieterkennzeichnung findest du im
          <a href="/impressum" class="text-blue-600 font-semibold hover:underline">Impressum</a>.
          Informationen zur Verarbeitung deiner Daten in der
          <a href="/datenschutz" class="text-blue-600 font-semibold hover:underline">Datenschutzerklärung</a>.
        </p>
      </section>
    </div>
  </main>
</Layout>
