---
import Layout from '../layouts/Layout.astro';
import KinderzuschlagRechner from '../components/rechner/KinderzuschlagRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Kinderzuschlag-Rechner 2025 & 2026 – Bis zu 297€ pro Kind";
const description = "Kinderzuschlag berechnen 2026: Bis zu 297€ pro Kind prüfen. Mit Einkommens- & Bedarfsprüfung, Wohngeld-Kombi. Jetzt KiZ-Anspruch kostenlos berechnen!";
const keywords = "Kinderzuschlag Rechner, KiZ Rechner, Kinderzuschlag berechnen, Kinderzuschlag 2026, Kinderzuschlag Höhe, Kinderzuschlag Antrag, Kinderzuschlag Anspruch";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Kinderzuschlag-Rechner", url: "/kinderzuschlag-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-green-500 to-emerald-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-green-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">💶</span>
          <div>
            <h1 class="text-2xl font-bold">Kinderzuschlag-Rechner</h1>
            <p class="text-green-100 text-sm">Bis zu 297 € pro Kind – Stand 2026</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <KinderzuschlagRechner client:load />
    </div>

    <!-- SEO Content -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <section class="bg-white rounded-2xl shadow-lg p-6 mb-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Was ist der Kinderzuschlag (KiZ)?</h2>
        <p class="text-gray-600 mb-4">
          Der <strong>Kinderzuschlag</strong> ist eine zusätzliche Familienleistung für erwerbstätige Eltern, 
          deren Einkommen zwar für den eigenen Lebensunterhalt reicht, aber nicht für den der Kinder. 
          Mit dem KiZ soll verhindert werden, dass Familien auf Bürgergeld angewiesen sind.
        </p>
        <p class="text-gray-600">
          2026 beträgt der <strong>maximale Kinderzuschlag 297 € pro Kind und Monat</strong>. 
          In Kombination mit Kindergeld (259 €) erhalten Familien so bis zu <strong>556 € pro Kind</strong>.
        </p>
      </section>

      <section class="bg-white rounded-2xl shadow-lg p-6 mb-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Wer hat Anspruch auf Kinderzuschlag?</h2>
        <ul class="space-y-2 text-gray-600">
          <li class="flex gap-2">
            <span class="text-green-500">✓</span>
            <span>Eltern mit Kindern unter 25 Jahren im Haushalt</span>
          </li>
          <li class="flex gap-2">
            <span class="text-green-500">✓</span>
            <span>Mindestbruttoeinkommen: 900 € (Paare) bzw. 600 € (Alleinerziehende)</span>
          </li>
          <li class="flex gap-2">
            <span class="text-green-500">✓</span>
            <span>Mit KiZ + Wohngeld muss der Bedarf gedeckt werden können</span>
          </li>
          <li class="flex gap-2">
            <span class="text-green-500">✓</span>
            <span>Kein Anspruch auf Bürgergeld oder SGB II-Leistungen</span>
          </li>
        </ul>
      </section>

      <section class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Häufig gestellte Fragen</h2>
        <div class="space-y-4">
          <div>
            <h3 class="font-semibold text-gray-800">Wie hoch ist der Kinderzuschlag 2026?</h3>
            <p class="text-gray-600 text-sm">Der maximale Kinderzuschlag beträgt 297 € pro Kind und Monat (seit 01.01.2025). Der tatsächliche Betrag hängt vom Einkommen ab.</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-800">Wird der Kinderzuschlag auf Bürgergeld angerechnet?</h3>
            <p class="text-gray-600 text-sm">Wer Kinderzuschlag erhält, bekommt kein Bürgergeld. Der KiZ ist eine Alternative zum Bürgergeld für erwerbstätige Familien.</p>
          </div>
          <div>
            <h3 class="font-semibold text-gray-800">Kann ich Kinderzuschlag und Wohngeld gleichzeitig bekommen?</h3>
            <p class="text-gray-600 text-sm">Ja! Die Kombination aus Kinderzuschlag und Wohngeld ist ausdrücklich vorgesehen und oft die optimale Lösung.</p>
          </div>
        </div>
      </section>
    </div>
  </main>

    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/kindergeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">👶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kindergeld-Rechner</p>
          </a>
          <a href="/wohngeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏠</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Wohngeld-Rechner</p>
          </a>
          <a href="/buergergeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏦</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Bürgergeld-Rechner</p>
          </a>
          <a href="/elterngeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🍼</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Elterngeld-Rechner</p>
          </a>
          <a href="/unterhalt-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Unterhalt-Rechner</p>
          </a>
          <a href="/brutto-netto-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Brutto-Netto-Rechner</p>
          </a>
        </div>
      </div>
    </div>

  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Kinderzuschlag-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/kinderzuschlag-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie hoch ist der Kinderzuschlag 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der maximale Kinderzuschlag beträgt 297€ pro Kind und Monat (seit 01.01.2025, unverändert in 2026). Der tatsächliche Betrag hängt vom Einkommen und den Wohnkosten ab."
        }
      },
      {
        "@type": "Question",
        "name": "Wer hat Anspruch auf Kinderzuschlag?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Anspruch haben erwerbstätige Eltern mit Kindern unter 25 im Haushalt, die mindestens 600€ (Alleinerziehende) bzw. 900€ (Paare) brutto verdienen. Mit KiZ + Wohngeld muss der Bedarf gedeckt werden können."
        }
      },
      {
        "@type": "Question",
        "name": "Kann man Kinderzuschlag und Wohngeld gleichzeitig bekommen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja! Die Kombination aus Kinderzuschlag und Wohngeld ist ausdrücklich vorgesehen und in den meisten Fällen die optimale Lösung, um Bürgergeld zu vermeiden – ohne Vermögensprüfung."
        }
      },
      {
        "@type": "Question",
        "name": "Wird der Kinderzuschlag auf Bürgergeld angerechnet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Wer Kinderzuschlag erhält, bekommt kein Bürgergeld. Der KiZ ist eine Alternative zum Bürgergeld für erwerbstätige Familien und schließt den Bezug von SGB II-Leistungen aus."
        }
      }
    ]
  })} />
</Layout>
