---
import Layout from '../layouts/Layout.astro';
import SpritkostenRechner from '../components/rechner/SpritkostenRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Spritkosten-Rechner – Benzinkosten berechnen";
const description = "Spritkosten-Rechner 2026: Benzin- & Dieselkosten für jede Fahrt berechnen. Mit CO₂-Berechnung & Bahn-Vergleich. Kostenlos!";
const keywords = "Spritkosten Rechner, Benzinkosten berechnen, Spritrechner, Fahrtkosten Rechner, Benzin Rechner, Diesel Kosten, Spritverbrauch berechnen, Tankkosten Rechner, Kraftstoffkosten, Auto Fahrt Kosten, Sprit Kosten pro km, Fahrtkosten Auto, Spritgeld berechnen, Benzinpreis Rechner, Dieselpreis Rechner";
import RechnerFeedback from '../components/RechnerFeedback.astro';
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Spritkosten-Rechner", url: "/spritkosten-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-green-500 to-emerald-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-green-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">⛽</span>
          <div>
            <h1 class="text-2xl font-bold">Spritkosten-Rechner</h1>
            <p class="text-green-100 text-sm">Benzin- & Dieselkosten berechnen 2026</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <SpritkostenRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Spritkosten-Rechner: Benzinkosten einfach berechnen</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem <strong>Spritkosten-Rechner</strong> berechnen Sie schnell und einfach, wie viel Benzin oder 
            Diesel Ihre Fahrt kostet. Egal ob Wochenendtrip, Pendeln zur Arbeit oder Urlaubsreise – 
            Sie erfahren sofort die <strong>genauen Kraftstoffkosten</strong> und können mit Bahn oder Fernbus vergleichen.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">So berechnen Sie Ihre Spritkosten</h3>
          <p>
            Die Formel für die Berechnung der Spritkosten ist einfach:
          </p>
          <div class="bg-green-50 p-4 rounded-xl my-4">
            <p class="font-mono text-center text-green-800 font-bold">
              (Strecke in km ÷ 100) × Verbrauch in l/100km × Spritpreis in €/l = Kosten
            </p>
          </div>
          
          <h4 class="font-semibold text-gray-800">Beispielrechnung:</h4>
          <ul class="list-disc pl-5 space-y-1">
            <li>Strecke: <strong>500 km</strong></li>
            <li>Verbrauch: <strong>7 Liter/100km</strong></li>
            <li>Spritpreis: <strong>1,70 €/Liter</strong></li>
            <li>Rechnung: 500 ÷ 100 × 7 × 1,70 = <strong>59,50 €</strong></li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Aktuelle Spritpreise 2026</h3>
          <p>
            Die Kraftstoffpreise in Deutschland schwanken täglich. Hier die aktuellen Durchschnittswerte:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Super E10 (Benzin):</strong> ca. 1,65-1,75 €/Liter</li>
            <li><strong>Super E5 / Super Plus:</strong> ca. 1,75-1,90 €/Liter</li>
            <li><strong>Diesel:</strong> ca. 1,55-1,65 €/Liter</li>
            <li><strong>Autogas (LPG):</strong> ca. 0,70-0,80 €/Liter</li>
          </ul>
          <p>
            <strong>Tipp:</strong> Tanken Sie möglichst abends zwischen 18 und 20 Uhr – 
            dann sind die Preise oft 5-10 Cent günstiger als morgens!
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Durchschnittsverbrauch nach Fahrzeugtyp</h3>
          <p>
            Der tatsächliche Verbrauch hängt von Fahrzeug, Fahrweise und Strecke ab:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Kleinwagen</strong> (z.B. VW Polo, Opel Corsa): 5-6 l/100km</li>
            <li><strong>Kompaktklasse</strong> (z.B. VW Golf, Opel Astra): 6-7 l/100km</li>
            <li><strong>Mittelklasse</strong> (z.B. VW Passat, BMW 3er): 7-8 l/100km</li>
            <li><strong>SUV / Oberklasse</strong> (z.B. BMW X3, Mercedes E-Klasse): 8-10 l/100km</li>
            <li><strong>Sportwagen</strong>: 10-15 l/100km</li>
          </ul>
          <p>
            <strong>Hinweis:</strong> Diesel-Fahrzeuge verbrauchen typischerweise 15-20% weniger als 
            vergleichbare Benziner.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">CO₂-Steuer auf Kraftstoff 2026</h3>
          <p>
            Seit 2021 wird in Deutschland eine <strong>CO₂-Steuer</strong> auf fossile Brennstoffe erhoben. 
            Diese ist bereits im Spritpreis enthalten:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>2021: 25 €/Tonne → ca. 7 Cent/Liter Benzin</li>
            <li>2022: 30 €/Tonne → ca. 8 Cent/Liter</li>
            <li>2024: 45 €/Tonne → ca. 12 Cent/Liter</li>
            <li><strong>2025: 55 €/Tonne → ca. 15 Cent/Liter</strong></li>
            <li><strong>2026: 65 €/Tonne → ca. 17 Cent/Liter</strong></li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Auto vs. Bahn: Was ist günstiger?</h3>
          <p>
            Ob Auto oder Bahn günstiger ist, hängt vor allem von der <strong>Anzahl der Mitfahrer</strong> ab:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>1 Person:</strong> Bahn oft günstiger (Sparpreis ab 17,99 €)</li>
            <li><strong>2 Personen:</strong> Etwa gleich teuer</li>
            <li><strong>3+ Personen:</strong> Auto meist deutlich günstiger</li>
          </ul>
          <p>
            <strong>Wichtig:</strong> Bei der Autofahrt fallen neben Spritkosten auch Verschleiß, 
            Versicherung und Parkgebühren an. Die realen Kosten pro Kilometer liegen bei ca. 30-50 Cent, 
            nicht nur bei den Spritkosten.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Spritkosten für Pendler</h3>
          <p>
            Pendler können die Fahrtkosten von der Steuer absetzen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Entfernungspauschale 2026:</strong> 38 Cent pro km ab dem 1. Kilometer (einfache Strecke)</li>
            <li><strong>Neu seit 01.01.2026:</strong> Die erhöhte Pauschale von 0,38 €/km gilt jetzt ab km 1 (vorher erst ab km 21)</li>
            <li><strong>Maximal:</strong> 4.500 € pro Jahr (außer bei eigener Anfahrt mit Auto)</li>
          </ul>
          <p>
            Nutzen Sie unseren <a href="/pendlerpauschale-rechner" class="text-blue-600 hover:underline">Pendlerpauschale-Rechner</a> 
            für die genaue Berechnung Ihrer Steuerersparnis.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Tipps zum Sprit sparen</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Vorausschauend fahren:</strong> Frühzeitig Gas wegnehmen statt bremsen</li>
            <li><strong>Niedrige Drehzahl:</strong> Früh hochschalten, bei 2.000 U/min (Benzin) bzw. 1.500 U/min (Diesel)</li>
            <li><strong>Reifendruck prüfen:</strong> Zu niedriger Druck erhöht den Verbrauch um 5%</li>
            <li><strong>Unnötigen Ballast entfernen:</strong> 100 kg extra = 0,5 l mehr Verbrauch</li>
            <li><strong>Klimaanlage sparsam:</strong> Erhöht Verbrauch um 0,5-1 l/100km</li>
            <li><strong>Preise vergleichen:</strong> Apps wie "Clever tanken" zeigen günstige Tankstellen</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Häufige Fragen zu Spritkosten</h3>
          
          <p class="font-semibold">Wie berechne ich meinen tatsächlichen Verbrauch?</p>
          <p>
            Tanken Sie voll, notieren Sie den Kilometerstand, fahren Sie normal, tanken Sie wieder voll. 
            Teilen Sie die getankten Liter durch die gefahrenen Kilometer und multiplizieren Sie mit 100.
          </p>
          
          <p class="font-semibold">Warum verbraucht mein Auto mehr als angegeben?</p>
          <p>
            Herstellerangaben basieren auf Labortests (WLTP). Im Alltag sind 10-20% mehr Verbrauch normal, 
            besonders im Stadtverkehr, bei kaltem Motor oder sportlicher Fahrweise.
          </p>
          
          <p class="font-semibold">Lohnt sich ein Umstieg auf Autogas (LPG)?</p>
          <p>
            Autogas kostet nur etwa die Hälfte von Benzin. Allerdings verbrauchen LPG-Fahrzeuge ca. 20% mehr. 
            Die Umrüstung (1.500-3.000 €) lohnt sich ab ca. 30.000 km Jahresfahrleistung.
          </p>
          
          <p class="font-semibold">Was kostet eine Fahrt von München nach Hamburg?</p>
          <p>
            Die Strecke ist ca. 790 km. Bei 7 l/100km und 1,70 €/l kosten nur die Spritkosten 
            ca. 94 € einfach oder 188 € hin und zurück.
          </p>
        </div>
      </div>
    </div>
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/spritverbrauch-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📊</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Spritverbrauch-Rechner</p>
          </a>
          <a href="/pendlerpauschale-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🚗</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Pendlerpauschale-Rechner</p>
          </a>
          <a href="/kfz-steuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🚙</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kfz-Steuer-Rechner</p>
          </a>
          <a href="/co2-steuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🌱</span>
            <p class="font-medium text-gray-800 text-sm mt-1">CO₂-Steuer-Rechner</p>
          </a>
          <a href="/entfernung-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📏</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Entfernung-Rechner</p>
          </a>
          <a href="/elektroauto-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🔌</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Elektroauto-Rechner</p>
          </a>
        </div>
      </div>
    </div>
      <RechnerFeedback rechnerName="Spritkosten-Rechner" rechnerSlug="spritkosten-rechner" />
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Spritkosten-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/spritkosten-rechner",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie berechne ich meine Spritkosten?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Formel lautet: (Strecke in km ÷ 100) × Verbrauch in l/100km × Spritpreis in €/l. Beispiel: 500 km mit 7 l/100km bei 1,70 €/l = 59,50 € Spritkosten."
        }
      },
      {
        "@type": "Question",
        "name": "Was kostet ein Liter Benzin aktuell 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Super E10 kostet durchschnittlich 1,65-1,75 €/Liter. Super Plus liegt bei 1,75-1,90 €/l und Diesel bei 1,55-1,65 €/l. Die Preise schwanken je nach Region und Tageszeit."
        }
      },
      {
        "@type": "Question",
        "name": "Wie hoch ist der durchschnittliche Spritverbrauch?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der Durchschnittsverbrauch liegt bei Kleinwagen bei 5-6 l/100km, bei Kompaktklasse bei 6-7 l/100km und bei SUVs bei 8-10 l/100km. Diesel verbraucht ca. 15-20% weniger als Benzin."
        }
      },
      {
        "@type": "Question",
        "name": "Wann ist die Bahn günstiger als das Auto?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Für eine Person ist die Bahn mit Sparpreis oft günstiger. Ab 3 Personen ist das Auto meist deutlich preiswerter, da sich die Spritkosten teilen. Beachten Sie aber: Auto-Vollkosten (mit Verschleiß, Versicherung) sind höher als nur die Spritkosten."
        }
      },
      {
        "@type": "Question",
        "name": "Wie viel CO₂-Steuer ist im Spritpreis enthalten?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "2025 beträgt die CO₂-Steuer 55€/Tonne, was etwa 15 Cent pro Liter Benzin entspricht. 2026 steigt sie auf 65€/Tonne (ca. 17 Cent/Liter). Die Steuer ist bereits im Tankstellenpreis enthalten."
        }
      },
      {
        "@type": "Question",
        "name": "Wie kann ich Sprit sparen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Vorausschauend fahren, früh hochschalten, Reifendruck prüfen, unnötiges Gewicht entfernen, Klimaanlage sparsam nutzen und abends tanken (18-20 Uhr). So können Sie bis zu 20% Sprit sparen."
        }
      }
    ]
  })} />
</Layout>
