---
import Layout from '../layouts/Layout.astro';
import TageRechner from '../components/rechner/TageRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import RechnerTrust from '../components/RechnerTrust.astro';
import VerwandteRechner from '../components/VerwandteRechner.astro';

const title = "Tage-Rechner – Tage zwischen zwei Daten berechnen";
const description = "Tage Rechner: Berechnen Sie die Anzahl der Tage zwischen zwei Daten. Inklusive Wochen, Monate, Arbeitstage und Wochenenden. Kostenlos & sofort.";
const keywords = "Tage Rechner, Tage berechnen, Tage zwischen Daten, Datum Differenz, wie viele Tage bis, Tage zählen, Datumsrechner, Countdown Tage, Arbeitstage berechnen, Kalenderrechner";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Tage-Rechner", url: "/tage-rechner" }]} />
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Alltag & Lifestyle', href: '/alltag-lifestyle' },
    { name: 'Tage-Rechner' }
  ]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-blue-500 to-cyan-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-blue-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">📅</span>
          <div>
            <h1 class="text-2xl font-bold">Tage-Rechner</h1>
            <p class="text-blue-100 text-sm">Tage zwischen Daten berechnen – kostenlos & sofort</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <TageRechner client:load />
    </div>
<!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Tage-Rechner: Alles, was Sie wissen müssen</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem <strong>Tage-Rechner</strong> können Sie die genaue Anzahl der Tage zwischen 
            zwei beliebigen Daten berechnen. Der Rechner zeigt Ihnen außerdem Wochen, Monate und 
            zusätzliche Details wie Arbeitstage und Wochenenden.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wie berechnet man Tage zwischen zwei Daten?</h3>
          <p>
            Die Berechnung erfolgt durch einfache Subtraktion der beiden Daten. Der Rechner 
            berücksichtigt dabei automatisch:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Unterschiedliche Monatslängen:</strong> 28-31 Tage je nach Monat</li>
            <li><strong>Schaltjahre:</strong> Der 29. Februar wird korrekt einberechnet</li>
            <li><strong>Jahrübergänge:</strong> Auch bei Daten über mehrere Jahre hinweg</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Häufige Anwendungsfälle</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Projektplanung:</strong> Wie viele Tage bis zur Deadline?</li>
            <li><strong>Urlaubsplanung:</strong> Wie lange ist mein Urlaub?</li>
            <li><strong>Countdown:</strong> Tage bis zum Geburtstag, Hochzeit oder Event</li>
            <li><strong>Fristen:</strong> Kündigungsfristen, Liefertermine berechnen</li>
            <li><strong>Verträge:</strong> Laufzeiten und Vertragsdauer ermitteln</li>
            <li><strong>Schwangerschaft:</strong> Tage bis zum errechneten Geburtstermin</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Tage zu einem Datum addieren</h3>
          <p>
            Sie können auch berechnen, welches Datum in X Tagen liegt:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>In 30 Tagen:</strong> Wann ist der Termin?</li>
            <li><strong>In 90 Tagen:</strong> Ende einer Probezeit</li>
            <li><strong>In 14 Tagen:</strong> Zwei Wochen Kündigungsfrist</li>
            <li><strong>In 365 Tagen:</strong> Ein Jahr ab heute</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Arbeitstage vs. Kalendertage</h3>
          <p>
            Bei der Berechnung ist wichtig zu unterscheiden:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Kalendertage:</strong> Alle Tage inklusive Wochenenden und Feiertage</li>
            <li><strong>Arbeitstage:</strong> Nur Montag bis Freitag (ohne Feiertage)</li>
            <li><strong>Werktage:</strong> Montag bis Samstag (ohne Sonntage und Feiertage)</li>
          </ul>
          <p>
            <strong>Tipp:</strong> Für detaillierte Arbeitstage-Berechnungen nutzen Sie unseren 
            <a href="/arbeitstage-rechner" class="text-blue-600 hover:underline">Arbeitstage-Rechner</a>.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wichtige Fristen in Deutschland</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Kündigungsfrist Arbeitnehmer:</strong> In der Regel 4 Wochen (28 Tage)</li>
            <li><strong>Widerrufsfrist Online-Kauf:</strong> 14 Tage</li>
            <li><strong>Probezeit:</strong> Maximal 6 Monate (ca. 180 Tage)</li>
            <li><strong>Mutterschutz vor Geburt:</strong> 6 Wochen (42 Tage)</li>
            <li><strong>Mutterschutz nach Geburt:</strong> 8 Wochen (56 Tage)</li>
            <li><strong>Elternzeit:</strong> Bis zu 3 Jahre (1.095 Tage)</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Ein Jahr in Zahlen</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Normales Jahr:</strong> 365 Tage, 52 Wochen + 1 Tag</li>
            <li><strong>Schaltjahr:</strong> 366 Tage (alle 4 Jahre, außer Jahrhundertwende)</li>
            <li><strong>Arbeitstage:</strong> Ca. 250-253 Tage (je nach Feiertagen)</li>
            <li><strong>Wochenendtage:</strong> 104 Tage (52 Samstage + 52 Sonntage)</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wann ist das nächste Schaltjahr?</h3>
          <p>
            Schaltjahre sind Jahre, die durch 4 teilbar sind (außer durch 100 teilbare, es sei denn 
            auch durch 400 teilbar). Die nächsten Schaltjahre sind:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>2024</strong> (bereits vergangen)</li>
            <li><strong>2028</strong></li>
            <li><strong>2032</strong></li>
            <li><strong>2036</strong></li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Tage-Rechner für Events</h3>
          <p>
            Beliebte Countdowns:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Tage bis Weihnachten:</strong> 25. Dezember</li>
            <li><strong>Tage bis Silvester:</strong> 31. Dezember</li>
            <li><strong>Tage bis Sommerferien:</strong> Je nach Bundesland</li>
            <li><strong>Tage bis zur Hochzeit:</strong> Ihr persönlicher Termin</li>
          </ul>
        </div>
      </div>
    </div>
    
    <!-- Wann brauchst du den Tage-Rechner? -->
    <div class="max-w-3xl mx-auto px-4 mt-8">
      <div class="prose prose-lg max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold mt-12 mb-6 text-gray-900">Wann brauchst du den Tage-Rechner?</h2>
        <p class="text-gray-700">
          Der häufigste Anlass: <strong>Fristen rechtssicher berechnen</strong>. Eine Online-Bestellung kommt am 12. April an — bis wann läuft die 14-tägige Widerrufsfrist? Eine Mietkündigung soll zum nächsten möglichen Termin raus — was ist das frühestmögliche Vertragsende? Bei einer Reisestornierung kommt es manchmal auf einen einzigen Tag an (50 % oder 80 % Stornogebühr), und dann willst du nicht im Kopf zählen.
        </p>
        <p class="text-gray-700">
          Weitere typische Anwendungsfälle: <strong>Karenzzeit bei Versicherungen</strong> (z. B. 3 Monate Wartezeit bei einer neuen Krankenzusatzversicherung), <strong>Schwangerschaftswoche</strong> ausgehend vom letzten Periodenbeginn, <strong>Lieferdatum + X Werktage</strong> beim Online-Shop, <strong>Probezeit-Ende</strong> nach 6 Monaten ab Vertragsbeginn, <strong>Garantiefrist</strong> (zwei Jahre ab Übergabe), <strong>Genehmigungsfrist</strong> bei Bauanträgen (oft 3 Monate), <strong>Countdown</strong> bis Hochzeit, Urlaub oder Geburtstag, sowie <strong>Vertragslaufzeiten</strong> in Tagen ausdrücken (z. B. wie lange ein Kredit oder eine Mitgliedschaft noch läuft). Für alle diese Fälle berechnet der Rechner Kalendertage; Werktage und Arbeitstage haben eigene Regeln, die wir unten erklären.
        </p>

        <h2 class="text-2xl font-bold mt-12 mb-6 text-gray-900">Beispiele aus der Praxis</h2>

        <h3 class="text-xl font-semibold mt-8 mb-3 text-gray-900">Beispiel 1: Widerrufsfrist nach Online-Bestellung</h3>
        <p class="text-gray-700">
          Du bestellst online am Sonntag, 12.04.2026, das Paket kommt am 15.04. Wann läuft deine 14-tägige Widerrufsfrist ab?
        </p>
        <div class="bg-cyan-50 p-4 rounded-lg my-4 text-sm text-gray-800">
          <p>Maßgeblich ist der <strong>Tag des Erhalts</strong> der Ware (§ 356 BGB), nicht der Bestelltag.</p>
          <p>Erhalt: 15.04.2026 → Frist beginnt am 16.04.2026 (Tag nach Erhalt, § 187 BGB)</p>
          <p>14 Kalendertage später: <strong>29.04.2026</strong> (das ist ein Mittwoch — kein Sonntag, also kein Aufschub)</p>
          <p>Bis Mitternacht des 29.04. muss der Widerruf <em>abgeschickt</em> sein (Eingang beim Händler nicht nötig).</p>
        </div>

        <h3 class="text-xl font-semibold mt-8 mb-3 text-gray-900">Beispiel 2: Mietvertrag kündigen mit 3 Monaten Frist zum Monatsende</h3>
        <p class="text-gray-700">
          Du willst aus deiner Wohnung raus, gesetzliche Kündigungsfrist sind 3 Monate zum Monatsende. Du wirfst die Kündigung am 15.05.2026 in den Briefkasten des Vermieters.
        </p>
        <div class="bg-cyan-50 p-4 rounded-lg my-4 text-sm text-gray-800">
          <p>Eingang Kündigung: <strong>15.05.2026</strong> (muss bis spätestens zum 3. Werktag des Monats eingegangen sein, sonst zählt der Folgemonat)</p>
          <p>Vertragsende: 31.05. + 3 volle Monate = <strong>31.08.2026</strong></p>
          <p>Wäre die Kündigung erst am 04.05. zugegangen (3. Werktag verpasst), wäre Vertragsende der 30.09.2026.</p>
        </div>

        <h3 class="text-xl font-semibold mt-8 mb-3 text-gray-900">Beispiel 3: Bauantrag und Genehmigungsfrist</h3>
        <p class="text-gray-700">
          Du reichst am 01.03.2026 einen vereinfachten Bauantrag bei der Bauaufsichtsbehörde ein. Viele Landesbauordnungen sehen eine Bearbeitungsfrist von 3 Monaten vor, danach gilt die Genehmigungsfiktion (Antrag gilt als genehmigt).
        </p>
        <div class="bg-cyan-50 p-4 rounded-lg my-4 text-sm text-gray-800">
          <p>Antragseingang: 01.03.2026</p>
          <p>3 Monate Bearbeitungsfrist: bis spätestens <strong>01.06.2026</strong></p>
          <p>Dazwischen: 92 Kalendertage — bei behördlicher Rückfrage kann sich die Frist verlängern (Hemmung).</p>
          <p>Wichtig: Vorgaben variieren je Bundesland (LBO). Im Zweifel deine zuständige Bauaufsicht fragen.</p>
        </div>

        <h2 class="text-2xl font-bold mt-12 mb-6 text-gray-900">Häufige Fragen zur Tage- und Fristberechnung</h2>

        <details class="border border-gray-200 rounded-lg p-4 my-3 bg-white">
          <summary class="font-semibold cursor-pointer text-gray-900">Wie zähle ich Werktage statt Kalendertage?</summary>
          <div class="mt-3 text-gray-700">
            <p>Bei <strong>Werktagen</strong> zählst du Montag bis Samstag — Sonntage und gesetzliche Feiertage werden übersprungen. Bei <strong>Arbeitstagen</strong> zählst du nur Montag bis Freitag, ohne Feiertage. Der Unterschied ist je nach Vertrag und Gesetz wichtig: Die meisten Online-Shops liefern in „Werktagen", manche Behördenfristen rechnen in Kalendertagen, Arbeitsverträge meist in Arbeitstagen. Für die exakte Werktag-/Arbeitstag-Berechnung mit Feiertagen pro Bundesland nutze unseren <a href="/arbeitstage-rechner" class="text-blue-600 underline">Arbeitstage-Rechner</a>.</p>
          </div>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 my-3 bg-white">
          <summary class="font-semibold cursor-pointer text-gray-900">Sind Samstage Werktage?</summary>
          <div class="mt-3 text-gray-700">
            <p><strong>Rechtlich ja</strong> — der Bundesgerichtshof hat mehrfach klargestellt, dass Samstage Werktage sind (auch wenn die meisten Branchen samstags geschlossen haben). Bei Mietkündigungen, Postzustellung und gesetzlichen Fristen zählt der Samstag also mit. <strong>Praktisch nein</strong> — viele Verträge und Lieferversprechen meinen mit „Werktagen" Montag bis Freitag, weil das den Liefer- und Bürobetrieb widerspiegelt. Lies im Zweifel die Vertragsdefinition: Steht „Bankarbeitstag", sind Sa/So und Feiertage immer raus. Steht nur „Werktag", ist Samstag drin.</p>
          </div>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 my-3 bg-white">
          <summary class="font-semibold cursor-pointer text-gray-900">Was passiert, wenn die Frist auf einen Sonntag oder Feiertag fällt?</summary>
          <div class="mt-3 text-gray-700">
            <p>Hier greift <strong>§ 193 BGB</strong>: Fällt das Fristende auf einen Sonntag, gesetzlichen Feiertag oder Sonnabend (Samstag), endet die Frist am <strong>nächsten Werktag</strong>. Beispiel: Eine 14-tägige Widerrufsfrist endet rechnerisch am Sonntag, 26.04.2026 — tatsächlich hast du dann bis Montag, 27.04.2026 Zeit. Achtung: Das gilt nur bei rechtsgeschäftlichen Fristen, nicht bei rein faktischen (z. B. „die Pizza-Bestellung muss bis Mitternacht raus"). Auch im Steuerrecht (§ 108 AO) gilt eine identische Regel.</p>
          </div>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 my-3 bg-white">
          <summary class="font-semibold cursor-pointer text-gray-900">Wie wird das Startdatum bei der Fristberechnung mitgezählt?</summary>
          <div class="mt-3 text-gray-700">
            <p>Nach <strong>§ 187 Abs. 1 BGB</strong> wird der Tag des auslösenden Ereignisses <em>nicht</em> mitgezählt — die Frist beginnt am Tag <em>danach</em>. Beispiel: Du bekommst am 12.04. eine fristauslösende Erklärung, die Frist läuft 14 Tage. Erster Fristtag ist der 13.04., letzter Tag der 26.04. Anders bei Geburtstagen und Altersgrenzen (§ 187 Abs. 2): Der Tag der Geburt wird mitgezählt, du wirst also am Vortag deines Geburtstags um Mitternacht ein Jahr älter (juristisch). Unser Rechner zeigt dir auf Wunsch beide Varianten — mit und ohne Mitzählen des Startdatums.</p>
          </div>
        </details>

        <details class="border border-gray-200 rounded-lg p-4 my-3 bg-white">
          <summary class="font-semibold cursor-pointer text-gray-900">Welche Tage sind 2026 in Deutschland gesetzliche Feiertage?</summary>
          <div class="mt-3 text-gray-700">
            <p>Bundeseinheitlich gelten 9 Feiertage: <strong>Neujahr (01.01.)</strong>, <strong>Karfreitag (03.04.2026)</strong>, <strong>Ostermontag (06.04.2026)</strong>, <strong>Tag der Arbeit (01.05.)</strong>, <strong>Christi Himmelfahrt (14.05.2026)</strong>, <strong>Pfingstmontag (25.05.2026)</strong>, <strong>Tag der Deutschen Einheit (03.10.)</strong>, <strong>1. Weihnachtstag (25.12.)</strong>, <strong>2. Weihnachtstag (26.12.)</strong>. Hinzu kommen länderspezifische Feiertage: Heilige Drei Könige (BW, BY, ST), Fronleichnam (in katholisch geprägten Ländern), Mariä Himmelfahrt (BY teilw., SL), Reformationstag (mehrere Bundesländer), Allerheiligen (BW, BY, NRW, RLP, SL), Buß- und Bettag (SN). Für Fristberechnungen gilt immer das Recht des Ortes, an dem die Frist ablaufen soll — also meist Wohnort des Empfängers.</p>
          </div>
        </details>

        <h2 class="text-2xl font-bold mt-12 mb-6 text-gray-900">Methodik & Quellen</h2>
        <p class="text-gray-700">
          Die Tage-Berechnung folgt den Regeln der <strong>Fristberechnung im BGB (§§ 187–193)</strong>: Beginn und Ende der Frist, Behandlung von Sonn- und Feiertagen, Mitzählen des Ereignistages bei Altersangaben. Schaltjahre werden korrekt nach gregorianischem Kalender berücksichtigt (durch 4 teilbar = Schaltjahr, außer durch 100 teilbar — es sei denn, durch 400 teilbar; nächstes Schaltjahr nach 2024 ist 2028). Gesetzliche Feiertage richten sich nach den <strong>Feiertagsgesetzen der Länder</strong>; die bundeseinheitlichen Feiertage sind in den jeweiligen Landesgesetzen einheitlich verankert. Berechnungen laufen vollständig im Browser — keine Daten verlassen dein Gerät. Zuletzt aktualisiert: April 2026.
        </p>
      </div>
    </div>

    <!-- Trust-Block -->
    <div class="max-w-3xl mx-auto px-4">
      <RechnerTrust quellen="§§187–193 BGB (Fristberechnung), Feiertagsgesetze der Länder" aktualisiert="April 2026" />
    </div>

    <!-- Verwandte Rechner -->
    <div class="max-w-7xl mx-auto px-4">
      <VerwandteRechner aktuellerSlug="tage" slugs={['arbeitstage', 'urlaubstage', 'alter', 'geburtstermin']} kategorie="alltag" />
    </div>
</main>
  
  <!-- Structured Data for SEO -->
