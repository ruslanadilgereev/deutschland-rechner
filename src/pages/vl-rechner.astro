---
import Layout from '../layouts/Layout.astro';
import VLRechner from '../components/rechner/VLRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "VL-Rechner 2025 & 2026 – Arbeitnehmersparzulage berechnen";
const description = "VL-Rechner 2026: Berechne VL und Arbeitnehmersparzulage. Bis 123€ Zulage/Jahr. Einkommensgrenze seit 2024: 40.000€ (ledig) / 80.000€ (verheiratet).";
const keywords = "VL Rechner, vermögenswirksame Leistungen, VL 2026, Arbeitnehmersparzulage, VWL Rechner, VL Zulage, VL Bauspar, VL Aktienfonds, 9 Prozent Zulage, 20 Prozent Zulage, Einkommensgrenze VL, VL Arbeitgeber";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "VL-Rechner", url: "/vl-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-green-500 to-emerald-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-green-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🏦</span>
          <div>
            <h1 class="text-2xl font-bold">VL-Rechner</h1>
            <p class="text-green-100 text-sm">Vermögenswirksame Leistungen & Arbeitnehmersparzulage 2026</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <VLRechner client:load />
    </div>
<!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">VL 2026: Alles über vermögenswirksame Leistungen</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            <strong>Vermögenswirksame Leistungen (VL oder VWL)</strong> sind eine staatlich geförderte Form der 
            Vermögensbildung für Arbeitnehmer. Der Arbeitgeber überweist monatlich einen Betrag (oft 6,65€ bis 40€) 
            direkt auf ein VL-fähiges Sparkonto. Zusätzlich gibt es die <strong>Arbeitnehmersparzulage</strong> vom Staat.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Arbeitnehmersparzulage 2026</h3>
          <p>
            Die Arbeitnehmersparzulage ist ein staatlicher Bonus auf deine VL-Einzahlungen. Die Höhe hängt von der 
            Anlageform und deinem Einkommen ab:
          </p>
          
          <div class="bg-gray-50 rounded-xl p-4 my-4">
            <h4 class="font-semibold text-gray-800 mb-2">🏠 Bausparvertrag</h4>
            <ul class="list-disc pl-5 space-y-1 text-sm">
              <li><strong>9% Zulage</strong> auf bis zu 470 €/Jahr → max. <strong>43 €/Jahr</strong></li>
              <li>Einkommensgrenze: 40.000 € (ledig) / 80.000 € (verheiratet)</li>
            </ul>
          </div>
          
          <div class="bg-gray-50 rounded-xl p-4 my-4">
            <h4 class="font-semibold text-gray-800 mb-2">📈 Aktienfonds-Sparplan</h4>
            <ul class="list-disc pl-5 space-y-1 text-sm">
              <li><strong>20% Zulage</strong> auf bis zu 400 €/Jahr → max. <strong>80 €/Jahr</strong></li>
              <li>Einkommensgrenze: 40.000 € (ledig) / 80.000 € (verheiratet)</li>
            </ul>
          </div>
          
          <p>
            <strong>Tipp:</strong> Beide Anlageformen lassen sich kombinieren! So sind bis zu <strong>123 €/Jahr</strong> 
            staatliche Zulage möglich (43€ + 80€).
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wer hat Anspruch auf VL?</h3>
          <p>
            Grundsätzlich jeder Arbeitnehmer, Beamte, Richter, Soldat oder Azubi. Ob dein Arbeitgeber VL zahlt, 
            steht im Arbeits- oder Tarifvertrag. Viele Beschäftigte wissen nicht, dass ihnen VL zustehen – 
            <strong>frag deinen Arbeitgeber!</strong>
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">7 Jahre Sperrfrist</h3>
          <p>
            VL-Verträge haben eine <strong>Sperrfrist von 7 Jahren</strong>: 6 Jahre Einzahlungsphase + 1 Jahr Ruhephase. 
            Erst danach kannst du über das Geld frei verfügen, ohne die Zulage zu verlieren. Vorzeitige Verfügung 
            ist möglich, aber dann entfällt die staatliche Förderung.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wie beantrage ich die Arbeitnehmersparzulage?</h3>
          <p>
            Die Arbeitnehmersparzulage muss jährlich über die <strong>Steuererklärung</strong> beantragt werden 
            (Anlage VL). Dein Anbieter (Bausparkasse, Fondsgesellschaft) stellt dir eine Bescheinigung aus. 
            Ohne Steuererklärung verfällt die Zulage!
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">VL auch ohne Arbeitgeberbeitrag</h3>
          <p>
            Selbst wenn dein Arbeitgeber keine VL zahlt, kannst du einen VL-Vertrag abschließen und selbst 
            einzahlen. Die Arbeitnehmersparzulage bekommst du trotzdem (sofern dein Einkommen unter der Grenze liegt).
          </p>
        </div>
      </div>
      
      <!-- FAQ Section -->
      <div class="bg-white rounded-2xl shadow-lg p-6 mt-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">❓ Häufige Fragen zu VL</h2>
        
        <div class="space-y-4">
          <details class="group">
            <summary class="font-semibold text-gray-800 cursor-pointer list-none flex justify-between items-center">
              <span>Welche Anlageform ist besser – Bauspar oder Aktienfonds?</span>
              <span class="transition-transform group-open:rotate-180">▼</span>
            </summary>
            <p class="text-gray-600 mt-2 text-sm">
              Bei Aktienfonds bekommst du 20% statt 9% Zulage und hast höhere Renditechancen (aber auch Risiko). 
              Bausparen ist sicherer und sinnvoll, wenn du in 7+ Jahren bauen/kaufen möchtest. Für reine 
              Vermögensbildung empfehlen Verbraucherschützer meist Aktienfonds-Sparpläne.
            </p>
          </details>
          
          <details class="group">
            <summary class="font-semibold text-gray-800 cursor-pointer list-none flex justify-between items-center">
              <span>Mein Einkommen ist zu hoch – lohnen sich VL trotzdem?</span>
              <span class="transition-transform group-open:rotate-180">▼</span>
            </summary>
            <p class="text-gray-600 mt-2 text-sm">
              Ja! Der Arbeitgeberbeitrag ist immer geschenktes Geld, das du zum Sparen nutzen kannst. 
              Du bekommst nur keine staatliche Zulage. Außerdem kann sich dein Einkommen ändern – 
              dann bekommst du die Zulage nachträglich mit der nächsten Steuererklärung.
            </p>
          </details>
          
          <details class="group">
            <summary class="font-semibold text-gray-800 cursor-pointer list-none flex justify-between items-center">
              <span>Was ist der Unterschied zur Wohnungsbauprämie?</span>
              <span class="transition-transform group-open:rotate-180">▼</span>
            </summary>
            <p class="text-gray-600 mt-2 text-sm">
              Die Wohnungsbauprämie (10% auf bis zu 700€/Jahr) gibt es auf eigene Bausparbeiträge, 
              nicht auf VL. Beide können kombiniert werden! Die Einkommensgrenze für die Wohnungsbauprämie 
              ist höher (35.000€ / 70.000€).
            </p>
          </details>
          
          <details class="group">
            <summary class="font-semibold text-gray-800 cursor-pointer list-none flex justify-between items-center">
              <span>Was passiert bei Jobwechsel?</span>
              <span class="transition-transform group-open:rotate-180">▼</span>
            </summary>
            <p class="text-gray-600 mt-2 text-sm">
              Der VL-Vertrag bleibt bestehen. Du kannst den neuen Arbeitgeber bitten, die VL auf 
              dasselbe Konto weiterzuzahlen. Alternativ ruht der alte Vertrag und du eröffnest einen neuen.
            </p>
          </details>
        </div>
      </div>
    </div>
</main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "VL-Rechner 2026 – Vermögenswirksame Leistungen",
    "description": description,
    "url": "https://www.deutschland-rechner.de/vl-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQPage Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Welche Anlageform ist besser – Bauspar oder Aktienfonds?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bei Aktienfonds bekommst du 20% statt 9% Zulage und hast höhere Renditechancen (aber auch Risiko). Bausparen ist sicherer und sinnvoll, wenn du in 7+ Jahren bauen/kaufen möchtest."
        }
      },
      {
        "@type": "Question",
        "name": "Mein Einkommen ist zu hoch – lohnen sich VL trotzdem?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja! Der Arbeitgeberbeitrag ist immer geschenktes Geld. Du bekommst nur keine staatliche Zulage. Außerdem kann sich dein Einkommen ändern."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist der Unterschied zur Wohnungsbauprämie?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Wohnungsbauprämie (10% auf bis zu 700€/Jahr) gibt es auf eigene Bausparbeiträge, nicht auf VL. Beide können kombiniert werden!"
        }
      }
    ]
  })} />
</Layout>
