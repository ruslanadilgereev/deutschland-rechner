    icon: "📜",
    desc: "Erbschaftsteuer berechnen – Freibeträge, Steuerklassen I–III, Steuersätze 7–50%",
  },
  {
    name: "Schenkungsteuer-Rechner",
    url: "/schenkungsteuer-rechner",
    icon: "🎁",
    desc: "Schenkungsteuer berechnen – Freibeträge alle 10 Jahre nutzbar",
  },
  {
    name: "Kapitalertragsteuer-Rechner",
    url: "/kapitalertragsteuer-rechner",
    icon: "📈",
