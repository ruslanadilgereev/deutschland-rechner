        }
      },
      {
        "@type": "Question",
        "name": "Was tun bei Überschuldung?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bei ernsten Schuldenproblemen hilft die Schuldnerberatung – kostenlos bei Verbraucherzentrale, Caritas oder Diakonie. Dort bekommen Sie professionelle Unterstützung, um Ihre Schulden zu ordnen."
        }
      }
    ]
  })} />
</Layout>
