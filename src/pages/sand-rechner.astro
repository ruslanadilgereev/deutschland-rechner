        }
      },
      {
        "@type": "Question",
        "name": "Sack oder BigBag – was ist günstiger?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bis wenige hundert Kilogramm ist der 25-kg-Sack praktisch. Ab etwa einer Tonne sind BigBags oder die lose Lieferung per Kipper pro Kilogramm deutlich günstiger – sofern eine Abladefläche vorhanden ist."
        }
      }
    ]
  })} />
</Layout>
