---
import Layout from '../layouts/Layout.astro';
import ElterngeldRechner from '../components/rechner/ElterngeldRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Elterngeld-Rechner 2025 & 2026 – Basiselterngeld & ElterngeldPlus";
const description = "Elterngeld-Rechner 2026: Basiselterngeld 300-1800€, ElterngeldPlus 150-900€. Einkommensgrenze 175.000€, Partnermonate & Bezugsdauer berechnen.";
const keywords = "Elterngeld Rechner, Elterngeld 2026, Elterngeld berechnen, Basiselterngeld, ElterngeldPlus, Elterngeld Höhe, Elterngeld Antrag, Partnermonate, Elterngeld Einkommensgrenze";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Elterngeld-Rechner", url: "/elterngeld-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-pink-500 to-rose-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-pink-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🍼</span>
          <div>
            <h1 class="text-2xl font-bold">Elterngeld-Rechner 2026</h1>
            <p class="text-pink-100 text-sm">Basiselterngeld & ElterngeldPlus berechnen</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <ElterngeldRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Elterngeld 2026: Berechnung, Antrag & Bezugsdauer</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit dem <strong>Elterngeld</strong> unterstützt der Staat Eltern nach der Geburt ihres Kindes. 
            Unser <strong>Elterngeld-Rechner 2026</strong> berechnet Ihr individuelles Elterngeld basierend 
            auf Ihrem Nettoeinkommen vor der Geburt.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Elterngeld Höhe 2026</h3>
          <p>
            Das Elterngeld ersetzt 65-67% des wegfallenden Nettoeinkommens:
          </p>
          <div class="bg-pink-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>Basiselterngeld:</strong> 300€ - 1.800€ pro Monat</li>
              <li><strong>ElterngeldPlus:</strong> 150€ - 900€ pro Monat (doppelte Bezugsdauer)</li>
              <li><strong>Partnerschaftsbonus:</strong> Zusätzliche ElterngeldPlus-Monate bei Teilzeitarbeit</li>
              <li><strong>Mindestbetrag:</strong> 300€ auch ohne vorheriges Einkommen</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Berechnung des Elterngelds</h3>
          <p>
            Das Elterngeld wird aus dem <strong>durchschnittlichen Nettoeinkommen der letzten 12 Monate</strong> 
            vor der Geburt berechnet:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Einkommen über 1.240€:</strong> 65% Ersatzrate</li>
            <li><strong>Einkommen 1.200€ - 1.240€:</strong> 67% → 65% (Abschmelzzone)</li>
            <li><strong>Einkommen 1.000€ - 1.200€:</strong> 67% Ersatzrate</li>
            <li><strong>Einkommen unter 1.000€:</strong> 67% + Geringverdiener-Zuschlag bis 100%</li>
            <li><strong>Geschwisterbonus:</strong> +10% (mind. 75€) bei weiteren Kindern unter 3 bzw. 6 Jahren</li>
            <li><strong>Mehrlingsbonus:</strong> +300€ pro weiterem Mehrling</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Bezugsdauer des Elterngelds</h3>
          <p>
            Die <strong>Bezugsdauer</strong> hängt von der gewählten Variante ab:
          </p>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>Basiselterngeld:</strong> 12 Monate (+ 2 Partnermonate = 14 Monate)</li>
              <li><strong>ElterngeldPlus:</strong> 24 Monate (+ 4 Partnermonate = 28 Monate)</li>
              <li><strong>Kombination:</strong> 1 Monat Basiselterngeld = 2 Monate ElterngeldPlus</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Einkommensgrenze 2026</h3>
          <p>
            <strong>Wichtige Änderung:</strong> Seit April 2025 gilt eine einheitliche Einkommensgrenze:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Paare:</strong> 175.000€ zu versteuerndes Jahreseinkommen</li>
            <li><strong>Alleinerziehende:</strong> 175.000€ zu versteuerndes Jahreseinkommen</li>
            <li>Bei Überschreitung: Kein Anspruch auf Elterngeld</li>
          </ul>
          
          <div class="bg-yellow-50 p-4 rounded-lg my-4">
            <p class="text-sm text-yellow-800">
              <strong>Achtung:</strong> Die Einkommensgrenze wurde schrittweise gesenkt: April 2024 von 
              300.000€/250.000€ auf 200.000€, April 2025 auf 175.000€ für alle. Prüfen Sie Ihren Anspruch!
            </p>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Elterngeld mit Teilzeitarbeit</h3>
          <p>
            Sie können während des Elterngeldbezugs in <strong>Teilzeit arbeiten</strong> 
            (max. 32 Stunden/Woche). Das Einkommen wird anteilig angerechnet. Bei ElterngeldPlus 
            ist Teilzeit besonders vorteilhaft.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Elterngeld beantragen</h3>
          <p>
            Der Antrag muss <strong>innerhalb der ersten 3 Lebensmonate</strong> des Kindes gestellt 
            werden (rückwirkende Zahlung max. 3 Monate). Zuständig ist die Elterngeldstelle Ihres 
            Bundeslandes.
          </p>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/elternzeit-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📅</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Elternzeit-Rechner</p>
          </a>
          <a href="/mutterschutz-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🤰</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Mutterschutz-Rechner</p>
          </a>
          <a href="/kindergeld-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">👶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kindergeld-Rechner</p>
          </a>
          <a href="/kinderzuschlag-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💶</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Kinderzuschlag-Rechner</p>
          </a>
          <a href="/brutto-netto-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💵</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Brutto-Netto-Rechner</p>
          </a>
          <a href="/geburtstermin-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📆</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Geburtstermin-Rechner</p>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Zuständige Behörde -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🏛️</span>
          Zuständige Behörde
        </h2>
        
        <div class="p-4 bg-pink-50 rounded-lg">
          <h3 class="font-semibold text-pink-800 mb-2">Elterngeldstelle</h3>
          <p class="text-pink-700 text-sm mb-2">
            Die <strong>Elterngeldstelle</strong> Ihres Bundeslandes ist für die Bearbeitung zuständig. 
            Der Antrag kann oft online gestellt werden (z.B. über ElterngeldDigital).
          </p>
          <p class="text-pink-700 text-sm">
            <strong>Familienportal:</strong> familienportal.de/elterngeld<br/>
            <strong>ElterngeldDigital:</strong> elterngeld-digital.de
          </p>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Elterngeld-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/elterngeld-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie hoch ist das Elterngeld 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Das Elterngeld beträgt 65-67% des vorherigen Nettoeinkommens. Basiselterngeld liegt zwischen 300€ und 1.800€ monatlich, ElterngeldPlus zwischen 150€ und 900€. Auch ohne vorheriges Einkommen erhalten Sie den Mindestbetrag von 300€."
        }
      },
      {
        "@type": "Question",
        "name": "Wie lange bekommt man Elterngeld?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Basiselterngeld gibt es 12 Monate für ein Elternteil, plus 2 Partnermonate wenn beide Eltern Elterngeld nehmen (= 14 Monate). ElterngeldPlus kann bis zu 28 Monate bezogen werden. Die Monate sind frei aufteilbar."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist der Unterschied zwischen Basiselterngeld und ElterngeldPlus?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Basiselterngeld ist höher (bis 1.800€), wird aber kürzer gezahlt. ElterngeldPlus ist halb so hoch (bis 900€), kann aber doppelt so lange bezogen werden. Besonders bei Teilzeitarbeit ist ElterngeldPlus oft vorteilhafter."
        }
      },
      {
        "@type": "Question",
        "name": "Wie hoch ist die Einkommensgrenze beim Elterngeld 2026?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Einkommensgrenze liegt bei 175.000€ zu versteuerndem Jahreseinkommen für Paare und Alleinerziehende. Bei Überschreitung besteht kein Anspruch auf Elterngeld. Diese Grenze wurde 2024 von 300.000€ gesenkt."
        }
      },
      {
        "@type": "Question",
        "name": "Kann ich während des Elterngeldbezugs arbeiten?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, Sie können in Teilzeit arbeiten (maximal 32 Stunden/Woche). Das Einkommen wird anteilig vom Elterngeld abgezogen. Bei ElterngeldPlus mit Partnerschaftsbonus erhalten Sie Zusatzmonate, wenn beide Eltern 24-32 Stunden arbeiten."
        }
      },
      {
        "@type": "Question",
        "name": "Wann muss ich Elterngeld beantragen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Elterngeld wird maximal 3 Monate rückwirkend gezahlt. Stellen Sie den Antrag daher innerhalb der ersten 3 Lebensmonate des Kindes bei der Elterngeldstelle Ihres Bundeslandes. Online geht das über ElterngeldDigital."
        }
      }
    ]
  })} />
</Layout>
