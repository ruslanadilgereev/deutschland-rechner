---
import Layout from '../layouts/Layout.astro';
import RentensteuerRechner from '../components/rechner/RentensteuerRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Rentensteuer-Rechner 2025 & 2026 – Netto-Rente nach Abzügen berechnen";
const description = "Rentensteuer-Rechner 2026: Berechnen Sie Ihre Netto-Rente nach Steuern & Sozialabgaben. Besteuerungsanteil, KV, PV. Kostenlos & sofort.";
const keywords = "Rentensteuer Rechner, Rentenabzüge, Netto Rente berechnen, Rentenbesteuerung, Besteuerungsanteil, Krankenversicherung Rentner, Steuern auf Rente, Rente Abzüge";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Rentensteuer-Rechner", url: "/rentensteuer-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-purple-500 to-pink-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-purple-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">💶</span>
          <div>
            <h1 class="text-2xl font-bold">Rentensteuer-Rechner 2026</h1>
            <p class="text-purple-100 text-sm">Was bleibt netto von Ihrer Rente?</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <RentensteuerRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Rentenbesteuerung: So viel bleibt netto von Ihrer Rente</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem <strong>Rentensteuer-Rechner</strong> berechnen Sie kostenlos, wie viel 
            von Ihrer Brutto-Rente nach <strong>Steuern und Sozialabgaben</strong> übrig bleibt. 
            Seit 2005 werden Renten schrittweise stärker besteuert – der Besteuerungsanteil 
            steigt mit jedem Rentenjahrgang.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Besteuerungsanteil nach Rentenbeginn</h3>
          <p>
            Der <strong>Besteuerungsanteil</strong> Ihrer Rente hängt vom Jahr Ihres Rentenbeginns ab:
          </p>
          <div class="bg-gray-100 p-4 rounded-lg my-4">
            <ul class="space-y-1 text-sm">
              <li><strong>Rentenbeginn 2024:</strong> 83% steuerpflichtig</li>
              <li><strong>Rentenbeginn 2025:</strong> 83,5% steuerpflichtig</li>
              <li><strong>Rentenbeginn 2026:</strong> 84% steuerpflichtig</li>
              <li><strong>Rentenbeginn 2040:</strong> 100% steuerpflichtig</li>
            </ul>
          </div>
          <p>
            Der <strong>Rentenfreibetrag</strong> (der steuerfreie Teil) wird im ersten vollen 
            Rentenjahr festgeschrieben und gilt dann lebenslang – auch bei Rentenerhöhungen.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Abzüge von der Brutto-Rente</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Krankenversicherung:</strong> ca. 7,3% + halber Zusatzbeitrag (ca. 8,75% gesamt bei Ø 2,9% ZB)</li>
            <li><strong>Pflegeversicherung:</strong> 1,8% (Kinderlose ab 23: +0,6%)</li>
            <li><strong>Einkommensteuer:</strong> Je nach Höhe und Besteuerungsanteil</li>
            <li><strong>Solidaritätszuschlag:</strong> Nur bei hohen Renten (ab ca. 18.000€ Steuer)</li>
            <li><strong>Kirchensteuer:</strong> 8-9% der Einkommensteuer (wenn Mitglied)</li>
          </ul>
          
          <div class="bg-green-50 p-4 rounded-lg my-4">
            <h4 class="font-semibold text-green-800 mb-2">Beispielrechnung (Rentenbeginn 2026, alleinstehend)</h4>
            <ul class="space-y-1 text-sm text-green-700">
              <li>Brutto-Rente: 1.800€/Monat = 21.600€/Jahr</li>
              <li>Besteuerungsanteil: 84% = 18.144€ steuerpflichtig</li>
              <li>Abzgl. Werbungskosten-Pauschale: −102€</li>
              <li>Abzgl. KV/PV-Vorsorgeaufwendungen: −2.279€</li>
              <li>Abzgl. Sonderausgaben-Pauschbetrag: −36€</li>
              <li>Zu versteuerndes Einkommen: ca. 15.727€</li>
              <li>Einkommensteuer: ca. 577€/Jahr (Grundfreibetrag 12.348€)</li>
              <li>Krankenversicherung: ca. 159€/Monat (8,75%)</li>
              <li>Pflegeversicherung: ca. 32€/Monat (1,8%)</li>
              <li class="pt-2 border-t border-green-200 font-bold">Netto-Rente: ca. 1.561€/Monat</li>
            </ul>
          </div>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wann müssen Rentner Steuern zahlen?</h3>
          <p>
            Steuern fallen erst an, wenn Ihre <strong>steuerpflichtigen Einkünfte</strong> den 
            <strong>Grundfreibetrag von 12.348€</strong> (2026) übersteigen. Bei Ehepaaren 
            verdoppelt sich dieser Betrag auf 24.696€.
          </p>
          <p>
            Bei einer Rente mit Rentenbeginn 2026 (84% Besteuerungsanteil) liegt die 
            ungefähre <strong>Steuerschwelle</strong> bei etwa 1.250€ Monatsrente für 
            Alleinstehende (nach Abzug von Werbungskosten und Vorsorgeaufwendungen).
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Krankenversicherung der Rentner (KVdR)</h3>
          <p>
            Als <strong>pflichtversicherter Rentner</strong> zahlen Sie auf Ihre gesetzliche 
            Rente den halben Beitragssatz – die andere Hälfte übernimmt die Rentenversicherung. 
            Auf Betriebsrenten und andere Einkünfte zahlen Sie jedoch den vollen Satz.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Steuererklärung für Rentner</h3>
          <p>
            Eine <strong>Steuererklärung</strong> ist Pflicht, wenn:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Sie Nebeneinkünfte über 410€/Jahr haben</li>
            <li>Sie eine Betriebsrente oder Riester-Rente beziehen</li>
            <li>Das Finanzamt Sie zur Abgabe auffordert</li>
            <li>Ihre Einkünfte über dem Grundfreibetrag liegen</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Absetzbare Kosten für Rentner</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Krankheitskosten:</strong> Zuzahlungen, Brillen, Zahnersatz</li>
            <li><strong>Pflegekosten:</strong> Zuzahlungen zur Pflege</li>
            <li><strong>Haushaltsnahe Dienstleistungen:</strong> Putzhilfe, Gärtner</li>
            <li><strong>Handwerkerleistungen:</strong> Reparaturen in der Wohnung</li>
            <li><strong>Spenden:</strong> An gemeinnützige Organisationen</li>
          </ul>
        </div>
      </div>
    </div>
    
    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/renten-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏖️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Renten-Rechner</p>
          </a>
          <a href="/rentenluecke-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📉</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Rentenlücke-Rechner</p>
          </a>
          <a href="/einkommensteuer-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🧾</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Einkommensteuer-Rechner</p>
          </a>
          <a href="/witwenrente-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🖤</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Witwenrente-Rechner</p>
          </a>
        </div>
      </div>
    </div>
    
    <!-- Zuständige Behörde -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🏛️</span>
          Zuständige Behörden & Hilfe
        </h2>
        
        <div class="space-y-4">
          <div class="p-4 bg-blue-50 rounded-lg">
            <h3 class="font-semibold text-blue-800 mb-2">Finanzamt</h3>
            <p class="text-blue-700 text-sm">
              Für Fragen zur <strong>Rentenbesteuerung</strong> ist Ihr Finanzamt zuständig. 
              Die Steuererklärung erfolgt über ELSTER oder in Papierform. Viele Finanzämter 
              bieten spezielle Beratung für Senioren an.
            </p>
          </div>
          
          <div class="p-4 bg-green-50 rounded-lg">
            <h3 class="font-semibold text-green-800 mb-2">Deutsche Rentenversicherung</h3>
            <p class="text-green-700 text-sm">
              <strong>Kostenlose Hotline:</strong> 0800 1000 4800<br/>
              Bei Fragen zu Kranken- und Pflegeversicherungsbeiträgen auf Ihre Rente 
              hilft die Deutsche Rentenversicherung weiter.
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Rentensteuer-Rechner 2026",
    "description": description,
    "url": "https://www.deutschland-rechner.de/rentensteuer-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie viel Steuern muss ich auf meine Rente zahlen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Steuer hängt vom Jahr Ihres Rentenbeginns ab. Bei Rentenbeginn 2026 sind 84% der Rente steuerpflichtig. Steuern fallen aber nur an, wenn Ihre Einkünfte über dem Grundfreibetrag von 12.348€ liegen."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist der Besteuerungsanteil bei der Rente?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der Besteuerungsanteil gibt an, welcher Teil Ihrer Rente versteuert werden muss. Er hängt vom Jahr des Rentenbeginns ab: 2026 sind 84% steuerpflichtig, ab 2040 werden 100% versteuert. Der steuerfreie Rentenfreibetrag wird im ersten Rentenjahr festgeschrieben und gilt lebenslang."
        }
      },
      {
        "@type": "Question",
        "name": "Welche Abzüge gibt es von der Brutto-Rente?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Von der Brutto-Rente werden abgezogen: Krankenversicherung (ca. 8,5%), Pflegeversicherung (1,8-2,4%), Einkommensteuer (je nach Höhe) und ggf. Kirchensteuer. Die Rentenversicherung übernimmt die Hälfte der KV- und PV-Beiträge."
        }
      },
      {
        "@type": "Question",
        "name": "Ab welcher Rente muss ich Steuern zahlen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Steuern fallen an, wenn Ihre steuerpflichtigen Einkünfte den Grundfreibetrag (2026: 12.348€) übersteigen. Bei Rentenbeginn 2026 (84% Besteuerungsanteil) liegt die Steuerschwelle bei etwa 1.200€ Monatsrente für Alleinstehende."
        }
      },
      {
        "@type": "Question",
        "name": "Muss ich als Rentner eine Steuererklärung abgeben?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Eine Steuererklärung ist Pflicht bei: Nebeneinkünften über 410€/Jahr, Bezug von Betriebsrente/Riester-Rente, Aufforderung durch das Finanzamt, oder wenn Ihre Einkünfte über dem Grundfreibetrag liegen."
        }
      },
      {
        "@type": "Question",
        "name": "Wie hoch ist die Krankenversicherung für Rentner?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pflichtversicherte Rentner zahlen auf ihre gesetzliche Rente den halben KV-Beitragssatz (ca. 7,3% + halber Zusatzbeitrag). Die andere Hälfte übernimmt die Rentenversicherung. Auf Betriebsrenten gilt der volle Beitragssatz."
        }
      }
    ]
  })} />
</Layout>
