        }
      },
      {
        "@type": "Question",
        "name": "Wie viel wiegt ein Kubikmeter Estrich?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Zementestrich (CT) hat eine Rohdichte von etwa 2.100 kg/m³, Calciumsulfat- bzw. Anhydritestrich (CA) rund 2.000 kg/m³. Ein Kubikmeter wiegt also je nach Art etwa 2,0 bis 2,1 Tonnen."
        }
      },
      {
        "@type": "Question",
        "name": "Wie dick muss Estrich mindestens sein?",
        "acceptedAnswer": {
