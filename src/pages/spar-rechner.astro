    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Was ist der Zinseszins-Effekt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der Zinseszins-Effekt bedeutet, dass Sie nicht nur Zinsen auf Ihr eingezahltes Geld erhalten, sondern auch Zinsen auf bereits erhaltene Zinsen. Dadurch wächst Ihr Vermögen exponentiell statt linear."
        }
      },
      {
        "@type": "Question",
        "name": "Wie viel sollte ich monatlich sparen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Eine Faustregel ist 10-20% des Nettoeinkommens. Bei 2.500 € netto wären das 250-500 € monatlich. Wichtiger als die Höhe ist die Regelmäßigkeit – früh anfangen zahlt sich aus!"
        }
      },
      {
        "@type": "Question",
        "name": "Wie lange dauert es, bis sich mein Geld verdoppelt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Mit der 72er-Regel können Sie das schnell berechnen: 72 geteilt durch den Zinssatz ergibt die Jahre bis zur Verdopplung. Bei 6% Zinsen: 72 ÷ 6 = 12 Jahre."
        }
