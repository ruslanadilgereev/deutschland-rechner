---
import Layout from '../layouts/Layout.astro';
import BrueckentageRechner from '../components/rechner/BrueckentageRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = "Brückentage-Rechner 2026 – Urlaub clever planen nach Bundesland";
const description = "Brückentage 2026 optimal nutzen: Aus wenigen Urlaubstagen viele freie Tage am Stück machen. Pro Bundesland die besten Konstellationen mit Hebel-Faktor – z. B. 16 freie Tage an Ostern mit nur 8 Urlaubstagen. Kostenlos & sofort.";
const keywords = "Brückentage 2026, Brückentage Rechner, Urlaub planen 2026, Feiertage 2026, Brückentage nach Bundesland, Urlaub maximieren, Brückentage Ostern 2026, Brückentage Pfingsten 2026, freie Tage 2026, Urlaubsplanung 2026, lange Wochenenden 2026";
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Brückentage-Rechner", url: "/brueckentage-rechner" }]} />
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Arbeit & Gehalt', href: '/arbeit-gehalt' },
    { name: 'Brückentage-Rechner' }
  ]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-blue-500 to-indigo-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-blue-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🌉</span>
          <div>
            <h1 class="text-2xl font-bold">Brückentage-Rechner 2026</h1>
            <p class="text-blue-200 text-sm">Aus wenig Urlaub maximal viele freie Tage – nach Bundesland</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Trust-Block -->
    <div class="max-w-2xl mx-auto px-4 mt-4">
      <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-sm text-green-800">
        <div class="flex items-start gap-3">
          <span class="text-xl mt-0.5">✅</span>
          <div>
            <p class="font-semibold mb-1">Zuletzt aktualisiert am 5. Juni 2026</p>
            <p class="mb-1"><strong>Grundlage:</strong> Gesetzliche Feiertage 2026 aller 16 Bundesländer (DGB-Feiertagsübersicht), Wochentage exakt berechnet</p>
            <p class="mb-1"><strong>Berücksichtigt:</strong> bundesweite und landesspezifische Feiertage (Heilige Drei Könige, Fronleichnam, Buß- und Bettag), Hebel-Faktor je Konstellation, Feiertage die 2026 auf ein Wochenende fallen</p>
            <p><strong>Nicht berücksichtigt:</strong> betriebliche Brückentag-Regelungen, Schulferien Ihres Bundeslandes, Betriebsurlaub – maßgeblich ist immer Ihre individuelle Urlaubsplanung mit dem Arbeitgeber</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <BrueckentageRechner client:load />
    </div>

    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Brückentage 2026: Urlaub clever planen</h2>

        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Ein <strong>Brückentag</strong> ist ein einzelner Arbeitstag, der zwischen einem gesetzlichen
            Feiertag und dem Wochenende liegt. Nehmen Sie genau diesen Tag frei, „überbrücken“ Sie die
            Lücke und erhalten mehrere freie Tage am Stück – bei minimalem Einsatz von Urlaubstagen.
            Mit unserem <strong>Brückentage-Rechner 2026</strong> sehen Sie für Ihr Bundesland sofort,
            welche Urlaubstage sich am meisten lohnen. Wie viele Urlaubstage Ihnen überhaupt zustehen,
            ermitteln Sie mit dem
            <a href="/urlaubstage-rechner" class="text-blue-600 hover:text-blue-800 underline">Urlaubstage-Rechner</a>.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Warum 2026 ein eher schwaches Brückentage-Jahr ist</h3>
          <p>
            2026 fallen ungewöhnlich viele Feiertage auf ein Wochenende und „verpuffen“ damit: der
            <strong>Tag der Deutschen Einheit</strong> (Sa, 03.10.), der <strong>2. Weihnachtstag</strong>
            (Sa, 26.12.), <strong>Allerheiligen</strong> (So, 01.11.) sowie der <strong>Reformationstag</strong>
            (Sa, 31.10.). Umso wichtiger ist es, die starken Brücken im Frühjahr und zum Jahreswechsel
            gezielt zu nutzen.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Der Hebel-Faktor erklärt</h3>
          <p>
            Der <strong>Hebel-Faktor</strong> beschreibt, wie viele freie Tage Sie pro eingesetztem
            Urlaubstag herausholen. Beispiel: An Christi Himmelfahrt (Do, 14.05.2026) reicht
            <strong>ein</strong> Urlaubstag am Freitag, um <strong>vier</strong> freie Tage am Stück
            zu erhalten – das ist ein Hebel von 4×. Die besten 1-Tages-Brücken 2026 liegen an
            Christi Himmelfahrt, Neujahr, dem 1. Mai und – in katholischen Bundesländern – an Fronleichnam.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Die stärksten Konstellationen 2026</h3>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>Ostern:</strong> 8 Urlaubstage → 16 freie Tage (28.03.–12.04.)</li>
              <li><strong>Weihnachten &amp; Neujahr:</strong> 8 Urlaubstage → 16 freie Tage (19.12.2026–03.01.2027)</li>
              <li><strong>Himmelfahrt + Pfingsten:</strong> 6 Urlaubstage → 12 freie Tage (14.05.–25.05.)</li>
              <li><strong>Pfingsten allein:</strong> 4 Urlaubstage → 9 freie Tage (23.05.–31.05.)</li>
              <li><strong>Christi Himmelfahrt allein:</strong> 1 Urlaubstag → 4 freie Tage (14.05.–17.05.)</li>
            </ul>
          </div>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Bundesland-spezifische Feiertage nutzen</h3>
          <p>
            Wer in einem katholisch geprägten Bundesland arbeitet, hat 2026 zusätzliche Brücken:
            <strong>Fronleichnam</strong> (Do, 04.06.) in Baden-Württemberg, Bayern, Hessen, Nordrhein-Westfalen,
            Rheinland-Pfalz und dem Saarland sowie <strong>Heilige Drei Könige</strong> (Di, 06.01.) in
            Baden-Württemberg, Bayern und Sachsen-Anhalt. In Sachsen kommt der <strong>Buß- und Bettag</strong>
            (Mi, 18.11.) hinzu. Mit dem
            <a href="/arbeitstage-rechner" class="text-blue-600 hover:text-blue-800 underline">Arbeitstage-Rechner</a>
            zählen Sie die tatsächlichen Arbeitstage Ihres Bundeslandes 2026.
          </p>
        </div>
      </div>
    </div>

    <!-- Beispielrechnungen -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Beispiele: So holen Sie das Maximum heraus</h2>
        <p class="text-gray-600 text-sm mb-4">
          Drei typische Strategien für die Urlaubsplanung 2026:
        </p>

        <div class="space-y-4">
          <!-- Beispiel 1 -->
          <div class="bg-gray-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 1: Maximaler Hebel mit 1 Urlaubstag</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Anlass:</div>
              <div class="font-medium text-gray-800">Christi Himmelfahrt (Do, 14.05.)</div>
              <div class="text-gray-600">Urlaubstag:</div>
              <div class="font-medium text-gray-800">Freitag, 15.05.2026</div>
              <div class="text-gray-600">Freie Tage am Stück:</div>
              <div class="font-medium text-green-700">4 Tage (14.–17.05.)</div>
              <div class="text-gray-600">Hebel-Faktor:</div>
              <div class="font-medium text-green-700">4× – bundesweit</div>
            </div>
          </div>

          <!-- Beispiel 2 -->
          <div class="bg-blue-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 2: Drei Wochen am Stück im Mai</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Anlass:</div>
              <div class="font-medium text-gray-800">Himmelfahrt + Pfingsten</div>
              <div class="text-gray-600">Urlaubstage:</div>
              <div class="font-medium text-gray-800">6 (15.05. + 18.–22.05.)</div>
              <div class="text-gray-600">Freie Tage am Stück:</div>
              <div class="font-medium text-green-700">12 Tage (14.–25.05.)</div>
              <div class="text-gray-600">Hebel-Faktor:</div>
              <div class="font-medium text-green-700">2× – bundesweit</div>
            </div>
          </div>

          <!-- Beispiel 3 -->
          <div class="bg-yellow-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 3: 16 freie Tage über die Feiertage</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Anlass:</div>
              <div class="font-medium text-gray-800">Weihnachten &amp; Neujahr</div>
              <div class="text-gray-600">Urlaubstage:</div>
              <div class="font-medium text-gray-800">8 (21.–24.12. + 28.–31.12.)</div>
              <div class="text-gray-600">Freie Tage am Stück:</div>
              <div class="font-medium text-green-700">16 Tage (19.12.–03.01.2027)</div>
              <div class="text-gray-600">Hebel-Faktor:</div>
              <div class="font-medium text-green-700">2× – bundesweit</div>
            </div>
          </div>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mt-4 text-sm text-blue-800">
          <strong>💡 Tipp:</strong> Wählen Sie oben im Rechner Ihr Bundesland aus – dann erscheinen
          zusätzlich die regionalen Brücken wie Fronleichnam oder der Buß- und Bettag. Ihren
          gesamten Urlaubsanspruch berechnen Sie mit dem
          <a href="/urlaubstage-rechner" class="text-blue-700 underline">Urlaubstage-Rechner</a>.
        </div>
      </div>
    </div>

    <!-- Typische Fehler -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">⚠️ Typische Fehler bei der Brückentag-Planung</h2>

        <div class="space-y-4 text-sm text-gray-600">
          <div class="border-l-4 border-red-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 1: Das falsche Bundesland zugrunde legen</h3>
            <p>Maßgeblich ist das Bundesland, in dem sich Ihr <strong>Arbeitsort</strong> befindet – nicht
            Ihr Wohnort. Wer in NRW wohnt, aber in Hessen arbeitet, richtet sich nach den hessischen
            Feiertagen. Fronleichnam, Heilige Drei Könige und der Buß- und Bettag gelten nur regional.</p>
          </div>

          <div class="border-l-4 border-red-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 2: Verpuffte Feiertage einplanen</h3>
            <p>2026 fallen mehrere Feiertage auf ein Wochenende (z. B. Tag der Deutschen Einheit am Sa, 03.10.
            und der 2. Weihnachtstag am Sa, 26.12.). Diese bringen <strong>keinen</strong> zusätzlichen
            freien Tag – planen Sie hier keine Brücke ein.</p>
          </div>

          <div class="border-l-4 border-orange-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 3: Zu spät beantragen</h3>
            <p>Beliebte Brückentage wie der Freitag nach Christi Himmelfahrt sind schnell vergeben. Reichen
            Sie Ihren Urlaubsantrag <strong>früh</strong> ein – bei gleichzeitigen Anträgen entscheidet oft
            das Eingangsdatum oder eine betriebliche Regelung.</p>
          </div>

          <div class="border-l-4 border-blue-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 4: Half-Day-Feiertage übersehen</h3>
            <p>Heiligabend (24.12.) und Silvester (31.12.) sind <strong>keine</strong> gesetzlichen
            Feiertage – beide fallen 2026 auf einen Donnerstag. In vielen Betrieben wird trotzdem
            (teilweise) freigegeben; prüfen Sie Ihren Arbeits- oder Tarifvertrag.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Section (sichtbar) -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">❓ Häufig gestellte Fragen zu Brückentagen 2026</h2>

        <div class="space-y-4">
          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Was ist ein Brückentag?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Ein Brückentag ist ein einzelner Arbeitstag, der zwischen einem gesetzlichen Feiertag und
              dem Wochenende liegt. Nehmen Sie diesen Tag frei, verbinden Sie Feiertag und Wochenende zu
              mehreren freien Tagen am Stück – mit minimalem Urlaubseinsatz.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viele freie Tage sind 2026 mit wenig Urlaub möglich?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>An Ostern erreichen Sie mit 8 Urlaubstagen 16 freie Tage am Stück (28.03.–12.04.2026), zu
              Weihnachten &amp; Neujahr ebenfalls 16 freie Tage mit 8 Urlaubstagen (19.12.2026–03.01.2027).
              Den höchsten Hebel pro Urlaubstag bietet 2026 Christi Himmelfahrt: 1 Urlaubstag bringt 4 freie Tage.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Warum sind die Brückentage je nach Bundesland unterschiedlich?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Neun Feiertage gelten 2026 bundesweit, acht weitere nur in bestimmten Bundesländern. So ist
              Fronleichnam (Do, 04.06.) etwa in Baden-Württemberg, Bayern, Hessen, NRW, Rheinland-Pfalz und im
              Saarland ein Feiertag, Heilige Drei Könige (Di, 06.01.) in Baden-Württemberg, Bayern und
              Sachsen-Anhalt. Wählen Sie im Rechner Ihr Bundesland, um genau diese Brücken zu sehen.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Welche Feiertage fallen 2026 auf ein Wochenende?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>2026 verpuffen mehrere Feiertage am Wochenende: Tag der Deutschen Einheit (Sa, 03.10.),
              2. Weihnachtstag (Sa, 26.12.), Allerheiligen (So, 01.11.), Reformationstag (Sa, 31.10.) sowie
              Mariä Himmelfahrt (Sa, 15.08.). Für diese Tage lässt sich kein zusätzlicher freier Tag herausholen.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Welches Bundesland zählt – Wohnort oder Arbeitsort?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Maßgeblich ist in der Regel das Bundesland Ihres <strong>Arbeitsortes</strong>. Wer also in
              einem Bundesland wohnt, aber in einem anderen arbeitet, richtet sich nach den Feiertagen am
              Arbeitsort. Wählen Sie im Rechner entsprechend das richtige Bundesland aus.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Sind Heiligabend und Silvester gesetzliche Feiertage?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Nein. Der 24.12. (Heiligabend) und der 31.12. (Silvester) sind <strong>keine</strong>
              gesetzlichen Feiertage – 2026 fallen beide auf einen Donnerstag. Viele Arbeitgeber geben
              dennoch (teilweise) frei; das regelt Ihr Arbeits- oder Tarifvertrag, nicht das Gesetz.</p>
            </div>
          </details>
        </div>
      </div>
    </div>

    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/urlaubstage-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏖️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Urlaubstage-Rechner</p>
          </a>
          <a href="/arbeitstage-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📆</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Arbeitstage-Rechner</p>
          </a>
          <a href="/ueberstunden-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">⏱️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Überstunden-Rechner</p>
          </a>
          <a href="/teilzeit-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">⚖️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Teilzeit-Rechner</p>
          </a>
          <a href="/stundenlohn-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">⌛</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Stundenlohn-Rechner</p>
          </a>
          <a href="/sabbatical-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">🏝️</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Sabbatical-Rechner</p>
          </a>
        </div>
      </div>
    </div>
  </main>

  <!-- Structured Data for SEO -->
