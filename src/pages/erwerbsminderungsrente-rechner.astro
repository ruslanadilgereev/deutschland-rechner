      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Formel lautet: Rente = Entgeltpunkte × Zugangsfaktor × Rentenartfaktor × Rentenwert. Bei voller EM ist der Rentenartfaktor 1,0, bei teilweiser EM 0,5. Der Rentenwert 2026 beträgt 40,79 €."
      }
    }
