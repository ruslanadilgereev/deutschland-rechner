---
import Layout from '../layouts/Layout.astro';
import WaehrungsRechner from '../components/rechner/WaehrungsRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Währungsrechner – Euro Wechselkurs umrechnen";
const description = "Währungsrechner für Euro: Umrechnung in Dollar, Pfund, Franken und mehr. Aktuelle Richtwerte basierend auf EZB-Referenzkursen. Kostenlos & ohne Anmeldung.";
const keywords = "Währungsrechner, Euro Wechselkurs, EUR USD umrechnen, Dollar Euro Kurs, Pfund Euro, Schweizer Franken, Wechselkurs berechnen, Devisen, EZB Referenzkurs, Währung umrechnen";
import RechnerFeedback from '../components/RechnerFeedback.astro';
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Währungsrechner", url: "/waehrungs-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-green-500 to-teal-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-green-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">💱</span>
          <div>
            <h1 class="text-2xl font-bold">Währungsrechner</h1>
            <p class="text-green-100 text-sm">Euro in andere Währungen umrechnen</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <WaehrungsRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Währungsrechner: Euro-Wechselkurse verstehen</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem <strong>Währungsrechner</strong> rechnen Sie schnell Euro in andere Währungen 
            um – von US-Dollar über Britisches Pfund bis Schweizer Franken. Die angezeigten Kurse 
            sind Richtwerte basierend auf <strong>EZB-Referenzkursen</strong>.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Wichtige Wechselkurse für Euro</h3>
          <p>
            Die wichtigsten Währungspaare für den Euro (Stand: März 2026):
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>EUR/USD:</strong> ~1,18 (1 Euro = 1,18 US-Dollar)</li>
            <li><strong>EUR/GBP:</strong> ~0,83 (1 Euro = 0,83 Britische Pfund)</li>
            <li><strong>EUR/CHF:</strong> ~0,96 (1 Euro = 0,96 Schweizer Franken)</li>
            <li><strong>EUR/JPY:</strong> ~158 (1 Euro = 158 Japanische Yen)</li>
            <li><strong>EUR/PLN:</strong> ~4,15 (1 Euro = 4,15 Polnische Złoty)</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was beeinflusst den Wechselkurs?</h3>
          <p>
            Wechselkurse werden durch Angebot und Nachfrage bestimmt. Wichtige Einflussfaktoren:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Zinsdifferenzen:</strong> Höhere Zinsen machen eine Währung attraktiver</li>
            <li><strong>Inflation:</strong> Niedrige Inflation stärkt die Währung</li>
            <li><strong>Wirtschaftswachstum:</strong> Starke Wirtschaft = starke Währung</li>
            <li><strong>Handelsbilanz:</strong> Exportüberschüsse stärken die Währung</li>
            <li><strong>Politische Stabilität:</strong> Unsicherheit schwächt die Währung</li>
            <li><strong>Zentralbankpolitik:</strong> Geldpolitische Entscheidungen der EZB/Fed</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">EZB-Referenzkurse</h3>
          <p>
            Die <strong>Europäische Zentralbank (EZB)</strong> veröffentlicht täglich gegen 16:00 Uhr 
            die offiziellen Referenzkurse. Diese gelten als Richtwerte, aber:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Sie sind <strong>keine verbindlichen Kurse</strong> für Bankgeschäfte</li>
            <li>Banken bieten eigene Kurse mit <strong>Spread</strong> (Differenz An-/Verkauf)</li>
            <li>Der tatsächliche Kurs kann <strong>mehrere Prozent abweichen</strong></li>
          </ul>
          <p>
            Für aktuelle Echtzeitkurse empfehlen wir die 
            <a href="https://www.ecb.europa.eu/stats/policy_and_exchange_rates/euro_reference_exchange_rates/html/index.de.html" class="text-green-600 underline" target="_blank">EZB-Wechselkursseite</a>.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Geld wechseln: Wo am günstigsten?</h3>
          <p>
            Die Kosten für den Währungstausch variieren stark:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Wechselstuben am Flughafen:</strong> Oft 5-10% schlechterer Kurs</li>
            <li><strong>Hausbank:</strong> Meist 1-3% Aufschlag, ggf. Gebühren</li>
            <li><strong>Online-Dienste (Wise, Revolut):</strong> Nahe am Echtzeitkurs, geringe Gebühren</li>
            <li><strong>Kreditkarte vor Ort:</strong> Visa/Mastercard-Kurs oft gut, aber ggf. Auslandsgebühr</li>
            <li><strong>Geldautomat im Ausland:</strong> EC-Karte oft teuer (bis 5%), Reisekreditkarte besser</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Tipps für den Geldwechsel</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Nicht am Flughafen wechseln</strong> – die schlechtesten Kurse</li>
            <li><strong>"Ohne Umrechnung" zahlen</strong> – bei Kartenzahlung im Ausland immer in Landeswährung</li>
            <li><strong>Reisekreditkarte nutzen</strong> – oft kostenlos Bargeld abheben weltweit</li>
            <li><strong>Größere Summen vorab tauschen</strong> – Online-Dienste bieten bessere Kurse</li>
            <li><strong>Restbeträge minimieren</strong> – Münzen werden oft nicht zurückgetauscht</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Eurozone: Wo gilt der Euro?</h3>
          <p>
            Der Euro ist offizielle Währung in 20 EU-Ländern (Eurozone):
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Deutschland, Frankreich, Italien, Spanien, Niederlande</li>
            <li>Belgien, Österreich, Finnland, Portugal, Irland</li>
            <li>Griechenland, Slowakei, Slowenien, Estland, Lettland</li>
            <li>Litauen, Luxemburg, Malta, Zypern, Kroatien (seit 2023)</li>
          </ul>
          <p>
            <strong>Nicht in der Eurozone:</strong> Polen, Tschechien, Ungarn, Schweden, Dänemark, 
            Rumänien, Bulgarien (EU-Länder mit eigener Währung).
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Starker vs. schwacher Euro</h3>
          <p>
            Ein <strong>starker Euro</strong> (z.B. EUR/USD = 1,20) bedeutet:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Günstigerer Urlaub im Nicht-Euro-Ausland</li>
            <li>Billigere Importe (Öl, Elektronik aus USA/Asien)</li>
            <li>Teurere deutsche Exporte → nachteilig für Exporteure</li>
          </ul>
          <p>
            Ein <strong>schwacher Euro</strong> (z.B. EUR/USD = 1,00) bedeutet:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Teurerer Urlaub außerhalb der Eurozone</li>
            <li>Höhere Importpreise (Energie, Rohstoffe)</li>
            <li>Wettbewerbsvorteil für deutsche Exporteure</li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Historische Entwicklung EUR/USD</h3>
          <p>
            Der Euro wurde 1999 eingeführt (als Buchgeld) und startete bei etwa 1,17 USD:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>2000:</strong> Tiefstand bei 0,83 USD (Euro-Schwäche)</li>
            <li><strong>2008:</strong> Höchststand bei 1,60 USD (Finanzkrise, Dollar-Schwäche)</li>
            <li><strong>2015:</strong> Parität fast erreicht (0,95 USD)</li>
            <li><strong>2022:</strong> Kurzfristig unter 1,00 USD (Energiekrise)</li>
            <li><strong>2025:</strong> Etwa 1,04-1,11 USD</li>
            <li><strong>2026:</strong> Etwa 1,18 USD</li>
          </ul>
        </div>
      </div>
    </div>
    
    <!-- Zuständige Behörde / Hilfe -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center gap-2">
          <span class="text-2xl">🏦</span>
          Offizielle Quellen & Tipps
        </h2>
        
        <div class="space-y-4">
          <div class="p-4 bg-blue-50 rounded-lg">
            <h3 class="font-semibold text-blue-800 mb-2">EZB-Referenzkurse</h3>
            <p class="text-blue-700 text-sm mb-2">
              Offizielle tägliche Wechselkurse der Europäischen Zentralbank:
            </p>
            <ul class="text-blue-700 text-sm space-y-1">
              <li>• <a href="https://www.ecb.europa.eu/stats/policy_and_exchange_rates/euro_reference_exchange_rates/html/index.de.html" class="underline" target="_blank">EZB Euro-Referenzkurse</a></li>
              <li>• Aktualisierung täglich um ca. 16:00 Uhr</li>
            </ul>
          </div>
          
          <div class="p-4 bg-green-50 rounded-lg">
            <h3 class="font-semibold text-green-800 mb-2">Günstig Geld wechseln</h3>
            <ul class="text-green-700 text-sm space-y-1">
              <li>• <strong>Wise</strong> (ehem. TransferWise) – Echtzeitkurse, geringe Gebühren</li>
              <li>• <strong>Revolut</strong> – Kostenlos bis zu einem Limit</li>
              <li>• <strong>Reisekreditkarte</strong> – Für Bargeld im Ausland</li>
            </ul>
          </div>
          
          <div class="p-4 bg-amber-50 rounded-lg">
            <h3 class="font-semibold text-amber-800 mb-2">Achtung bei Kartenzahlung</h3>
            <p class="text-amber-700 text-sm">
              Bei Kartenzahlung im Ausland werden Sie oft gefragt: "In Euro oder Landeswährung?" 
              Wählen Sie <strong>immer die Landeswährung</strong> – die "Dynamic Currency Conversion" 
              der Händler ist meist 3-5% teurer!
            </p>
          </div>
        </div>
      </div>
    </div>
      <RechnerFeedback rechnerName="Währungsrechner" rechnerSlug="waehrungs-rechner" />
  </main>
  
  <!-- Structured Data for SEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Währungsrechner – Euro Wechselkurs umrechnen",
    "description": description,
    "url": "https://www.deutschland-rechner.de/waehrungs-rechner",
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "EUR"
    },
    "author": {
      "@type": "Organization",
      "name": "Deutschland-Rechner"
    }
  })} />
  
  <!-- FAQ Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wie viel Dollar bekomme ich für einen Euro?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der Wechselkurs EUR/USD liegt aktuell bei etwa 1,18 (Stand März 2026). Das bedeutet: Für 1 Euro erhalten Sie ca. 1,18 US-Dollar. Der genaue Kurs ändert sich sekündlich und variiert je nach Wechselanbieter."
        }
      },
      {
        "@type": "Question",
        "name": "Wo finde ich den offiziellen Euro-Wechselkurs?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Die Europäische Zentralbank (EZB) veröffentlicht täglich um ca. 16:00 Uhr die offiziellen Referenzkurse. Diese finden Sie auf der EZB-Website. Banken und Wechselstuben können jedoch abweichende Kurse anbieten."
        }
      },
      {
        "@type": "Question",
        "name": "Wo wechsle ich am günstigsten Geld?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Am günstigsten sind Online-Dienste wie Wise oder Revolut mit Kursen nahe am Echtzeitkurs. Am teuersten sind Wechselstuben an Flughäfen (bis zu 10% Aufschlag). Bei Kartenzahlung im Ausland immer in Landeswährung zahlen."
        }
      },
      {
        "@type": "Question",
        "name": "Was bedeutet ein starker Euro?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ein starker Euro bedeutet, dass Sie für einen Euro mehr Fremdwährung bekommen. Das macht Reisen außerhalb der Eurozone günstiger und verbilligt Importe. Für deutsche Exporteure ist ein starker Euro jedoch nachteilig."
        }
      },
      {
        "@type": "Question",
        "name": "In welchen Ländern gilt der Euro?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Der Euro ist offizielle Währung in 20 EU-Ländern (Eurozone): Deutschland, Frankreich, Italien, Spanien, Niederlande, Belgien, Österreich, Finnland, Portugal, Irland, Griechenland und neun weitere. Nicht dabei: Polen, Tschechien, Schweden, Dänemark."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist die Dynamic Currency Conversion?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bei Kartenzahlung im Ausland bieten manche Händler an, in Euro statt Landeswährung abzurechnen. Das nennt sich Dynamic Currency Conversion (DCC). Der Kurs ist meist 3-5% schlechter. Wählen Sie immer die Landeswährung!"
        }
      }
    ]
  })} />
</Layout>
