import VorfaelligkeitsentschaedigungRechner from '../components/rechner/VorfaelligkeitsentschaedigungRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Vorfälligkeitsentschädigung-Rechner 2025 & 2026 – VFE berechnen";
const description = "Vorfälligkeitsentschädigung berechnen: Kosten der vorzeitigen Kreditablösung. Immobilien- & Verbraucherkredit. Restschuld, Zinssatz, Restlaufzeit.";
const keywords = "Vorfälligkeitsentschädigung Rechner, VFE berechnen, Kredit ablösen Kosten, Vorfälligkeitsentschädigung 2026, Immobilienkredit ablösen, Baufinanzierung kündigen, §502 BGB, Zinsmargenschaden, 10-Jahres-Kündigungsrecht, Sonderkündigungsrecht";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Vorfälligkeitsentschädigung-Rechner", url: "/vorfaelligkeitsentschaedigung-rechner" }]} />
  <main class="min-h-screen pb-8">
