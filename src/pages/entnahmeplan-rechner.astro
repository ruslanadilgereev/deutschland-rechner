---
import Layout from '../layouts/Layout.astro';
import EntnahmeplanRechner from '../components/rechner/EntnahmeplanRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const title = "Entnahmeplan-Rechner 2026 – Wie lange reicht mein Kapital? (FIRE & Rente)";
const description = "Entnahmeplan kostenlos berechnen: Wie lange reicht Ihr Startkapital bei monatlicher Entnahme und Verzinsung? Inklusive 4-Prozent-Regel, Restkapital-Verlauf und Inflations-Hinweis. Für Privatier, Rente & finanzielle Freiheit (FIRE).";
const keywords = "Entnahmeplan Rechner, Kapitalverzehr berechnen, 4-Prozent-Regel, FIRE Rechner, finanzielle Freiheit Rechner, Frugalisten Rechner, Frugalismus Rechner, 25x-Regel, Privatier Rechner, Auszahlplan, wie lange reicht mein Geld, Rente aus Kapital, ETF Entnahmeplan, sichere Entnahmerate";
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Entnahmeplan-Rechner", url: "/entnahmeplan-rechner" }]} />
  <Breadcrumb items={[
    { name: 'Home', href: '/' },
    { name: 'Finanzen & Kredit', href: '/finanzen-kredit' },
    { name: 'Entnahmeplan-Rechner' }
  ]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-emerald-600 to-teal-700 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a
          href="/"
          class="inline-flex items-center gap-2 text-emerald-200 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">🏖️</span>
          <div>
            <h1 class="text-2xl font-bold">Entnahmeplan-Rechner 2026</h1>
            <p class="text-emerald-200 text-sm">Wie lange reicht Ihr Kapital? Inklusive 4-Prozent-Regel</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Trust-Block -->
    <div class="max-w-2xl mx-auto px-4 mt-4">
      <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-sm text-green-800">
        <div class="flex items-start gap-3">
          <span class="text-xl mt-0.5">✅</span>
          <div>
            <p class="font-semibold mb-1">Zuletzt aktualisiert am 13. Juni 2026</p>
            <p class="mb-1"><strong>Grundlage:</strong> Finanzmathematische Standardberechnung des Kapitalverzehrs (monatlich verzinstes Restkapital) sowie die 4-Prozent-Regel aus der Trinity-Studie (Cooley, Hubbard, Walz, 1998)</p>
            <p class="mb-1"><strong>Berücksichtigt:</strong> Startkapital, erwartete Rendite p.&nbsp;a., monatliche Entnahme, Laufzeit bis zum Kapitalverzehr, „ewige" Entnahme bei ausreichender Verzinsung, Restkapital-Verlauf</p>
            <p><strong>Nicht berücksichtigt:</strong> Inflation (rechnen Sie ggf. mit der realen Rendite), Steuern, Renditeschwankungen und das Renditereihenfolge-Risiko – der Rechner liefert eine Orientierung, keine Anlageberatung</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <EntnahmeplanRechner client:load />
    </div>

    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Entnahmeplan berechnen: So lange reicht Ihr Kapital</h2>

        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Ein <strong>Entnahmeplan</strong> (auch Auszahlplan oder Kapitalverzehr-Plan) beantwortet
            eine der wichtigsten Fragen rund um Ruhestand und finanzielle Freiheit:
            <strong>Wie lange reicht mein angespartes Vermögen, wenn ich jeden Monat einen festen
            Betrag entnehme?</strong> Anders als beim
            <a href="/zinseszins-rechner" class="text-blue-600 hover:text-blue-800 underline">Sparen</a>
            wird das Kapital hier nicht aufgebaut, sondern planmäßig abgebaut – während der noch
            vorhandene Rest weiter verzinst wird.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">So funktioniert die Berechnung</h3>
          <p>
            Der Rechner simuliert Ihren Entnahmeplan Monat für Monat. In jedem Monat passiert
            Folgendes:
          </p>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>1. Verzinsung:</strong> Das Restkapital wächst um den Monatszins (Rendite p.&nbsp;a. ÷ 12)</li>
              <li><strong>2. Entnahme:</strong> Anschließend wird Ihre monatliche Entnahme abgezogen</li>
              <li><strong>3. Wiederholung:</strong> bis das Kapital aufgebraucht ist</li>
            </ul>
          </div>
          <p>
            Reichen die Erträge dauerhaft aus, um die Entnahme zu decken (Jahreszinsen ≥ Jahresentnahme),
            wird das Kapital nie aufgebraucht – der Rechner zeigt dann „unbegrenzt". Genau das ist
            das Prinzip der <strong>ewigen Rente</strong>.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Die 4-Prozent-Regel</h3>
          <p>
            Die wohl bekannteste Faustregel der FIRE-Bewegung („Financial Independence, Retire Early")
            stammt aus der <strong>Trinity-Studie</strong> von 1998. Sie besagt: Wer jährlich
            <strong>4 % seines Startkapitals</strong> entnimmt (inflationsangepasst), hat über einen
            Zeitraum von <strong>30 Jahren</strong> eine sehr hohe Wahrscheinlichkeit, dass das Geld
            reicht – in der Studie lag die Erfolgsquote bei einer Aktienquote von 50&nbsp;% bei
            mindestens 95&nbsp;%, bei 75&nbsp;% Aktien sogar bei 100&nbsp;% über alle untersuchten
            Zeiträume.
          </p>
          <p>
            Umgekehrt formuliert: Für finanzielle Unabhängigkeit benötigen Sie etwa das
            <strong>25-Fache Ihrer jährlichen Ausgaben</strong> als Kapital. Wer 24.000 € pro Jahr
            (2.000 € im Monat) braucht, kommt rechnerisch auf ein Zielvermögen von 600.000 €.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">4 % oder doch konservativer?</h3>
          <p>
            Die 4-%-Regel basiert auf historischen US-Marktdaten (S&amp;P&nbsp;500 und Anleihen). Für
            Deutschland mit höherer Steuerlast und bei längeren Entnahmezeiträumen empfehlen viele
            Experten eine vorsichtigere Rate von <strong>3 bis 3,5 %</strong>. Der Rechner zeigt
            Ihnen beide Marken – die 4-%- und die konservativere 3,5-%-Entnahme – damit Sie einen
            Puffer einplanen können.
          </p>

          <h3 class="text-lg font-semibold text-gray-800 mt-6">Warum Inflation alles verändert</h3>
          <p>
            2.000 € heute sind in 20 Jahren bei 2 % Inflation nur noch rund 1.345 € wert. Wer die
            Kaufkraft halten will, sollte die Entnahme über die Jahre erhöhen – oder von vornherein
            mit der <strong>realen Rendite</strong> rechnen (Rendite minus Inflation). Tragen Sie also
            bei einer erwarteten Aktienrendite von 7 % und 2 % Inflation lieber rund 5 % als reale
            Rendite ein. Wie viel Ihnen im Alter tatsächlich fehlt, zeigt der
            <a href="/rentenluecke-rechner" class="text-blue-600 hover:text-blue-800 underline">Rentenlücken-Rechner</a>.
          </p>
        </div>
      </div>
    </div>

    <!-- Beispielrechnungen -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Beispielrechnungen</h2>
        <p class="text-gray-600 text-sm mb-4">
          So wirken sich unterschiedliche Annahmen auf die Laufzeit aus:
        </p>

        <div class="space-y-4">
          <!-- Beispiel 1 -->
          <div class="bg-gray-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 1: 500.000 € mit 4 % Entnahme</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Startkapital:</div>
              <div class="font-medium text-gray-800">500.000 €</div>
              <div class="text-gray-600">Rendite p.&nbsp;a.:</div>
              <div class="font-medium text-gray-800">5 %</div>
              <div class="text-gray-600">Entnahme pro Monat:</div>
              <div class="font-medium text-gray-800">1.667 € (4 % / Jahr)</div>
              <div class="text-gray-600">Jahreszinsen:</div>
              <div class="font-medium text-gray-800">25.000 €</div>
              <div class="text-gray-600">Jahresentnahme:</div>
              <div class="font-medium text-gray-800">20.000 €</div>
              <div class="text-gray-600">Ergebnis:</div>
              <div class="font-medium text-green-700">reicht unbegrenzt</div>
            </div>
            <p class="text-xs text-gray-500 mt-2">
              Die Erträge (25.000 €) übersteigen die Entnahme (20.000 €) – das Kapital wächst sogar.
            </p>
          </div>

          <!-- Beispiel 2 -->
          <div class="bg-blue-50 rounded-lg p-4">
            <h3 class="font-semibold text-gray-800 mb-2">Beispiel 2: 300.000 € mit hoher Entnahme</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-600">Startkapital:</div>
              <div class="font-medium text-gray-800">300.000 €</div>
              <div class="text-gray-600">Rendite p.&nbsp;a.:</div>
              <div class="font-medium text-gray-800">4 %</div>
              <div class="text-gray-600">Entnahme pro Monat:</div>
              <div class="font-medium text-gray-800">2.000 €</div>
              <div class="text-gray-600">Entnahmequote:</div>
              <div class="font-medium text-gray-800">8 % / Jahr</div>
              <div class="text-gray-600">Ergebnis:</div>
              <div class="font-medium text-orange-700">rund 17 Jahre</div>
            </div>
            <p class="text-xs text-gray-500 mt-2">
              Die hohe Entnahmequote von 8 % zehrt das Kapital trotz Verzinsung in gut 17 Jahren auf.
            </p>
          </div>
        </div>

        <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mt-4 text-sm text-blue-800">
          <strong>💡 Tipp:</strong> Je niedriger die Entnahmequote im Verhältnis zur Rendite, desto
          länger reicht das Kapital. Bleibt die Entnahme unter den Erträgen, hält es sogar unbegrenzt.
        </div>
      </div>
    </div>

    <!-- Finanzielle Freiheit & FIRE -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Finanzielle Freiheit &amp; FIRE: Zielkapital nach der 4-%-/25x-Regel</h2>

        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            <strong>Finanzielle Freiheit</strong> bedeutet, dass Ihr Vermögen genug abwirft, um Ihre
            Lebenshaltungskosten dauerhaft zu decken – ohne auf ein aktives Erwerbseinkommen angewiesen
            zu sein. Genau hier setzt die <strong>FIRE-Bewegung</strong> („Financial Independence,
            Retire Early") an. Als Faustformel für das nötige Zielkapital dient die <strong>25x-Regel</strong>:
            Sie ist die Kehrseite der 4-%-Regel und besagt, dass Sie das <strong>25-Fache Ihrer
            jährlichen Ausgaben</strong> ansparen müssen, um anschließend rechnerisch jährlich 4 %
            entnehmen zu können.
          </p>
          <p>
            So berechnen Sie Ihr persönliches FIRE-Zielkapital für die finanzielle Freiheit in zwei
            Schritten:
          </p>
          <div class="bg-blue-50 p-4 rounded-lg my-4">
            <ul class="space-y-2 text-sm">
              <li><strong>1. Jahresausgaben ermitteln:</strong> monatliche Ausgaben × 12</li>
              <li><strong>2. Mit 25 multiplizieren:</strong> Jahresausgaben × 25 = Zielkapital (FIRE-Number)</li>
            </ul>
          </div>
          <p>
            Ein Rechenbeispiel: Wer mit <strong>1.500 € im Monat</strong> auskommt, braucht 18.000 €
            im Jahr und damit ein Zielvermögen von <strong>450.000 €</strong> (18.000 € × 25). Bei
            <strong>2.500 € monatlich</strong> sind es 30.000 € pro Jahr und folglich <strong>750.000 €</strong>.
            Sobald dieses Kapital erreicht ist, prüfen Sie mit dem Rechner oben, wie lange es bei Ihrer
            geplanten Entnahme und Rendite reicht – und ob es sogar in die „ewige Rente" übergeht.
          </p>
          <p>
            Wie schnell Sie dieses Zielkapital erreichen, hängt vor allem von Ihrer <strong>Sparquote</strong>
            ab: Wer einen großen Teil des Einkommens investiert, verkürzt den Weg zur finanziellen
            Freiheit drastisch. Mit dem
            <a href="/etf-sparplan-rechner" class="text-blue-600 hover:text-blue-800 underline">ETF-Sparplan-Rechner</a>
            und dem
            <a href="/zinseszins-rechner" class="text-blue-600 hover:text-blue-800 underline">Zinseszins-Rechner</a>
            ermitteln Sie die Ansparphase, mit diesem Entnahmeplan-Rechner die Auszahlphase danach.
          </p>
        </div>
      </div>
    </div>

    <!-- Typische Fehler -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">⚠️ Typische Fehler beim Entnahmeplan</h2>

        <div class="space-y-4 text-sm text-gray-600">
          <div class="border-l-4 border-red-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 1: Inflation ignorieren</h3>
            <p>Wer 30 Jahre lang konstant 2.000 € entnimmt, verliert massiv an Kaufkraft. Rechnen
            Sie mit der realen Rendite (Rendite minus Inflation) oder erhöhen Sie die Entnahme jährlich.</p>
          </div>

          <div class="border-l-4 border-red-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 2: Zu hohe Durchschnittsrendite ansetzen</h3>
            <p>Eine optimistische Rendite verlängert die Laufzeit auf dem Papier dramatisch. Bleiben
            Sie vorsichtig: Für ein Aktiendepot sind real eher 5 % als 8 % realistisch.</p>
          </div>

          <div class="border-l-4 border-orange-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 3: Renditereihenfolge-Risiko unterschätzen</h3>
            <p>Crasht die Börse direkt zu Beginn der Entnahmephase, müssen Sie aus einem geschrumpften
            Depot entnehmen. Das kann das Kapital deutlich früher aufzehren – selbst bei guter
            Durchschnittsrendite über die Jahre.</p>
          </div>

          <div class="border-l-4 border-blue-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 4: Steuern vergessen</h3>
            <p>Auf Kursgewinne fällt in Deutschland Abgeltungsteuer (25 % plus Soli, ggf. Kirchensteuer)
            an. Die Netto-Entnahme ist dadurch geringer als der hier angezeigte Bruttobetrag.</p>
          </div>

          <div class="border-l-4 border-blue-400 pl-4">
            <h3 class="font-semibold text-gray-800">Fehler 5: Keinen Puffer einplanen</h3>
            <p>Die 4-%-Regel ist kein Naturgesetz. Wer auf Nummer sicher gehen will, entnimmt
            3 bis 3,5 % oder hält einen Cash-Puffer für schlechte Börsenjahre bereit.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- FAQ Section (sichtbar) -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">❓ Häufig gestellte Fragen zum Entnahmeplan</h2>

        <div class="space-y-4">
          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie lange reicht mein Kapital bei monatlicher Entnahme?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Das hängt von drei Größen ab: Startkapital, erwarteter Rendite und der Höhe der
              monatlichen Entnahme. Der Rechner simuliert jeden Monat die Verzinsung des Restkapitals
              und zieht dann die Entnahme ab – bis das Geld aufgebraucht ist. Liegt die jährliche
              Entnahme unter den jährlichen Erträgen, reicht das Kapital sogar unbegrenzt.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Was ist die 4-Prozent-Regel?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Die 4-Prozent-Regel stammt aus der Trinity-Studie (1998) und besagt: Wer jährlich
              4 % seines Startkapitals entnimmt, hat über 30 Jahre eine sehr hohe Wahrscheinlichkeit,
              dass das Geld reicht. Umgekehrt benötigen Sie etwa das 25-Fache Ihrer Jahresausgaben
              als Vermögen. Für Deutschland gilt wegen höherer Steuern oft eine konservativere Marke
              von 3 bis 3,5 %.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Was sind Frugalisten und was bedeutet Frugalismus?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Frugalisten sind Menschen, die durch eine sehr hohe Sparquote (oft 50 % oder mehr des
              Einkommens) möglichst früh finanzielle Freiheit erreichen wollen – Frugalismus ist die
              dahinterstehende Lebensphilosophie aus bewusstem Konsum und konsequentem Investieren.
              Frugalismus ist damit der deutsche Zweig der internationalen FIRE-Bewegung. Für die
              Auszahlphase nutzen Frugalisten typischerweise die 4-Prozent-Regel und die 25x-Regel:
              Das Zielkapital entspricht etwa dem 25-Fachen der Jahresausgaben. Mit diesem Rechner
              prüfen Sie, wie lange Ihr angespartes Vermögen bei der geplanten Entnahme trägt.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viel Kapital brauche ich für finanzielle Freiheit?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Als Faustformel gilt die 25x-Regel: Multiplizieren Sie Ihre jährlichen Ausgaben mit
              25, um das Zielkapital (die „FIRE-Number“) für finanzielle Freiheit zu erhalten. Wer mit
              1.500 € im Monat (18.000 € pro Jahr) auskommt, braucht rund 450.000 €; bei 2.500 €
              monatlich (30.000 € pro Jahr) sind es 750.000 €. Die 25x-Regel ist die Kehrseite der
              4-Prozent-Regel: Aus dem 25-Fachen lassen sich rechnerisch jährlich 4 % entnehmen. Wegen
              Steuern und Inflation sollten Sie in Deutschland eher mit dem 28- bis 33-Fachen (3 bis
              3,5 % Entnahme) planen.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Wie viel Kapital brauche ich für 2.000 € im Monat?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>2.000 € pro Monat sind 24.000 € im Jahr. Nach der 4-Prozent-Regel benötigen Sie das
              25-Fache, also rund 600.000 € Startkapital. Soll das Kapital allein aus den Erträgen
              dauerhaft halten („ewige Rente"), genügen bei 5 % Rendite rein rechnerisch schon
              480.000 €, weil dann die Jahreszinsen (24.000 €) die Entnahme exakt decken. Wegen
              Steuern und Inflation ist der größere Puffer der 4-Prozent-Regel aber sinnvoller.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Muss ich die Inflation berücksichtigen?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Unbedingt. Bei 2 % Inflation halbiert sich die Kaufkraft etwa alle 35 Jahre. Am
              einfachsten rechnen Sie mit der realen Rendite (erwartete Rendite minus Inflation),
              dann sind die angezeigten Beträge in heutiger Kaufkraft zu verstehen. Alternativ erhöhen
              Sie Ihre Entnahme jedes Jahr um die Inflationsrate.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Was ist das Renditereihenfolge-Risiko?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Das Renditereihenfolge-Risiko (engl. „sequence of returns risk") beschreibt: Nicht
              nur die Höhe der Durchschnittsrendite zählt, sondern auch ihre Reihenfolge. Fallen die
              Kurse direkt zu Beginn der Entnahmephase stark, entnehmen Sie aus einem geschrumpften
              Depot – das Kapital kann dann trotz guter Durchschnittsrendite deutlich früher aufgebraucht
              sein. Dieser Rechner rechnet mit einer konstanten Rendite und bildet dieses Risiko nicht ab.</p>
            </div>
          </details>

          <details class="border border-gray-200 rounded-lg">
            <summary class="p-4 cursor-pointer font-medium text-gray-800 hover:bg-gray-50">Ersetzt dieser Rechner eine Finanzberatung?</summary>
            <div class="px-4 pb-4 text-sm text-gray-600">
              <p>Nein. Der Entnahmeplan-Rechner liefert eine Orientierung auf Basis vereinfachter
              Annahmen (konstante Rendite, keine Steuern, keine Inflation). Er ersetzt keine
              individuelle Finanz- oder Anlageberatung. Alle Angaben erfolgen ohne Gewähr.</p>
            </div>
          </details>
        </div>
      </div>
    </div>

    <!-- Verwandte Rechner -->
    <div class="max-w-2xl mx-auto px-4 mt-6">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">📊 Verwandte Rechner</h2>
        <div class="grid grid-cols-2 gap-3">
          <a href="/zinseszins-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">📈</span>
            <p class="font-medium text-gray-800 text-sm mt-1">Zinseszins-Rechner</p>
          </a>
          <a href="/etf-sparplan-rechner" class="p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
            <span class="text-2xl">💹</span>
            <p class="font-medium text-gray-800 text-sm mt-1">ETF-Sparplan-Rechner</p>
