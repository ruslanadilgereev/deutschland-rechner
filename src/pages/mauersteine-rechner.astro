        }
      },
      {
        "@type": "Question",
        "name": "Muss ich Fenster und Türen abziehen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Ziehen Sie die Summe aller Öffnungen in m² von der Wandfläche ab, damit Sie nicht zu viele Steine bestellen. Im Rechner gibt es dafür das Feld „Aussparungen“."
        }
      }
    ]
  })} />
</Layout>
