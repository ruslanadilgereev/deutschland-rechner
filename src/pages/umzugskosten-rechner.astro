---
import Layout from '../layouts/Layout.astro';
import UmzugskostenRechner from '../components/rechner/UmzugskostenRechner';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';

const title = "Umzugskosten-Rechner – Was kostet ein Umzug?";
const description = "Umzugskosten-Rechner 2026: Berechnen Sie Ihre Umzugskosten nach Wohnungsgröße & Entfernung. Vergleich Umzugsfirma vs. Selbstumzug inkl. Steuer-Tipps.";
const keywords = "Umzugskosten Rechner, Was kostet ein Umzug, Umzugskosten berechnen, Umzugsfirma Kosten, Selbstumzug Kosten, Umzugskosten Entfernung, Umzugskosten Wohnungsgröße, Umzug steuerlich absetzbar, Umzugskostenpauschale 2026, Umzugskosten Checkliste";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <BreadcrumbSchema items={[{ name: "Umzugskosten-Rechner", url: "/umzugskosten-rechner" }]} />
  <main class="min-h-screen pb-8">
    <!-- Header mit Zurück-Button -->
    <header class="bg-gradient-to-r from-orange-500 to-red-600 text-white py-6 px-4">
      <div class="max-w-2xl mx-auto">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-orange-100 hover:text-white mb-4 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Alle Rechner
        </a>
        <div class="flex items-center gap-3">
          <span class="text-4xl">📦</span>
          <div>
            <h1 class="text-2xl font-bold">Umzugskosten-Rechner</h1>
            <p class="text-orange-100 text-sm">Kosten nach Entfernung & Wohnungsgröße berechnen</p>
          </div>
        </div>
      </div>
    </header>

    <!-- Calculator -->
    <div class="max-w-2xl mx-auto px-4 py-6">
      <UmzugskostenRechner client:load />
    </div>
    
    <!-- SEO Content Section -->
    <div class="max-w-2xl mx-auto px-4 mt-8">
      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h2 class="text-xl font-bold text-gray-800 mb-4">Umzugskosten-Rechner 2026: Alle Kosten im Überblick</h2>
        
        <div class="prose prose-sm text-gray-600 space-y-4">
          <p>
            Mit unserem <strong>Umzugskosten-Rechner</strong> ermitteln Sie schnell und kostenlos, was Ihr Umzug 
            tatsächlich kosten wird. Ob <strong>Umzug mit Firma</strong> oder <strong>Selbstumzug</strong> – wir 
            berechnen alle Kosten basierend auf Ihrer Wohnungsgröße, Entfernung und gewünschten Zusatzleistungen.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Was kostet ein Umzug durchschnittlich?</h3>
          <p>
            Die <strong>durchschnittlichen Umzugskosten</strong> in Deutschland variieren stark je nach Wohnungsgröße 
            und Entfernung:
          </p>
          <div class="overflow-x-auto">
            <table class="min-w-full border-collapse text-sm">
              <thead>
                <tr class="bg-orange-50">
                  <th class="border border-gray-200 px-3 py-2 text-left">Wohnungsgröße</th>
                  <th class="border border-gray-200 px-3 py-2 text-left">Nahumzug (bis 50 km)</th>
                  <th class="border border-gray-200 px-3 py-2 text-left">Fernumzug (100+ km)</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="border border-gray-200 px-3 py-2">1-Zimmer (30 m²)</td>
                  <td class="border border-gray-200 px-3 py-2">300 – 600 €</td>
                  <td class="border border-gray-200 px-3 py-2">600 – 1.000 €</td>
                </tr>
                <tr class="bg-gray-50">
                  <td class="border border-gray-200 px-3 py-2">2-Zimmer (50 m²)</td>
                  <td class="border border-gray-200 px-3 py-2">500 – 900 €</td>
                  <td class="border border-gray-200 px-3 py-2">900 – 1.500 €</td>
                </tr>
                <tr>
                  <td class="border border-gray-200 px-3 py-2">3-Zimmer (75 m²)</td>
                  <td class="border border-gray-200 px-3 py-2">700 – 1.200 €</td>
                  <td class="border border-gray-200 px-3 py-2">1.200 – 2.200 €</td>
                </tr>
                <tr class="bg-gray-50">
                  <td class="border border-gray-200 px-3 py-2">4-Zimmer (100 m²)</td>
                  <td class="border border-gray-200 px-3 py-2">1.000 – 1.800 €</td>
                  <td class="border border-gray-200 px-3 py-2">1.800 – 3.000 €</td>
                </tr>
                <tr>
                  <td class="border border-gray-200 px-3 py-2">Haus (150+ m²)</td>
                  <td class="border border-gray-200 px-3 py-2">1.500 – 3.000 €</td>
                  <td class="border border-gray-200 px-3 py-2">2.500 – 5.000+ €</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-gray-500 mt-2">
            *Preise für professionelle Umzugsfirma inkl. Be-/Entladung, Transport und einfacher Möbelmontage (Stand 2024/2025)
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Umzugsfirma vs. Selbstumzug: Was lohnt sich?</h3>
          <p>
            Die Entscheidung zwischen <strong>professionellem Umzug</strong> und <strong>Selbstumzug</strong> 
            hängt von mehreren Faktoren ab:
          </p>
          
          <div class="grid md:grid-cols-2 gap-4 mt-4">
            <div class="bg-green-50 p-4 rounded-lg">
              <h4 class="font-semibold text-green-800 mb-2">✅ Vorteile Umzugsfirma</h4>
              <ul class="list-disc pl-5 space-y-1 text-green-700">
                <li>Professionelle Abwicklung & Zeitersparnis</li>
                <li>Versicherungsschutz für Möbel</li>
                <li>Fachgerechte Möbelmontage</li>
                <li>Keine körperliche Belastung</li>
                <li>Halteverbotszone wird organisiert</li>
              </ul>
            </div>
            <div class="bg-blue-50 p-4 rounded-lg">
              <h4 class="font-semibold text-blue-800 mb-2">💪 Vorteile Selbstumzug</h4>
              <ul class="list-disc pl-5 space-y-1 text-blue-700">
                <li>Deutlich günstigere Kosten</li>
                <li>Flexible Zeitplanung</li>
                <li>Kontrolle über alle Abläufe</li>
                <li>Hilfe von Freunden/Familie</li>
                <li>Eigenes Tempo beim Auspacken</li>
              </ul>
            </div>
          </div>
          
          <p class="mt-4">
            <strong>Faustregel:</strong> Ein Selbstumzug lohnt sich bei kleinen Wohnungen (bis 50 m²) und 
            kurzen Entfernungen. Bei Fernumzügen oder größeren Haushalten überwiegen oft die Vorteile einer 
            Umzugsfirma, besonders wenn man den Zeitaufwand und die körperliche Belastung einrechnet.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Diese Faktoren beeinflussen die Umzugskosten</h3>
          <ul class="list-disc pl-5 space-y-2">
            <li>
              <strong>Entfernung:</strong> Nahumzüge (unter 50 km) sind deutlich günstiger als Fernumzüge. 
              Bei Umzügen über 100 km verdoppeln sich die Kosten oft.
            </li>
            <li>
              <strong>Umzugsvolumen:</strong> Die Kubikmeter-Zahl Ihres Hausrats bestimmt LKW-Größe und 
              Arbeitsaufwand. Faustregel: ca. 10-15 m³ pro 25 m² Wohnfläche.
            </li>
            <li>
              <strong>Etage & Aufzug:</strong> Jede Etage ohne Aufzug erhöht den Preis um 20-50 €. 
              Bei schwierigen Zugangswegen wird ein Möbellift benötigt.
            </li>
            <li>
              <strong>Zusatzleistungen:</strong> Packservice (+15-25 €/m³), Möbelmontage (+50-150 €), 
              Halteverbotszone (+80-200 €), Einlagerung (ab 50 €/Monat).
            </li>
            <li>
              <strong>Umzugstermin:</strong> Monatsanfang und -ende sowie Wochenenden sind teurer. 
              In der Hauptsaison (April-September) steigen die Preise um 10-20%.
            </li>
          </ul>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Umzugsnebenkosten: Oft unterschätzt!</h3>
          <p>
            Neben den reinen Umzugskosten fallen weitere <strong>Nebenkosten</strong> an, die Sie einplanen sollten:
          </p>
          <ul class="list-disc pl-5 space-y-2">
            <li>
              <strong>Mietkaution:</strong> 2-3 Monats-Kaltmieten für die neue Wohnung. 
              Nutzen Sie unseren <a href="/mietkaution-rechner" class="text-orange-600 hover:underline">Mietkaution-Rechner</a> 
              zur Berechnung.
            </li>
            <li>
              <strong>Doppelmiete:</strong> Überschneidung alter und neuer Mietvertrag (oft 1-2 Monate).
            </li>
            <li>
              <strong>Renovierung:</strong> Schönheitsreparaturen in der alten Wohnung (ca. 5-10 €/m²).
            </li>
            <li>
              <strong>Ummeldung:</strong> Personalausweis, Kfz-Zulassung, Rundfunkbeitrag, Versicherungen.
            </li>
            <li>
              <strong>Nachsendeauftrag:</strong> Deutsche Post ab 28,90 € (6 Monate).
            </li>
            <li>
              <strong>Neue Einrichtung:</strong> Gardinen, Lampen, evtl. neue Möbel für andere Raummaße.
            </li>
          </ul>
          <p>
            Berechnen Sie Ihre monatlichen <strong>Nebenkosten</strong> in der neuen Wohnung mit unserem 
            <a href="/nebenkosten-rechner" class="text-orange-600 hover:underline">Nebenkosten-Rechner</a>.
          </p>
          
          <h3 class="text-lg font-semibold text-gray-800 mt-6">Umzugskosten steuerlich absetzen</h3>
          <p>
            Bei einem <strong>beruflich bedingten Umzug</strong> können Sie die Kosten als Werbungskosten 
            in Ihrer Steuererklärung geltend machen. Ein Umzug gilt als beruflich veranlasst, wenn:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Sie durch den Umzug <strong>mindestens 1 Stunde Arbeitsweg pro Tag einsparen</strong></li>
            <li>Sie eine <strong>neue Arbeitsstelle</strong> in einer anderen Stadt antreten</li>
            <li>Ihr Arbeitgeber Sie an einen anderen Standort <strong>versetzt</strong></li>
            <li>Sie aus dem Ausland nach Deutschland <strong>zurückkehren</strong></li>
          </ul>
          
          <h4 class="font-semibold text-gray-700 mt-4">Umzugskostenpauschale 2024/2025/2026</h4>
          <p>
            Seit dem 1. März 2024 gelten folgende <strong>Pauschbeträge</strong> für sonstige Umzugsauslagen 
            (BMF-Schreiben vom 28.12.2023). Für 2025 und 2026 gab es keine weitere Erhöhung:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li><strong>Berechtigte Person:</strong> 964 €</li>
            <li><strong>Jede weitere Person im Haushalt:</strong> zusätzlich 643 €</li>
          </ul>
          <p class="mt-2">
            <em>Beispiel:</em> Familie mit 2 Kindern = 964 € + 3 × 643 € = <strong>2.893 €</strong> Pauschale
          </p>
          <p class="mt-2">
            Zusätzlich zur Pauschale können Sie <strong>nachgewiesene Einzelkosten</strong> absetzen:
          </p>
          <ul class="list-disc pl-5 space-y-1">
            <li>Umzugsfirma (vollständig)</li>
            <li>Maklergebühren für Mietwohnungen</li>
            <li>Doppelte Mietzahlungen (bis 6 Monate)</li>
            <li>Fahrtkosten zu Wohnungsbesichtigungen (0,38 €/km ab 2026)</li>
            <li>Reparatur von Transportschäden</li>
          </ul>
        </div>
        
        <!-- FAQ Section -->
        <div class="mt-8 border-t border-gray-200 pt-6">
          <h2 class="text-xl font-bold text-gray-800 mb-4">Häufig gestellte Fragen (FAQ)</h2>
          
          <div class="space-y-4">
            <details class="bg-gray-50 rounded-lg p-4 cursor-pointer group">
              <summary class="font-semibold text-gray-800 flex justify-between items-center">
                Was kostet ein Umzug innerhalb derselben Stadt?
                <span class="text-orange-500 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="mt-3 text-gray-600">
                Ein <strong>Nahumzug innerhalb der Stadt</strong> kostet mit Umzugsfirma je nach Wohnungsgröße 
                zwischen 300 und 1.500 €. Für eine 2-Zimmer-Wohnung können Sie mit etwa 500-800 € rechnen, 
                für eine 3-Zimmer-Wohnung mit 700-1.200 €. Beim Selbstumzug liegen die Kosten bei etwa 
                150-500 € (Transporter, Helfer, Material).
              </p>
            </details>
            
            <details class="bg-gray-50 rounded-lg p-4 cursor-pointer group">
              <summary class="font-semibold text-gray-800 flex justify-between items-center">
                Kann ich Umzugskosten von der Steuer absetzen?
                <span class="text-orange-500 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="mt-3 text-gray-600">
                Ja, bei einem <strong>beruflich bedingten Umzug</strong> können Sie die Kosten als 
                Werbungskosten absetzen. Voraussetzung: Sie sparen durch den Umzug mindestens 1 Stunde 
                Arbeitsweg pro Tag, treten eine neue Stelle an oder werden versetzt. Die 
                <strong>Umzugskostenpauschale</strong> beträgt seit März 2024 964 € (+ 643 € pro 
                weitere Person). Zusätzlich können nachgewiesene Einzelkosten wie Umzugsfirma oder 
                Makler abgesetzt werden.
              </p>
            </details>
            
            <details class="bg-gray-50 rounded-lg p-4 cursor-pointer group">
              <summary class="font-semibold text-gray-800 flex justify-between items-center">
                Was kostet ein Umzug mit Umzugsfirma?
                <span class="text-orange-500 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="mt-3 text-gray-600">
                Die <strong>Kosten für eine Umzugsfirma</strong> setzen sich aus Grundpreis (abhängig vom 
                Umzugsvolumen), Entfernungszuschlag und Zusatzleistungen zusammen. Bei einem Nahumzug 
                zahlen Sie ca. 25-35 € pro m³ Umzugsgut, bei einem Fernumzug 40-55 € pro m³. Zusatzkosten: 
                Etage ohne Aufzug (+50 €), Packservice (+15-25 €/m³), Halteverbotszone (+100-200 €), 
                Möbellift (+150-300 €).
              </p>
            </details>
            
            <details class="bg-gray-50 rounded-lg p-4 cursor-pointer group">
              <summary class="font-semibold text-gray-800 flex justify-between items-center">
                Lohnt sich ein Selbstumzug?
                <span class="text-orange-500 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="mt-3 text-gray-600">
                Ein <strong>Selbstumzug</strong> lohnt sich besonders bei kleinen Wohnungen (bis 50 m²), 
                kurzen Entfernungen und wenn genügend Helfer zur Verfügung stehen. Sie können bis zu 
                50-60% der Kosten sparen. Bedenken Sie jedoch: Zeitaufwand, körperliche Anstrengung, 
                fehlendes Equipment und kein Versicherungsschutz bei Transportschäden. Bei Fernumzügen 
                oder wertvollen Möbeln empfiehlt sich eher eine Umzugsfirma.
              </p>
            </details>
            
            <details class="bg-gray-50 rounded-lg p-4 cursor-pointer group">
              <summary class="font-semibold text-gray-800 flex justify-between items-center">
                Welche Nebenkosten entstehen beim Umzug?
                <span class="text-orange-500 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="mt-3 text-gray-600">
                Neben den reinen Transportkosten sollten Sie folgende <strong>Umzugsnebenkosten</strong> 
                einplanen: Mietkaution (2-3 Kaltmieten), Doppelmiete bei Überschneidung, Renovierung der 
                alten Wohnung (5-10 €/m²), Ummeldungen (Ausweis, Kfz, Versicherungen), Nachsendeauftrag 
                (ab 29 €), neue Einrichtung (Gardinen, Lampen). Insgesamt können dies 1.000-3.000 € 
                zusätzlich sein.
              </p>
            </details>
            
            <details class="bg-gray-50 rounded-lg p-4 cursor-pointer group">
              <summary class="font-semibold text-gray-800 flex justify-between items-center">
                Wann ist die beste Zeit für einen Umzug?
                <span class="text-orange-500 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="mt-3 text-gray-600">
                Die <strong>günstigste Zeit für einen Umzug</strong> ist unter der Woche (Dienstag bis 
                Donnerstag) in der Monatsmitte, außerhalb der Hauptsaison (Oktober bis März). 
                Wochenenden, Monatsanfang/-ende und Feiertage sind teurer und meist ausgebucht. 
                Die Hauptsaison (April bis September) hat höhere Preise (+10-20%), aber besseres 
                Wetter. Tipp: Mindestens 6-8 Wochen vorher buchen!
              </p>
            </details>
            
            <details class="bg-gray-50 rounded-lg p-4 cursor-pointer group">
              <summary class="font-semibold text-gray-800 flex justify-between items-center">
                Wie berechne ich mein Umzugsvolumen?
                <span class="text-orange-500 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="mt-3 text-gray-600">
                <strong>Faustregel für das Umzugsvolumen:</strong> Pro 10 m² Wohnfläche ca. 3-4 m³ 
                Umzugsgut (bei normaler Einrichtung). Eine 60 m²-Wohnung hat also etwa 20-25 m³ Volumen. 
                Alternativ: Zählen Sie alle Möbelstücke und Kartons. Ein Umzugskarton = 0,06 m³, 
                Kleiderschrank = 1-2 m³, Sofa = 1,5 m³, Küche komplett = 3-5 m³.
              </p>
            </details>
            
            <details class="bg-gray-50 rounded-lg p-4 cursor-pointer group">
              <summary class="font-semibold text-gray-800 flex justify-between items-center">
                Zahlt der Arbeitgeber die Umzugskosten?
                <span class="text-orange-500 group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <p class="mt-3 text-gray-600">
                <strong>Bei dienstlich veranlassten Umzügen</strong> übernimmt der Arbeitgeber oft ganz 
                oder teilweise die Kosten (geregelt im Bundesumzugskostengesetz für öffentlichen Dienst). 
                Private Arbeitgeber sind nicht verpflichtet, können aber freiwillig zahlen oder 
                bezuschussen. Wichtig: Vom Arbeitgeber erstattete Kosten können Sie nicht zusätzlich 
                steuerlich absetzen. Fragen Sie frühzeitig nach einer Umzugskostenbeteiligung!
              </p>
            </details>
          </div>
        </div>

        <!-- Tipps Section -->
        <div class="mt-8 border-t border-gray-200 pt-6">
          <h2 class="text-xl font-bold text-gray-800 mb-4">💡 Umzugs-Tipps: So sparen Sie Geld</h2>
          
          <div class="grid md:grid-cols-2 gap-4">
            <div class="bg-green-50 p-4 rounded-lg">
              <h4 class="font-semibold text-green-800 mb-2">Vor dem Umzug</h4>
              <ul class="text-sm text-green-700 space-y-1">
                <li>✓ Frühzeitig Angebote vergleichen (mind. 3)</li>
                <li>✓ Ausmisten und verkaufen spart Volumen</li>
                <li>✓ Unter der Woche & Monatsmitte buchen</li>
                <li>✓ Kartons kostenlos im Supermarkt holen</li>
                <li>✓ Urlaubstage strategisch planen</li>
              </ul>
            </div>
            <div class="bg-blue-50 p-4 rounded-lg">
              <h4 class="font-semibold text-blue-800 mb-2">Am Umzugstag</h4>
              <ul class="text-sm text-blue-700 space-y-1">
                <li>✓ Alles vorher gut verpacken & beschriften</li>
                <li>✓ Möbel bereits abbauen (spart Arbeitszeit)</li>
                <li>✓ Parkplatz freihalten oder HVZ beantragen</li>
                <li>✓ Wertsachen separat transportieren</li>
                <li>✓ Fotos vom Zustand der alten Wohnung</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Internal Links Section -->
        <div class="mt-8 border-t border-gray-200 pt-6">
          <h3 class="text-lg font-semibold text-gray-800 mb-3">Verwandte Rechner</h3>
          <div class="grid grid-cols-2 gap-3">
            <a href="/mietkaution-rechner" class="bg-gray-50 hover:bg-gray-100 p-3 rounded-lg text-sm transition-colors">
              <span class="block font-medium text-gray-800">🔐 Mietkaution-Rechner</span>
              <span class="text-gray-500 text-xs">Kaution & Zinsen berechnen</span>
            </a>
            <a href="/nebenkosten-rechner" class="bg-gray-50 hover:bg-gray-100 p-3 rounded-lg text-sm transition-colors">
              <span class="block font-medium text-gray-800">🏠 Nebenkosten-Rechner</span>
              <span class="text-gray-500 text-xs">Betriebskosten kalkulieren</span>
            </a>
            <a href="/wohngeld-rechner" class="bg-gray-50 hover:bg-gray-100 p-3 rounded-lg text-sm transition-colors">
              <span class="block font-medium text-gray-800">💰 Wohngeld-Rechner</span>
              <span class="text-gray-500 text-xs">Mietzuschuss prüfen</span>
            </a>
            <a href="/pendlerpauschale-rechner" class="bg-gray-50 hover:bg-gray-100 p-3 rounded-lg text-sm transition-colors">
              <span class="block font-medium text-gray-800">🚗 Pendlerpauschale</span>
              <span class="text-gray-500 text-xs">Fahrtkosten berechnen</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Schema.org FAQ structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Was kostet ein Umzug durchschnittlich?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ein Umzug mit Umzugsfirma kostet je nach Wohnungsgröße und Entfernung zwischen 300 und 5.000 €. Eine 2-Zimmer-Wohnung kostet bei einem Nahumzug etwa 500-900 €, bei einem Fernumzug 900-1.500 €. Selbstumzüge sind 50-60% günstiger."
        }
      },
      {
        "@type": "Question",
        "name": "Kann ich Umzugskosten von der Steuer absetzen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, bei beruflich bedingten Umzügen können Sie die Kosten als Werbungskosten absetzen. Die Umzugskostenpauschale beträgt seit März 2024 964 € plus 643 € pro weitere Person im Haushalt. Zusätzlich sind nachgewiesene Einzelkosten absetzbar."
        }
      },
      {
        "@type": "Question",
        "name": "Lohnt sich ein Selbstumzug?",
        "acceptedAnswer": {
          "@type": "Answer",
