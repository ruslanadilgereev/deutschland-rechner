---
interface Props {
  rechnerName: string;
  rechnerSlug: string;
}

const { rechnerName, rechnerSlug } = Astro.props;

const githubBase = "https://github.com/ruslanadilgereev/deutschland-rechner";
const issueUrl = `${githubBase}/issues/new?template=rechner-fehler.yml&title=${encodeURIComponent(`Fehler: ${rechnerName}`)}`;
const sourceUrl = `${githubBase}/blob/master/src/pages/${rechnerSlug}.astro`;
---

<div class="max-w-2xl mx-auto px-4 mt-8 mb-4">
  <div class="bg-white rounded-2xl shadow-lg p-5">
    <div class="flex items-center gap-2 mb-3">
      <svg class="w-5 h-5 text-gray-800" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      <p class="text-sm font-semibold text-gray-800">Open-Source-Projekt</p>
    </div>
    <p class="text-sm text-gray-500 mb-4">Dieser Rechner ist Open Source. Hilf mit, ihn aktuell und korrekt zu halten.</p>
    <div class="flex flex-wrap gap-3">
      <a href={issueUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-red-50 text-red-700 hover:bg-red-100 px-4 py-2 rounded-xl text-sm font-medium transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Fehler melden
      </a>
      <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-gray-100 text-gray-700 hover:bg-gray-200 px-4 py-2 rounded-xl text-sm font-medium transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
        Quellcode ansehen
      </a>
      <a href="/mitmachen" class="inline-flex items-center gap-2 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 px-4 py-2 rounded-xl text-sm font-medium transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Mitmachen
      </a>
    </div>
  </div>
</div>
