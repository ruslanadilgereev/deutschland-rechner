---
const githubUrl = "https://github.com/ruslanadilgereev/deutschland-rechner";
---

<footer class="bg-gray-900 text-gray-400 mt-12">
  <div class="max-w-6xl mx-auto px-4 py-10">
    <!-- Mini-Sitemap Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
      <!-- Spalte 1: Kategorien -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3">Kategorien</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/familie-kinder" class="hover:text-white transition-colors">👨‍👩‍👧‍👦 Familie & Kinder</a></li>
          <li><a href="/arbeit-gehalt" class="hover:text-white transition-colors">💼 Arbeit & Gehalt</a></li>
          <li><a href="/steuern-abgaben" class="hover:text-white transition-colors">🏛️ Steuern & Abgaben</a></li>
          <li><a href="/sozialleistungen" class="hover:text-white transition-colors">🤝 Sozialleistungen</a></li>
          <li><a href="/wohnen-immobilien" class="hover:text-white transition-colors">🏠 Wohnen & Immobilien</a></li>
        </ul>
      </div>

      <!-- Spalte 2: Mehr Kategorien -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3">Mehr Kategorien</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/gesundheit" class="hover:text-white transition-colors">❤️ Gesundheit</a></li>
          <li><a href="/auto-mobilitaet" class="hover:text-white transition-colors">🚗 Auto & Mobilität</a></li>
          <li><a href="/finanzen-kredit" class="hover:text-white transition-colors">💳 Finanzen & Kredit</a></li>
          <li><a href="/alltag-lifestyle" class="hover:text-white transition-colors">🧮 Alltag & Lifestyle</a></li>
        </ul>
      </div>

      <!-- Spalte 3: Über -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3">Über</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/ueber-uns" class="hover:text-white transition-colors">Über uns</a></li>
          <li><a href="/mitmachen" class="hover:text-white transition-colors">Mitmachen</a></li>
          <li><a href={githubUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">GitHub ↗</a></li>
        </ul>
      </div>

      <!-- Spalte 4: Rechtliches -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-3">Rechtliches</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/impressum" class="hover:text-white transition-colors">Impressum</a></li>
          <li><a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a></li>
          <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
        </ul>
      </div>
    </div>

    <!-- Existierender Block: Branding + GitHub-CTA -->
    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row items-center md:items-start justify-between gap-6">
      <!-- Links -->
      <div class="text-center md:text-left">
        <p class="text-white font-semibold text-lg mb-1">Deutschlandrechner</p>
        <p class="text-sm">143+ kostenlose Rechner für Deutschland</p>
      </div>

      <!-- Rechts -->
      <div class="flex flex-col items-center md:items-end gap-3">
        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white px-4 py-2 rounded-xl text-sm font-medium transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          Open Source auf GitHub
        </a>
        <div class="flex items-center gap-4 text-sm">
          <a href="/mitmachen" class="hover:text-white transition-colors">Mitmachen</a>
          <span class="text-gray-600">&middot;</span>
          <a href={`${githubUrl}/issues/new?template=rechner-fehler.yml`} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Fehler melden</a>
        </div>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-8 pt-6 flex flex-col items-center gap-3 text-xs text-gray-500">
      <p>&copy; 2026 Deutschlandrechner &middot; Alle Berechnungen ohne Gewähr &middot; <a href={`${githubUrl}/blob/master/LICENSE`} target="_blank" rel="noopener noreferrer" class="hover:text-gray-400 transition-colors">MIT-Lizenz</a></p>
    </div>
  </div>
</footer>
