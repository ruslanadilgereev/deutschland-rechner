---
// Image-Banner für Check24/Tarifcheck — Backend-generiertes <a>+<img>-Pattern.
// Werbekennzeichnung als Untertitel + rel-Attribute korrekt gesetzt.

interface Props {
  /** Click-URL aus dem Backend (a.check24.net oder a.partner-versicherung.de). */
  href: string;
  /** Image-URL aus dem Backend (view.php-Endpoint). */
  imgSrc: string;
  /** Banner-Maße in Pixeln. */
  width: number;
  height: number;
  /** Alt-Text für Screenreader + Bildbeschreibung. */
  alt: string;
  /** Subid (tracking-Parameter) — wird an die href angehängt falls nicht schon enthalten. */
  subid?: string;
  /** Optional: zentriert die Banner-Box statt linksbündig. */
  center?: boolean;
}

const { href, imgSrc, width, height, alt, subid, center = true } = Astro.props;

// Subid an Click-URL anhängen (Check24 = tid, Tarifcheck = tracking)
let finalHref = href;
if (subid) {
  const isTarifcheck = href.includes('partner-versicherung.de');
  const param = isTarifcheck ? 'tracking' : 'tid';
  if (!href.includes(`${param}=`)) {
    const separator = href.includes('?') ? '&' : '?';
    finalHref = `${href}${separator}${param}=${subid}`;
  }
}
---

<aside class:list={['not-prose my-4', center && 'text-center']}>
  <p class="text-[11px] uppercase tracking-wide text-gray-400 mb-1.5">
    Anzeige
  </p>
  <a
    href={finalHref}
    target="_blank"
    rel="nofollow sponsored noopener noreferrer"
    class="inline-block max-w-full"
  >
    <img
      src={imgSrc}
      width={width}
      height={height}
      alt={alt}
      loading="lazy"
      class="max-w-full h-auto block mx-auto"
    />
  </a>
</aside>
