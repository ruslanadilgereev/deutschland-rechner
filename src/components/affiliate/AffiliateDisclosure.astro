---
interface Props {
  variant?: 'compact' | 'long';
}
const { variant = 'compact' } = Astro.props;
---

{variant === 'compact' && (
  <p class="text-xs text-gray-500 mt-2 leading-relaxed" data-nosnippet>
    <span aria-hidden="true">*</span> Werbelink. Wenn du über diesen Link einen Vertrag abschließt,
    erhalten wir eine Provision &mdash; für dich entstehen keine Mehrkosten.
    <a href="/werbehinweise" class="underline hover:text-gray-700">Was bedeutet das?</a>
  </p>
)}

{variant === 'long' && (
  <aside class="bg-slate-50 border border-slate-200 rounded-xl p-4 mt-6 text-sm text-gray-600 leading-relaxed" data-nosnippet>
    <p class="font-semibold text-gray-800 mb-2">Wie sich diese Seite finanziert</p>
    <p>
      Mit einem Sternchen (<span aria-hidden="true">*</span>) markierte Empfehlungen sind Werbelinks.
      Schließt du über einen solchen Link einen Vertrag ab, erhalten wir eine Provision
      vom Anbieter &mdash; für dich entstehen keine Mehrkosten. Welche Anbieter wir empfehlen,
      hängt nicht von der Höhe der Provision ab, sondern von der inhaltlichen Passung zum jeweiligen Rechner.
      <a href="/werbehinweise" class="underline hover:text-gray-700">Mehr darüber, wie wir arbeiten.</a>
    </p>
  </aside>
)}
