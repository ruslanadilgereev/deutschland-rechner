---
import { VERTICALS, type VerticalKey } from '../../data/affiliates';
import { buildAffiliateUrl, type SlotName } from '../../utils/affiliate';
import AffiliateDisclosure from './AffiliateDisclosure.astro';

interface Props {
  vertical: VerticalKey;
  pagePath: string;
  slot?: SlotName;
  headline?: string;
  hook?: string;
  cta?: string;
  trustBullets?: string[];
}

const {
  vertical,
  pagePath,
  slot = 'primary',
  headline,
  hook,
  cta = 'Jetzt vergleichen',
  trustBullets = [],
} = Astro.props;

const config = VERTICALS[vertical];
const url = buildAffiliateUrl({ vertical, pagePath, slot });
const finalHeadline = headline || config.label;

// Provisions-Hinweis variiert je nach Modell
const provisionLabel = config.provision.stornofrei
  ? 'Vergleich ist kostenlos · keine Folgekosten'
  : 'Vergleich ist kostenlos · keine Folgekosten';
---

<aside class="not-prose my-6">
  <div class="bg-blue-50 border border-blue-200 rounded-2xl shadow-sm p-5 md:p-6">
    <div class="flex items-center justify-between gap-2 mb-2">
      <span class="text-[11px] uppercase tracking-wide text-gray-500 font-medium">
        Anzeige
      </span>
    </div>

    <h3 class="text-lg md:text-xl font-bold text-gray-900 mb-2 leading-tight">
      {finalHeadline}
    </h3>

    {hook && (
      <p class="text-sm md:text-base text-gray-700 mb-4 leading-relaxed">
        {hook}
      </p>
    )}

    {trustBullets.length > 0 && (
      <ul class="text-sm text-gray-600 space-y-1 mb-4">
        {trustBullets.map((bullet) => (
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-green-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            <span>{bullet}</span>
          </li>
        ))}
      </ul>
    )}

    <a
      href={url}
      target="_blank"
      rel="nofollow sponsored noopener noreferrer"
      class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 active:scale-[0.98] text-white font-semibold text-sm md:text-base px-5 py-3 rounded-xl transition-all w-full md:w-auto"
    >
      <span>{cta}</span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
      <span aria-hidden="true" class="text-xs">*</span>
    </a>

    <p class="text-[11px] text-gray-500 mt-2">
      {provisionLabel}
    </p>
  </div>

  <AffiliateDisclosure variant="compact" />
</aside>
