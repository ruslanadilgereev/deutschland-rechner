---
// Globale Header-Navigation für deutschland-rechner.de
// Sticky Top-Nav mit Top-5-Kategorien, "Mehr"-Dropdown und Mobile-Menu
const currentPath = Astro.url.pathname;

const topKategorien = [
  { href: '/steuern-abgaben', label: 'Steuern', icon: '🏛️' },
  { href: '/familie-kinder', label: 'Familie', icon: '👨‍👩‍👧‍👦' },
  { href: '/arbeit-gehalt', label: 'Arbeit', icon: '💼' },
  { href: '/sozialleistungen', label: 'Sozial', icon: '🤝' },
  { href: '/wohnen-immobilien', label: 'Wohnen', icon: '🏠' },
];

const mehrKategorien = [
  { href: '/gesundheit', label: 'Gesundheit', icon: '❤️' },
  { href: '/auto-mobilitaet', label: 'Auto & Mobilität', icon: '🚗' },
  { href: '/finanzen-kredit', label: 'Finanzen & Kredit', icon: '💳' },
  { href: '/alltag-lifestyle', label: 'Alltag & Lifestyle', icon: '🧮' },
];

const alleKategorien = [...topKategorien, ...mehrKategorien];
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-20 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
    <!-- Logo / Brand -->
    <a href="/" class="flex items-center gap-2 font-bold text-gray-900 hover:text-blue-600 transition-colors shrink-0">
      <span class="text-xl">🇩🇪</span>
      <span class="text-base hidden sm:inline">Deutschlandrechner</span>
      <span class="text-base sm:hidden">DR</span>
    </a>

    <!-- Desktop Nav (Mitte) -->
    <nav class="hidden md:flex items-center gap-1 flex-1 justify-center" aria-label="Hauptnavigation">
      {topKategorien.map((kat) => (
        <a
          href={kat.href}
          class:list={[
            'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
            currentPath === kat.href
              ? 'text-blue-600 bg-blue-50'
              : 'text-gray-700 hover:text-blue-600 hover:bg-gray-50',
          ]}
        >
          {kat.label}
        </a>
      ))}

      <!-- Mehr-Dropdown -->
      <div class="relative group">
        <button
          type="button"
          class="px-3 py-2 rounded-lg text-sm font-medium text-gray-700 hover:text-blue-600 hover:bg-gray-50 transition-colors flex items-center gap-1"
          aria-haspopup="true"
          aria-expanded="false"
          id="mehr-button"
        >
          Mehr
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div
          class="absolute right-0 mt-1 w-56 bg-white border border-gray-200 rounded-xl shadow-lg py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all z-30"
          role="menu"
        >
          {mehrKategorien.map((kat) => (
            <a
              href={kat.href}
              class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 transition-colors"
              role="menuitem"
            >
              <span class="mr-2">{kat.icon}</span>{kat.label}
            </a>
          ))}
          <div class="border-t border-gray-100 my-1"></div>
          <a href="/ueber-uns" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 transition-colors" role="menuitem">Über uns</a>
          <a href="/mitmachen" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-blue-600 transition-colors" role="menuitem">Mitmachen</a>
        </div>
      </div>
    </nav>

    <!-- Rechts: Suche + Mobile-Burger -->
    <div class="flex items-center gap-2 shrink-0">
      <a
        href="/?focus=search"
        aria-label="Rechner suchen"
        title="Rechner suchen"
        class="p-2 rounded-lg text-gray-600 hover:text-blue-600 hover:bg-gray-50 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z"/></svg>
      </a>

      <!-- Mobile Burger -->
      <button
        type="button"
        id="mobile-menu-toggle"
        class="md:hidden p-2 rounded-lg text-gray-600 hover:text-blue-600 hover:bg-gray-50 transition-colors"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6 burger-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <svg class="w-6 h-6 close-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Sheet -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
    <nav class="max-w-7xl mx-auto px-4 py-3" aria-label="Mobile Navigation">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide px-2 mb-2">Kategorien</p>
      <ul class="space-y-1 mb-4">
        {alleKategorien.map((kat) => (
          <li>
            <a
              href={kat.href}
              class:list={[
                'flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors',
                currentPath === kat.href
                  ? 'text-blue-600 bg-blue-50'
                  : 'text-gray-700 hover:text-blue-600 hover:bg-gray-50',
              ]}
            >
              <span class="text-lg">{kat.icon}</span>
              <span>{kat.label}</span>
            </a>
          </li>
        ))}
      </ul>

      <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide px-2 mb-2">Über</p>
      <ul class="space-y-1 mb-2">
        <li><a href="/ueber-uns" class="block px-3 py-2 rounded-lg text-sm text-gray-700 hover:text-blue-600 hover:bg-gray-50 transition-colors">Über uns</a></li>
        <li><a href="/mitmachen" class="block px-3 py-2 rounded-lg text-sm text-gray-700 hover:text-blue-600 hover:bg-gray-50 transition-colors">Mitmachen</a></li>
        <li><a href="/kontakt" class="block px-3 py-2 rounded-lg text-sm text-gray-700 hover:text-blue-600 hover:bg-gray-50 transition-colors">Kontakt</a></li>
        <li><a href="/impressum" class="block px-3 py-2 rounded-lg text-sm text-gray-700 hover:text-blue-600 hover:bg-gray-50 transition-colors">Impressum</a></li>
        <li><a href="/datenschutz" class="block px-3 py-2 rounded-lg text-sm text-gray-700 hover:text-blue-600 hover:bg-gray-50 transition-colors">Datenschutz</a></li>
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    const burger = toggle.querySelector('.burger-icon');
    const close = toggle.querySelector('.close-icon');

    toggle.addEventListener('click', function () {
      const isOpen = !menu.classList.contains('hidden');
      if (isOpen) {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Menü öffnen');
        if (burger) burger.classList.remove('hidden');
        if (close) close.classList.add('hidden');
      } else {
        menu.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        toggle.setAttribute('aria-label', 'Menü schließen');
        if (burger) burger.classList.add('hidden');
        if (close) close.classList.remove('hidden');
      }
    });

    // Auto-close on resize to desktop
    window.addEventListener('resize', function () {
      if (window.innerWidth >= 768 && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        if (burger) burger.classList.remove('hidden');
        if (close) close.classList.add('hidden');
      }
    });
  })();
</script>
